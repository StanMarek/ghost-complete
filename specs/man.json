{
  "name": "man",
  "description": "Display manual pages",
  "args": [
    {
      "name": "section",
      "description": "Manual section number (1-9)"
    },
    {
      "name": "page",
      "description": "Name of the manual page to display"
    }
  ],
  "options": [
    {
      "name": [
        "-k",
        "--apropos"
      ],
      "description": "Search manual page names and descriptions",
      "args": {
        "name": "keyword"
      }
    },
    {
      "name": [
        "-f",
        "--whatis"
      ],
      "description": "Display one-line manual page descriptions",
      "args": {
        "name": "page"
      }
    },
    {
      "name": [
        "-a",
        "--all"
      ],
      "description": "Display all matching manual pages"
    },
    {
      "name": [
        "-w",
        "--where",
        "--path"
      ],
      "description": "Print location of manual page file"
    },
    {
      "name": [
        "-K",
        "--global-apropos"
      ],
      "description": "Search all manual pages for text"
    },
    {
      "name": [
        "-M",
        "--manpath"
      ],
      "description": "Set the search path for manual pages",
      "args": {
        "name": "path",
        "template": "folders"
      }
    },
    {
      "name": [
        "-S",
        "--sections"
      ],
      "description": "Colon-separated list of sections to search",
      "args": {
        "name": "sections"
      }
    },
    {
      "name": [
        "-s",
        "--section"
      ],
      "description": "Search only the specified section",
      "args": {
        "name": "section"
      }
    }
  ]
}
