{
  "name": "git-profile",
  "description": "Switch profiles",
  "subcommands": [
    {
      "name": "use",
      "description": "Use a profile",
      "args": {
        "name": "profile",
        "description": "Profile you want to apply in this repository",
        "generators": [
          {
            "script": [
              "git-profile",
              "list"
            ],
            "requires_js": true,
            "js_source": "i=>Array.from(i.matchAll(/^\\[(.+?)\\]$/gm)).map(e=>({name:e[1],description:`Use profile \"${e[1]}\"`}))"
          }
        ]
      }
    }
  ],
  "options": [
    {
      "name": [
        "--help",
        "-h"
      ],
      "description": "Help for git-profile script"
    },
    {
      "name": [
        "--config",
        "-c"
      ],
      "description": "Config file (default \"~/.gitprofile\")"
    }
  ]
}
