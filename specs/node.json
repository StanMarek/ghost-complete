{
  "name": "node",
  "description": "Node.js JavaScript runtime",
  "options": [
    { "name": ["-e", "--eval"], "description": "Evaluate script", "args": { "name": "script" } },
    { "name": ["-p", "--print"], "description": "Evaluate and print result", "args": { "name": "script" } },
    { "name": ["-c", "--check"], "description": "Syntax check script without executing" },
    { "name": ["-r", "--require"], "description": "Preload module at startup", "args": { "name": "module", "template": "filepaths" } },
    { "name": ["-i", "--interactive"], "description": "Open the REPL even if stdin is not a terminal" },
    { "name": ["--inspect"], "description": "Activate inspector on host:port (default 127.0.0.1:9229)", "args": { "name": "host:port" } },
    { "name": ["--inspect-brk"], "description": "Activate inspector and break at start", "args": { "name": "host:port" } },
    { "name": ["--inspect-port"], "description": "Set inspector port", "args": { "name": "port" } },
    { "name": ["-v", "--version"], "description": "Print Node.js version" },
    { "name": ["--v8-options"], "description": "Print V8 command-line options" },
    { "name": ["--max-old-space-size"], "description": "Set max old space size in MB", "args": { "name": "size" } },
    { "name": ["--max-semi-space-size"], "description": "Set max semi space size in MB", "args": { "name": "size" } },
    { "name": ["--stack-size"], "description": "Set max stack size in bytes", "args": { "name": "size" } },
    { "name": ["--experimental-modules"], "description": "Enable experimental ES modules" },
    { "name": ["--experimental-vm-modules"], "description": "Enable experimental VM modules" },
    { "name": ["--experimental-wasm-modules"], "description": "Enable experimental WebAssembly modules" },
    { "name": ["--experimental-specifier-resolution"], "description": "Set module specifier resolution algorithm", "args": { "name": "mode" } },
    { "name": ["--input-type"], "description": "Set input type for string input", "args": { "name": "type" } },
    { "name": ["--loader"], "description": "Specify custom module loader", "args": { "name": "url" } },
    { "name": ["--es-module-specifier-resolution"], "description": "Module specifier resolution", "args": { "name": "mode" } },
    { "name": ["--no-deprecation"], "description": "Silence deprecation warnings" },
    { "name": ["--no-warnings"], "description": "Silence all process warnings" },
    { "name": ["--pending-deprecation"], "description": "Emit pending deprecation warnings" },
    { "name": ["--throw-deprecation"], "description": "Throw errors for deprecations" },
    { "name": ["--trace-deprecation"], "description": "Show stack traces for deprecations" },
    { "name": ["--trace-warnings"], "description": "Show stack traces for process warnings" },
    { "name": ["--trace-uncaught"], "description": "Show stack trace for uncaught exceptions" },
    { "name": ["--unhandled-rejections"], "description": "Set unhandled rejection behavior", "args": { "name": "mode" } },
    { "name": ["--abort-on-uncaught-exception"], "description": "Abort on uncaught exceptions" },
    { "name": ["--preserve-symlinks"], "description": "Preserve symlinks when resolving modules" },
    { "name": ["--preserve-symlinks-main"], "description": "Preserve symlinks when resolving main module" },
    { "name": ["--prof"], "description": "Generate V8 profiler output" },
    { "name": ["--prof-process"], "description": "Process V8 profiler output" },
    { "name": ["--cpu-prof"], "description": "Start the V8 CPU profiler on startup" },
    { "name": ["--cpu-prof-dir"], "description": "Specify CPU profile directory", "args": { "name": "directory", "template": "folders" } },
    { "name": ["--heap-prof"], "description": "Start the V8 heap profiler on startup" },
    { "name": ["--heap-prof-dir"], "description": "Specify heap profile directory", "args": { "name": "directory", "template": "folders" } },
    { "name": ["--title"], "description": "Set process.title on startup", "args": { "name": "title" } },
    { "name": ["--tls-min-v1.0"], "description": "Set minimum TLS version to TLSv1.0" },
    { "name": ["--tls-min-v1.1"], "description": "Set minimum TLS version to TLSv1.1" },
    { "name": ["--tls-min-v1.2"], "description": "Set minimum TLS version to TLSv1.2" },
    { "name": ["--tls-min-v1.3"], "description": "Set minimum TLS version to TLSv1.3" },
    { "name": ["--tls-max-v1.2"], "description": "Set maximum TLS version to TLSv1.2" },
    { "name": ["--tls-max-v1.3"], "description": "Set maximum TLS version to TLSv1.3" },
    { "name": ["--openssl-config"], "description": "Load OpenSSL configuration file", "args": { "name": "file", "template": "filepaths" } },
    { "name": ["--icu-data-dir"], "description": "Set ICU data load path", "args": { "name": "directory", "template": "folders" } },
    { "name": ["--enable-source-maps"], "description": "Enable source maps" },
    { "name": ["--conditions"], "description": "Set resolution conditions", "args": { "name": "conditions" } },
    { "name": ["--dns-result-order"], "description": "Set DNS resolution order", "args": { "name": "order" } },
    { "name": ["--env-file"], "description": "Load environment variables from a file", "args": { "name": "file", "template": "filepaths" } },
    { "name": ["--watch"], "description": "Run in watch mode, restarting on file changes" },
    { "name": ["--watch-path"], "description": "Path to watch for changes", "args": { "name": "path", "template": "filepaths" } },
    { "name": ["--watch-preserve-output"], "description": "Preserve console output on restart in watch mode" },
    { "name": ["--test"], "description": "Run test runner" },
    { "name": ["--test-reporter"], "description": "Specify test reporter", "args": { "name": "reporter" } },
    { "name": ["--test-name-pattern"], "description": "Run tests matching pattern", "args": { "name": "pattern" } },
    { "name": ["-h", "--help"], "description": "Print command-line options" }
  ],
  "args": [
    { "name": "script", "description": "JavaScript file to run", "template": "filepaths" }
  ]
}
