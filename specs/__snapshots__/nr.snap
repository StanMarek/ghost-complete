{
  "args": {
    "description": "The script to run",
    "generators": [
      {
        "cache": {
          "cache_by_directory": true
        },
        "js_source": "function(n,[s]){if(n.trim()==\"\")return[];try{let c=JSON.parse(n),p=c.scripts,t=c.fig||{};if(p)return Object.entries(p).map(([r,h])=>{let g=s===\"yarn\"?\"fig://icon?type=yarn\":\"fig://icon?type=npm\",d=t[r];return{name:r,icon:g,description:h,priority:51,...d}})}catch(c){console.error(c)}return[]}",
        "requires_js": true,
        "script": [
          "bash",
          "-c",
          "until [[ -f package.json ]] || [[ $PWD = '/' ]]; do cd ..; done; cat package.json"
        ]
      }
    ],
    "name": "script"
  },
  "description": "Use the right package manager - run",
  "name": "nr",
  "options": [
    {
      "description": "Output usage information",
      "name": [
        "-h",
        "--help"
      ]
    }
  ]
}
