            {
              "args": {
                "name": "base64"
              },
              "description": "The session that will be used instead of triggering a new login each time NativeScript CLI communicates with Apple's APIs",
              "name": [
                "--appleSessionBase64"
              ]
            }
          ]
        }
      ]
