              "name": [
                "--env.replace=from:to"
              ]
            },
            {
              "description": "Disables Hot Module Replacement (HMR)",
              "name": [
                "--no-hmr"
              ]
            },
            {
              "description": "Skips the application compatibility checks and forces npm i to ensure all dependencies are installed",
              "name": [
                "--force"
              ]
            },
            {
