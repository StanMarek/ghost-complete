                    "js_source": "o=>JSON.parse(o).map(n=>{let i=n.Status;return{name:n.ID,description:`Organization: ${n.Organization.Slug}`,icon:i==\"running\"||i==\"deployed\"?\"\\u{1F7E2}\":i==\"pending\"?\"\\u{1F7E1}\":\"\\u{1F534}\"}})",
                    "requires_js": true,
                    "script": [
                      "flyctl",
                      "apps",
                      "list",
                      "--json"
                    ]
                  }
                ],
                "name": "app"
