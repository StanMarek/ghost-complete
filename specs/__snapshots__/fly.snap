{
  "description": "The flyctl is a command-line interface for fly.io",
  "name": "fly",
  "options": [
    {
      "args": {
        "name": "access-token"
      },
      "description": "Fly API Access Token",
      "name": [
        "--access-token",
        "-t"
      ]
    },
    {
      "args": {
        "name": "builtinsfile"
      },
      "description": "Load builtins from named file",
      "name": [
        "--builtinsfile"
      ]
    },
    {
      "description": "Json output",
      "name": [
        "--json",
        "-j"
      ]
    },
    {
      "description": "Verbose output",
      "name": [
        "--verbose"
      ]
    },
    {
      "description": "Display help",
      "name": [
        "--help",
        "-h"
      ]
    }
  ],
  "subcommands": [
    {
      "description": "Commands that manage the Fly agent, a background process that manages flyctl wireguard connections",
      "name": "agent",
      "subcommands": [
        {
          "description": "Ping the Fly agent",
          "name": "ping"
        },
        {
          "description": "Restart the Fly agent",
          "name": "restart"
        },
        {
          "description": "Run the Fly agent in the foreground",
          "name": "daemon-start"
        },
        {
          "description": "Start the Fly agent",
          "name": "start"
        },
        {
          "description": "Stop the Fly agent",
          "name": "stop"
        }
      ]
    },
    {
      "description": "Manage apps",
      "name": "apps",
      "priority": 78,
      "subcommands": [
        {
          "description": "Create a new application",
          "name": "create",
          "options": [
            {
              "description": "Generate a name for the app",
              "name": [
                "--generate-name"
              ]
            },
            {
              "args": {
                "name": "name"
              },
              "description": "The app name to use",
              "name": [
                "--name"
              ]
            },
            {
              "args": {
                "name": "network"
              },
              "description": "Specify custom network id",
              "name": [
                "--network"
              ]
            },
            {
              "args": {
                "generators": [
                  {
                    "js_source": "o=>{let t=JSON.parse(o);return Object.entries(t).sort(([n,i],[r,p])=>n==\"personal\"?-1:r==\"personal\"?1:i.localeCompare(p)).map(([n,i])=>({name:n,description:i,icon:n==\"personal\"?\"\\u{1F464}\":\"\\u{1F3E2}\"}))}",
                    "requires_js": true,
                    "script": [
                      "fly",
                      "orgs",
                      "list",
                      "--json"
                    ]
                  }
                ],
                "name": "org"
              },
              "description": "The organization to operate on",
              "name": [
                "--org",
                "-o"
              ],
              "priority": 75
            }
          ],
          "priority": 72
        },
        {
          "description": "Permanently destroys an app",
          "name": "destroy",
          "options": [
            {
              "description": "Accept all confirmations",
              "name": [
                "--yes",
                "-y"
              ]
            }
          ]
        },
        {
          "description": "List applications",
          "name": "list",
          "priority": 82
        },
        {
          "description": "Move an app to another organization",
          "name": "move",
          "options": [
            {
              "args": {
                "generators": [
                  {
                    "js_source": "o=>{let t=JSON.parse(o);return Object.entries(t).sort(([n,i],[r,p])=>n==\"personal\"?-1:r==\"personal\"?1:i.localeCompare(p)).map(([n,i])=>({name:n,description:i,icon:n==\"personal\"?\"\\u{1F464}\":\"\\u{1F3E2}\"}))}",
                    "requires_js": true,
                    "script": [
                      "fly",
                      "orgs",
                      "list",
                      "--json"
                    ]
                  }
                ],
                "name": "org"
              },
              "description": "The organization to operate on",
              "name": [
                "--org",
                "-o"
              ],
              "priority": 75
            },
            {
              "description": "Accept all confirmations",
              "name": [
                "--yes",
                "-y"
              ]
            }
          ]
        },
        {
          "description": "Open browser to current deployed application",
          "name": "open",
          "options": [
            {
              "args": {
                "generators": [
                  {
                    "js_source": "o=>JSON.parse(o).map(n=>{let i=n.Status;return{name:n.ID,description:`Organization: ${n.Organization.Slug}`,icon:i==\"running\"||i==\"deployed\"?\"\\u{1F7E2}\":i==\"pending\"?\"\\u{1F7E1}\":\"\\u{1F534}\"}})",
                    "requires_js": true,
                    "script": [
                      "flyctl",
                      "apps",
                      "list",
                      "--json"
                    ]
                  }
                ],
                "name": "app"
              },
              "description": "Application name",
              "name": [
                "--app",
                "-a"
              ]
            },
            {
              "args": {
                "name": "config",
                "template": "filepaths"
              },
              "description": "Path to application configuration file",
              "name": [
                "--config",
                "-c"
              ]
            }
          ],
          "priority": 75
        },
        {
          "description": "List app releases",
          "name": "releases",
          "options": [
            {
              "args": {
                "generators": [
                  {
                    "js_source": "o=>JSON.parse(o).map(n=>{let i=n.Status;return{name:n.ID,description:`Organization: ${n.Organization.Slug}`,icon:i==\"running\"||i==\"deployed\"?\"\\u{1F7E2}\":i==\"pending\"?\"\\u{1F7E1}\":\"\\u{1F534}\"}})",
                    "requires_js": true,
                    "script": [
                      "flyctl",
                      "apps",
                      "list",
                      "--json"
                    ]
                  }
                ],
                "name": "app"
              },
              "description": "Application name",
              "name": [
                "--app",
                "-a"
              ]
            },
            {
              "args": {
                "name": "config",
                "template": "filepaths"
              },
              "description": "Path to application configuration file",
              "name": [
                "--config",
                "-c"
              ]
            },
            {
              "description": "Display the Docker image reference of the release",
              "name": [
                "--image"
              ]
            }
          ]
        },
        {
          "args": {
            "generators": [
              {
                "js_source": "o=>JSON.parse(o).map(n=>{let i=n.Status;return{name:n.ID,description:`Organization: ${n.Organization.Slug}`,icon:i==\"running\"||i==\"deployed\"?\"\\u{1F7E2}\":i==\"pending\"?\"\\u{1F7E1}\":\"\\u{1F534}\"}})",
                "requires_js": true,
                "script": [
                  "flyctl",
                  "apps",
                  "list",
                  "--json"
                ]
              }
            ],
            "name": "app"
          },
          "description": "Restart an application",
          "name": "restart",
          "options": [
            {
              "description": "Will issue a restart against each Machine even if there are errors. ( Machines only )",
              "name": [
                "-f",
                "--force"
              ],
              "priority": 22
            },
            {
              "description": "Restarts app without waiting for health checks. ( Machines only )",
              "name": [
                "--skip-health-checks"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Manage authentication",
      "name": "auth",
      "subcommands": [
        {
          "description": "Authenticate docker",
          "name": "docker"
        },
        {
          "description": "Log in a user",
          "name": "login",
          "options": [
            {
              "args": {
                "name": "email"
              },
              "description": "Login email",
              "name": [
                "--email"
              ]
            },
            {
              "description": "Log in with an email and password interactively",
              "name": [
                "--interactive",
                "-i"
              ]
            },
            {
              "args": {
                "name": "otp"
              },
              "description": "One time password",
              "name": [
                "--otp"
              ]
            },
            {
              "args": {
                "name": "password"
              },
              "description": "Login password",
              "name": [
                "--password"
              ]
            }
          ],
          "priority": 88
        },
        {
          "description": "Logs out the currently logged in user",
          "name": "logout",
          "priority": 60
        },
        {
          "description": "Create a new fly account",
          "name": "signup"
        },
        {
          "description": "Show the current auth token",
          "name": "token"
        },
        {
          "description": "Displays the users email address/service identity currently authenticated and in use",
          "name": "whoami"
        }
      ]
    },
