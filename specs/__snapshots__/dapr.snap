          "description": "Upgrades or downgrades a Dapr control plane installation in a cluster. Supported platforms: Kubernetes",
          "name": "upgrade"
        },
        {
          "description": "Print the Dapr runtime and CLI version",
          "name": "version"
        }
      ]
    }
  ]
}
