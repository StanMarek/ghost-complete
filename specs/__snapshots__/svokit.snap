{
  "description": "Runs built svokit project",
  "name": "svokit",
  "options": [
    {
      "description": "Show help for svokit",
      "name": [
        "--help",
        "-h"
      ]
    }
  ],
  "subcommands": [
    {
      "description": "Creates svokit config (experimental)",
      "name": "setup"
    },
    {
      "description": "Runs build svokit project",
      "name": "run"
    }
  ]
}
