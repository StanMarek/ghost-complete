      "description": "Specify the list of directories to search (colon separated)",
      "name": [
        "-M"
      ]
    },
    {
      "args": {
        "name": "pager"
      },
      "description": "Specify the pager program",
      "name": [
        "-P"
      ]
    },
    {
      "args": {
        "name": "browser"
      },
      "description": "Specify which browser to use for HTML files",
      "name": [
        "-B"
      ]
    },
    {
      "args": {
        "name": "command"
      },
      "description": "Specify a command that renders HTML files as text",
      "name": [
        "-H"
      ]
    },
    {
      "args": {
        "generators": [
          {
            "js_source": "(...r)=>F(this,void 0,void 0,function*(){var o;let c=yield N(t,s?e:\"\",n,r);if(i)return c;let[f]=r,l=(o=f[f.length-1])===null||o===void 0?void 0:o.split(e);return E(l,c)})",
            "requires_js": true
