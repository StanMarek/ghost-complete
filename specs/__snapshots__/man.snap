      ]
    },
    {
      "description": "Both display and print debugging info",
      "name": [
        "-D"
      ]
    },
    {
      "description": "Equivalent to `whatis`",
      "name": [
        "-f"
      ]
    },
    {
      "description": "Format only, do not display",
      "name": [
