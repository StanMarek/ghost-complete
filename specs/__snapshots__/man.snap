        "--preformat"
      ]
    },
    {
      "description": "Print a help message and exit",
      "name": [
        "-h"
      ]
    },
    {
      "description": "Equivalent to apropos",
      "name": [
        "-k"
      ]
    },
    {
      "description": "Search for a given string in all pages",
      "name": [
        "-K"
      ]
    },
    {
      "args": {
        "name": "system"
      },
