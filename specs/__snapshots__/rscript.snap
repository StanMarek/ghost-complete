{
  "args": [
    {
      "description": "R script to run",
      "generators": [
        {
          "js_source": "(p,v,b)=>ce(this,void 0,void 0,function*(){var d;let{isDangerous:_,currentWorkingDirectory:O,searchTerm:h}=b,w=(d=(0,y.getCurrentInsertedDirectory)(c??O,h,b))!==null&&d!==void 0?d:\"/\";try{let E=yield v({command:\"ls\",args:[\"-1ApL\"],cwd:w}),X=W(E.stdout.split(`\n`),[\".DS_Store\"]),P=[];for(let V of X)if(V){let F=V.endsWith(\"/\")?\"folders\":\"filepaths\";(F===\"filepaths\"&&u!==\"only\"||F===\"folders\"&&u!==\"never\")&&P.push({type:F===\"filepaths\"?\"file\":\"folder\",name:V,insertValue:V,isDangerous:_,context:{templateType:F}})}return S(g(P))}catch{return[]}})",
          "requires_js": true
        }
      ],
      "name": "file"
    },
    {
      "description": "Arguments to pass to the script",
      "isVariadic": true,
      "name": "args"
    }
  ],
  "description": "Scripting Front-End for R",
  "name": "Rscript",
  "options": [
    {
      "args": {
        "description": "R expression",
        "name": "expression"
      },
      "description": "R expression to run",
      "name": [
        "-e"
      ]
    },
    {
      "description": "Print usage and exit",
      "name": [
        "--help"
      ]
    },
    {
      "description": "Print version and exit",
      "name": [
        "--version"
      ]
    },
    {
      "description": "Print information on progress",
      "name": [
        "--verbose"
      ]
    },
    {
      "description": "Run as quietly as possible",
      "name": [
        "--no-echo"
      ]
    },
    {
      "description": "Don't restore anything",
      "name": [
        "--no-restore"
      ]
    },
    {
      "description": "Do save workspace at the end of the session",
      "name": [
        "--save"
      ]
    },
    {
      "description": "Don't read the site and user environment files",
      "name": [
        "--no-environ"
      ]
    },
    {
      "description": "Don't read the site-wide Rprofile",
      "name": [
        "--no-site-file"
      ]
    },
    {
      "description": "Don't read the user R profile",
      "name": [
        "--no-init-file"
      ]
    },
    {
      "description": "Do restore previously saved objects at startup",
      "name": [
        "--restore"
      ]
    },
    {
      "description": "Combine --no-save, --no-restore, --no-site-file --no-init-file and --no-environ",
      "name": [
        "--vanilla"
      ]
    },
    {
      "args": {
        "description": "A comma-separated set of package names, or 'NULL'",
        "name": "packages"
      },
      "description": "Comma separated list of default packages",
      "name": [
        "--default-packages"
      ]
    }
  ]
}
