{
  "description": "Control the Lima(Linux virtual machines)",
  "name": "limactl",
  "options": [
    {
      "description": "Help for limactl",
      "name": [
        "-h",
        "--help"
      ]
    },
    {
      "description": "Debug mode",
      "name": [
        "--debug"
      ]
    },
    {
      "description": "Version for limactl",
      "name": [
        "-v",
        "--version"
      ]
    }
  ],
  "subcommands": [
    {
      "description": "Generate the autocompletion script for the specified shell",
      "name": "completion",
      "options": [
        {
          "description": "Help for completion",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "description": "Debug mode",
          "name": [
            "--debug"
          ]
        }
      ],
      "subcommands": [
        {
          "description": "Generate the autocompletion script for bash",
          "name": "bash",
          "options": [
            {
              "description": "Help for bash",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "description": "Debug mode",
              "name": [
                "--debug"
              ]
            },
            {
              "description": "Disable completion descriptions",
              "name": [
                "--no-descriptions"
              ]
            }
          ]
        },
        {
          "description": "Generate the autocompletion script for fish",
          "name": "fish",
          "options": [
            {
              "description": "Help for fish",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "description": "Debug mode",
              "name": [
                "--debug"
              ]
            },
            {
              "description": "Disable completion descriptions",
              "name": [
                "--no-descriptions"
              ]
            }
          ]
        },
        {
          "description": "Generate the autocompletion script for powershell",
          "name": "powershell",
          "options": [
            {
              "description": "Help for powershell",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "description": "Debug mode",
              "name": [
                "--debug"
              ]
            },
            {
              "description": "Disable completion descriptions",
              "name": [
                "--no-descriptions"
              ]
            }
          ]
        },
        {
          "description": "Generate the autocompletion script for zsh",
          "name": "zsh",
          "options": [
            {
              "description": "Help for zsh",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "description": "Debug mode",
              "name": [
                "--debug"
              ]
            },
            {
              "description": "Disable completion descriptions",
              "name": [
                "--no-descriptions"
              ]
            }
          ]
        }
      ]
    },
    {
      "args": [
        {
          "generators": [
            {
              "script": [
                "limactl",
                "list",
                "--quiet"
              ],
              "transforms": [
                "split_lines",
                "filter_empty"
              ]
            },
            {
              "template": "filepaths"
            }
          ],
          "isVariadic": true,
          "name": "SOURCE"
        },
        {
          "generators": [
            {
              "script": [
                "limactl",
                "list",
                "--quiet"
              ],
              "transforms": [
                "split_lines",
                "filter_empty"
              ]
            },
            {
              "template": "filepaths"
            }
          ],
          "name": "TARGET"
        }
      ],
      "description": "Copy files between host and guest",
      "name": "copy",
      "options": [
        {
          "description": "Help for copy",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "description": "Debug mode",
          "name": [
            "--debug"
          ]
        },
        {
          "description": "Copy directories recursively",
          "name": [
            "-r",
            "--recursive"
          ]
        }
      ]
    },
    {
      "args": {
        "generators": [
          {
            "script": [
              "limactl",
              "list",
              "--quiet"
            ],
            "transforms": [
              "split_lines",
              "filter_empty"
            ]
          }
        ],
        "isVariadic": true,
        "name": "INSTANCE"
      },
      "description": "Delete an instance of Lima",
      "name": "delete",
      "options": [
        {
          "description": "Help for delete",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "description": "Debug mode",
          "name": [
            "--debug"
          ]
        },
        {
          "description": "Forcibly kill the processes",
          "name": [
            "-f",
            "--force"
          ],
          "priority": 22
        }
      ]
    },
    {
      "description": "Show diagnostic information",
      "name": "info",
      "options": [
        {
          "description": "Help for info",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "description": "Debug mode",
          "name": [
            "--debug"
          ]
        }
      ],
      "priority": 55
    },
    {
      "description": "List instances of Lima",
      "name": "list",
      "options": [
        {
          "description": "Help for list",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "description": "Debug mode",
          "name": [
            "--debug"
          ]
        },
        {
          "description": "JSONify output",
          "name": [
            "--json"
          ]
        },
        {
          "description": "Only show names",
          "name": [
            "-q",
            "--quiet"
          ]
        }
      ]
    },
    {
      "description": "Prune garbage objects",
      "name": "prune",
      "options": [
        {
          "description": "Help for prune",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "description": "Debug mode",
          "name": [
            "--debug"
          ]
        }
      ]
    },
    {
      "args": [
        {
          "generators": [
            {
              "script": [
                "limactl",
                "list",
                "--quiet"
              ],
              "transforms": [
                "split_lines",
                "filter_empty"
              ]
            }
          ],
          "name": "INSTANCE"
        },
        {
          "isOptional": true,
          "isVariadic": true,
          "name": "COMMAND"
        }
      ],
      "description": "Lima command is provided as an alias for limactl shell $LIMA_INSTANCE. $LIMA_INSTANCE defaults to \"default\"",
      "name": "shell",
      "options": [
        {
          "description": "Help for shell",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "description": "Debug mode",
          "name": [
            "--debug"
          ]
        },
        {
          "args": {
            "name": "string"
          },
          "description": "Working directory",
          "name": [
            "--workdir"
          ]
        }
      ]
    },
    {
      "args": {
        "generators": [
          {
            "script": [
              "limactl",
              "list",
              "--quiet"
            ],
            "transforms": [
              "split_lines",
              "filter_empty"
            ]
          }
        ],
        "name": "INSTANCE"
      },
      "description": "Show the ssh command line",
      "name": "show-ssh",
      "options": [
        {
          "description": "Help for show-ssh",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "description": "Debug mode",
          "name": [
            "--debug"
          ]
        },
        {
          "args": {
            "name": "string",
            "suggestions": [
              {
                "description": "Full ssh command line",
                "name": "cmd"
              },
              {
                "description": "Similar to the cmd format but omits \"ssh\" and the destination address",
                "name": "args"
              },
              {
                "description": "Ssh option key value pairs",
                "name": "options"
              },
              {
                "description": "~/.ssh/config format",
                "name": "config"
              }
            ]
          },
          "description": "Format: cmd, args, options, config (default \"cmd\")",
          "name": [
            "-f",
            "--format"
          ]
        }
      ]
    },
    {
      "args": {
        "generators": [
          {
            "script": [
              "limactl",
              "list",
              "--quiet"
            ],
            "transforms": [
              "split_lines",
              "filter_empty"
            ]
          },
          {
            "js_source": "(p,h,S)=>he(this,void 0,void 0,function*(){var f;let{isDangerous:O,currentWorkingDirectory:b,searchTerm:m}=S,I=(f=(0,v.getCurrentInsertedDirectory)(c??b,m,S))!==null&&f!==void 0?f:\"/\";try{let q=yield h({command:\"ls\",args:[\"-1ApL\"],cwd:I}),ie=W(q.stdout.split(`\n`),[\".DS_Store\"]),$=[];for(let D of ie)if(D){let j=D.endsWith(\"/\")?\"folders\":\"filepaths\";(j===\"filepaths\"&&u!==\"only\"||j===\"folders\"&&u!==\"never\")&&$.push({type:j===\"filepaths\"?\"file\":\"folder\",name:D,insertValue:D,isDangerous:O,context:{templateType:j}})}return w(y($))}catch{return[]}})",
            "requires_js": true
          }
        ],
        "name": "NAME|FILE.yaml|URL"
      },
      "description": "Start an instance of Lima. If the instance does not exist, open an editor for creating new one, with name \"default\"",
      "name": "start",
      "options": [
        {
          "description": "Help for start",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "description": "Debug mode",
          "name": [
            "--debug"
          ]
        },
        {
          "description": "Enable TUI interactions such as opening an editor, defaults to true when stdout is a terminal (default true)",
          "name": [
            "--tty"
          ]
        }
      ],
      "priority": 75
    },
    {
      "args": {
        "generators": [
          {
            "script": [
              "limactl",
              "list",
              "--quiet"
            ],
            "transforms": [
              "split_lines",
              "filter_empty"
            ]
          }
        ],
        "name": "INSTANCE"
      },
      "description": "Stop an instance",
      "name": "stop",
      "options": [
        {
          "description": "Help for stop",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "description": "Debug mode",
          "name": [
            "--debug"
          ]
        },
        {
          "description": "Force stop the instance",
          "name": [
            "-f",
            "--force"
          ],
          "priority": 22
        }
      ],
      "priority": 75
    },
    {
      "args": {
        "isOptional": true,
        "name": "SUDORSFILE",
        "template": "filepaths"
      },
      "description": "Generate /etc/sudoers.d/lima file for enabling vmnet.framework support. See /usr/local/share/doc/lima/docs/network.md for the usage",
      "name": "sudoers",
      "options": [
        {
          "description": "Help for sudoers",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "description": "Debug mode",
          "name": [
            "--debug"
          ]
        },
        {
          "description": "Check that the sudoers file is up-to-date with \"~/.lima/_config/networks.yaml\"",
          "name": [
            "--check"
          ]
        }
      ]
    },
    {
      "args": {
        "generators": [
          {
            "js_source": "(p,h,S)=>he(this,void 0,void 0,function*(){var f;let{isDangerous:O,currentWorkingDirectory:b,searchTerm:m}=S,I=(f=(0,v.getCurrentInsertedDirectory)(c??b,m,S))!==null&&f!==void 0?f:\"/\";try{let q=yield h({command:\"ls\",args:[\"-1ApL\"],cwd:I}),ie=W(q.stdout.split(`\n`),[\".DS_Store\"]),$=[];for(let D of ie)if(D){let j=D.endsWith(\"/\")?\"folders\":\"filepaths\";(j===\"filepaths\"&&u!==\"only\"||j===\"folders\"&&u!==\"never\")&&$.push({type:j===\"filepaths\"?\"file\":\"folder\",name:D,insertValue:D,isDangerous:O,context:{templateType:j}})}return w(y($))}catch{return[]}})",
            "requires_js": true
          }
        ],
        "isVariadic": true,
        "name": "FILE.yaml"
      },
      "description": "Validate YAML files",
      "name": "validate",
      "options": [
        {
          "description": "Help for validate",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "description": "Debug mode",
          "name": [
            "--debug"
          ]
        }
      ]
    },
    {
      "args": {
        "isOptional": true,
        "name": "command",
        "suggestions": [
          {
            "description": "Generate the autocompletion script for the specified shell",
            "name": "completion"
          },
          {
            "description": "Copy files between host and guest",
            "name": "copy"
          },
          {
            "description": "Delete an instance of Lima",
            "name": "delete"
          },
          {
            "description": "Show diagnostic information",
            "name": "info"
          },
          {
            "description": "List instances of Lima",
            "name": "list"
          },
          {
            "description": "Prune garbage objects",
            "name": "prune"
          },
          {
            "description": "Lima command is provided as an alias for limactl shell $LIMA_INSTANCE. $LIMA_INSTANCE defaults to \"default\"",
            "name": "shell"
          },
          {
            "description": "Show the ssh command line",
            "name": "show-ssh"
          },
          {
            "description": "Start an instance of Lima. If the instance does not exist, open an editor for creating new one, with name \"default\"",
            "name": "start"
          },
          {
            "description": "Stop an instance",
            "name": "stop"
          },
          {
            "description": "Generate /etc/sudoers.d/lima file for enabling vmnet.framework support. See /usr/local/share/doc/lima/docs/network.md for the usage",
            "name": "sudoers"
          },
          {
            "description": "Validate YAML files",
            "name": "validate"
          },
          {
            "description": "Help provides help for any command in the application",
            "name": "help"
          }
        ]
      },
      "description": "Help provides help for any command in the application",
      "name": "help"
    }
  ]
