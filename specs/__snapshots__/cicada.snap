          ]
        },
        {
          "name": "workers",
          "options": [
            {
              "args": {
                "isOptional": true,
                "name": "oci_backend",
                "suggestions": [
                  {
                    "name": "docker"
                  },
                  {
                    "name": "podman"
                  }
                ]
              },
              "description": "The OCI backend to use",
              "name": [
                "--oci-backend"
              ]
            },
