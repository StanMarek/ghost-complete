            }
          ]
        },
        {
          "description": "Print this message or the help of the given subcommand(s)",
          "name": "help",
          "subcommands": [
            {
              "name": "daemon-info"
            },
            {
              "name": "disk-usage"
            },
            {
              "name": "workers"
            },
            {
              "description": "Print this message or the help of the given subcommand(s)",
              "name": "help"
            }
          ]
        }
      ]
    },
    {
      "description": "Print this message or the help of the given subcommand(s)",
      "name": "help",
      "subcommands": [
