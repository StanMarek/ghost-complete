    {
      "description": "The storage command allows you to manage your project files",
      "name": "storage",
      "subcommands": [
        {
          "description": "Get a list of all the storage buckets. You can use the query params to filter your results",
          "name": "listBuckets",
          "options": [
            {
              "args": {
