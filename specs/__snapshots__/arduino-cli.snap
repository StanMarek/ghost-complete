{
  "description": "Arduino Command Line Interface",
  "name": "arduino-cli",
  "options": [
    {
      "args": {},
      "description": "Comma-separated list of additional URLs for the Boards Manager",
      "name": [
        "--additional-urls"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "The custom config file (if not specified the default will be used)",
      "name": [
        "--config-file"
      ]
    },
    {
      "args": {
        "name": "data_format",
        "suggestions": [
          {
            "description": "Output in 'text'",
            "name": "text"
          },
          {
            "description": "Output in 'json'",
            "name": "json"
          },
          {
            "description": "Output in 'jsonmini'",
            "name": "jsonmini"
          },
          {
            "description": "Output in 'yaml'",
            "name": "yaml"
          }
        ]
      },
      "description": "The output format for the logs, can be: text, json, jsonmini, yaml (default 'text')",
      "name": [
        "--format"
      ]
    },
    {
      "description": "Help for arduino-cli",
      "name": [
        "-h",
        "--help"
      ]
    },
    {
      "description": "Print the logs on the standard output",
      "name": [
        "--log"
      ]
    },
    {
      "args": {
        "name": "filepath",
        "template": "filepaths"
      },
      "description": "Path to the file where logs will be written",
      "name": [
        "--log-file"
      ]
    },
    {
      "args": {
        "name": "format",
        "suggestions": [
          {
            "description": "Output in 'text'",
            "name": "text"
          },
          {
            "description": "Output in 'json'",
            "name": "json"
          }
        ]
      },
      "description": "The output format for the logs, can be: text, json",
      "name": [
        "--log-format"
      ]
    },
    {
      "args": {
        "name": "level",
        "suggestions": [
          {
            "description": "Log level of 'trace",
            "name": "trace"
          },
          {
            "description": "Log level of 'debug",
            "name": "debug"
          },
          {
            "description": "Log level of 'info'",
            "name": "info"
          },
          {
            "description": "Log level of 'warn'",
            "name": "warn"
          },
          {
            "description": "Log level of 'error'",
            "name": "error"
          },
          {
            "description": "Log level of 'fatal'",
            "name": "fatal"
          },
          {
            "description": "Log level of 'panic'",
            "name": "panic"
          }
        ]
      },
      "description": "Messages with this level and above will be logged. Valid levels are: trace, debug, info, warn, error, fatal, panic",
      "name": [
        "--log-level"
      ]
    },
    {
      "description": "Disable colored output",
      "name": [
        "--no-color"
      ]
    }
  ],
  "subcommands": [
    {
      "args": {
        "isOptional": true,
        "name": "attach, list..."
      },
      "description": "Arduino board commands",
      "name": "board",
      "options": [
        {
          "description": "Help for board",
          "name": [
            "-h",
            "--help"
          ]
        }
      ],
      "subcommands": [
        {
          "description": "Sets the default values for port and FQBN. If no port or FQBN are specified, the current default port and FQBN are displayed",
          "name": "attach",
          "options": [
            {
              "args": {},
              "description": "List of board options separated by commas. Or can be used multiple times for multiple options",
              "name": [
                "--board-options"
              ]
            },
            {
              "args": {
                "name": "duration"
              },
              "description": "Max time to wait for port discovery, example: '30s, 1m (default 1s)'",
              "name": [
                "--discovery-timeout"
              ]
            },
            {
              "args": {
                "description": "Fully qualified board name",
                "generators": [
                  {
                    "js_source": "t=>{try{return JSON.parse(t).filter(i=>i.matching_boards).map(i=>({name:i.matching_boards[0].fqbn,description:`${i.matching_boards[0].name} on port ${i.port.address}`}))}catch{return[]}}",
                    "requires_js": true,
                    "script": [
                      "arduino-cli",
                      "board",
                      "list",
                      "--format",
                      "json"
                    ]
                  }
                ],
                "name": "FQBN"
              },
              "description": "Fully Qualified Board Name, example: 'arduino:avr:uno'",
              "name": [
                "-b",
                "--fqbn"
              ]
            },
            {
              "description": "Help for attach",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "args": {
                "description": "Arduino board port connection",
                "generators": [
                  {
                    "js_source": "t=>{try{return JSON.parse(t).filter(i=>i.matching_boards).map(i=>({name:i.port.address,description:`${i.matching_boards[0].name} port connection`}))}catch{return[]}}",
                    "requires_js": true,
                    "script": [
                      "arduino-cli",
                      "board",
                      "list",
                      "--format",
                      "json"
                    ]
                  }
                ],
                "name": "port"
              },
              "description": "Upload port address, example: 'COM3 or /dev/ttyACM2'",
              "name": [
                "-p",
                "--port"
              ]
            },
            {
              "args": {
                "name": "protocol"
              },
              "description": "Upload port protocol, example: 'serial'",
              "name": [
                "-l",
                "--protocol"
              ]
            }
          ]
        },
        {
          "description": "Show information about a board, in particular if the board has options to be specified in the FQBN'",
          "name": "details",
          "options": [
            {
              "args": {},
              "description": "List of board options separated by commas. Or can be used multiple times for multiple options",
              "name": [
                "--board-options"
              ]
            },
            {
              "args": {
                "description": "Fully qualified board name",
                "generators": [
                  {
                    "js_source": "t=>{try{return JSON.parse(t).filter(i=>i.matching_boards).map(i=>({name:i.matching_boards[0].fqbn,description:`${i.matching_boards[0].name} on port ${i.port.address}`}))}catch{return[]}}",
                    "requires_js": true,
                    "script": [
                      "arduino-cli",
                      "board",
                      "list",
                      "--format",
                      "json"
                    ]
                  }
                ],
                "name": "FQBN"
              },
              "description": "Fully Qualified Board Name, example: 'arduino:avr:uno'",
              "name": [
                "-b",
                "--fqbn"
              ]
            },
            {
              "description": "Show full board details",
              "name": [
                "-f",
                "--full"
              ]
            },
            {
              "description": "Help for details",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "description": "Show list of available programmers",
              "name": [
                "--list-programmers"
              ]
            },
            {
              "args": {},
              "description": "Show build properties. The properties are expanded, use \"--show-properties=unexpanded\" if you want them exactly as they are defined. (default \"disabled\")",
              "name": [
                "--show-properties"
              ]
            }
          ]
        },
        {
          "description": "Detects and displays a list of boards connected to the current computer",
          "name": "list",
          "options": [
            {
              "args": {},
              "description": "List of board options separated by commas. Or can be used multiple times for multiple options",
              "name": [
                "--board-options"
              ]
            },
            {
              "args": {
                "name": "duration"
              },
              "description": "Max time to wait for port discovery, example: '30s, 1m (default 1s)'",
              "name": [
                "--discovery-timeout"
              ]
            },
            {
              "args": {
                "description": "Fully qualified board name",
                "generators": [
                  {
                    "js_source": "t=>{try{return JSON.parse(t).filter(i=>i.matching_boards).map(i=>({name:i.matching_boards[0].fqbn,description:`${i.matching_boards[0].name} on port ${i.port.address}`}))}catch{return[]}}",
                    "requires_js": true,
                    "script": [
                      "arduino-cli",
                      "board",
                      "list",
                      "--format",
                      "json"
                    ]
                  }
                ],
                "name": "FQBN"
              },
              "description": "Fully Qualified Board Name, example: 'arduino:avr:uno'",
              "name": [
                "-b",
                "--fqbn"
              ]
            },
            {
              "description": "Help for list",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "args": {},
              "description": "Command keeps running and prints list of connected boards whenever there is a change",
              "name": [
                "-w",
                "--watch"
              ]
            }
          ]
        },
        {
          "description": "List all boards that have the support platform installed, You can search for a specific board if you specify the board name",
          "name": "listall",
          "options": [
            {
              "description": "Help for listall",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "description": "Show also boards marked as 'hidden' in the platform",
              "name": [
                "-a",
                "--show-hidden"
              ]
            }
          ]
        },
        {
          "description": "Search for a board in the Boards Manager using the specified keywords",
          "name": "search",
          "options": [
            {
              "description": "Help for search",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "description": "Show also boards marked as 'hidden' in the platform",
              "name": [
                "-a",
                "--show-hidden"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Upload the bootloader on the board using an external programmer",
      "name": "burn-bootloader",
      "options": [
        {
          "args": {},
          "description": "List of board options separated by commas. Or can be used multiple times for multiple options",
          "name": [
            "--board-options"
          ]
        },
        {
          "args": {
            "name": "duration"
          },
          "description": "Max time to wait for port discovery, example: '30s, 1m (default 1s)'",
          "name": [
            "--discovery-timeout"
          ]
        },
        {
          "args": {
            "description": "Fully qualified board name",
            "generators": [
              {
                "js_source": "t=>{try{return JSON.parse(t).filter(i=>i.matching_boards).map(i=>({name:i.matching_boards[0].fqbn,description:`${i.matching_boards[0].name} on port ${i.port.address}`}))}catch{return[]}}",
                "requires_js": true,
                "script": [
                  "arduino-cli",
                  "board",
                  "list",
                  "--format",
                  "json"
                ]
              }
            ],
            "name": "FQBN"
          },
          "description": "Fully Qualified Board Name, example: 'arduino:avr:uno'",
          "name": [
            "-b",
            "--fqbn"
          ]
        },
        {
          "description": "Help for burn-bootloader",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "args": {
            "description": "Arduino board port connection",
            "generators": [
              {
                "js_source": "t=>{try{return JSON.parse(t).filter(i=>i.matching_boards).map(i=>({name:i.port.address,description:`${i.matching_boards[0].name} port connection`}))}catch{return[]}}",
                "requires_js": true,
                "script": [
                  "arduino-cli",
                  "board",
                  "list",
                  "--format",
                  "json"
                ]
              }
            ],
            "name": "port"
          },
          "description": "Upload port address, example: 'COM3 or /dev/ttyACM2'",
          "name": [
            "-p",
            "--port"
          ]
        },
        {
          "args": {},
          "description": "Programmer to use, example: 'atmel_ice'",
          "name": [
            "-P",
            "--programmer"
          ]
        },
        {
          "args": {},
          "description": "Upload port protocol, example: 'serial'",
          "name": [
            "-l",
            "--protocol"
          ]
        },
        {
          "description": "Turns on verbose mode",
          "name": [
            "-v",
            "--verbose"
          ]
        },
        {
          "description": "Verify uploaded binary after upload",
          "name": [
            "-t",
            "--verify"
          ]
        }
      ]
    },
    {
      "args": {
        "isOptional": true,
        "name": "clean"
      },
      "description": "Arduino cache commands",
      "name": "cache",
      "options": [
        {
          "description": "Help for cache",
          "name": [
            "-h",
            "--help"
          ]
        }
      ],
      "subcommands": [
        {
          "description": "Delete contents of the directories.downloads folder, where archive files are staged during installation of libraries and boards platforms",
          "name": "clean",
          "options": [
            {
              "description": "Help for clean",
              "name": [
                "-h",
                "--help"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Compiles Arduino sketches",
      "name": "compile",
      "options": [
        {
          "args": {},
          "description": "List of board options separated by commas. Or can be used multiple times for multiple option",
          "name": [
            "--board-options"
          ]
        },
        {
          "args": {},
          "description": "Builds of 'core.a' are saved into this path to be cached and reused",
          "name": [
            "--build-cache-path"
          ]
        },
        {
          "args": {
            "name": "filepath",
            "template": "filepaths"
          },
          "description": "Path where to save compiled files. If omitted, a directory will be created in the default temporary path of your OS",
          "name": [
            "--build-path"
          ]
        },
        {
          "args": {},
          "description": "Override a build property with a custom value. Can be used multiple times for multiple properties",
          "name": [
            "--build-property"
          ]
        },
        {
          "description": "Optional, cleanup the build folder and do not use any cached build",
          "name": [
            "--clean"
          ]
        },
        {
          "args": {
            "name": "duration"
          },
          "description": "Max time to wait for port discovery, example: '30s, 1m (default 1s)'",
          "name": [
            "--discovery-timeout"
          ]
        },
        {
          "description": "Create and print a profile configuration from the build",
          "name": [
            "--dump-profile"
          ]
        },
        {
          "args": {},
          "description": "The name of the custom encryption key to use to encrypt a binary during the compile process. Used only by the platforms that support it",
          "name": [
            "--encrypt-key"
          ]
        },
        {
          "description": "If set built binaries will be exported to the sketch folder",
          "name": [
            "e",
            "--export-binaries"
          ]
        },
        {
          "args": {
            "description": "Fully qualified board name",
            "generators": [
              {
                "js_source": "t=>{try{return JSON.parse(t).filter(i=>i.matching_boards).map(i=>({name:i.matching_boards[0].fqbn,description:`${i.matching_boards[0].name} on port ${i.port.address}`}))}catch{return[]}}",
                "requires_js": true,
                "script": [
                  "arduino-cli",
                  "board",
                  "list",
                  "--format",
                  "json"
                ]
              }
            ],
            "name": "FQBN"
          },
          "description": "Fully Qualified Board Name, example: 'arduino:avr:uno'",
          "name": [
            "-b",
            "--fqbn"
          ]
        },
        {
          "description": "Help for compile",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "args": {
            "name": "filepath",
            "template": [
              "filepaths",
              "folders"
            ]
          },
          "description": "The path of the dir to search for the custom keys to sign and encrypt a binary. Used only by the platforms that support it",
          "name": [
            "--keys-keychain"
          ]
        },
        {
          "args": {
            "name": "filepath",
            "template": [
              "filepaths",
              "folders"
            ]
          },
          "description": "Path to a collection of libraries. Can be used multiple times or entries can be comma separated",
          "name": [
            "--libraries"
          ]
        },
        {
          "args": {
            "name": "filepath",
            "template": [
              "filepaths",
              "folders"
            ]
          },
          "description": "Path to a single library’s root folder. Can be used multiple times or entries can be comma separated",
          "name": [
            "--library"
          ]
        },
        {
          "description": "Just produce the compilation database, without actually compiling. All build commands are skipped except pre* hooks",
          "name": [
            "--only-compilation-database"
          ]
        },
        {
          "description": "Optional, optimize compile output for debugging, rather than for release",
          "name": [
            "--optimize-for-debug"
          ]
        },
        {
          "args": {
            "name": "directory",
            "template": "folders"
          },
          "description": "Save build artifacts in this directory",
          "name": [
            "--output-dir"
          ]
        },
        {
          "args": {
            "description": "Arduino board port connection",
            "generators": [
              {
                "js_source": "t=>{try{return JSON.parse(t).filter(i=>i.matching_boards).map(i=>({name:i.port.address,description:`${i.matching_boards[0].name} port connection`}))}catch{return[]}}",
                "requires_js": true,
                "script": [
                  "arduino-cli",
                  "board",
                  "list",
                  "--format",
                  "json"
                ]
              }
            ],
            "name": "port"
          },
          "description": "Upload port address, example: 'COM3 or /dev/ttyACM2'",
          "name": [
            "-p",
            "--port"
          ]
        },
        {
          "description": "Print preprocessed code to stdout instead of compiling",
          "name": [
            "--preprocess"
          ]
        },
        {
          "args": {},
          "description": "Sketch profile to use",
          "name": [
            "-m",
            "--profile"
          ]
        },
        {
          "args": {},
          "description": "Programmer to use, example: 'atmel_ice'",
          "name": [
            "-P",
            "--programmer"
          ]
        },
        {
          "args": {},
          "description": "Upload port protocol, example: 'serial'",
          "name": [
            "-l",
            "--protocol"
          ]
        },
        {
          "description": "Optional, suppresses almost every output",
          "name": [
            "--quiet"
          ]
        },
        {
          "args": {},
          "description": "Show build properties. The properties are expanded, use \"--show-properties=unexpanded\" if you want them exactly as they are defined. (default \"disabled\")",
          "name": [
            "--show-properties"
          ]
        },
        {
          "args": {},
          "description": "The name of the custom signing key to use to sign a binary during the compile process. Used only by the platforms that support it",
          "name": [
            "--sign-key"
          ]
        },
        {
          "description": "Upload the binary after the compilation",
          "name": [
            "-u",
            "--upload"
          ]
        },
        {
          "description": "Optional, turns on verbose mode",
          "name": [
            "-v",
            "--verbose"
          ]
        },
        {
          "description": "Verify uploaded binary after the upload",
          "name": [
            "-t",
            "--verify"
          ]
        },
        {
          "args": {
            "suggestions": [
              {
                "description": "Use warning level 'none'",
                "name": "none"
              },
              {
                "description": "Use warning level 'default'",
                "name": "default"
              },
              {
                "description": "Use warning level 'more'",
                "name": "more"
              },
              {
                "description": "Use warning level 'all'",
                "name": "all"
              }
            ]
          },
          "description": "Optional, can be: none, default, more, all. Used to tell gcc which warning level to use (-W flag). (default \"none\")",
          "name": [
            "--warnings"
          ]
        }
      ]
    },
    {
      "description": "Generates completion scripts for various shells",
      "name": "completion",
      "options": [
        {
          "description": "Help for completion",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "description": "Disable completion description for shells that support it",
          "name": [
            "--no-description"
          ]
        }
      ]
    },
    {
      "args": {
        "isOptional": true,
        "name": "init, dump..."
      },
      "description": "Arduino configuration commands",
      "name": "config",
      "options": [
        {
          "description": "Help for config",
          "name": [
            "-h",
            "--help"
          ]
        }
      ],
      "subcommands": [
        {
          "description": "Adds one or more values to a setting",
          "name": "add",
          "options": [
            {
              "description": "Help for add",
              "name": [
                "-h",
                "--help"
              ]
            }
          ]
        },
        {
          "description": "Deletes a settings key and all its sub keys",
          "name": "delete",
          "options": [
            {
              "description": "Help for delete",
              "name": [
                "-h",
                "--help"
              ]
            }
          ]
        },
        {
          "description": "Prints the current configuration",
          "name": "dump",
          "options": [
            {
              "description": "Help for dump",
              "name": [
                "-h",
                "--help"
              ]
            }
          ]
        },
        {
          "description": "Creates or updates the configuration file in the data directory or custom directory with the current configuration settings",
          "name": "init",
          "options": [
            {
              "args": {
                "name": "directory",
                "template": "folders"
              },
              "description": "Sets where to save the configuration file",
              "name": [
                "--dest-dir"
              ]
            },
            {
              "args": {
                "name": "file",
                "template": "filepaths"
              },
              "description": "Sets where to save the configuration file",
              "name": [
                "--dest-file"
              ]
            },
            {
              "description": "Help for init",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "description": "Overwrite existing config file",
              "name": [
                "--overwrite"
              ]
            }
          ]
        },
        {
          "description": "Removes one or more values from a setting",
          "name": "remove",
          "options": [
            {
              "description": "Help for remove",
              "name": [
                "-h",
                "--help"
              ]
            }
          ]
        },
        {
          "description": "Sets a setting value",
          "name": "set",
          "options": [
            {
              "description": "Help for set",
              "name": [
                "-h",
                "--help"
              ]
            }
          ]
        }
      ]
    },
    {
      "args": {
        "isOptional": true,
        "name": "install, list..."
      },
      "description": "Arduino core operations",
      "name": "core",
      "options": [
        {
          "description": "Help for core",
          "name": [
            "-h",
            "--help"
          ]
        }
      ],
      "subcommands": [
        {
          "description": "Downloads one or more cores and corresponding tool dependencies",
          "name": "download",
          "options": [
            {
              "description": "Help for download",
              "name": [
                "-h",
                "--help"
              ]
            }
          ]
        },
        {
          "description": "Installs one or more cores and corresponding tool dependencies",
          "name": "install",
          "options": [
            {
              "description": "Help for install",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "description": "Do not overwrite already installed platforms",
              "name": [
                "--no-overwrite"
              ]
            },
            {
