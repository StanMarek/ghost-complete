                "js_source": "t=>{try{return JSON.parse(t).filter(i=>i.matching_boards).map(i=>({name:i.port.address,description:`${i.matching_boards[0].name} port connection`}))}catch{return[]}}",
                "requires_js": true,
                "script": [
                  "arduino-cli",
                  "board",
                  "list",
                  "--format",
                  "json"
