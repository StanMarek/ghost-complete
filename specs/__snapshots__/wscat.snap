          },
          {
            "name": "opcua+uajson"
          },
          {
            "name": "v1.swindon-lattice+json"
          },
          {
            "name": "v1.usp"
          },
          {
            "name": "mles-websocket"
          },
          {
            "name": "coap"
          },
