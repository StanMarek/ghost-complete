{
  "description": "Tsuru is the command line utility used by application developers, that will allow users to create, list, bind and manage apps",
  "name": "tsuru",
  "options": [
    {
      "description": "Show help for tsuru",
      "name": [
        "--help",
        "-h"
      ]
    }
  ],
  "subcommands": [
    {
      "description": "App commands",
      "name": "app",
      "subcommands": [
        {
          "description": "Builds a tsuru app image respecting",
          "name": "build",
          "options": [
            {
              "args": {
                "description": "App name",
                "generators": [
                  {
                    "js_source": "function(a){return o(a).map(i=>({name:i,description:\"Apps\"}))}",
                    "requires_js": true,
                    "script": [
                      "tsuru",
                      "app",
                      "list"
                    ]
                  }
                ],
                "name": "app"
              },
              "description": "App name",
              "name": [
                "-a",
                "--app"
              ]
            },
            {
              "args": {
                "name": "file-or-dir-n",
                "template": "filepaths"
              },
              "description": "Enables single file build into the root of the app's tree",
              "name": [
                "-f",
                "--files-only"
              ]
            },
            {
              "description": "Help for build",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "description": "The image tag",
              "name": [
                "-t",
                "--tag"
              ]
            }
          ]
        },
        {
          "args": [
            {
              "description": "App name",
              "generators": [
                {
                  "js_source": "function(a){return o(a).map(i=>({name:i,description:\"Apps\"}))}",
                  "requires_js": true,
                  "script": [
                    "tsuru",
                    "app",
                    "list"
                  ]
                }
              ],
              "name": "app"
            },
            {
              "description": "Platform of the app",
              "generators": [
                {
                  "script": [
                    "tsuru",
                    "platform",
                    "list"
                  ],
                  "transforms": [
                    "split_lines",
                    "filter_empty"
                  ]
                }
              ],
              "name": "platform"
            }
          ],
          "description": "Creates a new app using the given name and platform",
          "name": "create",
          "options": [
            {
              "args": {
                "description": "Poll name",
                "generators": [
                  {
                    "js_source": "function(a){return o(a).map(i=>({name:i,description:\"Pool\"}))}",
                    "requires_js": true,
                    "script": [
                      "tsuru",
                      "pool",
                      "list"
                    ]
                  }
                ],
                "name": "pool"
              },
              "description": "Filter applications by pool",
              "name": [
                "-o",
                "--pool"
              ]
            },
            {
              "args": {
                "description": "Pool where the app will be created",
                "generators": [
                  {
                    "js_source": "function(a){return o(a).map(i=>({name:i,description:\"Team\"}))}",
                    "requires_js": true,
                    "script": [
                      "tsuru",
                      "team",
                      "list"
                    ]
                  }
                ],
                "name": "team"
              },
              "description": "Team that will own the app",
              "name": [
                "-t",
                "--team"
              ]
            },
            {
              "args": {
                "description": "Plan to be used by the app",
                "generators": [
                  {
                    "js_source": "function(a){return o(a).map(i=>({name:i,description:\"Plan\"}))}",
                    "requires_js": true,
                    "script": [
                      "tsuru",
                      "plan",
                      "list"
                    ]
                  }
                ],
                "name": "plan"
              },
              "description": "Plan to be used by the app",
              "name": [
                "-p",
                "--plan"
              ]
            },
            {
              "description": "Description of the app",
              "name": [
                "-d",
                "--description"
              ]
            },
            {
              "description": "Tag to be used by the app",
              "name": [
                "-g",
                "--tag"
              ]
            },
            {
              "description": "Router options",
              "name": [
                "--router-opts"
              ]
            }
          ]
        },
        {
          "args": {
            "name": "file-or-dir-n",
            "template": "filepaths"
          },
          "description": "Deploys set of files and/or directories to tsuru server",
          "name": "deploy",
          "options": [
            {
              "args": {
                "description": "App name",
                "generators": [
                  {
                    "js_source": "function(a){return o(a).map(i=>({name:i,description:\"Apps\"}))}",
                    "requires_js": true,
                    "script": [
                      "tsuru",
                      "app",
                      "list"
                    ]
                  }
                ],
                "name": "app"
              },
              "description": "App name",
              "name": [
                "-a",
                "--app"
              ]
            },
            {
              "description": "Enables single file deployment into the root of the app's tree",
              "name": [
                "-f",
                "--files-only"
              ]
            },
            {
              "description": "The image to deploy in app",
              "name": [
                "-i",
                "--image"
              ]
            },
            {
              "description": "A message describing this deploy",
              "name": [
                "-m",
                "--message"
              ]
            },
            {
              "description": "Creates a new version for the current deployment while preserving existing versions",
              "name": [
                "--new-version"
              ]
            },
            {
              "description": "Force replace all deployed versions by this new deploy",
              "name": [
                "--override-old-versions"
              ]
            }
          ],
          "subcommands": [
            {
              "description": "List information about deploys for an application",
              "name": "list",
              "options": [
                {
                  "args": {
                    "description": "App name",
                    "generators": [
                      {
                        "js_source": "function(a){return o(a).map(i=>({name:i,description:\"Apps\"}))}",
                        "requires_js": true,
                        "script": [
                          "tsuru",
                          "app",
                          "list"
                        ]
                      }
                    ],
                    "name": "app"
                  },
                  "description": "App name",
                  "name": [
                    "-a",
                    "--app"
                  ]
                }
              ]
            },
            {
              "description": "Rebuild and deploy the last app image",
              "name": "rebuild",
              "options": [
                {
                  "args": {
                    "description": "App name",
                    "generators": [
                      {
                        "js_source": "function(a){return o(a).map(i=>({name:i,description:\"Apps\"}))}",
                        "requires_js": true,
                        "script": [
                          "tsuru",
                          "app",
                          "list"
                        ]
                      }
                    ],
                    "name": "app"
                  },
                  "description": "App name",
                  "name": [
                    "-a",
                    "--app"
                  ]
                },
                {
                  "description": "Creates a new version for the current deployment while preserving existing versions",
                  "name": [
                    "--new-version"
                  ]
                },
                {
                  "description": "Force replace all deployed versions by this new deploy",
                  "name": [
                    "--override-old-versions"
                  ]
                }
              ]
            },
            {
              "description": "Deploys an existing image for an app",
              "name": "rollback",
              "options": [
                {
                  "args": {
                    "description": "App name",
                    "generators": [
                      {
                        "js_source": "function(a){return o(a).map(i=>({name:i,description:\"Apps\"}))}",
                        "requires_js": true,
                        "script": [
                          "tsuru",
                          "app",
                          "list"
                        ]
                      }
                    ],
                    "name": "app"
                  },
                  "description": "App name",
                  "name": [
                    "-a",
                    "--app"
                  ]
                },
                {
                  "description": "Creates a new version for the current deployment while preserving existing versions",
                  "name": [
                    "--new-version"
                  ]
                },
                {
                  "description": "Force replace all deployed versions by this new deploy",
                  "name": [
                    "--override-old-versions"
                  ]
                },
                {
                  "description": "Answer yes to all questions",
                  "name": [
                    "y",
                    "--yes"
                  ]
                }
              ],
              "subcommands": [
                {
                  "description": "Locks an existing image of an app",
                  "name": "update",
                  "options": [
                    {
                      "args": {
                        "description": "App name",
                        "generators": [
                          {
                            "js_source": "function(a){return o(a).map(i=>({name:i,description:\"Apps\"}))}",
                            "requires_js": true,
                            "script": [
                              "tsuru",
                              "app",
                              "list"
                            ]
                          }
                        ],
                        "name": "app"
                      },
                      "description": "App name",
                      "name": [
                        "-a",
                        "--app"
                      ]
                    },
                    {
                      "description": "Enables or disables the rollback on a specific image version",
                      "name": [
                        "-d",
                        "--disable"
                      ]
                    },
                    {
                      "description": "The image name for an app version",
                      "name": [
                        "-i",
                        "--image"
                      ]
                    },
                    {
                      "description": "The reason why the rollback has to be disabled",
                      "name": [
                        "-r",
                        "--reason"
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
