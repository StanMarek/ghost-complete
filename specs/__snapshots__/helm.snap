              },
              "description": "Identify HTTPS client using this SSL certificate file",
              "name": [
                "--cert-file"
              ]
            },
            {
              "description": "Replace (overwrite) the repo if it already exists",
              "name": [
                "--force-update"
              ]
            },
            {
              "description": "Skip tls certificate checks for the repository",
