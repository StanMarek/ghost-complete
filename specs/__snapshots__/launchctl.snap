      "name": "unload",
      "options": [
        {
          "description": "Enable if disabled",
          "name": [
            "-w"
          ]
        },
        {
          "description": "Force load",
          "name": [
            "-F"
          ]
        },
        {
          "args": {
            "name": "session"
          },
          "description": "Session",
          "name": [
            "-S"
          ]
        },
        {
          "args": {
            "name": "domain"
          },
          "description": "Load files from specified domain",
          "name": [
            "-D"
          ]
        }
      ]
    },
    {
      "args": {
        "generators": [
