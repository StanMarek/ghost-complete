    {
      "args": {
        "generators": [
          {
            "script": [
              "launchctl",
              "list"
            ],
            "transforms": [
              "split_lines",
              "filter_empty"
            ]
          }
        ],
        "name": "label"
      },
      "description": "Stops the specified service if it is running",
