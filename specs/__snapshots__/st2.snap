          ]
        },
        {
          "description": "Get individual assignment",
          "name": "get",
          "options": [
            {
              "description": "Show this help and exit",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "args": {
                "name": "TOKEN"
              },
              "description": "Access token for user authentication. Get ST2_AUTH_TOKEN from the environment variables by default",
              "name": [
                "-t",
                "--token"
              ]
            },
            {
              "args": {
                "name": "API_KEY"
              },
              "description": "Api Key for user authentication. Get ST2_API_KEY from the environment variables by default",
              "name": [
                "--api-key"
              ]
            },
            {
              "description": "Print output in JSON format",
              "name": [
                "-j",
                "--json"
              ]
            },
            {
              "description": "Print output in YAML format",
              "name": [
                "-y",
                "--yaml"
              ]
            },
            {
              "args": {
                "name": "ROLE"
              },
              "description": "Role to filter on",
              "name": [
                "-r",
                "--role"
              ]
            },
            {
              "args": {
                "generators": [
                  {
                    "js_source": "async function(V,K){let F=V.find(c=>c.includes(\":\")),S=V.find(c=>/^-.*n.*/.test(c)),M;if(F){let{stdout:c}=await K({command:\"bash\",args:[\"-c\",\"dscl . -list /Groups PrimaryGroupID | tr -s ' '| sort -r\"]});M=c}else{let{stdout:c}=await K({command:\"bash\",args:[\"-c\",\"dscl . -list /Users UniqueID | tr -s ' '| sort -r\"]});M=c}return M.split(`\n`).map(c=>c.split(\" \")).map(c=>({name:S?c[1]:c[0],description:F?`Group - ${S?c[0]:`gid: ${c[1]}`}`:`User - ${S?c[0]:`uid: ${c[1]}`}`,icon:F?\"\\u{1F465}\":\"\\u{1F464}\",priority:90}))}",
                    "requires_js": true
                  }
                ],
                "name": "USER"
              },
              "description": "User under which to run the action (admins only)",
              "name": [
                "-u",
                "--user"
              ]
            },
            {
              "args": {
                "name": "SOURCE"
              },
              "description": "Source to filter on",
              "name": [
                "-s",
                "--source"
              ]
            },
            {
              "description": "Only display remote role assignments",
              "name": [
                "--remote"
              ]
            },
            {
              "args": {
                "isVariadic": true,
                "name": "ATTR"
              },
              "description": "List of attributes to include in the output. 'all' or unspecified will return all attributes",
              "name": [
                "--attr"
              ]
            },
            {
              "args": {
                "isVariadic": true,
                "name": "WIDTH"
              },
              "description": "Set the width of the columns in output",
              "name": [
                "-w",
                "--width"
              ]
            }
          ]
        }
      ]
    }
