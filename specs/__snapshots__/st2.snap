            {
              "args": {
                "generators": [
                  {
                    "js_source": "async function(V,K){let F=V.find(c=>c.includes(\":\")),S=V.find(c=>/^-.*n.*/.test(c)),M;if(F){let{stdout:c}=await K({command:\"bash\",args:[\"-c\",\"dscl . -list /Groups PrimaryGroupID | tr -s ' '| sort -r\"]});M=c}else{let{stdout:c}=await K({command:\"bash\",args:[\"-c\",\"dscl . -list /Users UniqueID | tr -s ' '| sort -r\"]});M=c}return M.split(`\n`).map(c=>c.split(\" \")).map(c=>({name:S?c[1]:c[0],description:F?`Group - ${S?c[0]:`gid: ${c[1]}`}`:`User - ${S?c[0]:`uid: ${c[1]}`}`,icon:F?\"\\u{1F465}\":\"\\u{1F464}\",priority:90}))}",
                    "requires_js": true
                  }
                ],
                "name": "USER"
              },
              "description": "User under which to run the action (admins only)",
              "name": [
                "-u",
                "--user"
              ]
            }
          ]
