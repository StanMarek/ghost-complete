              "description": "Maximum waiting time for '--wait' before canceling/returning",
              "name": [
                "--timeout"
              ]
            },
            {
              "description": "Wait for the server(s) (and loadbalancer) to be ready before returning",
              "name": [
                "--wait"
              ]
