    },
    {
      "description": "Builds your app and starts it on a connected Android emulator or device",
      "name": "run-android",
      "options": [
        {
          "args": {
            "name": "root",
            "template": "folders"
          },
          "description": "[DEPRECATED - root is discovered automatically] Override the root directory for the android build (which contains the android directory) (default: \"\")",
          "name": [
            "--root"
          ]
        },
        {
          "args": {
            "name": "variant",
            "suggestions": [
              {
                "name": "debug"
              },
              {
                "name": "release"
              }
            ]
          },
          "description": "Specify your app's build variant (default: \"debug\")",
          "name": [
            "--variant"
          ]
        },
        {
          "args": {
            "name": "string",
            "template": "folders"
          },
          "description": "[DEPRECATED – use \"project.android.appName\" in react-native.config.js] Specify a different application folder name for the android source. If not, we assume is \"app\"",
          "name": [
            "--appFolder"
          ]
        },
        {
          "args": {
            "name": "appId"
          },
          "description": "Specify an applicationId to launch after build. If not specified, `package` from AndroidManifest.xml will be used. (default: \"\")",
          "name": [
            "--appId"
          ]
        },
        {
          "args": {
            "name": "appIdSuffix"
          },
          "description": "Specify an applicationIdSuffix to launch after build. (default: \"\")",
          "name": [
            "--appIdSuffix"
          ]
        },
        {
          "args": {
            "name": "main activity"
          },
          "description": "Name of the activity to start (default: \"MainActivity\")",
          "name": [
            "--main-activity"
          ]
        },
        {
          "args": {
            "generators": [
              {
                "script": [
                  "adb",
                  "devices"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim",
                  {
                    "name": 1,
                    "pattern": "^(List)|\\*",
                    "type": "regex_extract"
                  }
                ]
              }
            ],
            "name": "deviceId"
          },
          "description": "Builds your app and starts it on a specific device/simulator with the given device id (listed by running \"adb devices\" on the command line)",
          "name": [
            "--deviceId"
          ]
        },
        {
          "description": "Do not launch packager while building",
          "name": [
            "--no-packager"
          ]
        },
        {
          "args": {
            "name": "free port"
          },
          "description": "Default: 8081",
          "name": [
            "--port"
          ]
        },
        {
          "args": {
            "name": "terminal path"
          },
          "description": "Launches the Metro Bundler in a new window using the specified terminal path. (default: \"Apple_Terminal\")",
          "name": [
            "--terminal"
          ]
        },
        {
          "args": {
            "generators": [
              {
                "script": [
                  "bash",
                  "-c",
                  "cd android/ && ./gradlew tasks"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  {
                    "name": 1,
                    "pattern": "^\\w+ \\- |\\*",
                    "type": "regex_extract"
                  }
                ]
              }
            ],
            "name": "task list"
          },
          "description": "Run custom Gradle tasks. By default it's \"installDebug\"",
          "name": [
            "--tasks"
          ]
        },
        {
          "description": "Do not run \"jetifier\" – the AndroidX transition tool. By default it runs before Gradle to ease working with libraries that don't support AndroidX yet. See more at: https://www.npmjs.com/package/jetifier",
          "name": [
            "--no-jetifier"
          ]
        },
        {
          "description": "Output usage information",
          "name": [
            "-h",
            "--help"
          ]
        }
      ]
    },
    {
      "description": "Builds your app and starts it on iOS simulator",
      "name": "run-ios",
      "options": [
        {
          "args": {
            "generators": [
              {
                "js_source": "e=>{let n=JSON.parse(e).devices;return Object.entries(n).map(([t,i])=>i).reduce((t,i)=>[...t,...i],[]).map(({name:t})=>({name:t,icon:G}))}",
                "requires_js": true,
                "script": [
                  "xcrun",
                  "simctl",
                  "list",
                  "--json",
                  "devices",
                  "available"
                ]
              }
            ],
            "name": "simulator"
          },
          "description": "Explicitly set simulator to use. Optionally include iOS version between parenthesis at the end to match an exact version: \"iPhone 6 (10.0)\" (default: \"iPhone 12\")",
          "name": [
            "--simulator"
          ]
        },
        {
          "args": {
            "generators": [
              {
                "script": [
                  "bash",
                  "-c",
                  "xcodebuild -project ios/*.xcodeproj  -list -json"
                ],
                "transforms": [
                  {
                    "path": "project.configurations",
                    "type": "json_extract_array"
                  }
                ]
              }
            ],
            "name": "config scheme"
          },
          "description": "Explicitly set the scheme configuration to use (default: \"Debug\")",
          "name": [
            "--configuration"
          ]
        },
        {
          "args": {
            "generators": [
              {
                "script": [
                  "bash",
                  "-c",
                  "xcodebuild -project ios/*.xcodeproj  -list -json"
                ],
                "transforms": [
                  {
                    "path": "project.schemes",
                    "type": "json_extract_array"
                  }
                ]
              }
            ],
            "name": "scheme"
          },
          "description": "Explicitly set Xcode scheme to use",
          "name": [
            "--scheme"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "folders"
          },
          "description": "Path relative to project root where the Xcode project (.xcodeproj) lives. (default: \"ios\")",
          "name": [
            "--project-path"
          ]
        },
        {
          "args": {
            "generators": [
              {
                "script": [
                  "xcrun",
                  "xctrace",
                  "list",
                  "devices"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim",
                  {
                    "name": 1,
                    "pattern": "^=",
                    "type": "regex_extract"
                  }
                ]
              }
            ],
            "isOptional": true,
            "name": "device name"
          },
          "description": "Explicitly set device to use by name",
          "name": [
            "--device"
          ]
        },
        {
          "args": {
            "generators": [
              {
                "script": [
                  "xcrun",
                  "xctrace",
                  "list",
                  "devices"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim",
                  {
                    "name": 1,
                    "pattern": "^=",
                    "type": "regex_extract"
                  }
                ]
              }
            ],
            "name": "udid"
          },
          "description": "Explicitly set device to use by udid",
          "name": [
            "--udid"
          ]
        },
        {
          "description": "Do not launch packager while building",
          "name": [
            "--no-packager"
          ]
        },
        {
          "description": "Do not use xcpretty even if installed",
          "name": [
            "--verbose"
          ]
        },
        {
          "args": {
            "name": "free port"
          },
          "description": "Default: 8081",
          "name": [
            "--port"
          ]
        },
        {
          "args": {
            "name": "terminal path"
          },
          "description": "Launches the Metro Bundler in a new window using the specified terminal path. (default: \"Apple_Terminal\")",
          "name": [
            "--terminal"
          ]
        },
        {
          "description": "Output usage information",
          "name": [
            "-h",
            "--help"
          ]
        }
      ]
    }
  ]
}
