        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Path to custom SSL cert",
          "name": [
            "--cert"
          ]
        },
        {
          "args": {
            "name": "string"
          },
          "description": "Path to the CLI configuration file",
          "name": [
            "--config"
          ]
        },
        {
          "description": "Disables interactive mode",
          "name": [
            "--no-interactive"
          ]
        },
        {
          "description": "Output usage information",
          "name": [
            "-h",
            "--help"
          ]
        }
      ]
    },
