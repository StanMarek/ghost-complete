          },
          "description": "Unix-style glob of directories to exclude when running *-all commands",
          "name": [
            "--terragrunt-exclude-dir"
          ]
        },
        {
          "args": {
            "template": [
              "folders"
            ]
          },
          "description": "Unix-style glob of directories to include when running *-all commands",
          "name": [
            "--terragrunt-include-dir"
          ]
        },
        {
          "description": "Only modules under the directories passed in with –terragrunt-include-dir will be included. All dependencies of the included directories will be excluded if they are not in the included directories. If no –terragrunt-include-dir flags are included, terragrunt will not include any modules during the execution of the commands",
          "name": [
            "--terragrunt-strict-include"
          ]
        },
        {
          "description": "Sets strict mode for the validate-inputs command. By default, strict mode is off. When this flag is passed, strict mode is turned on. When strict mode is turned off, the validate-inputs command will only return an error if required inputs are missing from all input sources (env vars, var files, etc). When strict mode is turned on, an error will be returned if required inputs are missing OR if unused variables are passed to Terragrunt",
          "name": [
            "--terragrunt-strict-validate"
          ]
        },
        {
          "description": "*-all commands will be run disregarding the dependencies",
          "name": [
            "--terragrunt-ignore-dependency-order"
          ]
        },
        {
          "description": "*-all commands will not attempt to include external dependencies",
          "name": [
            "--terragrunt-ignore-external-dependencies"
          ]
        },
        {
          "description": "*-all commands will include external dependencies",
          "name": [
            "--terragrunt-include-external-dependencies"
          ]
        },
        {
          "args": {
            "description": "Number of modules",
            "name": "N"
          },
          "description": "*-all commands parallelism set to at most N modules",
          "name": [
            "--terragrunt-parallelism"
          ]
        },
