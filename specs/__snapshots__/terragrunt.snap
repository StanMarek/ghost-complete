          ]
        },
        {
          "args": {
            "template": [
              "folders"
            ]
          },
          "description": "Download Terraform configurations from the specified source into a temporary folder, and run Terraform in that temporary folder",
          "name": [
            "--terragrunt-source"
          ]
        },
        {
          "description": "Replaces any source URL (including the source URL of a config pulled in with dependency blocks) that has root source with dest",
          "name": [
            "--terragrunt-source-map"
          ]
        },
        {
          "description": "Delete the contents of the temporary folder to clear out any old, cached source code before downloading new source code into it",
          "name": [
            "--terragrunt-source-update"
          ]
        },
        {
          "description": "*-all commands continue processing components even if a dependency fails",
          "name": [
            "--terragrunt-ignore-dependency-errors"
          ]
        },
        {
          "args": {
            "name": "IAM role ARN"
          },
          "description": "Assume the specified IAM role before executing Terraform. Can also be set via the TERRAGRUNT_IAM_ROLE environment variable",
          "name": [
            "--terragrunt-iam-role"
          ]
        },
        {
          "args": {
            "name": "Duration"
          },
          "description": "Session duration for IAM Assume Role session. Can also be set via the TERRAGRUNT_IAM_ASSUME_ROLE_DURATION environment variable",
          "name": [
            "--terragrunt-iam-assume-role-duration"
          ]
        },
        {
          "args": {
            "name": "Session name"
          },
          "description": "Name for the IAM Assummed Role session. Can also be set via TERRAGRUNT_IAM_ASSUME_ROLE_SESSION_NAME environment variable",
          "name": [
            "--terragrunt-iam-assume-role-session-name"
          ]
        },
        {
          "args": {
            "template": [
              "folders"
            ]
          },
          "description": "Unix-style glob of directories to exclude when running *-all commands",
          "name": [
            "--terragrunt-exclude-dir"
          ]
        },
        {
          "args": {
            "template": [
              "folders"
            ]
          },
          "description": "Unix-style glob of directories to include when running *-all commands",
          "name": [
            "--terragrunt-include-dir"
          ]
        },
        {
          "description": "Only modules under the directories passed in with –terragrunt-include-dir will be included. All dependencies of the included directories will be excluded if they are not in the included directories. If no –terragrunt-include-dir flags are included, terragrunt will not include any modules during the execution of the commands",
          "name": [
            "--terragrunt-strict-include"
          ]
        },
        {
          "description": "Sets strict mode for the validate-inputs command. By default, strict mode is off. When this flag is passed, strict mode is turned on. When strict mode is turned off, the validate-inputs command will only return an error if required inputs are missing from all input sources (env vars, var files, etc). When strict mode is turned on, an error will be returned if required inputs are missing OR if unused variables are passed to Terragrunt",
          "name": [
            "--terragrunt-strict-validate"
          ]
        },
        {
          "description": "*-all commands will be run disregarding the dependencies",
          "name": [
            "--terragrunt-ignore-dependency-order"
          ]
        },
        {
          "description": "*-all commands will not attempt to include external dependencies",
          "name": [
            "--terragrunt-ignore-external-dependencies"
          ]
        },
        {
          "description": "*-all commands will include external dependencies",
          "name": [
            "--terragrunt-include-external-dependencies"
          ]
        },
        {
          "args": {
            "description": "Number of modules",
            "name": "N"
          },
          "description": "*-all commands parallelism set to at most N modules",
          "name": [
            "--terragrunt-parallelism"
          ]
        },
        {
          "description": "Write terragrunt-debug.tfvars to working folder to help root-cause issues",
          "name": [
            "--terragrunt-debug"
          ]
        },
        {
          "description": "Sets the logging level for Terragrunt. Supported levels: panic, fatal, error, warn (default), info, debug, trace",
          "name": [
            "--terragrunt-log-level"
          ]
        },
        {
          "description": "Enable check mode in the hclfmt command",
          "name": [
            "--terragrunt-check"
          ]
        },
        {
          "args": {
            "name": "hcl file",
            "template": [
              "filepaths"
            ]
          },
          "description": "The path to a single hcl file that the hclfmt command should run on",
          "name": [
            "--terragrunt-hclfmt-file"
          ]
        },
        {
          "args": {},
          "description": "A key=value attribute to override in a provider block as part of the aws-provider-patch command. May be specified multiple times",
          "name": [
            "--terragrunt-override-attr"
          ]
        },
        {
          "args": {
            "template": [
              "filepaths"
            ]
          },
          "description": "The file path that terragrunt should use when rendering the terragrunt.hcl config as json. Only used in the render-json command. Defaults to terragrunt_rendered.json",
          "name": [
