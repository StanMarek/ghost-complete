                "requires_js": true
              }
            ],
            "isVariadic": true,
            "name": "paths"
          },
          "description": "Publish the provided VSIX packages",
          "name": [
            "-i",
            "--packagePath"
          ]
        },
        {
          "args": {
            "generators": [
              {
                "script": [
                  "git",
                  "--no-optional-locks",
                  "branch",
                  "-a",
                  "--no-color",
                  "--sort=-committerdate"
                ],
                "transforms": [
                  {
                    "starts_with": "fatal:",
                    "type": "error_guard"
                  },
                  "split_lines",
                  "filter_empty",
                  "trim",
                  {
                    "name": 0,
