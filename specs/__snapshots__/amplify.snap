    {
      "description": "Download and install the latest version of the Amplify CLI",
      "name": "upgrade"
    },
    {
      "description": "Remove all global Amplify configuration files and uninstall the Amplify CLI. This will not delete any Amplify projects",
      "name": "uninstall"
    },
