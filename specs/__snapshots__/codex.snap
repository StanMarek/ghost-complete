        {
          "args": {
            "description": "Custom review instructions",
            "isOptional": true,
            "name": "prompt"
          },
          "description": "Run code review in non-interactive mode",
          "name": "review",
          "options": [
            {
              "description": "Review staged, unstaged, and untracked changes",
              "name": [
                "--uncommitted"
              ]
            },
            {
              "args": {
                "generators": [
                  {
                    "type": "git_branches"
