    {
      "args": {
        "description": "Custom review instructions",
        "isOptional": true,
        "name": "prompt"
      },
      "description": "Run a code review non-interactively",
      "name": "review",
      "options": [
        {
          "description": "Review staged, unstaged, and untracked changes",
          "name": [
            "--uncommitted"
          ]
        },
        {
          "args": {
            "generators": [
              {
                "type": "git_branches"
              }
            ],
            "name": "branch"
          },
          "description": "Review changes against a base branch",
          "name": [
            "--base"
          ]
        },
        {
          "args": {
            "name": "sha"
          },
          "description": "Review changes from a specific commit",
          "name": [
            "--commit"
