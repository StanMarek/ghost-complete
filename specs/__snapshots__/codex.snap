{
  "args": {
    "description": "User prompt to start the session",
    "isOptional": true,
    "name": "prompt"
  },
  "description": "OpenAI Codex CLI - AI coding agent",
  "name": "codex",
  "options": [
    {
      "args": {
        "name": "key=value"
      },
      "description": "Override config value from config.toml (key=value)",
      "name": [
        "-c",
        "--config"
      ]
    },
    {
      "args": {
        "name": "feature"
      },
      "description": "Enable a feature flag",
      "name": [
        "--enable"
      ]
    },
    {
      "args": {
        "name": "feature"
      },
      "description": "Disable a feature flag",
      "name": [
        "--disable"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "Image(s) to attach to initial prompt",
      "name": [
        "-i",
        "--image"
      ]
    },
    {
      "args": {
        "name": "model"
      },
      "description": "Model the agent should use",
      "name": [
        "-m",
        "--model"
      ]
    },
    {
      "description": "Use local open source model provider",
      "name": [
        "--oss"
      ]
    },
    {
      "args": {
        "name": "provider",
        "suggestions": [
          {
            "name": "lmstudio"
          },
          {
            "name": "ollama"
          }
        ]
      },
      "description": "Specify local provider",
      "name": [
        "--local-provider"
      ]
    },
    {
      "args": {
        "name": "profile"
      },
      "description": "Configuration profile from config.toml",
      "name": [
        "-p",
        "--profile"
      ]
    },
    {
      "args": {
        "name": "mode",
        "suggestions": [
          {
            "name": "read-only"
          },
          {
            "name": "workspace-write"
          },
          {
            "name": "danger-full-access"
          }
        ]
      },
      "description": "Sandbox policy",
      "name": [
        "-s",
        "--sandbox"
      ]
    },
    {
      "args": {
        "name": "policy",
        "suggestions": [
          {
            "name": "untrusted"
          },
          {
            "name": "on-request"
          },
          {
            "name": "never"
          }
        ]
      },
      "description": "Approval policy",
      "name": [
        "-a",
        "--ask-for-approval"
      ]
    },
    {
      "description": "Alias for -a on-request --sandbox workspace-write",
      "name": [
        "--full-auto"
      ]
    },
    {
      "description": "Skip all prompts and sandbox",
      "name": [
        "--dangerously-bypass-approvals-and-sandbox"
      ]
    },
    {
      "args": {
        "name": "dir",
        "template": "folders"
      },
      "description": "Working directory root",
      "name": [
        "-C",
        "--cd"
      ]
    },
    {
      "description": "Enable live web search",
      "name": [
        "--search"
      ]
    },
    {
      "args": {
        "name": "dir",
        "template": "folders"
      },
      "description": "Additional writable directories",
      "name": [
        "--add-dir"
      ]
    },
    {
      "description": "Disable alternate screen mode (for tmux/Zellij)",
      "name": [
        "--no-alt-screen"
      ]
    },
    {
      "description": "Print help",
      "name": [
        "-h",
        "--help"
      ]
    },
    {
      "description": "Print version",
      "name": [
        "-V",
        "--version"
      ]
    }
  ],
  "subcommands": [
    {
      "args": {
        "description": "Instructions for agent",
        "isOptional": true,
        "name": "prompt"
      },
      "description": "Run Codex non-interactively",
      "name": "exec",
      "options": [
        {
          "description": "Allow running outside a Git repository",
          "name": [
            "--skip-git-repo-check"
          ]
        },
        {
          "description": "Run without persisting session files",
          "name": [
            "--ephemeral"
          ]
        },
        {
          "args": {
            "name": "file",
            "template": "filepaths"
          },
          "description": "Path to JSON Schema for response shape",
          "name": [
            "--output-schema"
          ]
        },
        {
          "args": {
            "name": "color",
            "suggestions": [
              {
                "name": "always"
              },
              {
                "name": "never"
              },
              {
                "name": "auto"
              }
            ]
          },
          "description": "Color settings",
          "name": [
            "--color"
          ]
        },
        {
          "description": "Force cursor-based progress updates",
          "name": [
            "--progress-cursor"
          ]
        },
        {
          "description": "Print events to stdout as JSONL",
          "name": [
            "--json"
          ]
        },
        {
          "args": {
            "name": "file",
            "template": "filepaths"
          },
          "description": "File to write last agent message",
          "name": [
            "-o",
            "--output-last-message"
          ]
        },
        {
          "args": {
            "name": "key=value"
          },
          "description": "Override config value (key=value)",
          "name": [
            "-c",
            "--config"
          ]
        },
        {
          "args": {
            "name": "file",
            "template": "filepaths"
