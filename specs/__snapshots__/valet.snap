{
  "description": "Valet is a Laravel development environment for macOS minimalists",
  "name": "valet",
  "options": [
    {
      "description": "Display help for the given command. When no command is given display help for the list command",
      "name": [
        "-h",
        "--help"
      ]
    },
    {
      "description": "Do not output any message",
      "name": [
        "-q",
        "--quiet"
      ]
    },
    {
      "description": "Display this application version",
      "name": [
        "-V",
        "--version"
      ]
    },
    {
      "description": "Force (or disable --no-ansi) ANSI output",
      "name": [
        "--ansi"
      ]
    },
    {
      "description": "Force (or disable --no-ansi) ANSI output",
      "name": [
        "--no-ansi"
      ]
    },
    {
      "description": "Do not ask any interactive question",
      "name": [
        "-n",
        "--no-interaction"
      ]
    },
    {
      "args": {
        "isOptional": true,
        "name": "verbosity",
        "suggestions": [
          {
            "description": "Normal output",
            "name": "1"
          },
          {
            "description": "More verbose output",
            "name": "2"
          },
          {
            "description": "Debug output",
            "name": "3"
          }
        ]
      },
      "description": "Increase the verbosity of messages: 1 for normal output, 2 for more verbose output and 3 for debug",
      "name": [
        "-v",
        "-vv",
        "-vvv",
        "--verbose"
      ]
    }
  ],
  "subcommands": [
