                "-I",
                "--ignore-first-depends-on-past"
              ]
            },
            {
              "description": "Run the task using the LocalExecutor",
              "name": [
                "-l",
                "--local"
              ]
            },
            {
              "description": "Mark jobs as succeeded without running them",
