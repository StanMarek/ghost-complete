{
  "args": {
    "description": "Pathname of an output file",
    "isVariadic": true,
    "name": "file",
    "template": "filepaths"
  },
  "description": "Duplicate standard input",
  "name": "tee",
  "options": [
    {
      "description": "Append the output to the files rather than overwriting them",
      "name": [
        "-a"
      ]
    },
    {
      "description": "Ignore the SIGINT signal",
      "name": [
        "-i"
      ]
    }
  ]
}
