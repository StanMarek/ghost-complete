{
  "args": {
    "description": "String to operate on (typically filenames)",
    "isVariadic": true,
    "name": "string",
    "template": "filepaths"
  },
  "description": "Return filename portion of pathname",
  "name": "basename",
  "options": [
    {
      "description": "Treat every argument as a string",
      "name": [
        "-a"
      ]
    },
    {
      "args": {
        "name": "suffix"
      },
      "description": "Suffix to remove from string",
      "name": [
        "-s"
      ]
    }
  ]
}
