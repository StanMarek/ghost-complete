            ],
            "transforms": [
              "split_lines",
              "filter_empty",
              "trim"
            ]
          }
        ],
        "name": "run name"
      },
      "description": "Print executions log and runtime info",
      "name": "log",
      "options": [
        {
          "args": {
            "generators": [
              {
                "script": [
                  "bash",
                  "-c",
                  "cat .nextflow/history | awk '{ print $4 }'"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim"
                ]
              }
            ],
            "name": "run name"
          },
          "description": "Show log entries for runs executed after the specified one",
          "name": [
            "-after"
          ]
        },
        {
          "args": {
            "generators": [
              {
                "script": [
                  "bash",
                  "-c",
                  "cat .nextflow/history | awk '{ print $4 }'"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim"
                ]
              }
            ],
            "name": "run name"
          },
          "description": "Show log entries for runs executed before the specified one",
