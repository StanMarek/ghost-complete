        },
        {
          "args": {
            "generators": [
              {
                "script": [
                  "bash",
                  "-c",
                  "cat .nextflow/history | awk '{ print $4 }'"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim"
                ]
              }
            ],
            "name": "run name"
          },
          "description": "Show log entries of all runs except the specified one",
          "name": [
            "-but"
          ]
        },
        {
          "args": {
            "name": "field1,field2,..."
