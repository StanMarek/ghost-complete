        "js_source": "function(e,[n]){if(e.trim()==\"\")return[];try{let i=JSON.parse(e),s=i.scripts,a=i.fig||{};if(s)return Object.entries(s).map(([o,r])=>{let d=n===\"yarn\"?\"fig://icon?type=yarn\":\"fig://icon?type=npm\",m=a[o];return{name:o,icon:d,description:r,priority:51,...m}})}catch(i){console.error(i)}return[]}",
        "requires_js": true,
        "script": [
          "bash",
          "-c",
          "until [[ -f package.json ]] || [[ $PWD = '/' ]]; do cd ..; done; cat package.json"
        ]
      }
    ],
    "isOptional": true
  },
  "description": "Manage packages and run scripts",
