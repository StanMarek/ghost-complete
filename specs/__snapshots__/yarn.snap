            {
              "description": "Set global config",
              "name": [
                "-g",
                "--global"
              ],
              "priority": 60
            }
          ]
        },
        {
          "args": {
            "generators": [
              {
                "js_source": "function(e){if(e.trim()==\"\")return[];try{let n=e.indexOf(\"{\"),i=e.indexOf(\"}\"),s=e.substring(n,i+1);s=s.replace(/\\'/gi,'\"').replace(\"lastUpdateCheck\",'\"lastUpdateCheck\"').replace(\"registry\",'\"lastUpdateCheck\"');let a=JSON.parse(s);if(a)return Object.keys(a).map(o=>({name:o}))}catch{}return[]}",
                "requires_js": true,
                "script": [
                  "yarn",
                  "config",
                  "list"
                ]
              }
            ]
          },
          "description": "Print the value for a given key",
          "name": "get"
        },
        {
          "args": {
            "generators": [
