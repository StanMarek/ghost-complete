{
  "args": {
    "isVariadic": true,
    "name": "input file(s)",
    "template": "filepaths"
  },
  "description": "A universal document converter",
  "name": "pandoc",
  "options": [
    {
      "args": {
        "generators": [
          {
            "script": [
              "pandoc",
              "--list-input-formats"
            ],
            "transforms": [
              "split_lines",
              "filter_empty"
            ]
          }
        ],
        "name": "format"
      },
      "description": "Specify input format",
      "name": [
        "-f",
        "-r",
        "--from",
        "--read"
      ]
    },
    {
      "args": {
        "generators": [
          {
            "script": [
              "pandoc",
              "--list-output-formats"
            ],
            "transforms": [
              "split_lines",
              "filter_empty"
            ]
          }
        ],
        "name": "format"
      },
      "description": "Specify output format",
      "name": [
        "-t",
        "-w",
        "--to",
        "--write"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "Write output to FILE instead of stdout",
      "name": [
        "-o",
        "--output"
      ]
    },
    {
      "args": {
        "name": "directory",
        "template": "folders"
      },
      "description": "Specify the user data directory to search for pandoc data files",
      "name": [
        "--data-dir"
      ]
    },
    {
      "args": {
        "generators": [
          {
            "js_source": "(f,m,w)=>ue(this,void 0,void 0,function*(){var p;let{isDangerous:v,currentWorkingDirectory:T,searchTerm:h}=w,x=(p=(0,y.getCurrentInsertedDirectory)(d??T,h,w))!==null&&p!==void 0?p:\"/\";try{let X=yield m({command:\"ls\",args:[\"-1ApL\"],cwd:x}),Z=q(X.stdout.split(`\n`),[\".DS_Store\"]),N=[];for(let _ of Z)if(_){let E=_.endsWith(\"/\")?\"folders\":\"filepaths\";(E===\"filepaths\"&&c!==\"only\"||E===\"folders\"&&c!==\"never\")&&N.push({type:E===\"filepaths\"?\"file\":\"folder\",name:_,insertValue:_,isDangerous:v,context:{templateType:E}})}return L(g(N))}catch{return[]}})",
            "requires_js": true
          }
        ],
        "name": "file"
      },
      "description": "Specify a set of default option settings",
      "name": [
        "-d",
        "--defaults"
      ]
    },
    {
      "description": "Generate a bash completion script",
      "name": [
        "--bash-completion"
      ]
    },
    {
      "description": "Give verbose debugging output",
      "name": [
        "--verbose"
      ]
    },
    {
      "description": "Suppress warning messages",
      "name": [
        "--quiet"
      ]
    },
    {
      "description": "Exit with error status if there are any warnings",
      "name": [
        "--fail-if-warnings"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "Write log messages in machine-readable JSON format to FILE",
      "name": [
        "--log"
      ]
    },
    {
      "description": "List supported input formats, one per line",
      "name": [
        "--list-input-formats"
      ]
    },
    {
      "description": "List supported output formats, one per line",
      "name": [
        "--list-output-formats"
      ]
    },
    {
      "args": {
        "generators": [
          {
            "js_source": "function(e){return Array.from(new Set(e.split(`\n`))).map(n=>({name:n,icon:`fig://icon?type=${n}`}))}",
            "requires_js": true,
            "script": [
              "pandoc",
              "--list-input-formats"
            ]
          },
          {
            "js_source": "function(e){return Array.from(new Set(e.split(`\n`))).map(n=>({name:n,icon:`fig://icon?type=${n}`}))}",
            "requires_js": true,
            "script": [
              "pandoc",
              "--list-output-formats"
            ]
          }
        ],
        "isOptional": true,
        "name": "format"
      },
      "description": "List supported extensions for FORMAT, one per line, preceded by a + or -  indicating whether it is enabled by default in FORMAT",
      "name": [
        "--list-extensions"
      ]
    },
    {
      "description": "List supported languages for syntax highlighting, one per line",
      "name": [
        "--list-highlight-languages"
      ]
    },
    {
      "description": "List supported styles for syntax highlighting, one per line",
      "name": [
        "--list-highlight-styles"
      ]
    },
    {
      "description": "Print version",
      "name": [
        "-v",
        "--version"
      ]
    },
    {
      "description": "Show usage message",
      "name": [
        "-h",
        "--help"
      ]
    },
    {
      "args": {
        "name": "number"
      },
      "description": "Shift heading levels by a positive or negative integer",
      "name": [
        "--shift-heading-level-by"
      ]
    },
    {
      "args": {
        "name": "classes"
      },
      "description": "Specify classes to use for indented code blocks–for example, perl,numberLines or haskell. Multiple classes may be separated by spaces or commas",
      "name": [
        "--indented-code-classes"
      ]
    },
    {
      "args": {
        "name": "extension"
      },
      "description": "Specify a default extension to use when image paths/URLs have no extension. This allows you to use the same source for formats that require different kinds of images. Currently this option only affects the Markdown and LaTeX readers",
      "name": [
        "--default-image-extension"
      ]
    },
    {
      "description": "Parse each file individually before combining for multifile documents. This will allow footnotes in different files with the same identifiers to work as expected",
      "name": [
        "--file-scope"
      ]
    },
    {
      "args": {
        "name": "executable",
        "template": "filepaths"
      },
      "description": "Specify an executable to be used as a filter transforming the pandoc AST after the input is parsed and before the output is written",
      "name": [
        "-F",
        "--filter"
      ]
    },
    {
      "args": {
        "name": "script",
        "template": "filepaths"
      },
      "description": "Transform the document in a similar fashion as JSON filters, but use pandoc’s built-in Lua filtering system",
      "name": [
        "-L",
        "--lua-filter"
      ]
    },
    {
      "args": [
        {
          "name": "key"
        },
        {
          "isOptional": true,
          "name": "value"
        }
      ],
      "description": "Set the metadata field KEY to the value VAL",
      "name": [
        "-M",
        "--metadata"
      ]
    },
    {
      "args": {
        "generators": [
          {
            "js_source": "(f,m,w)=>ue(this,void 0,void 0,function*(){var p;let{isDangerous:v,currentWorkingDirectory:T,searchTerm:h}=w,x=(p=(0,y.getCurrentInsertedDirectory)(d??T,h,w))!==null&&p!==void 0?p:\"/\";try{let X=yield m({command:\"ls\",args:[\"-1ApL\"],cwd:x}),Z=q(X.stdout.split(`\n`),[\".DS_Store\"]),N=[];for(let _ of Z)if(_){let E=_.endsWith(\"/\")?\"folders\":\"filepaths\";(E===\"filepaths\"&&c!==\"only\"||E===\"folders\"&&c!==\"never\")&&N.push({type:E===\"filepaths\"?\"file\":\"folder\",name:_,insertValue:_,isDangerous:v,context:{templateType:E}})}return L(g(N))}catch{return[]}})",
            "requires_js": true
          }
        ],
        "name": "file"
      },
      "description": "Read metadata from the supplied YAML (or JSON) file",
      "name": [
        "--metadata-file"
      ]
    },
    {
      "description": "Preserve tabs instead of converting them to spaces",
      "name": [
        "-p",
        "--preserve-tabs"
      ]
    },
    {
      "args": {
        "name": "number"
      },
      "description": "Specify the number of spaces per tab",
      "name": [
        "--tab-stop"
      ]
    },
    {
      "args": {
        "name": "mode",
        "suggestions": [
          {
            "description": "Processes all the insertions and deletions and ignores comments",
            "name": "accept"
          },
          {
            "description": "Ignores all the insertions and deletions and ignores comments",
            "name": "reject"
          },
          {
            "description": "Includes all insertions, deletions, and comments, wrapped in spans with insertion, deletion, comment-start, and comment-end classes, respectively",
            "name": "all"
          }
        ]
      },
      "description": "Specifies what to do with insertions, deletions, and comments produced by the MS Word `Track Changes` feature",
      "name": [
        "--track-changes"
      ]
    },
    {
      "args": {
        "name": "dir",
        "template": "folders"
      },
      "description": "Extract images and other media contained in or linked from the source document to the path DIR, creating it if necessary, and adjust the images references in the document so they point to the extracted files",
      "name": [
        "--extract-media"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "Specifies a custom abbreviations file, with abbreviations one to a line. If this option is not specified, pandoc will read the data file abbreviations from the user data directory or fall back on a system default",
      "name": [
        "--abbreviations"
      ]
    },
    {
      "description": "Produce output with an appropriate header and footer (e.g. a standalone HTML, LaTeX, TEI, or RTF file, not a fragment). This option is set automatically for pdf, epub, epub3, fb2, docx, and odt output",
      "name": [
        "-s",
        "--standalone"
      ]
    },
    {
      "args": {
        "name": "file or URL",
        "template": "filepaths"
      },
      "description": "Use the specified file as a custom template for the generated document",
      "name": [
        "--template"
      ]
    },
    {
      "args": [
        {
          "name": "key"
        },
        {
          "isOptional": true,
          "name": "value"
        }
      ],
      "description": "Set the template variable KEY to the value VAL when rendering the document in standalone mode. If no VAL is specified, the key will be given the value true",
      "name": [
        "-V",
        "--variable"
      ]
    },
    {
      "args": {
        "generators": [
          {
            "script": [
              "pandoc",
              "--list-output-formats"
            ],
            "transforms": [
              "split_lines",
              "filter_empty"
            ]
          }
        ],
        "name": "format"
      },
      "description": "Print the system default template for an output FORMAT. Templates in the user data directory are ignored",
      "name": [
        "-D",
        "--print-default-template"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "Print a system default data file. Files in the user data directory are ignored",
      "name": [
        "--print-default-data-file"
      ]
    },
    {
      "args": {
        "name": "type",
        "suggestions": [
          {
            "description": "Windows",
            "name": "crlf"
          },
          {
            "description": "MacOS/Linux/UNIX",
            "name": "lf"
          },
          {
            "description": "Line endings appropriate to the OS on which Pandoc is being run",
            "name": "native"
          }
        ]
      },
      "description": "Manually specify line endings: crlf (Windows), lf (macOS/Linux/UNIX), or native (line endings appropriate to the OS on which pandoc is being run). The default is native",
      "name": [
        "--eol"
      ]
    },
    {
      "args": {
        "name": "number"
      },
      "description": "Specify the default dpi (dots per inch) value for conversion from pixels to inch/centimeters and vice versa",
      "name": [
        "--dpi"
      ]
    },
    {
      "args": {
        "name": "mode",
        "suggestions": [
          {
            "description": "Attempts to wrap lines to the column width specified by --columns (default 72)",
            "name": "auto"
          },
          {
            "description": "Will not wrap lines at all",
            "name": "none"
          },
          {
            "description": "Attempts to preserve the wrapping from the source document",
            "name": "preserve"
          }
        ]
      },
      "description": "Determine how text is wrapped in the output (the source code, not the rendered version)",
      "name": [
        "--wrap"
      ]
    },
    {
      "args": {
        "name": "number"
      },
      "description": "Specify length of lines in characters. This affects text wrapping in the generated source code",
      "name": [
        "--columns"
      ]
    },
    {
      "description": "Include an automatically generated table of contents (or, in the case of latex, context, docx, odt, opendocument, rst, or ms, an instruction to create one) in the output document. It has no effect on man, docbook4, docbook5, or jats output",
      "name": [
        "--toc",
        "--table-of-contents"
      ]
    },
    {
      "args": {
        "name": "number"
      },
      "description": "Specify the number of section levels to include in the table of contents",
      "name": [
        "--toc-depth"
      ]
    },
    {
      "description": "Strip out HTML comments in the Markdown or Textile source, rather than passing them on to Markdown, Textile or HTML output as raw HTML. This does not apply to HTML comments inside raw HTML blocks when the markdown_in_html_blocks extension is not set",
      "name": [
        "--strip-comments"
      ]
    },
    {
      "description": "Disables syntax highlighting for code blocks and inlines, even when a language attribute is given",
      "name": [
        "--no-highlight"
      ]
    },
    {
      "args": {
        "name": "STYLE|FILE",
        "suggestions": [
          {
            "name": "pygments"
          },
          {
            "name": "kate"
          },
          {
            "name": "monochrome"
          },
          {
            "name": "breezeDark"
          },
          {
            "name": "espresso"
          },
          {
            "name": "zenburn"
          },
          {
            "name": "haddock"
          },
          {
            "name": "tango"
          }
        ],
        "template": "filepaths"
      },
      "description": "Specifies the coloring style to be used in highlighted source code",
      "name": [
        "--highlight-style"
      ]
    },
    {
      "args": {
        "name": "STYLE|FILE",
        "suggestions": [
          {
            "name": "pygments"
          },
          {
            "name": "kate"
          },
          {
            "name": "monochrome"
          },
          {
            "name": "breezeDark"
          },
          {
            "name": "espresso"
          },
          {
            "name": "zenburn"
          },
          {
            "name": "haddock"
          },
          {
            "name": "tango"
          }
        ],
        "template": "filepaths"
      },
      "description": "Prints a JSON version of a highlighting style, which can be modified, saved with a .theme extension, and used with --highlight-style",
      "name": [
        "--print-highlight-style"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "Instructs pandoc to load a KDE XML syntax definition file, which will be used for syntax highlighting of appropriately marked code blocks",
      "name": [
        "--syntax-definition"
      ]
    },
    {
      "args": {
        "name": "FILE|URL",
        "template": "filepaths"
      },
      "description": "Include contents of FILE, verbatim, at the end of the header",
      "name": [
        "-H",
        "--include-in-header"
      ]
    },
    {
      "args": {
        "name": "FILE|URL",
        "template": "filepaths"
      },
      "description": "Include contents of FILE, verbatim, at the beginning of the document body",
      "name": [
        "-B",
        "--include-before-body"
      ]
    },
    {
      "args": {
        "name": "FILE|URL",
        "template": "filepaths"
      },
      "description": "Include contents of FILE, verbatim, at the end of the document body",
      "name": [
        "-A",
        "--include-after-body"
      ]
    },
    {
      "args": {
        "description": "The paths should be separated by : on Linux, UNIX, and macOS systems, and by ; on Windows",
        "name": "search path",
        "template": "folders"
      },
      "description": "List of paths to search for images and other resources. If --resource-path is not specified, the default resource path is the working directory",
      "name": [
        "--resource-path"
      ]
    },
    {
      "args": {
        "name": "NAME:VAL"
      },
      "description": "Set the request header NAME to the value VAL when making HTTP requests. If you’re behind a proxy, you also need to set the environment variable http_proxy to http://",
      "name": [
        "--request-header"
      ]
    },
    {
      "description": "Disable the certificate verification to allow access to unsecure HTTP resources",
      "name": [
        "--no-check-certificate"
      ]
    },
    {
      "description": "Produce a standalone HTML file with no external dependencies, using data: URIs to incorporate the contents of linked scripts, stylesheets, images, and videos",
      "name": [
        "--self-contained"
      ]
    },
    {
      "description": "Use <q> tags for quotes in HTML. This option only has an effect if the smart extension is enabled",
      "name": [
        "--html-q-tags"
      ]
    },
    {
      "description": "Use only ASCII characters in output. Currently supported for XML, HTML formats, CommonMark, gfm, Markdown, roff ms , and to a limited degree LaTeX, roff man output uses ASCII by default",
      "name": [
        "--ascii"
      ]
    },
    {
      "description": "Use reference-style links, rather than inline links, in writing Markdown or reStructuredText",
      "name": [
        "--reference-links"
      ]
    },
    {
      "args": {
        "name": "type",
        "suggestions": [
          {
            "name": "block"
          },
          {
            "name": "section"
          },
          {
            "name": "document"
          }
        ]
      },
      "description": "Specify whether footnotes (and references, if reference-links is set) are placed at the end of the current (top-level) block, the current section, or the document. Currently only affects the markdown writer",
      "name": [
        "--reference-location"
      ]
    },
    {
      "args": {
        "name": "type",
        "suggestions": [
          {
            "name": "setext"
          },
          {
            "name": "atx"
          }
        ]
      },
      "description": "Specify whether to use ATX-style (#-prefixed) or Setext-style (underlined) headings for level 1 and 2 headings in Markdown output",
      "name": [
        "--markdown-headings"
      ]
    },
    {
      "description": "Deprecated synonym for --markdown-headings=atx",
      "name": [
        "--atx-headers"
      ]
    },
    {
      "args": {
        "name": "mode",
        "suggestions": [
          {
            "name": "default"
          },
          {
            "name": "section"
          },
          {
            "name": "chapter"
          },
          {
            "name": "part"
          }
        ]
      },
      "description": "Treat top-level headings as the given division type in LaTeX, ConTeXt, DocBook, and TEI output",
      "name": [
        "--top-level-division"
      ]
    },
    {
      "description": "Number section headings in LaTeX, ConTeXt, HTML, Docx, ms, or EPUB output. By default, sections are not numbered",
      "name": [
        "-N",
        "--number-sections"
      ]
    },
    {
      "args": {
        "description": "The first number is added to the section number for top-level headings, the second for second-level headings, and so on",
        "isVariadic": true,
        "name": "number"
      },
      "description": "Offset for section headings in HTML output (ignored in other output formats)",
      "name": [
        "--number-offset"
      ]
    },
    {
      "description": "Use the listings package for LaTeX code blocks. The package does not support multi-byte encoding for source code. To handle UTF-8 you would need to use a custom template",
      "name": [
        "--listings"
      ]
    },
    {
      "description": "Make list items in slide shows display incrementally",
      "name": [
        "-i",
        "--incremental"
      ]
    },
    {
      "args": {
        "description": "Number",
        "name": "level"
      },
      "description": "Specifies that headings with the specified level create slides (for beamer, s5, slidy, slideous, dzslides). Headings above this level in the hierarchy are used to divide the slide show into sections; headings below this level create subheads within a slide",
      "name": [
        "--slide-level"
      ]
    },
    {
      "description": "Wrap sections in <section> tags (or <div> tags for html4), and attach identifiers to the enclosing <section> (or <div>) rather than the heading itself",
      "name": [
        "--section-divs"
      ]
    },
    {
      "args": {
        "name": "type",
        "suggestions": [
          {
            "description": "Leaves mailto: links as they are",
            "name": "none"
          },
          {
            "description": "Obfuscates mailto: links using JavaScript",
            "name": "javascript"
          },
          {
            "description": "Obfuscates mailto: links by printing their letters as decimal or hexadecimal character references",
            "name": "references"
          }
        ]
      },
      "description": "Specify a method for obfuscating mailto: links in HTML documents references . The default is none",
      "name": [
        "--email-obfuscation"
      ]
    },
    {
      "args": {
        "name": "string"
      },
      "description": "Specify a prefix to be added to all identifiers and internal links in HTML and DocBook output, and to footnote numbers in Markdown and Haddock output",
      "name": [
        "--id-prefix"
      ]
    },
    {
      "args": {
        "name": "string"
      },
      "description": "Specify STRING as a prefix at the beginning of the title that appears in the HTML header (but not in the title as it appears at the beginning of the HTML body)",
      "name": [
        "-T",
        "--title-prefix"
      ]
    },
    {
      "args": {
        "name": "URL"
      },
      "description": "Link to a CSS style sheet. This option can be used repeatedly to include multiple files. They will be included in the order specified",
      "name": [
        "-c",
        "--css"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "Use the specified file as a style reference in producing a docx or ODT file",
      "name": [
        "--reference-doc"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "Use the specified image as the EPUB cover. It is recommended that the image be less than 1000px in width and height. Note that in a Markdown source document you can also specify cover-image in a YAML metadata block",
      "name": [
        "--epub-cover-image"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "Look in the specified XML file for metadata for the EPUB. The file should contain a series of Dublin Core elements",
      "name": [
        "--epub-metadata"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "Embed the specified font in the EPUB. This option can be repeated to embed multiple fonts. Wildcards can also be used",
      "name": [
        "--epub-embed-font"
      ]
    },
    {
      "args": {
        "name": "program",
        "suggestions": [
          {
            "name": "pdflatex"
          },
          {
            "name": "lualatex"
          },
          {
            "name": "xelatex"
          },
          {
            "name": "latexmk"
          },
          {
            "name": "tectonic"
          },
          {
            "name": "wkhtmltopdf"
          },
          {
            "name": "weasyprint"
          },
          {
            "name": "prince"
          },
          {
            "name": "context"
          },
          {
            "name": "pdfroff"
          }
        ]
      },
      "description": "Use the specified engine when producing PDF output",
      "name": [
        "--pdf-engine"
      ]
    },
    {
      "args": {
        "name": "string"
      },
      "description": "Use the given string as a command-line argument to the pdf-engine",
      "name": [
        "--pdf-engine-opt"
      ]
    },
    {
      "description": "Process the citations in the file, replacing them with rendered citations and adding a bibliography. Citation processing will not take place unless bibliographic data is supplied, either through an external file specified using the --bibliography option or the bibliography field in metadata, or via a references section in metadata containing a list of citations in CSL YAML format with Markdown formatting. The style is controlled by a CSL stylesheet specified using the --csl option or the csl field in metadata. (If no stylesheet is specified, the chicago-author-date style will be used by default)",
      "name": [
        "-C",
        "--citeproc"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "Set the bibliography field in the document’s metadata to FILE, overriding any value set in the metadata. If you supply this argument multiple times, each FILE will be added to bibliography. If FILE is a URL, it will be fetched via HTTP. If FILE is not found relative to the working directory, it will be sought in the resource path",
      "name": [
        "--bibliography"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "Set the csl field in the document’s metadata to FILE, overriding any value set in the metadata. (This is equivalent to --metadata csl=FILE.) If FILE is a URL, it will be fetched via HTTP. If FILE is not found relative to the working directory, it will be sought in the resource path and finally in the csl subdirectory of the pandoc user data directory",
      "name": [
        "--csl"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "Set the citation-abbreviations field in the document’s metadata to FILE, overriding any value set in the metadata. If FILE is a URL, it will be fetched via HTTP. If FILE is not found relative to the working directory, it will be sought in the resource path and finally in the csl subdirectory of the pandoc user data directory",
      "name": [
        "--citation-abbreviations"
      ]
    },
    {
      "description": "Use natbib for citations in LaTeX output. It is intended for use in producing a LaTeX file that can be processed with bibtex",
      "name": [
        "--natbib"
      ]
    },
    {
      "description": "Use biblatex for citations in LaTeX output. It is intended for use in producing a LaTeX file that can be processed with bibtex or biber",
      "name": [
        "--biblatex"
      ]
    },
    {
      "args": {
        "name": "URL"
      },
      "description": "Use MathJax to display embedded TeX math in HTML output. TeX math will be put between (...) (for inline math) or [...] (for display math) and wrapped in <span> tags with class math. Then the MathJax JavaScript will render it. The URL should point to the MathJax.js load script. If a URL is not provided, a link to the Cloudflare CDN will be inserted",
      "name": [
        "--mathjax"
      ]
    },
    {
      "description": "Convert TeX math to MathML (in epub3, docbook4, docbook5, jats, html4 and html5). This is the default in odt output. Note that currently only Firefox and Safari (and select e-book readers) natively support MathML",
      "name": [
        "--mathml"
      ]
    },
    {
      "args": {
        "name": "URL"
      },
      "description": "Convert TeX formulas to <img> tags that link to an external script that converts formulas to images. The formula will be URL-encoded and concatenated with the URL provided. For SVG images you can for example use --webtex https://latex.codecogs.com/svg.latex?. If no URL is specified, the CodeCogs URL generating PNGs will be used (https://latex.codecogs.com/png.latex?). Note: the --webtex option will affect Markdown output as well as HTML, which is useful if you’re targeting a version of Markdown without native math support",
      "name": [
        "--webtex"
      ]
    },
    {
      "args": {
        "name": "URL"
      },
      "description": "Use KaTeX to display embedded TeX math in HTML output. The URL is the base URL for the KaTeX library. That directory should contain a katex.min.js and a katex.min.css file. If a URL is not provided, a link to the KaTeX CDN will be inserted",
      "name": [
        "--katex"
      ]
    },
    {
      "description": "Enclose TeX math in <eq> tags in HTML output. The resulting HTML can then be processed by GladTeX to produce SVG images of the typeset formulas and an HTML file with these images embedded",
      "name": [
        "--gladtex"
      ]
    },
    {
      "description": "Print information about command-line arguments to stdout, then exit. This option is intended primarily for use in wrapper scripts",
      "name": [
        "--dump-args"
      ]
    },
    {
      "description": "Ignore command-line arguments (for use in wrapper scripts). Regular pandoc options are not ignored",
      "name": [
        "--ignore-args"
      ]
    }
  ]
}
