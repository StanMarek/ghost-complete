        },
        {
          "description": "Disables poetry source caches",
          "name": [
            "--no-cache"
          ]
        },
        {
          "args": {
            "name": "directory"
          },
          "description": "The working directory for the poetry command",
          "name": [
            "--directory"
          ]
        },
        {
          "description": "Do not output any message",
          "name": [
            "-q",
            "--quiet"
          ]
        },
        {
          "description": "Output the version number only",
          "name": [
            "--short"
          ]
        },
        {
          "description": "Do not update pyproject.toml file",
          "name": [
            "--dry-run"
          ]
        }
      ]
    }
  ]
}
