    {
      "description": "Modify or query the installed toolchains",
      "name": "toolchain",
      "options": [
        {
          "description": "Prints help information",
          "name": [
            "-h",
            "--help"
          ]
        }
      ],
      "subcommands": [
        {
          "description": "List installed toolchains",
          "name": "list",
          "options": [
            {
              "description": "Prints help information",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "description": "Prints version information",
              "name": [
                "-V",
                "--version"
              ]
            }
          ]
        },
        {
          "args": {
            "description": "Toolchain name",
            "generators": [
              {
                "cache": {
                  "ttl_seconds": 3600
                },
                "js_source": "o=>{if(o===\"\")return[];let t=JSON.parse(o);return[{name:\"stable\"},{name:\"beta\"},{name:\"nightly\"},...t.map(n=>({name:n.tag_name,description:`${n.name} - ${new Date(n.published_at).toLocaleDateString()}`}))]}",
                "requires_js": true,
                "script": [
                  "bash",
                  "-c",
                  "if command -v gh > /dev/null; then       gh api -H \"Accept: application/vnd.github+json\" /repos/rust-lang/rust/releases;     else       curl -sfL -H \"Accept: application/vnd.github+json\" https://api.github.com/repos/rust-lang/rust/releases;     fi"
                ]
              }
            ],
            "isVariadic": true,
            "name": "toolchain"
          },
          "description": "Install or update a given toolchain",
          "name": "install",
          "options": [
            {
              "description": "Prints help information",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "args": {
                "generators": [
                  {
                    "script": [
                      "rustup",
                      "target",
                      "list"
                    ],
                    "transforms": [
                      "split_lines",
                      "filter_empty"
                    ]
                  }
                ],
                "isVariadic": true,
                "name": "targets"
              },
              "description": "Add specific targets on installation",
              "name": [
                "-t",
                "--target"
              ]
            },
            {
              "args": {
                "isVariadic": true,
                "name": "components"
              },
              "description": "Add specific components on installation",
              "name": [
                "-c",
                "--component"
              ]
