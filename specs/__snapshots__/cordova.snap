{
  "description": "Manage your Cordova application",
  "name": "cordova",
  "options": [
    {
      "description": "Pipe out more verbose output to your shell. You can also subscribe to log and warn events if you are consuming cordova-cli as a node module by calling cordova.on('log', function() {}) or cordova.on('warn', function() {})",
      "name": [
        "-d",
        "--verbose"
      ]
    },
    {
      "description": "Print out the version of your cordova-cli install",
      "name": [
        "-v",
        "--version"
      ]
    },
    {
      "description": "Will disable updates check",
      "name": [
        "--no-update-notifier"
      ]
    },
    {
      "description": "Suppress executing hooks (taking RegExp hook patterns as parameters)",
      "name": [
        "--nohooks"
      ]
    },
    {
      "description": "Disable telemetry collection for the current command",
      "name": [
        "--no-telemetry"
      ]
    }
  ],
  "subcommands": [
    {
      "args": [
        {
          "description": "Directory which should not already exist. Cordova will create this directory",
          "name": "path",
          "template": "folders"
        },
        {
          "description": "Reverse domain-style identifier that maps to id attribute of widget element in config.xml. This can be changed but there may be code generated using this value, such as Java package names. It is recommended that you select an appropriate value",
          "isOptional": true,
          "name": "id"
        },
        {
          "description": "Application's display title that maps name element in config.xml file. This can be changed but there may be code generated using this value, such as Java class names. The default value is HelloCordova, but it is recommended that you select an appropriate value",
          "isOptional": true,
          "name": "name"
        }
      ],
      "description": "Create a project",
      "name": "create",
      "options": [
        {
          "description": "Pipe out more verbose output to your shell. You can also subscribe to log and warn events if you are consuming cordova-cli as a node module by calling cordova.on('log', function() {}) or cordova.on('warn', function() {})",
          "name": [
            "-d",
            "--verbose"
          ]
        },
        {
          "description": "Print out the version of your cordova-cli install",
          "name": [
            "-v",
            "--version"
          ]
        },
        {
          "description": "Will disable updates check",
          "name": [
            "--no-update-notifier"
          ]
        },
        {
          "description": "Suppress executing hooks (taking RegExp hook patterns as parameters)",
          "name": [
            "--nohooks"
          ]
        },
        {
          "description": "Disable telemetry collection for the current command",
          "name": [
            "--no-telemetry"
          ]
        },
        {
          "description": "Use a custom template located locally, in NPM, or GitHub",
          "name": [
            "--template"
          ]
        }
      ]
    },
    {
      "args": {
        "isOptional": true,
        "name": "command",
        "suggestions": [
          {
            "name": "create"
          },
          {
            "name": "help"
          },
          {
            "name": "telemetry"
          },
          {
            "name": "config"
          },
          {
            "name": "info"
          },
          {
            "name": "requirements"
          },
          {
            "name": "platform"
          },
          {
            "name": "plugin"
          },
          {
            "name": "prepare"
          },
          {
            "name": "compile"
          },
          {
            "name": "build"
          },
          {
            "name": "clean"
          },
          {
            "name": "run"
          },
          {
            "name": "serve"
          }
        ]
      },
      "description": "Get help for a command",
      "name": "help"
    },
    {
      "args": [
        {
          "description": "Turn telemetry collection on",
          "name": "on"
        },
        {
          "description": "Turn telemetry collection off",
          "name": "off"
        }
      ],
      "description": "Turn telemetry collection on or off",
      "name": "telemetry"
    },
    {
      "description": "Set, get, delete, edit, and list global cordova options",
      "name": "config",
      "subcommands": [
        {
          "description": "Lists contents of config file",
          "name": "ls"
        },
        {
          "description": "Opens the config file in an editor",
          "name": "edit"
        },
        {
          "args": [
            {
              "name": "key"
            },
            {
              "name": "value"
            }
          ],
          "description": "Sets the config key to the value. If value is omitted, then it sets it to \"true\"",
          "name": "set"
        },
        {
          "args": {
            "name": "key"
          },
          "description": "Echo the config value to stdout",
          "name": "get"
        },
        {
          "args": {
            "name": "key"
          },
          "description": "Deletes the key from all configuration files",
          "name": "delete"
        }
      ]
    },
    {
      "description": "Generate project information",
      "name": "info"
    },
    {
      "args": {
        "description": "Platform name(s) to build. If not specified, all platforms are built",
        "generators": [
          {
            "js_source": "function(t){let i=[];try{if(t.trim()==\"\")return i;let n=JSON.parse(t).cordova.platforms;if(n)for(let r of n)i.push({name:r,description:\"Platform\"})}catch(a){console.log(a)}return i}",
            "requires_js": true,
            "script": [
              "cat",
              "package.json"
            ]
          }
        ],
        "name": "platform"
      },
      "description": "Checks and print out all the installation requirements for platforms specified",
      "name": "requirements"
    },
    {
      "description": "Manage project platforms",
      "name": "platform",
      "subcommands": [
        {
          "args": {
            "isVariadic": true,
            "name": "platform",
            "suggestions": [
              {
                "name": "android"
              },
              {
                "name": "ios"
              },
              {
                "name": "windows"
              },
              {
                "name": "browser"
              },
              {
                "name": "electron"
              }
            ],
            "template": [
              "filepaths",
              "folders"
            ]
          },
          "description": "Add specified platforms",
          "name": "add",
          "options": [
            {
              "description": "Do not save",
              "name": [
                "--nosave"
              ]
            },
            {
              "args": {
                "name": "path",
                "template": "folders"
              },
              "description": "When platform-spec is a local path, link the platform library directly instead of making a copy of it",
              "name": [
                "--link"
              ]
            }
          ]
        },
        {
          "args": {
            "generators": [
              {
                "js_source": "function(t){let i=[];try{if(t.trim()==\"\")return i;let n=JSON.parse(t).cordova.platforms;if(n)for(let r of n)i.push({name:r,description:\"Platform\"})}catch(a){console.log(a)}return i}",
                "requires_js": true,
                "script": [
                  "cat",
                  "package.json"
                ]
              }
            ],
            "isVariadic": true,
            "name": "platform"
          },
          "description": "Remove specified platforms",
          "name": "remove",
          "options": [
            {
              "description": "Do not delete specified platforms from",
              "name": [
                "--nosave"
              ]
            }
          ]
        },
        {
          "description": "Update specified platforms",
          "name": "update",
          "options": [
            {
              "description": "Updates the version specified in **config.xml**",
              "name": [
                "--save"
              ]
            }
          ]
        },
        {
          "description": "List all installed and available platforms",
          "name": "list"
        }
      ]
    },
    {
      "description": "Manage project plugins",
      "name": "plugin",
      "subcommands": [
        {
          "args": {
            "isVariadic": true,
            "name": "plugin",
            "template": "folders"
          },
          "description": "Add specified plugins",
          "name": "add",
          "options": [
            {
              "args": {
                "name": "directory",
                "template": "folders"
              },
              "description": "When looking up plugins by ID, look in this directory and each of its subdirectories before hitting the registry. Multiple search paths can be specified. Use ':' as a separator in *nix based systems and ';' for Windows",
              "name": [
                "--searchpath"
              ]
            },
            {
              "description": "Don't search the registry for plugins",
              "name": [
                "--noregistry"
              ]
            },
            {
              "description": "When installing from a local path, creates a symbolic link instead of copying files. The extent to which files are linked varies by platform. Useful for plugin development",
              "name": [
                "--link"
              ]
            },
            {
              "description": "Do NOT save the <plugin-spec> as part of the plugin element into config.xml or package.json",
              "name": [
                "--nosave"
              ]
            },
            {
              "description": "Forces copying source files from the plugin even if the same file already exists in the target directory",
              "name": [
                "--force"
              ]
            }
          ]
        },
        {
          "args": {
            "generators": [
              {
                "script": [
                  "cordova",
                  "plugin",
                  "list"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty"
                ]
              }
            ],
            "isVariadic": true,
            "name": "plugin"
          },
          "description": "Remove plugins with the given IDs/name",
          "name": "remove",
          "options": [
            {
              "description": "Do NOT remove the specified plugin from config.xml or package.json",
              "name": [
                "--nosave"
              ]
            }
          ]
        },
        {
          "description": "List currently installed plugins",
          "name": "list"
        }
      ]
    },
    {
      "args": {
        "generators": [
          {
            "js_source": "function(t){let i=[];try{if(t.trim()==\"\")return i;let n=JSON.parse(t).cordova.platforms;if(n)for(let r of n)i.push({name:r,description:\"Platform\"})}catch(a){console.log(a)}return i}",
            "requires_js": true,
            "script": [
              "cat",
              "package.json"
            ]
          }
        ],
        "name": "platform"
      },
      "description": "Copy files into platform(s) for building",
      "name": "prepare"
    },
    {
      "args": {
        "description": "Platform name(s) to build. If not specified, all platforms are built",
        "generators": [
          {
            "js_source": "function(t){let i=[];try{if(t.trim()==\"\")return i;let n=JSON.parse(t).cordova.platforms;if(n)for(let r of n)i.push({name:r,description:\"Platform\"})}catch(a){console.log(a)}return i}",
            "requires_js": true,
            "script": [
              "cat",
              "package.json"
            ]
          }
        ],
        "name": "platform"
      },
      "description": "Compile project for platform(s)",
      "name": "compile",
      "options": [
        {
          "description": "Pipe out more verbose output to your shell. You can also subscribe to log and warn events if you are consuming cordova-cli as a node module by calling cordova.on('log', function() {}) or cordova.on('warn', function() {})",
          "name": [
            "-d",
            "--verbose"
          ]
        },
        {
          "description": "Print out the version of your cordova-cli install",
          "name": [
            "-v",
            "--version"
          ]
        },
        {
          "description": "Will disable updates check",
          "name": [
            "--no-update-notifier"
          ]
        },
        {
          "description": "Suppress executing hooks (taking RegExp hook patterns as parameters)",
          "name": [
            "--nohooks"
          ]
        },
        {
          "description": "Disable telemetry collection for the current command",
          "name": [
            "--no-telemetry"
          ]
        },
        {
          "description": "Perform a debug build. This typically translates to debug mode for the underlying platform being built",
          "name": [
            "--debug"
          ]
        },
        {
          "description": "Perform a release build. This typically translates to release mode for the underlying platform being built",
          "name": [
            "--release"
          ]
        },
        {
          "description": "Build it for a device",
          "name": [
            "--device"
          ]
        },
        {
          "description": "Build it for an emulator. In particular, the platform architecture might be different for a device vs. emulator",
          "name": [
            "--emulator"
          ]
        },
        {
          "args": {
            "template": [
              "filepaths",
              "folders"
            ]
          },
          "description": "Use the specified build configuration file. build.json file is used to specify parameters to customize the app build process especially related to signing the package",
          "name": [
            "--buildConfig"
          ]
        }
      ]
    },
    {
      "args": {
        "description": "Platform name(s) to build. If not specified, all platforms are built",
        "generators": [
          {
            "js_source": "function(t){let i=[];try{if(t.trim()==\"\")return i;let n=JSON.parse(t).cordova.platforms;if(n)for(let r of n)i.push({name:r,description:\"Platform\"})}catch(a){console.log(a)}return i}",
            "requires_js": true,
            "script": [
              "cat",
              "package.json"
            ]
          }
        ],
        "name": "platform"
      },
      "description": "Build project for platform(s) (prepare + compile)",
      "name": "build",
      "options": [
        {
          "description": "Pipe out more verbose output to your shell. You can also subscribe to log and warn events if you are consuming cordova-cli as a node module by calling cordova.on('log', function() {}) or cordova.on('warn', function() {})",
          "name": [
            "-d",
            "--verbose"
          ]
        },
        {
          "description": "Print out the version of your cordova-cli install",
          "name": [
            "-v",
            "--version"
          ]
        },
        {
          "description": "Will disable updates check",
          "name": [
            "--no-update-notifier"
          ]
        },
        {
          "description": "Suppress executing hooks (taking RegExp hook patterns as parameters)",
          "name": [
            "--nohooks"
          ]
        },
        {
          "description": "Disable telemetry collection for the current command",
          "name": [
            "--no-telemetry"
          ]
        },
        {
          "description": "Perform a debug build. This typically translates to debug mode for the underlying platform being built",
          "name": [
            "--debug"
          ]
        },
        {
          "description": "Perform a release build. This typically translates to release mode for the underlying platform being built",
          "name": [
            "--release"
          ]
        },
        {
          "description": "Build it for a device",
          "name": [
            "--device"
          ]
        },
        {
          "description": "Build it for an emulator. In particular, the platform architecture might be different for a device vs. emulator",
          "name": [
            "--emulator"
          ]
        },
        {
          "args": {
            "template": [
              "filepaths",
              "folders"
            ]
          },
          "description": "Use the specified build configuration file. build.json file is used to specify parameters to customize the app build process especially related to signing the package",
          "name": [
            "--buildConfig"
          ]
        }
      ]
    },
    {
      "args": {
        "description": "Platform name(s) to build. If not specified, all platforms are built",
        "generators": [
          {
            "js_source": "function(t){let i=[];try{if(t.trim()==\"\")return i;let n=JSON.parse(t).cordova.platforms;if(n)for(let r of n)i.push({name:r,description:\"Platform\"})}catch(a){console.log(a)}return i}",
            "requires_js": true,
            "script": [
              "cat",
              "package.json"
            ]
          }
        ],
        "name": "platform"
      },
      "description": "Cleanup project from build artifacts",
      "name": "clean"
    },
    {
      "args": {
        "description": "Platform name(s) to run. If not specified, all platforms are run",
        "generators": [
          {
            "js_source": "function(t){let i=[];try{if(t.trim()==\"\")return i;let n=JSON.parse(t).cordova.platforms;if(n)for(let r of n)i.push({name:r,description:\"Platform\"})}catch(a){console.log(a)}return i}",
            "requires_js": true,
            "script": [
              "cat",
              "package.json"
            ]
          }
        ],
        "name": "platform"
      },
      "description": "Run project (including prepare && compile)",
      "name": "run",
      "options": [
        {
          "description": "Lists available targets. Displays both device and emulator deployment targets unless specified",
          "name": [
            "--list"
          ]
        },
        {
          "description": "Deploy a debug build. This is the default behavior unless --release is specified",
          "name": [
            "--debug"
          ]
        },
        {
          "description": "Deploy a release build",
          "name": [
            "--release"
          ]
        },
        {
          "description": "Skip preparing (available in Cordova v6.2 or later)",
          "name": [
            "--noprepare"
          ]
        },
        {
          "description": "Skip building",
          "name": [
            "--nobuild"
          ]
        },
        {
          "description": "Deploy to a device",
          "name": [
            "--device"
          ]
        },
        {
          "description": "Deploy to an emulator",
          "name": [
            "--emulator"
          ]
        },
        {
          "args": {
            "name": "target"
          },
          "description": "Deploy to a specific target emulator/device. Use --list to display target options",
          "name": [
            "--target"
          ]
        },
        {
          "args": {
            "name": "configFile",
            "template": "filepaths"
          },
          "description": "Use the specified build configuration file. build.json file is used to specify parameters to customize the app build process especially related to signing the package",
          "name": [
            "--buildConfig"
          ]
        }
      ]
    },
    {
      "args": {
        "description": "Port to use for local web server",
        "name": "port"
      },
      "description": "Run project with a local webserver (including prepare)",
      "name": "serve"
    }
  ]
}
