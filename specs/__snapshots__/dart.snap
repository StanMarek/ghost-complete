        {
          "args": {
            "name": "path",
            "template": "folders"
          },
          "description": "The path to a cache directory containing the trusted root certificates to use for secure socket connections",
          "name": [
            "--root-certs-cache"
          ]
        },
        {
          "description": "Enables tracing of library and script loading",
          "name": [
            "--trace-loading"
          ]
