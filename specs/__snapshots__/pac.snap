              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Max number of applications to show. Default: 20",
              "name": [
                "--max",
                "-m"
              ]
            }
          ]
        },
        {
          "description": "Enable, disable, and edit managed environments",
          "name": "set-governance-config",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "URL or ID of the environment for which managed environments need to be enabled, disabled or edited",
              "name": [
                "--environment",
                "-env"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Set protection level : 'Standard' to enable managed environments, 'Basic' to disable managed environments",
              "name": [
                "--protection-level",
                "-pl"
              ]
            },
            {
              "description": "Disable group sharing",
              "name": [
                "--disable-group-sharing",
                "-dgs"
              ]
            },
            {
              "description": "Exclude usage insights for the environment from the weekly digest email",
              "name": [
                "--exclude-analysis",
                "-ea"
              ]
            },
            {
              "description": "Include insights in the Power Platform Admin Center homepage cards",
              "name": [
                "--include-insights",
                "-ii"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Limit sharing mode",
              "name": [
                "--limit-sharing-mode",
                "-lsm"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "If group sharing is disabled, specify the number of people that makers can share canvas apps with",
              "name": [
                "--max-limit-user-sharing",
                "-ml"
              ]
            },
            {
              "args": {
                "name": "string",
                "suggestions": [
                  {
                    "description": "None",
                    "name": "none"
                  },
