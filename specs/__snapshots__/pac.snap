        {
          "description": "Package solution components on local filesystem into solution.zip (SolutionPackager)",
          "name": "pack",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "The full path to the solution ZIP file",
              "name": [
                "--zipfile",
                "-z"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "The path to the root folder on the local filesystem. When unpacking or extracting, this is written to. When packing this is read from",
              "name": [
                "--folder",
                "-f"
              ]
            },
            {
              "args": {
                "name": "string",
                "suggestions": [
                  {
                    "description": "Unmanaged",
                    "name": "Unmanaged"
                  },
                  {
                    "description": "Managed",
                    "name": "Managed"
                  },
                  {
                    "description": "Both",
                    "name": "Both"
                  }
                ]
              },
              "description": "When unpacking or extracting, use to specify dual Managed and Unmanaged operation. When packing, use to specify Managed or Unmanaged from a previous unpack 'Both'. Can be: 'Unmanaged', 'Managed' or 'Both'. The default value is 'Unmanaged'",
              "name": [
                "--packagetype",
                "-p"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "The path to the log file",
              "name": [
                "--log",
                "-l"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Minimum logging level for log output [Verbose|Info|Warning|Error|Off]. The default value is 'Info'",
              "name": [
                "--errorlevel",
                "-e"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Only perform action on a single component type [WebResource|Plugin|Workflow|None]. The default value is 'None'",
              "name": [
                "--singleComponent",
                "-sc"
              ]
            },
            {
              "description": "Dictates if delete operations may occur. The default value is 'false'",
              "name": [
                "--allowDelete",
                "-ad"
              ]
            },
            {
              "description": "Dictates if write operations may occur. The default value is 'false'",
              "name": [
                "--allowWrite",
                "-aw"
              ]
            },
            {
              "description": "Enables that files marked read-only can be deleted or overwritten. The default value is 'false'",
              "name": [
                "--clobber",
                "-c"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "The full path to a mapping xml file from which to read component folders to pack",
              "name": [
                "--map",
                "-m"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Generates a template resource file. Valid only on extract. Possible values are 'auto', or language code of the language you wish to export. You can use Language Code Identifier (LCID), or International Organization for Standardization (ISO) language code formats. When present, this extracts the string resources from the given locale as a neutral .resx. If 'auto' or just the long or short form of the switch is specified, the base locale for the solution is used",
              "name": [
                "--sourceLoc",
                "-src"
              ]
            },
            {
              "description": "Extract or merge all string resources into .resx files",
              "name": [
                "--localize",
                "-loc"
              ]
            },
            {
              "description": "Use Language Code Identifier (LCID) values (1033) rather than International Organization for Standardization (ISO) codes (en-US) for language files",
              "name": [
                "--useLcid",
                "-lcid"
              ]
            },
            {
              "description": "Use the same XML source file when packaging for Managed and only Unmanaged XML file is found; applies to AppModuleSiteMap, AppModuleMap, FormXml files",
              "name": [
                "--useUnmanagedFileForMissingManaged",
                "-same"
              ]
            },
            {
              "description": "Disabled plug-in fully qualified type name remapping. The default value is 'false'",
              "name": [
                "--disablePluginRemap",
                "-dpm"
              ]
            },
            {
              "description": "(Preview) Pack/unpack any Canvas apps (.msapp) while processing the solution. The default value is 'false'",
              "name": [
                "--processCanvasApps",
                "-pca"
              ]
            }
          ]
        },
