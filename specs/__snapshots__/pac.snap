    {
      "description": "Code Generator for Dataverse APIs and Tables",
      "name": "modelbuilder",
      "subcommands": [
        {
          "description": "Builds a code model for Dataverse APIs and Tables",
          "name": "build",
          "options": [
            {
              "description": "When set, this suppress all generated objects being tagged with the code generation engine and version",
              "name": [
                "--suppressGeneratedCodeAttribute",
                "-sgca"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "The language to use for the generated proxy code. This value can be either 'CS' or 'VB'. The default language is 'CS'",
              "name": [
                "--language",
                "-l"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "The namespace for the generated code. The default namespace is the global namespace",
              "name": [
                "--namespace",
                "-n"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "The name for the generated service context. If a value is passed in, it's used for the Service Context. If not, no Service Context is generated",
              "name": [
                "--serviceContextName",
                "-sctx"
              ]
            },
            {
              "description": "When set, emits Sdk message classes as part of code generation",
              "name": [
                "--generatesdkmessages",
                "-a"
              ]
            },
            {
              "description": "When set, includes the entity ETC ( entity type code ) in the generated code",
              "name": [
                "--emitentityetc",
                "-etc"
              ]
            },
            {
              "description": "When set, includes the Virtual Attributes of entities in the generated code",
              "name": [
                "--emitvirtualattributes",
                "-eva"
              ]
            },
            {
              "description": "Generate a constants structure that contains all of the field names by entity at the time of code generation",
              "name": [
                "--emitfieldsclasses",
                "-efc"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Filters the list of entities are retrieved when reading data from Dataverse. Passed in as a semicolon separated list. Using the form <entitylogicalname>;<entitylogicalname>",
              "name": [
                "--entitynamesfilter",
                "-enf"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Filters the list of messages that are retrieved when reading data from Dataverse. Passed in as a semicolon separated list, required messages (Create, Update, Delete, Retrieve, RetrieveMultiple, Associate and Disassociate) are always included. Use a trailing or leading asterisk (*) with the names of the messages to allow for all messages starting with or ending with a string. Using the form <messagename>;<messagename>",
              "name": [
                "--messagenamesfilter",
                "-mnf"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Write directory for entity, message, and optionset files",
              "name": [
                "--outdirectory",
                "-o"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Folder name that contains entities. The default name is 'Entities'",
              "name": [
                "--entitytypesfolder",
                "-etf"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Folder name that contains messages. The default name is 'Messages'",
              "name": [
                "--messagestypesfolder",
                "-mtf"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Folder name that contains option sets. The default name is 'OptionSets'",
              "name": [
                "--optionsetstypesfolder",
                "-otf"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Emit all Global OptionSets. Note: If an entity contains a reference to a global optionset, it is emitted even if this switch is not present",
              "name": [
                "--generateGlobalOptionSets",
                "-go"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "When set, writes a settings file out to the output directory with the current passed settings or default settings",
              "name": [
                "--writesettingsTemplateFile",
                "-wstf"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Contains Settings to be used for this run of the Dataverse Model Builder, overrides any duplicate parameters on command line. Can't be set when --writesettingstemplate is used",
              "name": [
                "--settingsTemplateFile",
                "-stf"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "When enabled, doesn't write the INotify wrappers for properties and classes",
              "name": [
                "--suppressINotifyPattern"
              ]
            },
            {
              "args": {
                "name": "string",
                "suggestions": [
                  {
                    "description": "Off",
                    "name": "Off"
                  },
                  {
                    "description": "Critical",
                    "name": "Critical"
                  },
                  {
                    "description": "Error",
                    "name": "Error"
                  },
                  {
                    "description": "Warning",
                    "name": "Warning"
                  },
                  {
                    "description": "Information",
                    "name": "Information"
                  },
                  {
                    "description": "Verbose",
                    "name": "Verbose"
                  },
                  {
                    "description": "ActivityTracing",
                    "name": "ActivityTracing"
                  },
                  {
                    "description": "All",
                    "name": "All"
                  }
                ]
              },
              "description": "Log level. The default value is 'Off'",
              "name": [
                "--logLevel",
                "-ll"
              ]
            }
          ]
        }
      ]
    },
