                  },
                  {
                    "description": "AadOfficeGroup",
                    "name": "AadOfficeGroup"
                  }
                ]
              },
              "description": "Type of team",
              "name": [
                "--team-type",
                "-tt"
              ]
            },
            {
              "args": {
                "name": "string",
                "suggestions": [
                  {
                    "description": "MembersAndGuests",
                    "name": "MembersAndGuests"
                  },
                  {
                    "description": "Members",
                    "name": "Members"
                  },
                  {
                    "description": "Owners",
                    "name": "Owners"
                  },
                  {
                    "description": "Guests",
                    "name": "Guests"
                  }
                ]
              },
              "description": "Team membership type",
              "name": [
                "--membership-type",
                "-mt"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "ID of business unit to associate application user with",
              "name": [
                "--business-unit",
                "-bu"
              ]
            }
          ]
        },
