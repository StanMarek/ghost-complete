{
  "description": "Power Platform CLI",
  "name": "pac",
  "subcommands": [
    {
      "description": "Work with your Power Platform Admin Account",
      "name": "admin",
      "subcommands": [
        {
          "description": "List all environments from your tenant",
          "name": "list",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "List all environments that contain given string in their name or ID",
              "name": [
                "--environment",
                "-env"
              ]
            },
            {
              "args": {
                "name": "environmentTypes",
                "suggestions": [
                  {
                    "description": "Trial",
                    "name": "Trial"
                  },
                  {
                    "description": "Sandbox",
                    "name": "Sandbox"
                  },
                  {
                    "description": "Production",
                    "name": "Production"
                  },
                  {
                    "description": "Developer",
                    "name": "Developer"
                  },
                  {
                    "description": "Teams",
                    "name": "Teams"
                  },
                  {
                    "description": "SubscriptionBasedTrial",
                    "name": "SubscriptionBasedTrial"
                  }
                ]
              },
              "description": "List all environments with the given type",
              "name": [
                "--type",
                "-t"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "List all environments that contain given string in their name",
              "name": [
                "--name",
                "-n"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "List all environments that contain given string in their organization ID",
              "name": [
                "--organization-id",
                "-oi"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "List all environments that have specified application installed. To specify application, use unique name or ID",
              "name": [
                "--application",
                "-a"
              ]
            }
          ]
        },
        {
          "description": "Creates a Dataverse instance in your tenant",
          "name": "create",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "Sets the name of the environment",
              "name": [
                "--name",
                "-n"
              ]
            },
            {
              "args": {
                "name": "string",
                "suggestions": [
                  {
                    "description": "Unitedstates",
                    "name": "unitedstates"
                  },
                  {
                    "description": "Unitedstatesfirstrelease",
                    "name": "unitedstatesfirstrelease"
                  },
                  {
                    "description": "Europe",
                    "name": "europe"
                  },
                  {
                    "description": "Asia",
                    "name": "asia"
                  },
                  {
                    "description": "Australia",
                    "name": "australia"
                  },
                  {
                    "description": "India",
                    "name": "india"
                  },
                  {
                    "description": "Japan",
                    "name": "japan"
                  },
                  {
                    "description": "Canada",
                    "name": "canada"
                  },
                  {
                    "description": "Unitedkingdom",
                    "name": "unitedkingdom"
                  },
                  {
                    "description": "Southamerica",
                    "name": "southamerica"
                  },
                  {
                    "description": "France",
                    "name": "france"
                  },
                  {
                    "description": "Unitedarabemirates",
                    "name": "unitedarabemirates"
                  },
                  {
                    "description": "Germany",
                    "name": "germany"
                  },
                  {
                    "description": "Switzerland",
                    "name": "switzerland"
                  },
                  {
                    "description": "Norway",
                    "name": "norway"
                  },
                  {
                    "description": "Korea",
                    "name": "korea"
                  }
                ]
              },
              "description": "Sets the environment's region name. [defaults to unitedstates]",
              "name": [
                "--region",
                "-r"
              ]
            },
            {
              "args": {
                "name": "environmentTypes",
                "suggestions": [
                  {
                    "description": "Trial",
                    "name": "Trial"
                  },
                  {
                    "description": "Sandbox",
                    "name": "Sandbox"
                  },
                  {
                    "description": "Production",
                    "name": "Production"
                  },
                  {
                    "description": "Developer",
                    "name": "Developer"
                  },
                  {
                    "description": "Teams",
                    "name": "Teams"
                  },
                  {
                    "description": "SubscriptionBasedTrial",
                    "name": "SubscriptionBasedTrial"
                  }
                ]
              },
              "description": "Sets the environment Type",
              "name": [
                "--type",
                "-t"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Sets the currency used for your environment. [defaults to USD]",
              "name": [
                "--currency",
                "-c"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Sets the language used for your environment. [defaults to English]",
              "name": [
                "--language",
                "-l"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Sets the Dynamics 365 app that needs to be deployed, passed as comma separated values. For example: -tm 'D365_Sample, D365_Sales'",
              "name": [
                "--templates",
                "-tm"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "The domain name is part of the environment URL. If domain name is already in use, a numeric value is appended to the domain name. For example: If 'contoso' is already in use, then the environment URL is updated to https://{contoso}0.crm.dynamics.com",
              "name": [
                "--domain",
                "-d"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "The verb arguments to be passed in a .json input file. For example: {'name' : 'contoso'}. The arguments passed through command-line will take precedence over arguments from the .json input file",
              "name": [
                "--input-file",
                "-if"
              ]
            },
            {
              "description": "Optional boolean argument to run pac verbs asynchronously, defaults to false",
              "name": [
                "--async",
                "-a"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Team ID as Guid",
              "name": [
                "--team-id",
                "-tid"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Max asynchronous wait time in minutes. The default value is 60 minutes",
              "name": [
                "--max-async-wait-time",
                "-wt"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Object ID or user principal name (UPN) of Microsoft Entra ID user to be assigned to the environment",
              "name": [
                "--user",
                "-u"
              ]
            }
          ]
        },
        {
          "description": "Takes a manual backup of your environment",
          "name": "backup",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "Environment URL or ID of the Environment that requires backup",
              "name": [
                "--environment",
                "-env"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Sets the backup label as provided",
              "name": [
                "--label",
                "-l"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "**ignored**: Additional notes for this backup",
              "name": [
                "--notes",
                "-n"
              ]
            }
          ]
        },
        {
          "description": "Takes a manual backup of your environment",
          "name": "set-backup-retention-period",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "Environment URL or ID of the Environment that requires backup",
              "name": [
                "--environment",
                "-env"
              ]
            },
            {
              "args": {
                "name": "string",
                "suggestions": [
                  {
                    "description": "7",
                    "name": "7"
                  },
                  {
                    "description": "14",
                    "name": "14"
                  },
                  {
                    "description": "21",
                    "name": "21"
                  },
                  {
                    "description": "28",
                    "name": "28"
                  }
                ]
              },
              "description": "Sets the backup retention period in days as provided. Valid values are: 7, 14, 21, 28",
              "name": [
                "--backup-retention-period",
                "-br"
              ]
            },
            {
              "description": "Optional boolean argument to run pac verbs asynchronously, defaults to false",
              "name": [
                "--async",
                "-a"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Max asynchronous wait time in minutes. The default value is 60 minutes",
              "name": [
                "--max-async-wait-time",
                "-wt"
              ]
            }
          ]
        },
        {
          "description": "Deletes the environment from your tenant",
          "name": "delete",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "Environment URL or ID of the Environment that needs to be deleted from your tenant",
              "name": [
                "--environment",
                "-env"
              ]
            },
            {
              "description": "Optional boolean argument to run pac verbs asynchronously, defaults to false",
              "name": [
                "--async",
                "-a"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Max asynchronous wait time in minutes. The default value is 60 minutes",
              "name": [
                "--max-async-wait-time",
                "-wt"
              ]
            }
          ]
        },
        {
          "description": "Reset the environment from your tenant",
          "name": "reset",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "URL or ID of the Environment that needs to be reset",
              "name": [
                "--environment",
                "-env"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Sets the currency used for your environment. [defaults to USD]",
              "name": [
                "--currency",
                "-c"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "The domain name is part of the environment URL. If domain name is already in use, a numeric value is appended to the domain name. For example: If 'contoso' is already in use, then the environment URL is updated to https://{contoso}0.crm.dynamics.com",
              "name": [
                "--domain",
                "-d"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Sets the name of the environment",
              "name": [
                "--name",
                "-n"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Sets the language used for your environment. [defaults to English]",
              "name": [
                "--language",
                "-l"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Sets the description used to associate the environment with a specific intent",
              "name": [
                "--purpose",
                "-p"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Sets the Dynamics 365 app that needs to be deployed, passed as comma separated values. For example: -tm 'D365_Sample, D365_Sales'",
              "name": [
                "--templates",
                "-tm"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "The verb arguments to be passed in a .json input file. For example: {'name' : 'contoso'}. The arguments passed through command-line will take precedence over arguments from the .json input file",
              "name": [
                "--input-file",
                "-if"
              ]
            },
            {
              "description": "Optional boolean argument to run pac verbs asynchronously, defaults to false",
              "name": [
                "--async",
                "-a"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Max asynchronous wait time in minutes. The default value is 60 minutes",
              "name": [
                "--max-async-wait-time",
                "-wt"
              ]
            }
          ]
        },
        {
          "description": "Lists all backups of your environment",
          "name": "list-backups",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "List all environments that contain a given string in their Environment ID or URL",
              "name": [
                "--environment",
                "-env"
              ]
            }
          ]
        },
        {
          "description": "Restores an environment to a given backup",
          "name": "restore",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "Environment URL or ID of the source environment required for restore",
              "name": [
                "--source-env",
                "-se"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Environment URL or ID of the target environment required for restore. This would default to source URL/ID if not provided",
              "name": [
                "--target-env",
                "-te"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "DateTime of the backup in 'mm/dd/yyyy hh:mm' format OR string 'latest'",
              "name": [
                "--selected-backup",
                "-sb"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Optional name of the restored environment",
              "name": [
                "--name",
                "-n"
              ]
            },
            {
              "description": "Switch indicating whether audit data should be skipped",
              "name": [
                "--skip-audit-data",
                "-sa"
              ]
            },
            {
              "description": "Optional boolean argument to run pac verbs asynchronously, defaults to false",
              "name": [
                "--async",
                "-a"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Max asynchronous wait time in minutes. The default value is 60 minutes",
              "name": [
                "--max-async-wait-time",
                "-wt"
              ]
            }
          ]
        },
        {
          "description": "Copy Source Environment to Destination Environment",
          "name": "copy",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "Environment URL or ID of the source environment that is being copied",
              "name": [
                "--source-env",
                "-se"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Environment URL or ID of the target environment",
              "name": [
                "--target-env",
                "-te"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Name of the target environment",
              "name": [
                "--name",
                "-n"
              ]
            },
            {
              "args": {
                "name": "string",
                "suggestions": [
                  {
                    "description": "MinimalCopy",
                    "name": "MinimalCopy"
                  },
                  {
                    "description": "FullCopy",
                    "name": "FullCopy"
                  }
                ]
              },
              "name": [
                "--type",
                "-t"
              ]
            },
            {
              "description": "Switch indicating whether audit data should be skipped",
              "name": [
                "--skip-audit-data",
                "-sa"
              ]
            },
            {
              "description": "Optional boolean argument to run pac verbs asynchronously, defaults to false",
              "name": [
                "--async",
                "-a"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Max asynchronous wait time in minutes. The default value is 60 minutes",
              "name": [
                "--max-async-wait-time",
                "-wt"
              ]
            }
          ]
        },
        {
          "description": "This command lists the status of all the operations in progress",
          "name": "status"
        },
        {
          "description": "Assign a user to a target Dataverse environment with specified security role",
          "name": "assign-user",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "ID or URL of the environment to assign a user to",
              "name": [
                "--environment",
                "-env"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Object ID or user principal name (UPN) of Microsoft Entra ID user to be assigned to the environment or Application ID if assigning an Application User",
              "name": [
                "--user",
                "-u"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Name or ID of security role to be applied to user",
              "name": [
                "--role",
                "-r"
              ]
            },
            {
              "description": "Specifies whether the input user is an application user. If a business unit isn't specified, the application user is added to the authenticated users business unit",
              "name": [
                "--application-user",
                "-au"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "ID of business unit to associate application user with",
              "name": [
                "--business-unit",
                "-bu"
              ]
            },
            {
              "description": "Optional boolean argument to run pac verbs asynchronously, defaults to false",
              "name": [
                "--async",
                "-a"
              ]
            }
          ]
        },
        {
          "description": "Assign group to target Dataverse environment with specified security role",
          "name": "assign-group",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "ID or URL of the environment to assign a user to",
              "name": [
                "--environment",
                "-env"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Microsoft Entra ID object ID of group to assign to target Dataverse environment",
              "name": [
                "--group",
                "-g"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Name of the group or team to create in Dataverse",
              "name": [
                "--group-name",
                "-gn"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Name or ID of security role to be applied to user",
              "name": [
                "--role",
                "-r"
              ]
            },
            {
              "args": {
                "name": "string",
                "suggestions": [
                  {
                    "description": "Owner",
                    "name": "Owner"
                  },
                  {
                    "description": "Access",
                    "name": "Access"
                  },
                  {
                    "description": "AadSecurityGroup",
