    {
      "description": "Commands for working with Dataverse package projects",
      "name": "package",
      "subcommands": [
        {
          "description": "Initializes a directory with a new Dataverse package project",
          "name": "init",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "Output directory",
              "name": [
                "--outputDirectory",
                "-o"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Sets the default name of the package. Applies to the generation of ImportExtension.GetNameOfImport",
              "name": [
                "--package-name"
              ]
            }
          ]
        },
        {
          "description": "Adds a package that is external to the Dataverse solution system to a Package Deployer Package project",
          "name": "add-external-package",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "Path to the external package",
              "name": [
                "--path",
                "-p"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "The type of the package being added. For example: 'xpp' for FnO packages",
              "name": [
                "--package-type",
                "-t"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "A whole number that indicates the order to insert this item into the final ImportConfig.xml file at build time. Negative numbers are inserted before existing elements. Positive numbers are added after existing elements",
              "name": [
                "--import-order"
              ]
            },
            {
              "description": "Adds the item to the project file even if the file doesn't exist or appears to be invalid. Note: Using this doesn't affect any validation performed by MSBuild",
              "name": [
                "--skip-validation",
                "-sv"
              ]
            }
          ]
        },
        {
          "description": "Adds a prebuilt Dataverse solution file to a Package Deployer Package project",
          "name": "add-solution",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "Path to the Dataverse solution file. The file must be a compressed ZIP file",
              "name": [
                "--path",
                "-p"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "A whole number that indicates the order to insert this item into the final ImportConfig.xml file at build time. Negative numbers are inserted before existing elements. Positive numbers are added after existing elements",
              "name": [
                "--import-order"
              ]
            },
            {
              "description": "Adds the item to the project file even if the file doesn't exist or appears to be invalid. Note: Using this doesn't affect any validation performed by MSBuild",
              "name": [
                "--skip-validation",
                "-sv"
              ]
            },
            {
              "args": {
                "name": "string",
                "suggestions": [
                  {
                    "description": "True",
                    "name": "true"
                  },
                  {
                    "description": "False",
                    "name": "false"
                  }
                ]
              },
              "description": "Explicitly indicates whether to publish the workflows and activate plug-ins when this solution is imported",
              "name": [
                "--publish-workflows-activate-plugins"
              ]
            },
            {
              "args": {
                "name": "string",
                "suggestions": [
                  {
                    "description": "True",
                    "name": "true"
                  },
                  {
                    "description": "False",
                    "name": "false"
                  }
                ]
              },
              "description": "Explicitly indicates whether to overwrite unmanaged customizations when this solution is imported",
              "name": [
                "--overwrite-unmanaged-customizations"
              ]
            },
            {
              "args": {
                "name": "string",
                "suggestions": [
                  {
                    "description": "True",
                    "name": "true"
                  },
                  {
                    "description": "False",
                    "name": "false"
                  }
                ]
              },
              "description": "Explicitly specifies the required mode when importing this solution",
              "name": [
                "--import-mode"
              ]
            },
            {
              "args": {
                "name": "string",
                "suggestions": [
                  {
                    "description": "Skip",
                    "name": "skip"
                  },
                  {
                    "description": "Fault",
                    "name": "fault"
                  }
                ]
              },
              "description": "Specifies the behavior on import when a dependency of this solution is missing from the target environment",
              "name": [
                "--missing-dependency-behavior"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "A semicolon delimited list of overrides. This value overrides any dependency information encoded in the solution's metadata. Each override should be in the format: '<uniquename>:<minVersion>:<maxVersion>'. Where minVersion and maxVersion are optional but should be in .NET version format syntax",
              "name": [
                "--dependency-overrides"
              ]
            }
          ]
        },
