          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "The target Environment ID or URL. The default value is the environment of your currently active Dataverse Auth Profile",
              "name": [
                "--environment",
                "-env"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "The Chatbot ID or schema name (unique name found in Bot Details or file name in solution explorer)",
              "name": [
                "--bot",
                "-id"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Location of the yaml file to write the bot template to",
              "name": [
                "--templateFileName"
              ]
            },
            {
              "description": "Allow overwrite of the output data file if it already exists",
              "name": [
                "--overwrite",
                "-o"
              ]
            }
          ]
        },
        {
          "description": "Creates a new bot using an existing template file as the reference",
          "name": "create",
          "options": [
            {
              "args": {
                "name": "string"
              },
              "description": "The target Environment ID or URL. The default value is the environment of your currently active Dataverse Auth Profile",
              "name": [
                "--environment",
                "-env"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "The schema name (unique name) of the new bot",
              "name": [
                "--schemaName"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Source yaml file containing the bot template that was extracted using the extract-template command",
              "name": [
                "--templateFileName"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "The display name of the new bot",
              "name": [
                "--displayName"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Name of the solution",
              "name": [
                "--solution",
                "-s"
              ]
            }
          ]
        }
      ]
    }
  ]
}
