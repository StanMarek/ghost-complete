{
  "args": {
    "generators": [
      {
        "js_source": "(g,h,j)=>Pe(this,void 0,void 0,function*(){var f;let{isDangerous:x,currentWorkingDirectory:T,searchTerm:v}=j,_=(f=(0,O.getCurrentInsertedDirectory)(p??T,v,j))!==null&&f!==void 0?f:\"/\";try{let X=yield h({command:\"ls\",args:[\"-1ApL\"],cwd:_}),ue=ie(X.stdout.split(`\n`),[\".DS_Store\"]),Z=[];for(let z of ue)if(z){let q=z.endsWith(\"/\")?\"folders\":\"filepaths\";(q===\"filepaths\"&&c!==\"only\"||q===\"folders\"&&c!==\"never\")&&Z.push({type:q===\"filepaths\"?\"file\":\"folder\",name:z,insertValue:z,isDangerous:x,context:{templateType:q}})}return y(b(Z))}catch{return[]}})",
        "requires_js": true
