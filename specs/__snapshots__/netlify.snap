          "name": [
            "--httpProxyCertificateFilename"
          ]
        }
      ]
    },
    {
      "args": {
        "description": "Environment variable name",
        "name": "name"
      },
      "description": "Unset an environment variable which removes it from the UI",
      "name": "env:unset",
      "options": [
        {
          "description": "Print debugging information",
          "name": [
            "--debug"
          ]
        },
        {
          "args": {
