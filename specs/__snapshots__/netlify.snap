          "name": [
            "--httpProxyCertificateFilename"
          ]
        }
      ]
    },
    {
      "args": {
        "description": "Name of your new function file inside your functions directory",
        "name": "name"
      },
      "description": "Create a new function locally",
      "name": "functions:create",
      "options": [
        {
          "args": {
            "name": "name"
          },
          "description": "Function name",
          "name": [
            "-n",
            "--name"
          ]
        },
        {
          "args": {
