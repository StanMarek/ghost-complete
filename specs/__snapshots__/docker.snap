              "description": "Listen address (format: <ip|interface>[:port]) (default 0.0.0.0:2377)",
              "name": [
                "--listen-addr"
              ]
            },
            {
              "args": {
                "name": "uint"
              },
              "description": "Number of additional Raft snapshots to retain",
              "name": [
                "--max-snapshots"
              ]
            },
            {
              "args": {
                "name": "uint"
              },
              "description": "Number of log entries between Raft snapshots (default 10000)",
