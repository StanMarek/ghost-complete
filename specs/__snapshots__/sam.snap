{
  "description": "AWS Serverless Application Model CLI",
  "name": "sam",
  "options": [
    {
      "description": "Turn on debug logging to print debug message generated by SAM CLI and display timestamps",
      "name": [
        "--debug"
      ]
    },
    {
      "description": "Show help for sam",
      "name": [
        "--help",
        "-h"
      ]
    },
    {
      "description": "Show the version and exit",
      "name": [
        "--version"
      ]
    },
    {
      "name": [
        "--info"
      ]
    }
  ],
  "subcommands": [
    {
      "description": "Init an AWS SAM application",
      "name": "init",
      "options": [
        {
          "args": {
            "name": "environment"
          },
          "description": "The environment name specifying the default parameter values in the configuration file to use",
          "name": [
            "--config-env"
          ]
        },
        {
          "args": {
            "name": "config file"
          },
          "description": "The path and file name of the configuration file containing default parameter values to use",
          "name": [
            "--config-file"
          ]
        },
        {
          "description": "Turn on debug logging to print debug message generated by SAM CLI and display timestamps",
          "name": [
            "--debug"
          ]
        },
        {
          "description": "Show help for sam",
          "name": [
            "--help",
            "-h"
          ]
        },
        {
          "description": "Disable interactive prompting for init parameters, and fail if any required values are missing",
          "name": [
            "--no-interactive"
          ]
        },
        {
          "args": {
            "name": "architecture",
            "suggestions": [
              {
                "name": "arm64"
              },
              {
                "name": "x86_64"
              }
            ]
          },
          "description": "Architectures your Lambda function will run on",
          "name": [
            "-a",
            "--architecture"
          ]
        },
        {
          "args": {
            "name": "location"
          },
          "description": "Template location (git, mercurial, http(s), zip, path)",
          "name": [
            "-l",
            "--location"
          ]
        },
        {
          "args": {
            "name": "runtime",
            "suggestions": [
              {
                "name": "dotnet8"
              },
              {
                "name": "dotnet6"
              },
              {
                "name": "go1.x"
              },
              {
                "name": "java21"
              },
              {
                "name": "java17"
              },
              {
                "name": "java11"
              },
              {
                "name": "java8.al2"
              },
              {
                "name": "nodejs20.x"
              },
              {
                "name": "nodejs18.x"
              },
              {
                "name": "nodejs16.x"
              },
              {
                "name": "provided.al2023"
              },
              {
                "name": "provided.al2"
              },
              {
                "name": "provided"
              },
              {
                "name": "python3.12"
              },
              {
                "name": "python3.11"
              },
              {
                "name": "python3.10"
              },
              {
                "name": "python3.9"
              },
              {
                "name": "python3.8"
              },
              {
                "name": "ruby3.2"
              }
            ]
          },
          "description": "Lambda Runtime for your app",
          "name": [
            "-r",
            "--runtime"
          ]
        },
        {
          "args": {
            "name": "type",
            "suggestions": [
              {
                "name": "zip"
              },
              {
                "name": "image"
              }
            ]
          },
          "description": "Package type for your app",
          "name": [
            "-p",
            "--package-type"
          ]
        },
        {
          "args": {
            "name": "image name",
            "suggestions": [
              {
                "name": "amazon/dotnet8-base"
              },
              {
                "name": "amazon/dotnet6-base"
              },
              {
                "name": "amazon/go1.x-base"
              },
              {
                "name": "amazon/go-provided.al2-base"
              },
              {
                "name": "amazon/go-provided.al2023-base"
              },
              {
                "name": "amazon/java21-base"
              },
              {
                "name": "amazon/java17-base"
              },
              {
                "name": "amazon/java11-base"
              },
              {
                "name": "amazon/java8.al2-base"
              },
              {
                "name": "amazon/nodejs20.x-base"
              },
              {
                "name": "amazon/nodejs18.x-base"
              },
              {
                "name": "amazon/nodejs16.x-base"
              },
              {
                "name": "amazon/python3.12-base"
              },
              {
                "name": "amazon/python3.11-base"
              },
              {
                "name": "amazon/python3.10-base"
              },
              {
                "name": "amazon/python3.9-base"
              },
              {
                "name": "amazon/python3.8-base"
              },
              {
                "name": "amazon/ruby3.2-base"
              }
            ]
          },
          "description": "Lambda Image of your app",
          "name": [
            "-i",
            "--base-image"
          ]
        },
        {
          "args": {
            "name": "manager",
            "suggestions": [
              {
                "name": "npm"
              },
              {
                "name": "mod"
              },
              {
                "name": "gradle"
              },
              {
                "name": "cli-package"
              },
              {
                "name": "bundler"
              },
              {
                "name": "pip"
              },
              {
                "name": "maven"
              }
            ]
          },
          "description": "Dependency manager for your Lambda runtime",
          "name": [
            "-d",
            "--dependency-manager"
          ]
        },
        {
          "args": {
            "name": "path"
          },
          "description": "Where to output the initialized app into",
          "name": [
            "-o",
            "--output-dir"
          ]
        },
        {
          "args": {
            "name": "text"
          },
          "description": "Name of your project to be generated as a folder",
          "name": [
            "-n",
            "--name"
          ]
        },
        {
          "args": {
            "description": "Template name",
            "name": "text"
          },
          "description": "Identifier of the managed application template you want to use",
          "name": [
            "--app-template"
          ]
        },
        {
          "description": "Disable Cookiecutter prompting and accept default values defined template config",
          "name": [
            "--no-input"
          ]
        },
        {
          "args": {
            "description": "E.g. {\"customParam1\": \"customValue1\", \"customParam2\":\"customValue2\"}",
            "name": "text"
          },
          "description": "Override any custom parameters in the template's cookiecutter.json configuration",
          "name": [
            "--extra-context"
          ]
        }
      ]
    },
    {
      "description": "Validate an AWS SAM template",
      "name": "validate",
      "options": [
        {
          "args": {
            "name": "environment"
          },
          "description": "The environment name specifying the default parameter values in the configuration file to use",
          "name": [
            "--config-env"
          ]
        },
        {
          "args": {
            "name": "config file"
          },
          "description": "The path and file name of the configuration file containing default parameter values to use",
          "name": [
            "--config-file"
          ]
        },
        {
          "description": "Turn on debug logging to print debug message generated by SAM CLI and display timestamps",
          "name": [
            "--debug"
          ]
        },
        {
          "description": "Show help for sam",
          "name": [
            "--help",
            "-h"
          ]
        },
        {
          "args": {
            "description": "The name of the AWS profile",
            "generators": [
              {
                "cache": {
                  "cache_by_directory": true
                },
                "script": [
                  "aws",
                  "configure",
                  "list-profiles"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim"
                ]
              }
            ],
            "name": "profile name"
          },
          "description": "Select a specific profile from your credential file to get AWS credentials",
          "name": [
            "--profile"
          ]
        },
        {
          "args": {
            "name": "region"
          },
          "description": "Set the AWS Region of the service",
          "name": [
            "--region"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "AWS SAM template file",
          "name": [
            "-t",
            "--template-file",
            "--template"
          ]
        }
      ]
    },
    {
      "description": "Build your Lambda function code",
      "name": "build",
      "options": [
        {
          "args": {
            "name": "environment"
          },
          "description": "The environment name specifying the default parameter values in the configuration file to use",
          "name": [
            "--config-env"
          ]
        },
        {
          "args": {
            "name": "config file"
          },
          "description": "The path and file name of the configuration file containing default parameter values to use",
          "name": [
            "--config-file"
          ]
        },
        {
          "description": "Turn on debug logging to print debug message generated by SAM CLI and display timestamps",
          "name": [
            "--debug"
          ]
        },
        {
          "args": {
            "name": "network name"
          },
          "description": "Specifies the name or id of an existing docker network to lambda docker containers should connect to, along with the default bridge network. If not specified, the Lambda containers will only connect to the default bridge docker network.",
          "name": [
            "--docker-network"
          ]
        },
        {
          "description": "Show help for sam",
          "name": [
            "--help",
            "-h"
          ]
        },
        {
          "args": {
            "description": "For example, 'ParameterKey=KeyPairName,ParameterValue=MyKey ParameterKey=InstanceType,ParameterValue=t1.micro' or 'KeyPairName=MyKey InstanceType=t1.micro'",
            "name": "override string"
          },
          "description": "A string that contains AWS CloudFormation parameter overrides encoded as key=value pairs",
          "name": [
            "--parameter-overrides"
          ]
        },
        {
          "args": {
            "description": "The name of the AWS profile",
            "generators": [
              {
                "cache": {
                  "cache_by_directory": true
                },
                "script": [
                  "aws",
                  "configure",
                  "list-profiles"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim"
                ]
              }
            ],
            "name": "profile name"
          },
          "description": "Select a specific profile from your credential file to get AWS credentials",
          "name": [
            "--profile"
          ]
        },
        {
          "args": {
            "name": "region"
          },
          "description": "Set the AWS Region of the service",
          "name": [
            "--region"
          ]
        },
        {
          "description": "Specify whether CLI should skip pulling down the latest Docker image for Lambda runtime",
          "name": [
            "--skip-pull-image"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "AWS SAM template file",
          "name": [
            "-t",
            "--template-file",
            "--template"
          ]
        },
        {
          "description": "If your functions depend on packages that have natively compiled dependencies, use this flag to build your function inside an AWS Lambda-like Docker container",
          "name": [
            "-u",
            "--use-container"
          ]
        },
        {
          "args": {
            "name": "env var"
          },
          "description": "Input environment variables through command line to pass into build containers, you can either input function specific format (FuncName.VarName=Value) or global format (VarName=Value)",
          "name": [
            "-e",
            "--container-env-var"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Path to environment variable json file (e.g., env_vars.json) to pass into build containers",
          "name": [
            "-ef",
            "--container-env-var-file"
          ]
        },
        {
          "args": {
            "description": "Container image URIs for building functions/layers. You can specify for all functions/layers with just the image URI (--build-image public.ecr.aws/sam/build-nodejs14.x:latest). You can specify for each individual function with (--build-image FunctionLogicalID=public.ecr.aws/sam/build-nodejs14.x:latest). A combination of the two can be used. If a function does not have build image specified or an image URI for all functions, the default SAM CLI build images will be used.",
            "name": "image uri"
          },
          "description": "Container image URIs",
          "name": [
            "-bi",
            "--build-image"
          ]
        },
        {
          "description": "Enabled parallel builds",
          "name": [
            "-p",
            "--parallel"
          ]
        },
        {
          "args": {
            "name": "directory",
            "template": "folders"
          },
          "description": "Path to a folder where the built artifacts will be stored",
          "name": [
            "-b",
            "--build-dir"
          ]
        },
        {
          "args": {
            "name": "directory",
            "template": "folders"
          },
          "description": "The folder where the cached artifacts are stored with `--cached` is specified",
          "name": [
            "-cd",
            "--cache-dir"
          ]
        },
        {
          "args": {
            "name": "directory",
            "template": "folders"
          },
          "description": "Resolve relative paths to function's source code with respect to this folder",
          "name": [
            "-s",
            "--base-dir"
          ]
        },
        {
          "args": {
            "name": "directory",
            "template": "folders"
          },
          "description": "Path to a custom dependency manifest to use instead of the default one",
          "name": [
            "-m",
            "--manifest"
          ]
        },
        {
          "description": "Enable cached builds. Use this flag to reuse build artifacts that have not changed from previous builds",
          "name": [
            "-c",
            "--cached"
          ]
        },
        {
          "description": "Should beta features be enabled",
          "name": [
            "--beta-features",
            "--no-beta-features"
          ]
        }
      ]
    },
    {
      "description": "Run your Serverless application locally for quick development & testing",
      "name": "local",
      "options": [
        {
          "description": "Show help for sam",
          "name": [
            "--help",
            "-h"
          ]
        }
      ],
      "subcommands": [
        {
          "description": "You can use this command to generate sample payloads from different event sources such as S3, API Gateway, and SNS",
          "name": "generate-event",
          "options": [
            {
              "description": "Show help for sam",
              "name": [
                "--help",
                "-h"
              ]
            }
          ]
        },
        {
          "description": "Invokes a local Lambda function once",
          "name": "invoke",
          "options": [
            {
              "args": {
                "name": "environment"
              },
              "description": "The environment name specifying the default parameter values in the configuration file to use",
              "name": [
                "--config-env"
              ]
            },
            {
              "args": {
                "name": "config file"
              },
              "description": "The path and file name of the configuration file containing default parameter values to use",
              "name": [
                "--config-file"
              ]
            },
            {
              "args": {
                "name": "path",
                "template": "filepaths"
              },
              "description": "JSON file containing environment variables to be set within the container environment",
              "name": [
                "--container-env-vars"
              ]
            },
            {
              "args": {
                "name": "text"
              },
              "description": "IP address of the host network interface that container ports should bind to. Use 0.0.0.0 to bind to all interfaces",
              "name": [
                "--container-host-interface"
              ]
            },
            {
              "args": {
                "name": "text"
              },
              "description": "Host of locally emulated Lambda container",
              "name": [
                "--container-host"
              ]
            },
            {
              "args": {
                "name": "text"
              },
              "description": "Additional arguments to be passed to the debugger",
              "name": [
                "--debugger-args"
              ]
            },
            {
              "args": {
                "name": "text"
              },
              "description": "Host path to a debugger to mount into the Lambda container",
              "name": [
                "--debugger-path"
              ]
            },
            {
              "description": "Turn on debug logging to print debug message generated by SAM CLI and display timestamps",
              "name": [
                "--debug"
              ]
            },
            {
              "args": {
                "name": "port number"
              },
              "description": "When specified, Lambda function will start in debug mode and expose this port to localhost",
              "name": [
                "-d",
                "--debug-port"
              ]
            },
            {
              "args": {
                "name": "network name"
              },
              "description": "Specifies the name or id of an existing docker network to lambda docker containers should connect to, along with the default bridge network. If not specified, the Lambda containers will only connect to the default bridge docker network.",
              "name": [
                "--docker-network"
              ]
            },
            {
              "args": {
                "name": "text"
              },
              "description": "Location basedir where the SAM file exists",
              "name": [
                "-v",
                "--docker-volume-basedir"
              ]
            },
            {
              "args": {
                "name": "path",
                "template": "filepaths"
              },
              "description": "JSON file containing values for Lambda function environment variables",
              "name": [
                "-n",
                "--env-vars"
              ]
            },
            {
              "description": "Whether the image should be rebuilt",
              "name": [
                "--force-image-build"
              ]
            },
            {
              "description": "Show help for sam",
              "name": [
                "--help",
                "-h"
              ]
            },
            {
              "args": {
                "name": "text"
              },
              "description": "Container image URIs for invoking functions or starting api and function",
              "name": [
                "-ii",
                "--invoke-image"
              ]
            },
            {
              "args": {
                "name": "directory",
                "template": "folders"
              },
              "description": "Location where Layers your template uses will be downloaded to",
              "name": [
                "--layer-cache-basedir"
              ]
            },
            {
              "args": {
                "name": "text"
              },
              "description": "Log file to send runtime logs to",
              "name": [
                "-l",
                "--log-file"
              ]
            },
            {
              "args": {
                "description": "For example, 'ParameterKey=KeyPairName,ParameterValue=MyKey ParameterKey=InstanceType,ParameterValue=t1.micro' or 'KeyPairName=MyKey InstanceType=t1.micro'",
                "name": "override string"
              },
              "description": "A string that contains AWS CloudFormation parameter overrides encoded as key=value pairs",
              "name": [
                "--parameter-overrides"
              ]
            },
            {
              "args": {
                "description": "The name of the AWS profile",
                "generators": [
                  {
                    "cache": {
                      "cache_by_directory": true
                    },
                    "script": [
                      "aws",
                      "configure",
                      "list-profiles"
                    ],
                    "transforms": [
                      "split_lines",
                      "filter_empty",
                      "trim"
                    ]
                  }
                ],
                "name": "profile name"
              },
              "description": "Select a specific profile from your credential file to get AWS credentials",
              "name": [
                "--profile"
              ]
            },
            {
              "args": {
                "name": "region"
              },
              "description": "Set the AWS Region of the service",
              "name": [
                "--region"
              ]
            },
            {
              "description": "If set, will emulate a shutdown event after the invoke completes, in order to test extension handling of shutdown behavior",
              "name": [
                "--shutdown"
              ]
            },
            {
              "description": "Specify whether CLI should skip pulling down the latest Docker image for Lambda runtime",
              "name": [
                "--skip-pull-image"
              ]
            },
            {
              "args": {
                "name": "path",
                "template": "filepaths"
              },
              "description": "AWS SAM template file",
              "name": [
                "-t",
                "--template-file",
                "--template"
              ]
            },
            {
              "args": {
                "name": "path",
                "template": "filepaths"
              },
              "description": "JSON file containing event data passed to the Lambda function",
              "name": [
                "-e",
                "--event"
              ]
            }
          ]
        },
        {
          "description": "Sets up a local endpoint you can use to test your API",
          "name": "start-api",
          "options": [
            {
              "args": {
                "name": "environment"
              },
              "description": "The environment name specifying the default parameter values in the configuration file to use",
              "name": [
                "--config-env"
              ]
            },
            {
              "args": {
                "name": "config file"
              },
              "description": "The path and file name of the configuration file containing default parameter values to use",
              "name": [
                "--config-file"
              ]
            },
            {
              "args": {
                "name": "path",
                "template": "filepaths"
              },
              "description": "JSON file containing environment variables to be set within the container environment",
              "name": [
                "--container-env-vars"
              ]
            },
            {
              "args": {
                "name": "text"
              },
              "description": "IP address of the host network interface that container ports should bind to. Use 0.0.0.0 to bind to all interfaces",
              "name": [
                "--container-host-interface"
              ]
            },
            {
              "args": {
                "name": "text"
              },
              "description": "Host of locally emulated Lambda container",
              "name": [
                "--container-host"
              ]
            },
            {
              "args": {
                "name": "text"
              },
              "description": "Specifies the Lambda Function logicalId to apply debug options to when --warm-containers is specified.  This parameter applies to --debug-port, --debugger-path, and --debug-args",
              "name": [
                "--debug-function"
              ]
            },
            {
              "args": {
                "name": "text"
              },
              "description": "Additional arguments to be passed to the debugger",
              "name": [
                "--debugger-args"
              ]
            },
            {
              "args": {
                "name": "text"
              },
              "description": "Host path to a debugger to mount into the Lambda container",
              "name": [
                "--debugger-path"
              ]
            },
            {
              "description": "Turn on debug logging to print debug message generated by SAM CLI and display timestamps",
              "name": [
                "--debug"
              ]
            },
            {
              "args": {
                "name": "port number"
              },
              "description": "When specified, Lambda function will start in debug mode and expose this port to localhost",
              "name": [
                "-d",
                "--debug-port"
              ]
            },
            {
              "args": {
                "name": "network name"
              },
              "description": "Specifies the name or id of an existing docker network to lambda docker containers should connect to, along with the default bridge network. If not specified, the Lambda containers will only connect to the default bridge docker network.",
              "name": [
                "--docker-network"
              ]
            },
            {
              "args": {
                "name": "text"
              },
              "description": "Location basedir where the SAM file exists",
              "name": [
                "-v",
                "--docker-volume-basedir"
              ]
            },
            {
              "args": {
                "name": "path",
                "template": "filepaths"
              },
              "description": "JSON file containing values for Lambda function environment variables",
              "name": [
                "-n",
                "--env-vars"
              ]
            },
            {
              "description": "Whether the image should be rebuilt",
              "name": [
                "--force-image-build"
              ]
            },
            {
              "description": "Show help for sam",
              "name": [
                "--help",
                "-h"
              ]
            },
            {
              "args": {
                "description": "Default: '127.0.0.1'",
                "name": "text"
              },
              "description": "Local hostname or IP address to bind to",
              "name": [
                "--host"
              ]
            },
            {
              "args": {
                "name": "text"
              },
              "description": "Container image URIs for invoking functions or starting api and function",
              "name": [
                "-ii",
                "--invoke-image"
              ]
            },
            {
              "args": {
                "name": "directory",
