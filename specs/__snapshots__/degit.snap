{
  "args": [
    {
      "generators": [
        {
          "js_source": "async(r,e)=>{let n=r[r.length-1];if(n.includes(\":\"))return[];let t=n.slice(0,n.indexOf(\"/\")),{stdout:i}=await e({command:\"curl\",args:[\"-sL\",`https://api.github.com/users/${t}/repos`]});return JSON.parse(i).map(s=>({name:s.full_name,description:s.description??\"Repository\",priority:s.is_template?51:50,displayName:s.name,icon:\"fig://icon?type=git\"}))}",
          "requires_js": true
        }
      ],
      "name": "user/repo"
    },
    {
      "isOptional": true,
      "name": "location",
      "template": "folders"
    }
  ],
  "description": "Straightforward project scaffolding",
  "name": "degit",
  "options": [
    {
      "description": "Print help",
      "name": [
        "--help"
      ]
    },
    {
      "description": "Overwrite existing files",
      "name": [
        "-f",
        "--force"
      ]
    },
    {
      "description": "Use a cache",
      "name": [
        "-c",
        "--cache"
      ]
    },
    {
      "description": "Be verbose?",
      "name": [
        "-v",
        "--verbose"
      ]
    },
    {
      "args": {
        "name": "mode",
        "suggestions": [
          {
            "name": "git"
          },
          {
            "name": "tar"
          }
        ]
      },
      "description": "Clone mode",
      "name": [
        "-m",
        "--mode"
      ]
    }
  ]
}
