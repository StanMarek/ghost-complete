    {
      "description": "Start a build",
      "name": "build",
      "options": [
        {
          "args": {
            "name": "Profile Name"
          },
          "description": "Name of the build profile from eas.json. Defaults to \"production\" if defined in eas.json",
          "name": [
            "-e",
            "--profile"
          ]
        },
        {
          "args": {
            "name": "Value"
          },
          "description": "A short message describing the build",
          "name": [
            "-m",
            "--message"
          ]
        },
        {
          "args": {
            "name": "Platform",
            "suggestions": [
              {
                "name": "android"
              },
              {
                "name": "ios"
              },
              {
                "name": "all"
              }
            ]
          },
          "name": [
            "-p",
            "--platform"
          ]
        },
        {
          "description": "Submit on build complete using the submit profile with the same name as the build profile",
          "name": [
            "--auto-submit"
          ]
        },
        {
          "args": {
            "name": "Profile Name"
          },
          "description": "Submit on build complete using the submit profile with provided name",
          "name": [
            "--auto-submit-with-profile"
          ]
        },
        {
          "description": "Clear cache before the build",
          "name": [
            "--clear-cache"
          ]
        },
        {
          "description": "Enable JSON output, non-JSON messages will be printed to stderr",
          "name": [
            "--json"
          ]
        },
        {
          "description": "Run build locally [experimental]",
          "name": [
            "--local"
          ]
        },
        {
          "description": "Run the command in non-interactive mode",
          "name": [
            "--non-interactive"
          ]
        },
        {
          "args": {
            "name": "Value"
          },
          "description": "Output path for local build",
          "name": [
            "--output"
          ]
        },
        {
          "description": "Don't wait for build(s) to complete",
          "name": [
            "--no-wait"
          ]
        },
        {
          "description": "Wait for build(s) to complete",
          "name": [
            "--wait"
          ]
        }
      ]
    },
