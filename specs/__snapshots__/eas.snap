    {
      "description": "Inspect the state of the project at specific build stages, useful for troubleshooting",
      "name": "build:inspect",
      "options": [
        {
          "args": {
            "name": "Profile Name"
          },
          "description": "Name of the build profile from eas.json. Defaults to \"production\" if defined in eas.json",
          "name": [
