{
  "description": "EAS CLI is the command-line app that you will use to interact with EAS services from your terminal",
  "name": "eas",
  "subcommands": [
    {
      "description": "Log in with your Expo account",
      "name": "account:login"
    },
    {
      "description": "Log out",
      "name": "account:logout"
    },
    {
      "description": "Show the username you are logged in as",
      "name": "account:view"
    },
    {
      "args": {
        "isOptional": true,
        "name": "Status",
        "suggestions": [
          {
            "name": "on"
          },
          {
            "name": "off"
          }
        ]
      },
      "description": "Display or change analytics settings",
      "name": "analytics"
    },
    {
      "args": {
        "description": "Select the shell you'd like to display autocomplete information for",
        "name": "Shell",
        "suggestions": [
