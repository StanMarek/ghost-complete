            },
            {
              "args": {
                "name": "attachment-tag-prefix"
              },
              "description": "Optional custom prefix to use for attached image tags. Attachment images are tagged as: `[AttachmentTagPrefix]sha256-[TargetImageDigest].[AttachmentName]`",
