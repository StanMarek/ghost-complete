    {
      "args": {
        "name": "secrets"
      },
      "description": "Upload secrets",
      "name": "secrets:upload",
      "options": [
        {
          "description": "Show CLI help",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "args": {},
          "description": "Name of project",
          "name": [
            "-p",
            "--project"
          ]
        },
        {
          "args": {
            "name": "Environment to update"
          },
