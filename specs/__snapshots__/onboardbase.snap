      "name": "secrets:delete",
      "options": [
        {
          "description": "Show CLI help",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "args": {},
          "description": "Name of project",
          "name": [
            "-p",
            "--project"
          ]
        },
        {
          "args": {
            "name": "Environment to update"
          },
          "description": "Environment to run by default",
          "name": [
            "-e",
            "--environment"
          ]
        }
      ]
    },
    {
