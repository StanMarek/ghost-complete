{
  "args": {
    "generators": [
      {
        "script": [
          "defaultbrowser"
        ],
        "transforms": [
          "split_lines",
          "filter_empty",
          "trim"
        ]
      }
    ],
    "isOptional": true
  },
  "description": "Change your default browser from the CLI",
  "name": "defaultbrowser"
}
