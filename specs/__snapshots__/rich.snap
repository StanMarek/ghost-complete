      "description": "Use LEXER for syntax highlighting. See https://pygments.org/docs/lexers/",
      "name": [
        "-x",
        "--lexer"
      ]
    },
    {
      "description": "Render hyperlinks in markdown",
      "name": [
        "-y",
        "--hyperlinks"
      ]
    },
    {
      "description": "Don't word wrap syntax highlighted files",
      "name": [
        "--no-wrap"
      ]
    },
    {
      "args": {
        "name": "text"
      },
      "description": "Set panel title to TEXT",
      "name": [
        "--title"
      ]
    },
    {
      "args": {
        "name": "text"
      },
      "description": "Set panel caption to TEXT",
      "name": [
        "--caption"
      ]
    },
    {
      "description": "Force terminal output when not writing to a terminal",
      "name": [
        "--force-terminal"
      ]
    },
    {
      "args": {
        "name": "path",
        "template": "filepaths"
      },
      "description": "Write HTML to PATH",
      "name": [
        "-o",
        "--export-html"
      ]
    },
    {
      "args": {
        "name": "path",
        "template": "filepaths"
      },
      "description": "Write SVG to PATH",
      "name": [
        "--export-svg"
      ]
    },
    {
      "description": "Display in an interactive pager",
      "name": [
        "--pager"
      ]
    },
    {
      "description": "Print version and exit",
      "name": [
        "-v",
        "--version"
      ]
    },
    {
      "description": "Show this message and exit",
      "name": [
        "--help"
      ]
    }
  ]
