        {
          "description": "Reports activity for the current day",
          "name": [
            "--day",
            "-d"
          ]
        },
        {
          "description": "Reports all activities",
          "name": [
            "--all",
            "-a"
          ]
        },
        {
          "args": {
            "generators": [
              {
                "script": [
                  "watson",
