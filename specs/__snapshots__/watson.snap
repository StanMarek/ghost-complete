      "description": "Restart monitoring time for a previously stopped project",
      "name": "restart",
      "options": [
        {
          "args": {
            "name": "DATETIME"
          },
          "description": "Start frame at this time. Must be in (YYYY-MM-DDT)?HH:MM(:SS)? format",
          "name": [
            "--at"
