          "description": "Don't Reverse the order of the days in output",
          "name": [
            "--no-reverse",
            "-R"
          ]
        },
        {
          "args": {
            "name": "DATETIME"
          },
          "description": "The date from when the log should start. Defaults to seven days ago",
          "name": [
            "--from",
            "-f"
