            },
            {
              "args": {
                "name": "string"
              },
              "description": "Set the new title",
              "name": [
                "-t",
                "--title"
              ]
            }
          ]
        },
        {
          "description": "List and filter issues in this repository",
          "name": "list",
          "options": [
            {
              "args": {
                "name": "repo"
              },
              "description": "Select another repository using the [HOST/]OWNER/REPO format",
              "name": [
                "-R",
                "--repo"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Filter by assignee",
              "name": [
                "-a",
                "--assignee"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Filter by author",
              "name": [
                "-A",
                "--author"
              ]
            },
            {
              "args": {
                "name": "expression"
              },
              "description": "Filter JSON output using a jq expression",
              "name": [
                "-q",
                "--jq"
              ]
            },
            {
              "args": {
                "name": "fields"
              },
              "description": "Output JSON with the specified fields",
              "name": [
                "--json"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Filter by labels",
              "name": [
                "-l",
                "--label"
              ]
            },
            {
              "args": {
                "name": "int"
              },
              "description": "Maximum number of issues to fetch (default 30)",
              "name": [
                "-L",
                "--limit"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Filter by mention",
              "name": [
                "--mention"
              ]
            },
            {
              "args": {
                "description": "Number or Title",
                "name": "number"
              },
              "description": "Filter by milestone number or `title`",
              "name": [
                "-m",
                "--milestone"
              ]
            },
            {
              "args": {
                "name": "query"
              },
              "description": "Search issues with query",
              "name": [
                "-S",
                "--search"
              ]
            },
            {
              "args": {
                "description": "(default \"open\")",
                "name": "state",
                "suggestions": [
                  {
                    "name": "open"
                  },
                  {
                    "name": "closed"
                  },
                  {
                    "name": "all"
                  }
                ]
              },
              "description": "Filter by state (default \"open\")",
              "name": [
                "-s",
                "--state"
              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Format JSON output using a Go template",
              "name": [
                "-t",
                "--template"
              ]
            },
            {
              "description": "Open the browser to list the issue(s)",
              "name": [
                "-w",
                "--web"
              ]
            }
          ]
        },
        {
          "description": "Reopen issue",
          "name": "reopen",
          "options": [
            {
              "args": {
                "name": "repo"
              },
              "description": "Select another repository using the [HOST/]OWNER/REPO format",
              "name": [
                "-R",
                "--repo"
              ]
            }
          ]
        },
        {
          "description": "Show status of relevant issues",
          "name": "status",
          "options": [
            {
              "args": {
                "name": "repo"
              },
              "description": "Select another repository using the [HOST/]OWNER/REPO format",
              "name": [
                "-R",
                "--repo"
              ]
            },
            {
              "args": {
                "name": "expression"
              },
              "description": "Filter JSON output using a jq expression",
              "name": [
                "-q",
                "--jq"
              ]
