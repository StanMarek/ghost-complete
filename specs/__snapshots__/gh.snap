{
  "args": {
    "description": "Custom user defined gh alias",
    "generators": [
      {
        "script": [
          "gh",
          "alias",
          "list"
        ],
        "transforms": [
          "split_lines",
          "filter_empty",
          "trim"
        ]
      }
    ],
    "isOptional": true,
    "name": "alias"
  },
  "description": "GitHub's CLI tool",
  "name": "gh",
  "options": [
    {
      "description": "Show help for command",
      "name": [
        "--help"
      ]
    }
  ],
  "subcommands": [
    {
      "description": "Create command shortcuts",
      "name": "alias",
      "subcommands": [
        {
          "args": {
            "generators": [
              {
                "script": [
                  "gh",
                  "alias",
                  "list"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim"
                ]
              }
            ],
            "name": "alias"
          },
          "description": "Delete an alias",
          "name": "delete"
        },
        {
          "description": "List available aliases",
          "name": "list"
        },
        {
          "args": [
            {
              "description": "A word that will expand to the gh command",
              "name": "alias"
            },
            {
              "description": "The gh command to be invoked, more info with --help",
              "name": "expansion"
            }
          ],
          "description": "Set an alias for a gh command",
          "name": "set",
          "options": [
            {
              "description": "Declare an alias to be passed through a shell interpreter",
              "name": [
                "-s",
                "--shell"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Make an authenticated GitHub API request",
      "name": "api"
    },
    {
      "description": "Login, logout, and refresh your authentication",
      "name": "auth",
      "subcommands": [
        {
          "description": "Authenticate with a GitHub host",
          "name": "login",
          "options": [
            {
              "args": {
                "name": "hostname"
              },
              "description": "The hostname of the GitHub instance to authenticate with",
              "name": [
                "-h",
                "--hostname"
              ]
            },
            {
              "args": {
                "name": "scopes"
              },
              "description": "Additional authentication scopes for gh to have",
              "name": [
                "-s",
                "--scopes"
              ]
            },
            {
              "description": "Open a browser to authenticate",
              "name": [
                "-w",
                "--web"
              ]
            },
            {
              "args": {
                "name": "token"
              },
              "description": "Read token from standard input",
              "name": [
                "--with-token"
              ]
            }
          ]
        },
        {
          "description": "Log out of a GitHub host",
          "name": "logout",
          "options": [
            {
              "args": {
                "name": "hostname"
              },
              "description": "The hostname of the GitHub instance to authenticate with",
              "name": [
                "-h",
                "--hostname"
              ]
            }
          ]
        },
        {
          "description": "Refresh stored authentication credentials",
          "name": "refresh",
          "options": [
            {
              "args": {
                "name": "hostname"
              },
              "description": "The hostname of the GitHub instance to authenticate with",
              "name": [
                "-h",
                "--hostname"
              ]
            },
            {
              "args": {
                "name": "scopes"
              },
              "description": "Additional authentication scopes for gh to have",
              "name": [
                "-s",
                "--scopes"
              ]
            }
          ]
        },
        {
          "description": "Configure git to use GitHub CLI as a credential helper",
          "name": "setup-git",
          "options": [
            {
              "args": {
                "name": "hostname"
              },
              "description": "The hostname of the GitHub instance to authenticate with",
              "name": [
                "-h",
                "--hostname"
              ]
            }
          ]
        },
        {
          "description": "View authentication status",
          "name": "status",
          "options": [
            {
              "args": {
                "name": "hostname"
              },
              "description": "The hostname of the GitHub instance to authenticate with",
              "name": [
                "-h",
                "--hostname"
              ]
            },
            {
              "args": {
                "name": "token"
              },
              "description": "Read token from standard input",
              "name": [
                "--with-token"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Manage GPG keys registered with your GitHub account",
      "name": "gpg-key",
      "subcommands": [
        {
          "description": "Add a GPG key to your GitHub account",
          "name": "add"
        },
        {
          "description": "Lists GPG keys in your GitHub account",
          "name": "list"
        }
      ]
    },
    {
      "args": {
        "generators": [
          {
            "cache": {},
            "js_source": "e=>JSON.parse(e).map(n=>{let{number:i,title:r,headRefName:o,state:s}=n;return{name:i.toString(),displayName:r,description:`#${i} | ${o}`,icon:s===\"OPEN\"?\"\\u2705\":\"\\u2611\\uFE0F\"}})",
            "requires_js": true,
            "script": [
              "gh",
              "pr",
              "list",
              "--json=number,title,headRefName,state"
            ]
          }
        ],
        "name": "[pr | issue | path[:line]"
      },
      "description": "Open the repository in the browser",
      "name": "browse",
      "options": [
        {
          "args": {
            "generators": [
              {
                "type": "git_branches"
              }
            ],
            "name": "branch"
          },
          "description": "Select another branch by passing in the branch name",
          "name": [
            "-b",
            "--branch"
          ]
        },
        {
          "description": "Open the last commit",
          "name": [
            "-c",
            "--commit"
          ]
        },
        {
          "description": "Print destination URL instead of opening the browser",
          "name": [
            "-n",
            "--no-browser"
          ]
        },
        {
          "description": "Open repository projects",
          "name": [
            "-p",
            "--projects"
          ]
        },
        {
          "args": {
            "name": "[HOST/]OWNER/REPO"
          },
          "description": "Select another repository using the [HOST/]OWNER/REPO format",
          "name": [
            "-R",
            "--repo"
          ]
        },
        {
          "description": "Open repository settings",
          "name": [
            "-s",
            "--settings"
          ]
        },
        {
          "description": "Open repository wiki",
          "name": [
            "-w",
            "--wiki"
          ]
        }
      ]
    },
    {
      "description": "Generate shell completion scripts",
      "name": "completion",
      "options": [
        {
          "args": {
            "name": "shell",
            "suggestions": [
              {
                "name": "bash"
              },
              {
                "name": "zsh"
              },
              {
                "name": "fish"
              },
              {
                "name": "powershell"
              }
            ]
          },
          "name": [
            "-s",
            "--shell"
          ]
        }
      ]
    },
    {
      "description": "Manage configuration for gh",
      "name": "config",
      "subcommands": [
        {
          "args": {
            "name": "key",
            "suggestions": [
              {
                "name": "git_protocol"
              },
              {
                "name": "editor"
              },
              {
                "name": "prompt"
              },
              {
                "name": "pager"
              },
              {
                "name": "http_unix_socket"
              }
            ]
          },
          "description": "Print the value of a given configuration key",
          "name": "get",
          "options": [
            {
              "args": {
                "name": "host"
              },
              "description": "Get per-host setting",
              "name": [
                "-h",
                "--host"
              ]
            }
          ]
        },
        {
          "description": "Update configuration with a value for the given key",
          "name": "set",
          "options": [
            {
              "args": {
                "name": "host"
              },
              "description": "Get per-host setting",
              "name": [
                "-h",
                "--host"
              ]
            }
          ],
          "subcommands": [
            {
              "args": {
                "name": "option",
                "suggestions": [
                  {
                    "name": "https"
                  },
                  {
                    "name": "ssh"
                  }
                ]
              },
              "description": "The protocol to use for git clone and push operations",
              "name": "git_protocol"
            },
            {
              "args": {
                "name": "editor",
                "suggestions": [
                  {
                    "name": "vim"
                  },
                  {
                    "name": "nano"
                  }
                ]
              },
              "description": "The text editor program to use for authoring text",
              "name": "editor"
            },
            {
              "args": {
                "name": "value",
                "suggestions": [
                  {
                    "name": "enable"
                  },
                  {
                    "name": "disable"
                  }
                ]
              },
              "description": "Toggle interactive prompting in the terminal",
              "name": "prompt"
            },
            {
              "args": {
                "name": "value"
              },
              "description": "The terminal pager program to send standard output to",
              "name": "pager"
            },
            {
              "args": {
                "name": "path"
              },
              "description": "The path to a unix socket through which to make HTTP connection",
              "name": "http_unix_socket"
            }
          ]
        }
      ]
    },
    {
      "description": "Manage gh extensions",
      "name": "extensions",
      "subcommands": [
        {
          "args": {
            "name": "name"
          },
          "description": "Create a new extension",
          "name": "create"
        },
        {
          "args": {
            "name": "repo"
          },
          "description": "Install a gh extension from a repository",
          "name": "install"
        },
        {
          "description": "List installed extension commands",
          "name": "list"
        },
        {
          "args": {
            "name": "name"
          },
          "description": "Remove an installed extension",
          "name": "remove"
        },
        {
          "args": {
            "name": "name"
          },
          "description": "Upgrade installed extensions",
          "name": "upgrade",
          "options": [
            {
              "description": "Upgrade all extensions",
              "name": [
                "--all"
              ]
            },
            {
              "description": "Force upgrade extensions",
              "name": [
                "--force"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Manage gists",
      "name": "gist",
      "subcommands": [
        {
          "args": [
            {
              "description": "Gist ID or URL",
              "name": "gist"
            },
            {
              "isOptional": true,
              "name": "directory",
              "template": "folders"
            }
          ],
          "description": "Clone a gist locally",
          "name": "clone"
        },
        {
          "args": {
            "name": "filename",
            "template": "filepaths"
          },
          "description": "Create a new gist",
          "name": "create",
          "options": [
            {
              "args": {
                "name": "description"
              },
              "description": "A description for this gist",
              "name": [
                "-d",
                "--desc"
              ]
            },
            {
              "args": {
                "name": "filename",
                "template": "filepaths"
              },
              "description": "Provide a filename to be used when reading from STDIN",
              "name": [
                "-f",
                "--filename"
              ]
            },
            {
              "description": "List the gist publicly (default: secret)",
              "name": [
                "-p",
                "--public"
              ]
            },
            {
              "description": "Open the web browser with created gist",
              "name": [
                "-w",
                "--web"
              ]
            }
          ]
        },
        {
          "args": {
            "description": "Gist ID or URL",
            "name": "gist"
          },
          "description": "Delete a gist",
          "name": "delete"
        },
        {
          "args": {
            "description": "Gist ID or URL",
            "name": "gist"
          },
          "description": "Edit one of your gists",
          "name": "edit",
          "options": [
            {
              "args": {
                "name": "filename",
                "template": "filepaths"
              },
              "description": "Add a new file to the gist",
              "name": [
                "-a",
                "--add"
              ]
            },
            {
              "description": "Select a file to edit",
              "name": [
                "-f",
                "--filename"
              ]
            }
          ]
        },
        {
          "description": "List your gists",
          "name": "list",
          "options": [
            {
              "args": {
                "name": "int"
              },
              "description": "Maximum number of gists to fetch (default 10)",
              "name": [
                "-L",
                "--limit"
              ]
            },
            {
              "description": "Show only public gists",
              "name": [
                "--public"
              ]
            },
            {
              "description": "Show only secret gists",
              "name": [
                "--secret"
              ]
            }
          ]
        },
        {
          "args": {
            "description": "Gist ID or URL",
            "name": "gist"
          },
          "description": "View a gist",
          "name": "view",
          "options": [
            {
              "description": "Display a single file from the gist",
              "name": [
                "-f",
                "--filename"
              ]
            },
            {
              "description": "List file names from the gist",
              "name": [
                "--files"
              ]
            },
            {
              "description": "Print raw instead of rendered gist contents",
              "name": [
                "-r",
                "--raw"
              ]
            },
            {
              "description": "Open gist in the browser",
              "name": [
                "-w",
                "--web"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Manage issues",
