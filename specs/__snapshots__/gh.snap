          "name": "close",
          "options": [
            {
              "args": {
                "name": "repo"
              },
              "description": "Select another repository using the [HOST/]OWNER/REPO format",
              "name": [
                "-R",
                "--repo"
              ]
            }
          ]
        },
        {
          "args": {
            "description": "Number or URL",
            "name": "issue"
          },
