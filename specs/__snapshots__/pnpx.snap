{
  "description": "Execute binaries from npm packages",
  "name": "pnpx",
  "options": [
    {
      "args": {
        "name": "package"
      },
      "description": "Package to be executed",
      "name": [
        "--package",
        "-p"
      ]
    },
    {
      "args": {
        "name": "path",
        "template": "filepaths"
      },
      "description": "Location of the npm cache",
      "name": [
        "--cache"
      ]
    },
    {
      "description": "Always spawn a child process to execute the command",
      "name": [
        "--always-spawn"
      ]
    },
    {
      "description": "Skip installation if a package is missing",
      "name": [
        "--no-install"
      ]
    },
    {
      "args": {
        "name": "path",
        "template": "filepaths"
      },
      "description": "Path to user npmrc",
      "name": [
        "--userconfig"
      ]
    },
    {
      "args": {
        "name": "script"
      },
      "description": "Execute string as if inside `npm run-script`",
      "name": [
        "--call",
        "-c"
      ]
    },
    {
      "args": {
        "name": "shell",
        "suggestions": [
          {
            "name": "bash"
          },
          {
            "name": "fish"
          },
          {
            "name": "zsh"
          }
        ]
      },
      "description": "Shell to execute the command with, if any",
      "name": [
        "--shell",
        "-s"
      ]
    },
    {
      "args": {
        "name": "shell-fallback",
        "suggestions": [
          {
            "name": "bash"
          },
          {
            "name": "fish"
          },
          {
            "name": "zsh"
          }
        ]
      },
      "description": "Generate shell code to use pnpx as the \"command not found\" fallback",
      "name": [
        "--shell-auto-fallback"
      ]
    },
    {
      "description": "Ignores existing binaries in $PATH, or in the localproject. This forces pnpx to do a temporary install and use the latest version",
      "name": [
        "--ignore-existing"
      ]
    },
    {
      "description": "Suppress output from pnpx itself. Subcommands will not be affected",
      "name": [
        "--quiet",
        "-q"
      ]
    },
    {
      "args": {
        "name": "path to binary",
        "template": "filepaths"
      },
      "description": "Npm binary to use for internal operations",
      "name": [
        "--npm"
      ]
    },
    {
      "args": {},
      "description": "Extra node argument when calling a node binary",
      "name": [
        "--node-arg",
        "-n"
      ]
    },
    {
      "description": "Show version number",
      "name": [
        "--version",
        "-v"
      ]
    },
    {
      "description": "Show help",
      "name": [
        "--help",
        "-h"
      ]
    }
  ],
  "subcommands": [
    {
      "args": {
        "name": "name",
        "template": "folders"
      },
      "name": "create-react-native-app",
      "options": [
        {
          "args": {
            "name": "template"
          },
          "description": "The name of a template from expo/examples or URL to a GitHub repo that contains an example",
          "name": [
            "--template"
          ]
        },
        {
          "args": {
            "name": "name"
          },
          "description": "The path inside of a GitHub repo where the example lives",
          "name": [
            "--template-path"
          ]
        },
        {
          "args": {
            "isOptional": true,
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Use the default options for creating a project",
          "name": [
            "--yes"
          ]
        },
        {
          "args": {
            "isOptional": true,
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Skip installing npm packages or CocoaPods",
          "name": [
            "--no-install"
          ]
        },
        {
          "args": {
            "isOptional": true,
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Use npm to install dependencies. (default when Yarn is not installed)",
          "name": [
            "--use-npm"
          ]
        },
        {
          "description": "Output usage information",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "description": "Output the version number",
          "name": [
            "-V",
            "--version"
          ]
        }
      ]
    },
    {
      "name": "react-native",
      "options": [
        {
          "description": "Print CLI version",
          "name": [
            "--version"
          ]
        },
        {
          "description": "Increase logging verbosity",
          "name": [
            "--verbose"
          ]
        },
        {
          "description": "Output usage information",
          "name": [
            "-h",
            "--help"
          ]
        }
      ],
      "subcommands": [
        {
          "description": "[EXPERIMENTAL] Diagnose and fix common Node.js, iOS, Android & React Native issues",
          "name": "doctor",
          "options": [
            {
              "description": "Attempt to fix all diagnosed issues",
              "name": [
                "--fix"
              ]
            },
            {
              "description": "Add healthchecks required to installations required for contributing to React Native",
              "name": [
                "--contributor"
              ]
            },
            {
              "description": "Output usage information",
              "name": [
                "-h",
                "--help"
              ]
            }
          ]
        },
        {
          "description": "Builds the javascript bundle for offline use",
          "name": "bundle",
          "options": [
            {
              "args": {
                "generators": [
                  {
                    "js_source": "(m,g,w)=>me(this,void 0,void 0,function*(){var p;let{isDangerous:b,currentWorkingDirectory:O,searchTerm:f}=w,x=(p=(0,v.getCurrentInsertedDirectory)(l??O,f,w))!==null&&p!==void 0?p:\"/\";try{let V=yield g({command:\"ls\",args:[\"-1ApL\"],cwd:x}),te=H(V.stdout.split(`\n`),[\".DS_Store\"]),B=[];for(let T of te)if(T){let P=T.endsWith(\"/\")?\"folders\":\"filepaths\";(P===\"filepaths\"&&u!==\"only\"||P===\"folders\"&&u!==\"never\")&&B.push({type:P===\"filepaths\"?\"file\":\"folder\",name:T,insertValue:T,isDangerous:b,context:{templateType:P}})}return S(h(B))}catch{return[]}})",
                    "requires_js": true
                  }
                ],
                "name": "file"
              },
              "description": "Path to the root JS file, either absolute or relative to JS root",
              "name": [
                "--entry-file"
              ]
            },
            {
              "args": {
                "name": "platform",
                "suggestions": [
                  {
                    "name": "android"
                  },
                  {
                    "name": "ios"
                  }
                ]
              },
              "description": "Either \"ios\" or \"android\" (default: \"ios\")",
              "name": [
                "--platform"
              ]
            },
            {
              "args": {
                "name": "transformer"
              },
              "description": "Specify a custom transformer to be used",
              "name": [
                "--transformer"
              ]
            },
            {
              "args": {
                "isOptional": true,
                "name": "boolean",
                "suggestions": [
                  {
                    "name": "true"
                  },
                  {
                    "name": "false"
                  }
                ]
              },
              "description": "If false, warnings are disabled and the bundle is minified (default: true)",
              "name": [
                "--dev"
              ]
            },
            {
              "args": {
                "isOptional": true,
                "name": "boolean",
                "suggestions": [
                  {
                    "name": "true"
                  },
                  {
                    "name": "false"
                  }
                ]
              },
              "description": "Allows overriding whether bundle is minified. This defaults to false if dev is true, and true if dev is false. Disabling minification can be useful for speeding up production builds for testing purposes",
              "name": [
                "--minify"
              ]
            },
            {
              "args": {
                "name": "bundle file"
              },
              "description": "File name where to store the resulting bundle, ex. /tmp/groups.bundle",
              "name": [
                "--bundle-output"
              ]
            },
            {
              "args": {
                "name": "encoding",
                "suggestions": [
                  {
                    "name": "utf8"
                  },
                  {
                    "name": "utf16le"
                  },
                  {
                    "name": "latin1"
                  }
                ]
              },
              "description": "Encoding the bundle should be written in (https://nodejs.org/api/buffer.html#buffer_buffer). (default: \"utf8\")",
              "name": [
                "--bundle-encoding"
              ]
            },
            {
              "args": {
                "generators": [
                  {
                    "js_source": "e=>Array.from({length:Number(e)},(n,t)=>({name:`${t}`}))",
                    "requires_js": true,
                    "script": [
                      "sysctl",
                      "-n",
                      "hw.ncpu"
                    ]
                  }
                ],
                "name": "Number of workers"
              },
              "description": "Specifies the maximum number of workers the worker-pool will spawn for transforming files. This defaults to the number of the cores available on your machine",
              "name": [
                "--max-workers"
              ]
            },
            {
              "args": {
                "name": "sourcemap-output"
              },
              "description": "File name where to store the sourcemap file for resulting bundle, ex. /tmp/groups.map",
              "name": [
                "--sourcemap-output"
              ]
            },
            {
              "args": {
                "name": "root",
                "template": "folders"
              },
              "description": "Path to make sourcemap's sources entries relative to, ex. /root/dir",
              "name": [
                "--sourcemap-sources-root"
              ]
            },
            {
              "description": "Report SourceMapURL using its full path",
              "name": [
                "--sourcemap-use-absolute-path"
              ]
            },
            {
              "args": {
                "name": "directory",
                "template": "folders"
              },
              "description": "Directory name where to store assets referenced in the bundle",
              "name": [
                "--assets-dest"
              ]
            },
            {
              "args": {
                "name": "transform-profile",
                "suggestions": [
                  {
                    "name": "hermes"
                  },
                  {
                    "name": "hermes-canary"
                  },
                  {
                    "name": "default"
                  }
                ]
              },
              "description": "Experimental, transform JS for a specific JS engine. Currently supported: hermes, hermes-canary, default",
              "name": [
                "--unstable-transform-profile"
              ]
            },
            {
              "description": "Removes cached files",
              "name": [
                "--reset-cache"
              ]
            },
            {
              "description": "Try to fetch transformed JS code from the global cache, if configured",
              "name": [
                "--read-global-cache"
              ]
            },
            {
              "args": {
                "name": "string",
                "template": "filepaths"
              },
              "description": "Path to the CLI configuration file",
              "name": [
                "--config"
              ]
            },
            {
              "description": "Output usage information",
              "name": [
                "-h",
                "--help"
              ]
            }
          ]
        },
        {
          "args": {
            "name": "projectName"
          },
          "description": "Initialize a new React Native project named <projectName> in a directory of the same name",
          "name": "init",
          "options": [
            {
              "args": {
                "name": "version"
              },
              "description": "Shortcut for `--template react-native@version`",
