{
  "description": "Pscale is a CLI library for communicating with PlanetScale's API",
  "name": "pscale",
  "options": [
    {
      "description": "Show help",
      "name": [
        "--help",
        "-h"
      ]
    },
    {
      "args": {
        "name": "string"
      },
      "description": "The API token to use for authenticating against the PlanetScale API",
      "name": [
        "--api-token"
      ]
    },
    {
      "args": {
        "name": "string"
      },
      "description": "The base URL for the PlanetScale API. (default \"https://api.planetscale.com/\")",
      "name": [
        "--api-url"
      ]
    },
    {
      "args": {
        "name": "string",
        "template": "filepaths"
      },
      "description": "Config file (default is $HOME/.config/planetscale/pscale.yml)",
      "name": [
        "--config"
      ]
    },
    {
      "description": "Enable debug mode",
      "name": [
        "--debug"
      ]
    },
    {
      "args": {
        "name": "string",
        "suggestions": [
          {
            "name": "human"
          },
          {
            "name": "json"
          },
          {
            "name": "csv"
          }
        ]
      },
      "description": "Show output in a specific format. Possible values: [human, json, csv] (default \"human\")",
      "name": [
        "--format",
        "-f"
      ]
    },
    {
      "description": "Disable color output",
      "name": [
        "--no-color"
      ]
    },
    {
      "args": {
        "name": "string"
      },
      "description": "Service Token for authenticating",
      "name": [
        "--service-token"
      ]
    },
    {
      "args": {
        "name": "string"
      },
      "description": "The Service Token name for authenticating",
      "name": [
        "--service-token-name"
      ]
    },
    {
      "description": "Show pscale version",
      "name": [
        "--version"
      ]
    }
  ],
  "subcommands": [
