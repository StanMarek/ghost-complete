          "name": [
            "--hostname",
            "-hostname"
          ]
        },
        {
          "args": {
            "name": "subdomain"
          },
          "description": "Host tunnel on a custom subdomain",
          "name": [
            "--subdomain",
            "-subdomain"
          ]
        },
        {
          "args": {
            "name": "user:password"
          },
          "description": "Enforce basic auth on tunnel endpoint, 'user:password'",
          "name": [
            "--auth",
            "-auth"
          ]
        },
        {
          "args": {
            "name": "true/false/both",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              },
              {
                "name": "both"
              }
            ]
          },
          "description": "Listen for http, https or both: true/false/both",
          "name": [
            "--bind-tls",
            "-bind-tls"
          ]
        },
        {
          "args": {
            "suggestions": [
              {
                "name": "rewrite"
              }
            ]
          },
