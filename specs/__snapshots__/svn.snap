{
  "description": "The first content tracker",
  "name": "svn",
  "options": [
    {
      "description": "Show help for svn",
      "name": [
        "--version"
      ]
    },
    {
      "description": "Show help for svn",
      "name": [
        "--verbose"
      ]
    },
    {
      "description": "Show help for svn",
      "name": [
        "--quiet"
      ]
    }
  ],
  "subcommands": [
    {
      "args": {
        "description": "Help about specific subcommand",
        "isOptional": true,
        "name": "subcommand",
        "suggestions": [
          {
            "name": "add"
          },
          {
            "name": "auth"
          },
          {
            "name": "blame"
          },
          {
            "name": "cat"
          },
          {
            "name": "changelist"
          },
          {
            "name": "checkout"
          },
          {
            "name": "cleanup"
          },
          {
            "name": "commit"
          },
          {
            "name": "copy"
          },
          {
            "name": "delete"
          },
          {
            "name": "diff"
          },
          {
            "name": "export"
          },
          {
            "name": "help"
          },
          {
            "name": "import"
          },
          {
            "name": "info"
          },
          {
            "name": "list"
          },
          {
            "name": "lock"
          },
          {
            "name": "log"
          },
          {
            "name": "merge"
          },
          {
            "name": "mergeinfo"
          },
          {
            "name": "mkdir"
          },
          {
            "name": "move"
          },
          {
            "name": "patch"
          },
          {
            "name": "propdel"
          },
          {
            "name": "propedit"
          },
          {
            "name": "propget"
          },
          {
            "name": "proplist"
          },
          {
            "name": "propset"
          },
          {
            "name": "relocate"
          },
          {
            "name": "resolve"
          },
          {
            "name": "resolved"
          },
          {
            "name": "revert"
          },
          {
            "name": "status"
          },
          {
            "name": "switch"
          },
          {
            "name": "unlock"
          },
          {
            "name": "update"
          },
          {
            "name": "upgrade"
          }
        ]
      },
      "description": "Show help for svn",
      "name": "help"
    },
    {
      "description": "Show the working tree status",
      "name": "status"
    },
    {
      "description": "Show information about a local or remote item",
      "name": "info"
    },
    {
      "args": {
        "description": "The repository you want to checkout",
        "name": "repository"
      },
      "description": "Check out a working copy from a repository",
      "name": "checkout"
    },
    {
      "description": "Commit to a repository",
      "name": "commit",
      "options": [
        {
          "args": {
            "name": "message"
          },
          "description": "Use the given message as the commit message",
          "name": [
            "-m",
            "--message"
          ]
        },
        {
          "args": {
            "name": "username"
          },
          "description": "Specify a username ARG",
          "name": [
            "--username"
          ]
        },
        {
          "args": {
            "name": "password"
          },
          "description": "Specify a password ARG",
          "name": [
            "--password"
          ]
        },
        {
          "description": "Read password from stdin",
          "name": [
            "--password-from-stdin"
          ]
        },
        {
          "description": "Do not cache authentication tokens",
          "name": [
            "--no-auth-cache"
          ]
        },
        {
          "description": "Do no interactive prompting (default is to prompt only if standard input is a terminal device)",
          "name": [
            "--non-interactive"
          ]
        },
        {
          "description": "Do interactive prompting even if standard input is not a terminal device",
          "name": [
            "--force-interactive"
          ]
        },
        {
          "args": {
            "name": "message"
          },
          "description": "Specify a password ARG",
          "name": [
            "--trust-server-cert"
          ]
        },
        {
          "args": {
            "name": "message"
          },
          "description": "Specify a password ARG",
          "name": [
            "--trust-server-cert-failures"
          ]
        },
        {
          "args": {
            "name": "message"
          },
          "description": "Read user configuration files from directory ARG",
          "name": [
            "--config-dir"
          ]
        },
        {
          "args": {
            "name": "message"
          },
          "description": "Specify a password ARG",
          "name": [
            "--config-option"
          ]
        }
      ]
    }
  ]
}
