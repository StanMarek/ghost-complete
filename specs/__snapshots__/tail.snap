{
  "args": {
    "isVariadic": true,
    "template": "filepaths"
  },
  "description": "Display the last part of a file",
  "name": "tail",
  "options": [
    {
      "description": "Wait for additional data to be appended",
      "name": [
        "-f"
      ]
    },
    {
      "description": "Display in reverse order",
      "name": [
        "-r"
      ],
      "priority": 70
    }
  ]
}
