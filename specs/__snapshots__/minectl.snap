{
  "description": "Create Minecraft Server on different cloud provider",
  "name": "minectl",
  "options": [
    {
      "description": "Set this value to if mincetl is called by a CI system. Enables logging and disables human-readable output rendering (default: false)",
      "name": [
        "--headless"
      ]
    },
    {
      "args": {
        "name": "log-encoding",
        "suggestions": [
          {
            "name": "console"
          },
          {
            "name": "json"
          }
        ]
      },
      "description": "Set the log encoding: console|json (default: console)",
      "name": [
        "--log-encoding"
      ]
    },
    {
      "args": {
        "name": "verbose",
        "suggestions": [
          {
            "name": "debug"
          },
          {
            "name": "info"
          },
          {
            "name": "warn"
          },
          {
            "name": "error"
          },
          {
            "name": "dpanic"
          },
          {
            "name": "panic"
          },
          {
            "name": "fatal"
          }
        ]
      },
      "description": "Enable verbose logging: debug|info|warn|error|dpanic|panic|fatal",
      "name": [
        "--verbose"
      ]
    },
    {
      "description": "Display help",
      "name": [
        "--help",
        "-h"
      ]
    }
  ],
  "subcommands": [
    {
      "description": "Generate the autocompletion script for the specified shell",
      "name": "completion",
      "subcommands": [
        {
          "description": "Generate the autocompletion script for bash",
          "name": "bash",
          "options": [
            {
              "description": "Disable completion descriptions",
              "name": [
                "--no-descriptions"
              ]
            }
          ]
        },
        {
          "description": "Generate the autocompletion script for fish",
          "name": "fish",
          "options": [
            {
              "description": "Disable completion descriptions",
              "name": [
                "--no-descriptions"
              ]
            }
          ]
        },
        {
          "description": "Generate the autocompletion script for powershell",
          "name": "powershell",
          "options": [
            {
              "description": "Disable completion descriptions",
              "name": [
                "--no-descriptions"
              ]
            }
          ]
        },
        {
          "description": "Generate the autocompletion script for zsh",
          "name": "zsh",
          "options": [
            {
              "description": "Disable completion descriptions",
              "name": [
                "--no-descriptions"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Create an Minecraft Server",
      "name": "create",
      "options": [
        {
          "args": {
            "name": "filename",
            "template": [
              "filepaths"
            ]
          },
          "description": "Location of the manifest file",
          "name": [
            "--filename",
            "-f"
          ]
        },
        {
          "description": "Wait for Minecraft Server is started",
          "name": [
            "--wait",
            "-w"
          ]
        }
      ]
    },
    {
      "description": "Delete an Minecraft Server",
      "name": "delete",
      "options": [
        {
          "args": {
            "name": "filename",
            "template": [
              "filepaths"
            ]
          },
          "description": "Location of the manifest file",
          "name": [
            "--filename",
            "-f"
          ]
        },
        {
          "args": {
            "name": "id"
          },
          "description": "Contains the server id",
          "name": [
            "--id"
          ]
        },
        {
          "description": "Automatically delete the server",
          "name": [
            "--yes",
            "-y"
          ]
        }
      ]
    },
    {
      "description": "List all Minecraft Server",
      "name": "list",
      "options": [
        {
          "args": {
            "name": "provider",
            "suggestions": [
              {
                "name": "civo"
              },
              {
                "name": "scaleway"
              },
              {
                "name": "do"
              },
              {
                "name": "hetzner"
              },
              {
                "name": "linode"
              },
              {
                "name": "ovh"
              },
              {
                "name": "equinix"
              },
              {
                "name": "gce"
              },
              {
                "name": "vultr"
              },
              {
                "name": "azure"
              },
              {
                "name": "oci"
              },
              {
                "name": "ionos"
              },
              {
                "name": "aws"
              },
              {
                "name": "vexxhost"
              },
              {
                "name": "multipass"
              },
              {
                "name": "exoscale"
              }
            ]
          },
          "description": "The cloud provider - civo|scaleway|do|hetzner|akamai|ovh|equinix|gce|vultr|azure|oci|ionos|aws|vexxhost|multipass|exoscale",
          "name": [
            "--provider",
            "-p"
          ]
        },
        {
          "args": {
            "name": "region"
          },
          "description": "The region (gce: zone) for your cloud provider - civo|gce",
          "name": [
            "--region",
            "-r"
          ]
        }
      ]
    },
    {
      "description": "Manage your plugins for a specific server",
      "name": "plugins",
      "options": [
        {
          "args": {
            "name": "destination",
            "template": [
              "folders"
            ]
          },
          "description": "Plugin destination folder",
          "name": [
            "--destination",
            "-d"
          ]
        },
        {
          "args": {
            "name": "filename",
            "template": [
              "filepaths"
            ]
          },
          "description": "Location of the manifest file",
          "name": [
            "--filename",
            "-f"
          ]
        },
        {
          "args": {
            "name": "id"
          },
          "description": "Contains the server id",
          "name": [
            "--id"
          ]
        },
        {
          "args": {
            "name": "plugin",
            "template": [
              "filepaths"
            ]
          },
          "description": "Location of the plugin",
          "name": [
            "--plugin",
            "-p"
          ]
        },
        {
          "args": {
            "name": "ssh-key"
          },
          "description": "Specify a specific path for the SSH key",
          "name": [
            "--ssh-key",
            "-k"
          ]
        }
      ]
    },
    {
      "description": "RCON client to your Minecraft server",
      "name": "rcon",
      "options": [
        {
          "args": {
            "name": "filename",
            "template": [
              "filepaths"
            ]
          },
          "description": "Location of the manifest file",
          "name": [
            "--filename",
            "-f"
          ]
        },
        {
          "args": {
            "name": "id"
          },
          "description": "Contains the server id",
          "name": [
            "--id"
          ]
        }
      ]
    },
    {
      "description": "Update an Minecraft Server",
      "name": "update",
      "options": [
        {
          "args": {
            "name": "filename",
            "template": [
              "filepaths"
            ]
          },
          "description": "Location of the manifest file",
          "name": [
            "--filename",
            "-f"
          ]
        },
        {
          "args": {
            "name": "id"
          },
          "description": "Contains the server id",
          "name": [
            "--id"
          ]
        },
        {
          "args": {
            "name": "ssh-key"
          },
          "description": "Specify a specific path for the SSH key",
          "name": [
            "--ssh-key",
            "-k"
          ]
        }
      ]
    },
    {
      "description": "Display the clients version information",
      "name": "version"
    },
    {
      "description": "Calls the minectl wizard to create interactively a minectl 🗺 config",
      "name": "wizard",
      "options": [
        {
          "args": {
            "name": "output",
            "template": [
              "folders"
            ]
          },
          "description": "Output folder for the configuration file for minectl 🗺 (default: ~/.minectl)",
          "name": [
            "--output",
            "-o"
          ]
        }
      ]
    },
    {
      "description": "Help about any command",
      "name": "help",
      "subcommands": [
        {
          "description": "Generate the autocompletion script for the specified shell",
          "name": "completion",
          "subcommands": [
            {
              "description": "Generate the autocompletion script for bash",
              "name": "bash"
            },
            {
              "description": "Generate the autocompletion script for fish",
              "name": "fish"
            },
            {
              "description": "Generate the autocompletion script for powershell",
              "name": "powershell"
            },
            {
              "description": "Generate the autocompletion script for zsh",
              "name": "zsh"
            }
          ]
        },
        {
          "description": "Create an Minecraft Server",
          "name": "create"
        },
        {
          "description": "Delete an Minecraft Server",
          "name": "delete"
        },
        {
          "description": "List all Minecraft Server",
          "name": "list"
        },
        {
          "description": "Manage your plugins for a specific server",
          "name": "plugins"
        },
        {
          "description": "RCON client to your Minecraft server",
          "name": "rcon"
        },
        {
          "description": "Update an Minecraft Server",
          "name": "update"
        },
        {
          "description": "Display the clients version information",
          "name": "version"
        },
        {
          "description": "Calls the minectl wizard to create interactively a minectl 🗺 config",
          "name": "wizard"
        }
      ]
    }
  ]
}
