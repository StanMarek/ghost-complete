{
  "description": "WP-CLI is the command-line interface for WordPress",
  "name": "wp",
  "subcommands": [
    {
      "description": "Adds, removes, fetches, and flushes the WP Object Cache object",
      "name": "cache",
      "options": [
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Path to the WordPress files",
          "name": [
            "--path"
          ]
        },
        {
          "args": {
            "name": "url"
          },
          "description": "Pretend request came from given URL. In multisite, this argument is how the target site is specified",
          "name": [
            "--url"
          ]
        },
        {
          "args": {
            "name": "options",
            "suggestions": [
              {
                "name": "scheme:"
              },
              {
                "name": "user@"
              },
              {
                "name": "host"
              },
              {
                "name": "container"
              },
              {
                "name": ":port"
              },
              {
                "name": "path"
              }
            ]
          },
          "description": "Perform operation against a remote server over SSH (or a container using scheme of “docker”, “docker-compose”, “vagrant”)",
          "name": [
            "--ssh"
          ]
        },
        {
          "args": {
            "name": "http"
          },
          "description": "Perform operation against a remote WordPress installation over HTTP",
          "name": [
            "--http"
          ]
        },
        {
          "args": {
            "name": "options",
            "suggestions": [
              {
                "name": "id"
              },
              {
                "name": "login"
              },
              {
                "name": "email"
              }
            ]
          },
          "description": "Set the WordPress user",
          "name": [
            "--user"
          ]
        },
        {
          "description": "Skip loading all plugins, or a comma-separated list of plugins. Note: mu-plugins are still loaded",
          "name": [
            "--skip-plugins"
          ]
        },
        {
          "args": {
            "name": "plugins"
          },
          "description": "Skip loading all plugins, or a comma-separated list of plugins. Note: mu-plugins are still loaded",
          "name": [
            "--skip-plugins"
          ]
        },
        {
          "description": "Skip loading all themes, or a comma-separated list of themes",
          "name": [
            "--skip-themes"
          ]
        },
        {
          "args": {
            "name": "themes"
          },
          "description": "Skip loading all themes, or a comma-separated list of themes",
          "name": [
            "--skip-themes"
          ]
        },
        {
          "description": "Skip loading all installed packages",
          "name": [
            "--skip-packages"
          ]
        },
        {
          "args": {
            "name": "path"
          },
          "description": "Load PHP file before running the command (may be used more than once)",
          "name": [
            "--require"
          ]
        },
        {
          "args": {
            "name": "php-code"
          },
          "description": "Execute PHP code before running the command (may be used more than once)",
          "name": [
            "--exec"
          ]
        },
        {
          "description": "Whether to colorize the output",
          "name": [
            "--color"
          ]
        },
        {
          "description": "Whether to colorize the output",
          "name": [
            "--no-color"
          ]
        },
        {
          "description": "Show all PHP errors and add verbosity to WP-CLI output. Built-in groups include: bootstrap, commandfactory, and help",
          "name": [
            "--debug"
          ]
        },
        {
          "args": {
            "name": "group"
          },
          "description": "Show all PHP errors and add verbosity to WP-CLI output. Built-in groups include: bootstrap, commandfactory, and help",
          "name": [
            "--debug"
          ]
        },
        {
          "description": "Prompt the user to enter values for all command arguments, or a subset specified as comma-separated values",
          "name": [
            "--prompt"
          ]
        },
        {
          "args": {
            "name": "assoc"
          },
          "description": "Prompt the user to enter values for all command arguments, or a subset specified as comma-separated values",
          "name": [
            "--prompt"
          ]
        },
        {
          "description": "Suppress informational messages",
          "name": [
            "--quiet"
          ]
        }
      ],
      "subcommands": [
        {
          "args": [
            {
              "description": "Cache key",
              "name": "key"
            },
            {
              "description": "Value to add to the key",
              "name": "value"
            },
            {
              "description": "Method for grouping data within the cache which allows the same key to be used across groups",
              "name": "group"
            },
            {
              "description": "Define how long to keep the value, in seconds. 0 means as long as possible",
              "name": "expiration"
            }
          ],
          "description": "Adds a value to the object cache",
          "name": "add"
        },
        {
          "args": [
            {
              "description": "Cache key",
              "name": "key"
            },
            {
              "description": "The amount by which to decrement the item’s value",
              "name": "offset"
            },
            {
              "description": "Method for grouping data within the cache which allows the same key to be used across groups",
              "name": "group"
            }
          ],
          "description": "Decrements a value in the object cache",
          "name": "decr"
        },
        {
          "args": [
            {
              "description": "Cache key",
              "name": "key"
            },
            {
              "description": "Method for grouping data within the cache which allows the same key to be used across groups",
              "name": "group"
            }
          ],
          "description": "Removes a value from the object cache",
          "name": "delete"
        },
        {
          "description": "Flushes the object cache",
          "name": "flush"
        },
        {
          "args": [
            {
              "description": "Cache key",
              "name": "key"
            },
            {
              "description": "Method for grouping data within the cache which allows the same key to be used across groups",
              "name": "group"
            }
          ],
          "description": "Gets a value from the object cache",
          "name": "get"
        },
        {
          "args": [
            {
              "description": "Cache key",
              "name": "key"
            },
            {
              "description": "The amount by which to increment the item’s value",
              "name": "offset"
            },
            {
              "description": "Method for grouping data within the cache which allows the same key to be used across groups",
              "name": "group"
            }
          ],
          "description": "Increments a value in the object cache",
          "name": "incr"
        },
        {
          "args": [
            {
              "description": "Cache key",
              "name": "key"
            },
            {
              "description": "Value to replace",
              "name": "value"
            },
            {
              "description": "Method for grouping data within the cache which allows the same key to be used across groups",
              "name": "group"
            },
            {
              "description": "Define how long to keep the value, in seconds. 0 means as long as possible",
              "name": "expiration"
            }
          ],
          "description": "Replaces a value in the object cache, if the value already exists",
          "name": "replace"
        },
        {
          "args": [
            {
              "description": "Cache key",
              "name": "key"
            },
            {
              "description": "Value to set on the key",
              "name": "value"
            },
            {
              "description": "Method for grouping data within the cache which allows the same key to be used across groups",
              "name": "group"
            },
            {
              "description": "Define how long to keep the value, in seconds. 0 means as long as possible",
              "name": "expiration"
            }
          ],
          "description": "Sets a value to the object cache, regardless of whether it already exists",
          "name": "set"
        },
        {
          "description": "Attempts to determine which object cache is being used",
          "name": "type"
        }
      ]
    },
