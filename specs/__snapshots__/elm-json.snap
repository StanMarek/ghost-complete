                "--compressed",
                "https://package.elm-lang.org/search.json"
              ]
            }
          ],
          "name": "PACKAGE"
        },
        {
          "description": "The elm.json file to upgrade [default: elm.json]",
          "generators": [
            {
              "js_source": "(p,m,b)=>ue(this,void 0,void 0,function*(){var f;let{isDangerous:_,currentWorkingDirectory:O,searchTerm:h}=b,j=(f=(0,v.getCurrentInsertedDirectory)(c??O,h,b))!==null&&f!==void 0?f:\"/\";try{let K=yield m({command:\"ls\",args:[\"-1ApL\"],cwd:j}),Z=R(K.stdout.split(`\n`),[\".DS_Store\"]),k=[];for(let V of Z)if(V){let F=V.endsWith(\"/\")?\"folders\":\"filepaths\";(F===\"filepaths\"&&u!==\"only\"||F===\"folders\"&&u!==\"never\")&&k.push({type:F===\"filepaths\"?\"file\":\"folder\",name:V,insertValue:V,isDangerous:_,context:{templateType:F}})}return w(g(k))}catch{return[]}})",
              "requires_js": true
            }
          ],
          "isOptional": true,
          "name": "-- INPUT"
        }
      ],
      "description": "Uninstall a package",
      "name": "uninstall",
      "options": [
        {
          "description": "Prints help information",
          "name": [
            "--help",
            "-h"
          ]
        },
        {
          "description": "Prints version information",
          "name": [
            "--version",
            "-V"
          ]
        },
        {
          "description": "Answer \"yes\" to all questions",
          "name": [
            "--yes"
          ]
        }
      ]
    },
    {
      "args": {
        "description": "The elm.json file to upgrade [default: elm.json]",
        "generators": [
          {
