{
  "description": "Deal with your elm.json",
  "name": "elm-json",
  "options": [
    {
      "description": "Prints help information",
      "name": [
        "--help",
        "-h"
      ]
    },
    {
      "description": "Enable offline mode, which means no HTTP traffic will happen",
      "name": [
        "--offline"
      ]
    },
    {
      "description": "Prints version information",
      "name": [
        "--version",
        "-V"
      ]
    },
    {
      "description": "Sets the level of verbosity",
      "name": [
        "--verbose",
        "-v"
      ]
    }
  ],
  "subcommands": [
    {
      "args": {
        "name": "subcommand",
        "template": "help"
      },
      "description": "Prints help information or the help of the given subcommand(s)",
      "name": "help"
    },
    {
      "args": [
        {
          "description": "Package to install, e.g. elm/core or elm/core@1.0.2 or elm/core@1",
          "generators": [
            {
              "cache": {
                "ttl_seconds": 259200
              },
              "js_source": "e=>JSON.parse(e).map(n=>({name:n.name,description:n.summary}))",
              "requires_js": true,
              "script": [
                "curl",
                "-sH",
                "accept-encoding: gzip",
                "--compressed",
                "https://package.elm-lang.org/search.json"
              ]
            }
          ],
          "name": "PACKAGE"
        },
        {
          "description": "The elm.json file to upgrade [default: elm.json]",
          "generators": [
            {
              "js_source": "(p,m,b)=>ue(this,void 0,void 0,function*(){var f;let{isDangerous:_,currentWorkingDirectory:O,searchTerm:h}=b,j=(f=(0,v.getCurrentInsertedDirectory)(c??O,h,b))!==null&&f!==void 0?f:\"/\";try{let K=yield m({command:\"ls\",args:[\"-1ApL\"],cwd:j}),Z=R(K.stdout.split(`\n`),[\".DS_Store\"]),k=[];for(let V of Z)if(V){let F=V.endsWith(\"/\")?\"folders\":\"filepaths\";(F===\"filepaths\"&&u!==\"only\"||F===\"folders\"&&u!==\"never\")&&k.push({type:F===\"filepaths\"?\"file\":\"folder\",name:V,insertValue:V,isDangerous:_,context:{templateType:F}})}return w(g(k))}catch{return[]}})",
              "requires_js": true
            }
          ],
          "isOptional": true,
          "name": "-- INPUT"
        }
      ],
      "description": "Install a package",
      "name": "install",
      "options": [
        {
          "description": "Prints help information",
          "name": [
            "--help",
            "-h"
          ]
        },
        {
          "description": "Install as a test-dependency",
          "name": [
            "--test"
          ]
        },
        {
          "description": "Prints version information",
          "name": [
            "--version",
            "-V"
          ]
        },
        {
          "description": "Answer \"yes\" to all questions",
          "name": [
            "--yes"
          ]
        }
      ]
    },
    {
      "description": "Create a new elm.json file",
      "name": "new",
      "options": [
        {
          "description": "Prints help information",
          "name": [
            "--help",
            "-h"
          ]
        },
        {
          "description": "Prints version information",
          "name": [
            "--version",
            "-V"
          ]
        }
      ]
    },
    {
      "args": [
        {
          "description": "Limit output to show path to some (indirect) dependency",
