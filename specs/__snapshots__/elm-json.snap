            "requires_js": true
          }
        ],
        "isOptional": true,
        "name": "INPUT"
      },
      "description": "Bring your dependencies up to date",
      "name": "upgrade",
      "options": [
        {
          "description": "Prints help information",
          "name": [
            "--help",
            "-h"
          ]
        },
        {
          "description": "Allow major versions bumps",
          "name": [
            "--unsafe"
