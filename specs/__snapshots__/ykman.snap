            {
              "description": "List enabled applications",
              "name": [
                "-l",
                "--list"
              ]
            },
            {
              "description": "Enable all applications",
              "name": [
                "-a",
                "--enable-all"
              ]
            },
            {
              "description": "Disable all applications",
              "name": [
                "-D",
                "--disable-all"
              ]
            },
            {
              "args": {
                "name": "HEX"
              },
              "description": "Current application configuration lock code",
              "name": [
                "-L",
                "--lock-code"
              ]
            },
            {
              "description": "When set, the button toggles the state of the smartcard between ejected and inserted (CCID mode only)",
              "name": [
                "--touch-eject"
              ]
            },
            {
              "description": "Disable touch eject (CCID only)",
              "name": [
                "--no-touch-eject"
              ]
            },
            {
              "args": {
                "name": "SECONDS"
              },
              "description": "When set, the smartcard will automatically eject after the given time. Implies --touch-eject",
              "name": [
                "--autoeject-timeout"
              ]
            },
            {
              "args": {
                "name": "SECONDS"
              },
              "description": "Sets the timeout when waiting for touch for challenge-response in the OTP application",
              "name": [
                "--chalresp-timeout"
              ]
            },
            {
              "description": "Show config usb usage information",
              "name": [
                "-h",
                "--help"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Manage the FIDO applications",
      "name": "fido",
      "options": [
        {
          "description": "Show fido usage information",
          "name": [
            "-h",
            "--help"
          ]
        }
      ],
      "subcommands": [
        {
          "description": "Display general status of the FIDO2 application",
          "name": "info",
          "options": [
            {
              "description": "Show fido info usage information",
              "name": [
                "-h",
                "--help"
              ]
            }
          ]
        },
        {
          "description": "Reset all FIDO applications. This action will wipe all FIDO credentials, including FIDO U2F credentials, on the YubiKey and remove the PIN code",
          "name": "reset",
          "options": [
            {
              "description": "Confirm the action without prompting",
              "name": [
                "-f",
                "--force"
              ]
            },
            {
              "description": "Show fido reset usage information",
              "name": [
                "-h",
                "--help"
              ]
            }
          ]
        },
        {
          "description": "Manage the PIN for FIDO",
          "name": "access",
          "options": [
            {
              "description": "Show fido access usage information",
              "name": [
                "-h",
                "--help"
              ]
            }
          ],
          "subcommands": [
            {
              "description": "Set or change PIN code",
              "name": "change-pin",
              "options": [
                {
                  "args": {
                    "name": "TEXT"
                  },
                  "description": "Current PIN code",
                  "name": [
                    "-P",
                    "--pin"
                  ]
                },
                {
                  "args": {
                    "name": "TEXT"
                  },
                  "description": "Current PIN code",
                  "name": [
                    "-n",
                    "--new-pin"
                  ]
                },
                {
                  "description": "Set FIDO U2F pin instead of FIDO2 PIN",
                  "name": [
                    "-u",
                    "--u2f"
                  ]
                },
                {
                  "description": "Show fido access change-pin usage information",
                  "name": [
                    "-h",
                    "--help"
                  ]
                }
              ]
            },
            {
              "description": "Verify the PIN against a YubiKey",
              "name": "verify-pin",
              "options": [
                {
                  "args": {
                    "name": "TEXT"
                  },
                  "description": "Current PIN code",
                  "name": [
                    "-P",
                    "--pin"
                  ]
                },
                {
                  "description": "Show fido access verify-pin usage information",
                  "name": [
                    "-h",
                    "--help"
                  ]
                }
              ]
            }
          ]
        },
        {
          "description": "Manage discoverable (resident) credentials. This command lets you manage credentials stored on your YubiKey. Credential management is only available when a FIDO PIN is set on the YubiKey",
          "name": "credentials",
          "options": [
            {
              "description": "Show fido credentials usage information",
              "name": [
                "-h",
                "--help"
              ]
            }
          ],
          "subcommands": [
            {
              "args": {
                "description": "A unique substring match of a credentials RP ID, user ID (hex) or name, or credential ID",
                "name": "QUERY"
              },
              "description": "Delete a credential",
              "name": "delete",
              "options": [
                {
                  "args": {
                    "name": "TEXT"
                  },
                  "description": "PIN code",
                  "name": [
                    "-P",
                    "--pin"
                  ]
                },
                {
                  "description": "Confirm deletion without prompting",
                  "name": [
                    "-f",
                    "--force"
                  ]
                },
                {
                  "description": "Show fido credentials delete usage information",
                  "name": [
                    "-h",
                    "--help"
                  ]
                }
              ]
            },
            {
              "description": "List credentials",
              "name": "list",
              "options": [
                {
                  "args": {
                    "name": "TEXT"
                  },
                  "description": "PIN code",
                  "name": [
                    "-P",
                    "--pin"
                  ]
                },
                {
                  "description": "Show fido credentials list usage information",
                  "name": [
                    "-h",
                    "--help"
                  ]
                }
              ]
            }
          ]
        },
        {
          "description": "Manage fingerprints",
          "name": "fingerprints",
          "options": [
            {
              "description": "Show fido fingerprints usage information",
              "name": [
                "-h",
                "--help"
              ]
            }
          ],
          "subcommands": [
            {
              "args": {
                "description": "A short readable name for the fingerprint (eg. \"Left thumb\")",
                "name": "NAME"
              },
              "description": "Add a new fingerprint",
              "name": "add",
              "options": [
                {
                  "args": {
                    "name": "TEXT"
                  },
                  "description": "PIN code",
                  "name": [
                    "-P",
                    "--pin"
                  ]
                },
                {
                  "description": "Show fido fingerprints add usage information",
                  "name": [
                    "-h",
                    "--help"
                  ]
                }
              ]
            },
            {
              "args": {
                "name": "ID"
              },
              "description": "Delete a fingerprint. Delete a fingerprint from the YubiKey by its ID, which can be seen by running the \"list\" subcommand",
              "name": "delete",
              "options": [
                {
                  "args": {
                    "name": "TEXT"
                  },
                  "description": "PIN code",
                  "name": [
                    "-P",
                    "--pin"
                  ]
                },
                {
                  "description": "Confirm deletion without prompting",
                  "name": [
                    "-f",
                    "--force"
                  ]
                },
                {
                  "description": "Show fido fingerprints delete usage information",
                  "name": [
                    "-h",
                    "--help"
                  ]
                }
              ]
            },
            {
              "description": "List registered fingerprint. Lists fingerprints by ID and (if available) label",
              "name": "list",
              "options": [
                {
                  "args": {
                    "name": "TEXT"
                  },
                  "description": "PIN code",
                  "name": [
                    "-P",
                    "--pin"
                  ]
                },
                {
                  "description": "Show fido fingerprints list usage information",
                  "name": [
                    "-h",
                    "--help"
                  ]
                }
              ]
            },
            {
              "args": [
                {
                  "description": "The ID of the fingerprint to rename (as shown in \"list\")",
                  "name": "ID"
                },
                {
                  "description": "A short readable name for the fingerprint (eg. \"Left thumb\")",
                  "name": "NAME"
                }
              ],
              "description": "Set the label for a fingerprint",
              "name": "rename",
              "options": [
                {
                  "args": {
                    "name": "TEXT"
                  },
                  "description": "PIN code",
                  "name": [
                    "-P",
                    "--pin"
                  ]
                },
                {
                  "description": "Show fido rename usage information",
                  "name": [
                    "-h",
                    "--help"
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Manage the OATH applications",
      "name": "oath",
      "options": [
        {
          "description": "Show oath usage information",
          "name": [
            "-h",
            "--help"
          ]
        }
      ],
      "subcommands": [
        {
          "description": "Display general status of OATH application",
          "name": "info",
          "options": [
            {
              "description": "Show oath info usage information",
              "name": [
                "-h",
                "--help"
              ]
            }
          ]
        },
        {
          "description": "Reset all OATH data. This action will delete all accounts and restore factory settings for the OATH application on the YubiKey",
          "name": "reset",
          "options": [
            {
              "description": "Show oath reset usage information",
              "name": [
                "-h",
                "--help"
              ]
            },
            {
              "description": "Confirm the action without prompting",
              "name": [
                "-f",
                "--force"
              ]
            }
          ]
        },
        {
          "description": "Manage password protection for OATH",
          "name": "access",
          "options": [
            {
              "description": "Show oath access usage information",
              "name": [
                "-h",
                "--help"
              ]
            }
          ],
          "subcommands": [
            {
              "description": "Change the password used to protect OATH accounts. Alows you to set or change a password that will be required to access the OATH accounts stored on the YubiKey",
              "name": "change",
              "options": [
                {
                  "args": {
                    "name": "TEXT"
                  },
                  "description": "Provide a password to unlock the YubiKey",
                  "name": [
                    "-p",
                    "--password"
                  ]
                },
                {
                  "description": "Clear the current password",
                  "name": [
                    "-c",
                    "--clear"
                  ]
                },
                {
                  "args": {
                    "name": "TEXT"
                  },
                  "description": "Provide a new password as an argument",
                  "name": [
                    "-n",
                    "--new-password"
                  ]
                },
                {
                  "description": "Show oath access change usage information",
                  "name": [
                    "-h",
                    "--help"
                  ]
                }
              ]
            },
            {
              "description": "Remove a stored password from this computer",
              "name": "forget",
              "options": [
                {
                  "description": "Remove all stored passwords",
                  "name": [
                    "-a",
                    "--all"
                  ]
                },
                {
                  "description": "Show oath forget usage information",
                  "name": [
                    "-h",
                    "--help"
                  ]
                }
              ]
            },
            {
              "description": "Store the YubiKeys password on this computer to avoid having to enter it on each use",
              "name": "remember",
              "options": [
                {
                  "args": {
                    "name": "TEXT"
                  },
                  "description": "Provide a password to unlock the YubiKey",
                  "name": [
                    "-P",
                    "--password"
                  ]
                },
                {
                  "description": "Show oath remember usage information",
                  "name": [
                    "-h",
                    "--help"
                  ]
                }
              ]
            }
          ]
        },
        {
          "description": "Manage and use OATH accounts",
          "name": "accounts",
          "options": [
            {
              "description": "Show oath accounts usage information",
              "name": [
                "-h",
                "--help"
              ]
            }
          ],
          "subcommands": [
            {
              "args": [
                {
                  "description": "Human readable name of the account, such as a username or e-mail address",
                  "name": "NAME"
                },
                {
                  "description": "Base32-encoded secret/key value provided by the server",
                  "isOptional": true,
                  "name": "SECRET"
                }
              ],
              "description": "Add a new account",
              "name": "add",
              "options": [
                {
                  "args": {
                    "name": "oath type",
                    "suggestions": [
                      {
                        "name": "HOTP"
                      },
                      {
                        "name": "TOTP"
                      }
                    ]
                  },
                  "description": "Time-based (TOTP) or counter-based (HOTP) account",
                  "name": [
                    "-o",
                    "--oath-type"
                  ]
                },
                {
                  "args": {
                    "name": "number of digits",
                    "suggestions": [
                      {
                        "name": "6"
                      },
                      {
                        "name": "7"
                      },
                      {
                        "name": "8"
                      }
                    ]
                  },
                  "description": "Number of digits in generated code",
                  "name": [
                    "-d",
                    "--digits"
                  ]
                },
                {
                  "args": {
                    "name": "algorithm",
                    "suggestions": [
                      {
                        "name": "SHA1"
                      },
                      {
                        "name": "SHA256"
                      },
                      {
                        "name": "SHA512"
                      }
                    ]
                  },
                  "description": "Algorithm to use for code generation",
                  "name": [
                    "-a",
                    "--algorithm"
                  ]
                },
                {
                  "args": {
                    "name": "INTEGER"
                  },
                  "description": "Initial counter value for HOTP accounts",
                  "name": [
                    "-c",
                    "--counter"
                  ]
                },
                {
                  "args": {
                    "name": "TEXT"
                  },
                  "description": "Issuer of the account",
                  "name": [
                    "-i",
                    "--issuer"
                  ]
                },
                {
                  "args": {
                    "name": "INTEGER"
                  },
                  "description": "Number of seconds a TOTP code is valid",
                  "name": [
                    "-P",
                    "--period"
                  ]
                },
                {
                  "description": "Require touch on YubiKey to generate code",
                  "name": [
                    "-t",
