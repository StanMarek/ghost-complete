{
  "description": "Configure your YubiKey via the command line",
  "name": "ykman",
  "options": [
    {
      "args": {
        "generators": [
          {
            "script": [
              "bash",
              "-c",
              "ykman list | sed -rn 's/.*Serial: (.*)/\\1/p'"
            ],
            "transforms": [
              "split_lines",
              "filter_empty"
            ]
          }
        ],
        "name": "SERIAL"
      },
      "description": "Specify which YubiKey to interact with by serial number",
      "name": [
        "-d",
        "--device"
      ]
    },
    {
      "args": {
        "generators": [
          {
            "script": [
              "ykman",
              "list",
              "--readers"
            ],
            "transforms": [
              "split_lines",
              "filter_empty"
            ]
          }
        ],
        "name": "NAME"
      },
      "description": "Use an exteral smart card reader. Conflicts with --device and list",
      "name": [
        "-r",
        "--reader"
      ]
    },
    {
      "args": {
        "name": "log level",
        "suggestions": [
          {
            "name": "DEBUG"
          },
          {
            "name": "INFO"
          },
          {
            "name": "WARNING"
          },
          {
            "name": "ERROR"
          },
          {
            "name": "CRITICAL"
          }
        ]
      },
      "description": "Enable logging at given verbosity level",
      "name": [
        "-l",
        "--log-level"
      ]
    },
    {
      "args": {
        "name": "FILE",
        "template": "filepaths"
      },
      "description": "Write logs to the given FILE instead of standard error; ignore unless --log-level is also set",
      "name": [
        "--log-file"
      ]
    },
    {
      "description": "Show diagnostics information useful for troubleshooting",
      "name": [
        "--diagnose"
      ]
    },
    {
      "description": "Show version information about the app",
      "name": [
        "-v",
        "--version"
      ]
    },
    {
      "description": "Show --help, including hidden commands, and exit",
      "name": [
        "--full-help"
      ]
    },
    {
      "description": "Show usage information",
      "name": [
        "-h",
        "--help"
      ]
    }
  ],
  "subcommands": [
    {
      "description": "Displays information about the attached YubiKey such as serial number, firmware version, capabilities, etc",
      "name": "info",
      "options": [
        {
          "description": "Check if YubiKey is in FIPS Approved mode (available on YubiKey 4 FIPS only)",
          "name": [
            "-c",
            "--check-fips"
          ]
        },
        {
          "description": "Show info usage information",
          "name": [
            "-h",
            "--help"
          ]
        }
      ]
    },
    {
      "description": "List connected YubiKeys",
      "name": "list",
      "options": [
        {
          "description": "Output only serial numbers, one per line (devices without serial will be omitted)",
          "name": [
            "-s",
            "--serials"
          ]
        },
        {
          "description": "List available smart card readers",
          "name": [
            "-r",
            "--readers"
          ]
        },
        {
          "description": "Show list usage information",
          "name": [
            "-h",
            "--help"
          ]
        }
      ]
    },
    {
      "description": "Enable or disable applications",
      "name": "config",
      "options": [
        {
          "description": "Show config usage information",
          "name": [
            "-h",
            "--help"
          ]
        }
      ],
      "subcommands": [
        {
          "args": {
            "description": "MODE can be a string, such as 'OTP+FIDO+CCID', or a shortened form: 'o+f+c'. It can also be a mode number",
            "generators": [
              {
                "js_source": "async(e,n)=>{let s=e[e.length-1].split(\"+\"),o=new Map([[\"OTP\",[\"o\"]],[\"o\",[\"OTP\"]],[\"FIDO\",[\"f\"]],[\"f\",[\"FIDO\"]],[\"CCID\",[\"c\"]],[\"c\",[\"CCID\"]]]),t=new Set([...o.values()].flat());for(let i of s){t.delete(i);let a=o.get(i);a&&a.forEach(r=>{t.delete(r)})}return[...t].map(i=>({name:i}))}",
                "requires_js": true
              }
            ],
            "name": "MODE"
          },
          "description": "Manage connection modes (USB Interfaces)",
          "name": "mode",
          "options": [
            {
              "description": "When set, the button toggles the state of the smartcard between ejected and inserted (CCID mode only)",
              "name": [
                "--touch-eject"
              ]
            },
            {
              "args": {
                "name": "SECONDS"
              },
              "description": "When set, the button toggles the state of the smartcard between ejected and inserted (CCID mode only)",
              "name": [
                "--autoeject-timeout"
              ]
            },
            {
              "args": {
                "name": "SECONDS"
              },
              "description": "When set, the smartcard will automatically eject after the given time. Implies --touch-eject (CCID mode only)",
              "name": [
                "--chalresp-timeout"
              ]
            },
            {
              "description": "Confirm the action without prompting",
              "name": [
                "-f",
                "--force"
              ]
            },
            {
              "description": "Show config mode usage information",
              "name": [
                "-h",
                "--help"
              ]
            }
          ]
        },
        {
          "description": "Enable or disable applications over NFC",
          "name": "nfc",
          "options": [
            {
              "description": "Confirm the action without prompting",
              "name": [
                "-f",
                "--force"
              ]
            },
            {
              "args": {
                "name": "application",
                "suggestions": [
                  {
                    "name": "OTP"
                  },
                  {
                    "name": "U2F"
                  },
                  {
                    "name": "FIDO2"
                  },
                  {
                    "name": "OATH"
                  },
                  {
                    "name": "PIV"
                  },
                  {
                    "name": "OPENPGP"
                  },
                  {
                    "name": "HSMAUTH"
                  }
                ]
              },
              "description": "Enable applications",
              "name": [
                "-e",
                "--enable"
              ]
            },
            {
              "args": {
