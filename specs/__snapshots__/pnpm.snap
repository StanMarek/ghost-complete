            "suggestions": [
              {
                "name": "silent"
              },
              {
                "name": "default"
              },
              {
                "name": "append-only"
              },
              {
                "name": "ndjson"
              }
            ]
          },
          "description": "Allows you to choose the reporter that will log debug info to the terminal about the installation progress",
          "name": [
            "--reporter"
          ]
        },
        {
          "description": "Install the specified packages as regular dependencies",
          "name": [
            "-P",
            "--save-prod"
          ]
        },
        {
