    {
      "args": {
        "isOptional": true,
        "name": "command options"
      },
      "description": "Use Cloudflare Tunnel to expose private services to the Internet or to Cloudflare connected private users",
      "name": "tunnel",
      "options": [
        {
          "args": {
            "description": "Config file",
            "generators": [
              {
                "js_source": "(f,g,N)=>ue(this,void 0,void 0,function*(){var p;let{isDangerous:T,currentWorkingDirectory:E,searchTerm:m}=N,w=(p=(0,y.getCurrentInsertedDirectory)(d??E,m,N))!==null&&p!==void 0?p:\"/\";try{let F=yield g({command:\"ls\",args:[\"-1ApL\"],cwd:w}),Q=H(F.stdout.split(`\n`),[\".DS_Store\"]),V=[];for(let I of Q)if(I){let A=I.endsWith(\"/\")?\"folders\":\"filepaths\";(A===\"filepaths\"&&u!==\"only\"||A===\"folders\"&&u!==\"never\")&&V.push({type:A===\"filepaths\"?\"file\":\"folder\",name:I,insertValue:I,isDangerous:T,context:{templateType:A}})}return L(h(V))}catch{return[]}})",
                "requires_js": true
              }
            ],
            "name": "value"
          },
          "description": "Specifies a config file in YAML format. (default: \"/usr/local/etc/cloudflared/config.yml\")",
          "name": [
            "--config"
          ]
        },
        {
          "args": {
            "description": "Certificate path",
            "name": "value",
            "template": "filepaths"
          },
          "description": "Path to the certificate generated for your origin when you run cloudflared login. [$TUNNEL_ORIGIN_CERT]",
          "name": [
            "--origincert"
          ]
        },
        {
          "args": {
            "description": "Frequency",
            "name": "value"
          },
          "description": "Autoupdate frequency. Default is 24h0m0s. (default: 24h0m0s)",
          "name": [
            "--autoupdate-freq"
          ]
        },
        {
          "description": "Disable periodic check for updates, restarting the server with the new version. (default: false) [$NO_AUTOUPDATE]",
          "name": [
            "--no-autoupdate"
          ]
        },
        {
          "args": {
            "description": "Address",
            "name": "value"
          },
          "description": "Listen address for metrics reporting. (default: \"localhost:\") [$TUNNEL_METRICS]",
          "name": [
            "--metrics"
          ]
        },
        {
          "args": {
            "description": "PID",
            "name": "value"
          },
          "description": "Write the application's PID to this file after first successful connection. [$TUNNEL_PIDFILE]",
          "name": [
            "--pidfile"
          ]
        },
        {
          "args": {
            "description": "Url",
            "name": "URL"
          },
          "description": "Connect to the local webserver at URL. (default: \"http://localhost:8080\") [$TUNNEL_URL]",
          "name": [
            "--url"
          ]
        },
        {
          "description": "Run Hello World Server (default: false) [$TUNNEL_HELLO_WORLD]",
          "name": [
            "--hello-world"
          ]
        },
        {
          "description": "Specify if this tunnel is running as a SOCK5 Server This flag only takes effect if you define your origin with --url and if you do not use ingress rules. The recommended way is to rely on ingress rules and define this property under `originRequest` as per https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/configuration/configuration-file/ingress (default: false) [$TUNNEL_SOCKS]",
          "name": [
            "--socks5"
          ]
        },
        {
          "description": "HTTP proxy timeout for establishing a new connection This flag only takes effect if you define your origin with --url and if you do not use ingress rules. The recommended way is to rely on ingress rules and define this property under `originRequest` as per https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/configuration/configuration-file/ingress (default: 30s)",
          "name": [
            "--proxy-connect-timeout"
          ]
        },
        {
          "description": "HTTP proxy timeout for completing a TLS handshake This flag only takes effect if you define your origin with --url and if you do not use ingress rules. The recommended way is to rely on ingress rules and define this property under `originRequest` as per https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/configuration/configuration-file/ingress (default: 10s)",
          "name": [
            "--proxy-tls-timeout"
          ]
        },
        {
          "description": "HTTP proxy TCP keepalive duration This flag only takes effect if you define your origin with --url and if you do not use ingress rules. The recommended way is to rely on ingress rules and define this property under `originRequest` as per https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/configuration/configuration-file/ingress (default: 30s)",
          "name": [
            "--proxy-tcp-keepalive"
          ]
        },
        {
          "description": "HTTP proxy should disable \"happy eyeballs\" for IPv4/v6 fallback This flag only takes effect if you define your origin with --url and if you do not use ingress rules. The recommended way is to rely on ingress rules and define this property under `originRequest` as per https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/configuration/configuration-file/ingress (default: false)",
          "name": [
            "--proxy-no-happy-eyeballs"
          ]
        },
        {
          "description": "HTTP proxy maximum keepalive connection pool size This flag only takes effect if you define your origin with --url and if you do not use ingress rules. The recommended way is to rely on ingress rules and define this property under `originRequest` as per https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/configuration/configuration-file/ingress (default: 100)",
          "name": [
            "--proxy-keepalive-connections"
          ]
        },
        {
          "description": "HTTP proxy timeout for closing an idle connection This flag only takes effect if you define your origin with --url and if you do not use ingress rules. The recommended way is to rely on ingress rules and define this property under `originRequest` as per https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/configuration/configuration-file/ingress (default: 1m30s)",
          "name": [
            "--proxy-keepalive-timeout"
          ]
        },
        {
          "description": "DEPRECATED. No longer has any effect. (default: 1m30s)",
          "name": [
            "--proxy-connection-timeout"
          ]
        },
        {
          "description": "DEPRECATED. No longer has any effect. (default: 1m30s)",
          "name": [
            "--proxy-expect-continue-timeout"
          ]
        },
        {
          "description": "Sets the HTTP Host header for the local webserver. This flag only takes effect if you define your origin with --url and if you do not use ingress rules. The recommended way is to rely on ingress rules and define this property under `originRequest` as per https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/configuration/configuration-file/ingress [$TUNNEL_HTTP_HOST_HEADER]",
          "name": [
            "--http-host-header"
          ]
        },
        {
          "description": "Hostname on the origin server certificate. This flag only takes effect if you define your origin with --url and if you do not use ingress rules. The recommended way is to rely on ingress rules and define this property under `originRequest` as per https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/configuration/configuration-file/ingress [$TUNNEL_ORIGIN_SERVER_NAME]",
          "name": [
            "--origin-server-name"
          ]
        },
        {
          "args": {
            "description": "Unix socket",
            "name": "value",
            "template": "filepaths"
          },
          "description": "Path to unix socket to use instead of --url [$TUNNEL_UNIX_SOCKET]",
          "name": [
            "--unix-socket"
          ]
        },
        {
