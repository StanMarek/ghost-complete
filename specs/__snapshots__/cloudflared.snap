{
  "description": "Cloudflared connects your machine or user identity to Cloudflare's global network",
  "name": "cloudflared",
  "options": [
    {
      "args": {
        "description": "Credentials path",
        "name": "value",
        "template": "filepaths"
      },
      "description": "Filepath at which to read/write the tunnel credentials [$TUNNEL_CRED_FILE]",
      "name": [
        "--credentials-file",
        "--cred-file"
      ]
    },
    {
      "args": {
        "description": "Region",
        "name": "value"
      },
      "description": "Cloudflare Edge region to connect to. Omit or set to empty to connect to the global region. [$TUNNEL_REGION]",
      "name": [
        "--region"
      ]
    },
    {
      "description": "Overwrites existing DNS records with this hostname (default: false) [$TUNNEL_FORCE_PROVISIONING_DNS]",
      "name": [
        "--overwrite-dns",
        "-f"
      ]
    },
    {
      "description": "Show help for cloudflared",
      "name": [
        "--help",
        "-h"
      ]
    }
  ],
  "subcommands": [
    {
      "args": {
        "isOptional": true,
        "isVariadic": true,
        "name": "arguments"
      },
      "description": "Update the agent if a new version exists",
      "name": "update",
      "options": [
        {
          "description": "Specify if you wish to update to the latest beta version (default: false)",
          "name": [
            "--beta"
          ]
        },
        {
          "args": {
            "name": "value"
          },
          "description": "Specify a version you wish to upgrade or downgrade to",
          "name": [
            "--version"
          ]
        }
      ]
    },
    {
      "args": {
        "isOptional": true,
        "isVariadic": true,
        "name": "arguments"
      },
      "description": "Print the version",
      "name": "version"
    },
    {
      "args": {
        "isOptional": true,
        "name": "command options"
      },
      "description": "Run a DNS over HTTPS proxy server",
      "name": "proxy-dns",
      "options": [
        {
          "args": {
            "name": "value"
          },
          "description": "Listen address for metrics reporting. (default: \"localhost:\") [$TUNNEL_METRICS]",
          "name": [
            "--metrics"
          ]
        },
        {
          "args": {
            "name": "value"
          },
          "description": "Listen address for the DNS over HTTPS proxy server. (default: \"localhost\") [$TUNNEL_DNS_ADDRESS]",
          "name": [
            "--address"
          ]
        },
        {
          "args": {
            "name": "value"
          },
          "description": "Listen on given port for the DNS over HTTPS proxy server. (default: 53) [$TUNNEL_DNS_PORT]",
          "name": [
            "--port"
          ]
        },
        {
          "args": {
            "isVariadic": true,
            "name": "value"
          },
          "description": "Upstream endpoint URL, you can specify multiple endpoints for redundancy. (default: \"https://1.1.1.1/dns-query\", \"https://1.0.0.1/dns-query\") (accepts multiple inputs) [$TUNNEL_DNS_UPSTREAM]",
          "name": [
            "--upstream"
          ]
        },
        {
          "args": {
            "isVariadic": true,
            "name": "value"
          },
          "description": "Bootstrap endpoint URL, you can specify multiple endpoints for redundancy. (default: \"https://162.159.36.1/dns-query\", \"https://162.159.46.1/dns-query\", \"https://[2606:4700:4700::1111]/dns-query\", \"https://[2606:4700:4700::1001]/dns-query\")  (accepts multiple inputs) [$TUNNEL_DNS_BOOTSTRAP]",
          "name": [
            "--bootstrap"
          ]
        },
        {
          "args": {
            "isVariadic": true,
            "name": "value"
          },
          "description": "Maximum concurrent connections to upstream. Setting to 0 means unlimited. (default: 5) [$TUNNEL_DNS_MAX_UPSTREAM_CONNS]",
          "name": [
            "--max-upstream-conns"
          ]
        }
      ]
    },
    {
      "args": [
        {
          "isOptional": true,
          "name": "command options"
        },
        {
          "isOptional": true,
          "isVariadic": true,
          "name": "arguments"
        }
      ],
      "description": "Manages the cloudflared launch agent",
      "name": "service",
      "subcommands": [
        {
          "description": "Install cloudflared as an user launch agent",
          "name": "install"
        },
        {
          "description": "Uninstall the cloudflared launch agent",
          "name": "uninstall"
        },
        {
          "description": "Shows a list of commands or help for one command",
          "name": "help"
        }
      ]
    },
    {
      "description": "Shows a list of commands or help for one command",
      "name": "help"
    },
    {
      "args": [
        {
          "isOptional": true,
          "name": "command options"
        },
        {
          "isOptional": true,
          "isVariadic": true,
          "name": "arguments"
        }
      ],
      "description": "Cloudflare Access protects internal resources by securing, authenticating and monitoring access per-user and by application. With Cloudflare Access, only authenticated users with the required permissions are able to reach sensitive resources. The commands provided here allow you to interact with Access protected applications from the command line",
      "name": "access",
      "subcommands": [
        {
          "args": {
            "name": "url"
          },
          "description": "The login subcommand initiates an authentication flow with your identity provider. The subcommand will launch a browser. For headless systems, a url is provided. Once authenticated with your identity provider, the login command will generate a JSON Web Token (JWT) scoped to your identity, the application you intend to reach, and valid for a session duration set by your administrator. cloudflared stores the token in local storage",
          "name": "login"
        },
        {
          "args": [
            {
              "name": "url"
            },
            {
              "isVariadic": true,
              "name": "curl args"
            }
          ],
          "description": "Uninstall the cloudflared launch agent",
          "name": "curl",
          "options": [
            {
              "name": [
                "--allow-request",
                "--ar"
              ]
            }
          ]
        },
        {
          "description": "The token subcommand produces a JWT which can be used to authenticate requests",
          "name": "token",
          "options": [
            {
              "args": {
                "description": "Url of access application",
                "name": "value"
              },
              "name": [
                "--app"
              ]
            }
          ]
        },
        {
          "description": "The tcp subcommand sends data over a proxy to the Cloudflare edge",
          "name": "tcp",
          "options": [
            {
              "args": {
                "description": "Hostname",
                "name": "value"
              },
              "description": "Specify the hostname of your application",
              "name": [
                "--hostname",
                "--tunnel-host",
                "-T"
              ]
            },
            {
              "args": {
                "description": "Address of SSH server",
                "name": "value"
              },
              "description": "Specify the destination address of your SSH server",
              "name": [
                "--destination"
              ]
            },
            {
              "args": {
                "description": "Host:port to forward data to Cloudflare edge",
                "name": "value"
              },
              "description": "Specify the host:port to forward data to Cloudflare edge",
              "name": [
                "--url",
                "--listener",
                "-L"
              ]
            },
            {
              "args": {
                "description": "Access service token ID",
                "name": "value"
              },
              "description": "Specify an Access service token ID you wish to use. [$TUNNEL_SERVICE_TOKEN_ID]",
              "name": [
                "--service-token-id",
                "--id"
              ]
            },
            {
              "args": {
                "description": "Access service token secret",
                "name": "value"
              },
              "description": "Specify an Access service token secret you wish to use. [$TUNNEL_SERVICE_TOKEN_SECRET]",
              "name": [
                "--service-token-secret",
                "--secret"
              ]
            },
            {
              "args": {
                "description": "Directory",
                "name": "value",
                "template": [
                  "folders"
                ]
              },
              "description": "Save application log to this directory for reporting issues",
              "name": [
                "--log-directory",
                "--logfile"
              ]
            },
            {
              "args": {
                "description": "Directory",
                "name": "value",
                "suggestions": [
                  {
                    "name": "debug"
                  },
                  {
                    "name": "info"
                  },
                  {
                    "name": "warn"
                  },
                  {
                    "name": "error"
                  },
                  {
                    "name": "fatal"
                  }
                ]
              },
              "description": "Application logging level {debug, info, warn, error, fatal}",
              "name": [
                "--log-level",
                "--loglevel"
              ]
            }
          ]
        },
        {
          "description": "The rdp subcommand sends data over a proxy to the Cloudflare edge",
          "name": "rdp",
          "options": [
            {
              "args": {
