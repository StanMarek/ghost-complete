{
  "description": "Tools for creating, running, and deploying Universal Expo and React Native apps",
  "name": "expo",
  "options": [
    {
      "description": "Output usage information",
      "name": [
        "-h",
        "--help"
      ]
    },
    {
      "description": "Output the version number",
      "name": [
        "-V",
        "--version"
      ]
    }
  ],
  "subcommands": [
    {
      "description": "Login to an Expo account",
      "name": "login",
      "options": [
        {
          "description": "Output usage information",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "args": {
            "isOptional": true,
            "name": "string"
          },
          "description": "Username",
          "name": [
            "-u",
            "--username"
          ]
        },
        {
          "args": {
            "isOptional": true,
            "name": "string"
          },
          "description": "Password",
          "name": [
            "-p",
            "--password"
          ]
        },
        {
          "args": {
            "isOptional": true,
            "name": "string"
          },
          "description": "One-time password from your 2FA device",
          "name": [
            "--otp"
          ]
        }
      ]
    },
    {
      "description": "Logout of an Expo account",
      "name": "logout",
      "options": [
        {
          "description": "Output usage information",
          "name": [
            "-h",
            "--help"
          ]
        }
      ]
    },
    {
      "description": "Sign up for a new Expo account",
      "name": "register",
      "options": [
        {
          "description": "Output usage information",
          "name": [
            "-h",
            "--help"
          ]
        }
      ]
    },
    {
      "description": "Return the currently authenticated account",
      "name": "whoami",
      "options": [
        {
          "description": "Output usage information",
          "name": [
            "-h",
            "--help"
          ]
        }
      ]
    },
    {
      "args": {
        "isOptional": true,
        "name": "path",
        "template": "folders"
      },
      "description": "Build and sign a standalone IPA for the Apple App Store",
      "name": "build:ios",
      "options": [
        {
          "description": "Output usage information",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Clear all credentials stored on Expo servers",
          "name": [
            "-c",
            "--clear-credentials"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Remove Distribution Certificate stored on Expo servers",
          "name": [
            "--clear-dist-cert"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Remove Push Notifications Key stored on Expo servers",
          "name": [
            "--clear-push-key"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Remove Push Notifications Certificate stored on Expo servers. Use of Push Notifications Certificates is deprecated",
          "name": [
            "--clear-push-cert"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Remove Provisioning Profile stored on Expo servers",
          "name": [
            "--clear-provisioning-profile"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Revoke credentials on developer.apple.com, select appropriate using --clear-* options",
          "name": [
            "-r",
            "--revoke-credentials"
          ]
        },
        {
          "args": {
            "name": "login"
          },
          "description": "Apple ID username (please also set the Apple ID password as EXPO_APPLE_PASSWORD environment variable)",
          "name": [
            "--apple-id"
          ]
        },
        {
          "args": {
            "name": "archive|simulator",
            "suggestions": [
              {
                "name": "archive"
              },
              {
                "name": "simulator"
              }
            ]
          },
          "description": "Type of build: [archive|simulator]",
          "name": [
            "-t",
            "--type"
          ]
        },
        {
          "args": {
            "name": "name"
          },
          "description": "Pull from specified release channel",
          "name": [
            "--release-channel"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Disable automatic publishing before building",
          "name": [
            "--no-publish"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Exit immediately after scheduling build",
          "name": [
            "--no-wait"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Apple Team ID",
          "name": [
            "--team-id"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Path to your Distribution Certificate P12 (set password as EXPO_IOS_DIST_P12_PASSWORD environment variable)",
          "name": [
            "--dist-p12-path"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Push Key ID (ex: 123AB4C56D)",
          "name": [
            "--push-id"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Path to your Push Key .p8 file",
          "name": [
            "--push-p8-path"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Path to your Provisioning Profile",
          "name": [
            "--provisioning-profile-path"
          ]
        },
        {
          "args": {
            "name": "url"
          },
          "description": "The URL of an externally hosted manifest (for self-hosted apps)",
          "name": [
            "--public-url"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Skip checking credentials",
          "name": [
            "--skip-credentials-check"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Skip warning about build service bare workflow limitations",
          "name": [
            "--skip-workflow-check"
          ]
        },
        {
          "args": {
            "isOptional": true,
            "name": "file",
            "template": "filepaths"
          },
          "description": "Deprecated: Use app.config.js to switch config files instead",
          "name": [
            "--config"
          ]
        }
      ]
    },
    {
      "args": {
        "isOptional": true,
        "name": "path",
        "template": "folders"
      },
      "description": "Build and sign a standalone APK or App Bundle for the Google Play Store",
      "name": "build:android",
      "options": [
        {
          "description": "Output usage information",
          "name": [
            "-h",
            "--help"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Clear stored credentials",
          "name": [
            "-c",
            "--clear-credentials"
          ]
        },
        {
          "args": {
            "name": "name"
          },
          "description": "Pull from specified release channel",
          "name": [
            "--release-channel"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Disable automatic publishing before building",
          "name": [
            "--no-publish"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Exit immediately after triggering build",
          "name": [
            "--no-wait"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Path to your Keystore: *.jks",
          "name": [
            "--keystore-path"
          ]
        },
        {
          "args": {
            "name": "alias"
          },
          "description": "Keystore Alias",
          "name": [
            "--keystore-alias"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "[deprecated] Generate Keystore if one does not exist",
          "name": [
            "--generate-keystore"
          ]
        },
        {
          "args": {
            "name": "url"
          },
          "description": "The URL of an externally hosted manifest (for self-hosted apps)",
          "name": [
            "--public-url"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Skip warning about build service bare workflow limitations",
          "name": [
            "--skip-workflow-check"
          ]
        },
        {
          "args": {
            "name": "boolean",
            "suggestions": [
              {
                "name": "true"
              },
              {
                "name": "false"
              }
            ]
          },
          "description": "Type of build: [app-bundle|apk]",
          "name": [
            "-t",
            "--type"
          ]
        },
        {
          "args": {
            "isOptional": true,
            "name": "file",
            "template": "filepaths"
          },
          "description": "Deprecated: Use app.config.js to switch config files instead",
          "name": [
            "--config"
          ]
        }
      ]
    },
    {
      "args": {
        "isOptional": true,
        "name": "path",
        "template": "folders"
      },
      "description": "Build the web app for production",
      "name": "build:web",
      "options": [
        {
          "description": "Output usage information",
