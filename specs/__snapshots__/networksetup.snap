            }
          ],
          "name": "networkservice"
        },
        {
          "description": "One or more tuples of (destination address, subnet mask, gateway address). Specify 'Empty' to clear routes",
          "isOptional": true,
          "isVariadic": true,
          "name": "dest mask gate"
