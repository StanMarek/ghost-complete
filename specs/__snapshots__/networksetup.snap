              ]
            }
          ],
          "name": "networkservice"
        },
        {
          "description": "The IP address to set for the network service",
          "name": "ip"
        }
      ],
      "description": "Use this command to specify a manual IP address to use for DHCP for the specified <networkservice>",
      "name": "-setmanualwithdhcprouter"
    },
    {
      "args": {
        "generators": [
          {
            "js_source": "o=>{let r=[],n=o.split(`\n`);for(let t of n){let d=t.trim();if(d!==\"An asterisk (*) denotes that a network service is disabled.\"&&d.length>0){let h=d.replace(/^\\* /,\"\").trim(),l=d.startsWith(\"*\")?\"Disabled network service\":\"Network service\";r.push({name:h,description:l})}}return r}",
