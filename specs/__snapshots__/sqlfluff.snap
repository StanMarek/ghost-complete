          ]
        },
        {
          "args": {
            "name": "recurse"
          },
          "description": "The depth to recursively parse to (0 for unlimited)",
          "name": [
            "--recurse"
          ]
        },
        {
          "args": {
            "description": "Name of logger to limit to, eg. templater",
