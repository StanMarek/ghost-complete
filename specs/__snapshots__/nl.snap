{
  "args": {
    "description": "File(s) to number",
    "name": "file",
    "template": "filepaths"
  },
  "description": "Line numbering filter",
  "name": "nl",
  "options": [
    {
      "args": {
        "name": "type",
        "suggestions": [
          {
            "description": "Number all lines",
            "name": "a"
          },
          {
            "description": "Number only non-empty lines",
            "name": "t"
          },
          {
            "description": "Only those lines that contain the basic regular expression specified by 'expr'",
            "name": "pexpr"
          }
        ]
      },
      "description": "Specify the logical page body lines to be numbered",
      "name": [
        "-b"
      ]
    },
    {
      "args": {
        "name": "delim",
        "suggestions": [
          {
            "name": "\\:"
          }
        ]
      },
      "description": "Specify the delimiter characters used to indicate the\nstart of a logical page section in the input file. At most two\ncharacters may be specified; if only one character is specified,\nthe first character is replaced and the second character remains unchanged",
      "name": [
        "-d"
      ]
    },
    {
      "args": {
        "name": "type",
        "suggestions": [
          {
            "name": "n"
          }
        ]
      },
      "description": "Specify the same as -b type except for logical page footer lines",
      "name": [
        "-f"
      ]
    },
    {
      "args": {
        "name": "type",
        "suggestions": [
          {
            "name": "n"
          }
        ]
      },
      "description": "Specify the same as -b type except for logical page header lines",
      "name": [
        "-h"
      ]
    },
    {
      "args": {
        "name": "incr",
        "suggestions": [
          {
            "name": "1"
          }
        ]
      },
      "description": "Specify the increment value used to number logical page lines",
      "name": [
        "-i"
      ]
    },
    {
      "args": {
        "name": "num",
        "suggestions": [
          {
            "name": "1"
          }
        ]
      },
      "description": "If numbering of all lines is specified for the current\nlogical section using the corresponding -b a, -f a or -h a option, specify\nthe number of adjacent blank lines to be considered as one. For example,\n-l 2 results in only the second adjacent blank line being numbered",
      "name": [
        "-l"
      ]
    },
    {
      "args": {
        "name": "format",
        "suggestions": [
          {
            "description": "Left justified",
            "name": "ln"
          },
          {
            "description": "Right justified (leading zeros suppressed)",
            "name": "rn"
          },
          {
            "description": "Right justified (leading zeros kept)",
            "name": "rz"
          }
        ]
      },
      "description": "Specify the line numbering output format",
      "name": [
        "-n"
      ]
    },
    {
      "description": "Specify that line numbering should not be restarted at logical page delimiters",
      "name": [
        "-p"
      ]
    },
    {
      "args": {
        "name": "sep",
        "suggestions": [
          {
            "name": "\\t"
          }
        ]
      },
      "description": "Specify the characters used in separating the line\nnumber and the corresponding text line.  The default\nsep setting is a single tab character",
      "name": [
        "-s"
      ]
    },
    {
      "args": {
        "name": "startnum",
        "suggestions": [
          {
            "name": "1"
          },
          {
            "name": "2"
          },
          {
            "name": "3"
          }
        ]
      },
      "description": "Specify the initial value used to number logical page lines; see also the description of the -p option",
      "name": [
        "-v"
      ]
    },
    {
      "args": {
        "name": "width",
        "suggestions": [
          {
            "name": "6"
          },
          {
            "name": "5"
          },
          {
            "name": "4"
          },
          {
            "name": "3"
          },
          {
            "name": "2"
          },
          {
            "name": "1"
          }
        ]
      },
      "description": "Specify the number of characters to be occupied by the\nline number; in case the width is insufficient to hold the line number,\nit will be truncated to its width least significant digits",
      "name": [
        "-w"
      ]
    }
  ]
}
