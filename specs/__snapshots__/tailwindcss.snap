{
  "description": "Tailwindcss CLI tools",
  "name": "tailwindcss",
  "options": [
    {
      "args": {
        "name": "input file",
        "template": "filepaths"
      },
      "description": "Specify input file",
      "name": [
        "-i",
        "--input"
      ]
    },
    {
      "args": {
        "name": "output file",
        "template": "filepaths"
      },
      "description": "Specify output file",
      "name": [
        "-o",
        "--output"
      ]
    },
    {
      "args": {
        "name": "config file",
        "template": "filepaths"
      },
      "description": "Specify config file to use",
      "name": [
        "-c",
        "--config"
      ]
    },
    {
      "args": {
        "isOptional": true,
        "name": "postcss config file",
        "template": "filepaths"
      },
      "description": "Load custom PostCSS configuration",
      "name": [
        "--postcss"
      ]
    },
    {
      "description": "Content paths to use for removing unused classes. [Deprecated]: use `--content` instead",
      "name": [
        "--purge"
      ]
    },
    {
      "description": "Content paths to use for removing unused classes",
      "name": [
        "--content"
      ]
    },
    {
      "description": "Watch for changes and rebuild as needed",
      "name": [
        "--watch",
        "-w"
      ]
    },
    {
      "description": "Minify the output",
      "name": [
        "--minify",
        "-m"
      ]
    },
    {
      "description": "Disable autoprefixer",
      "name": [
        "--no-autoprefixer"
      ]
    },
    {
      "description": "Display usage information",
      "name": [
        "--help",
        "-h"
      ]
    }
  ],
  "subcommands": [
    {
      "args": {
        "isOptional": true,
        "name": "filename"
      },
      "description": "Creates Tailwind config file. Default: tailwind.config.js",
      "name": "init",
      "options": [
        {
          "description": "Initialize a 'postcss.config.js' file",
          "name": [
            "-p",
            "--postcss"
          ]
        },
        {
          "description": "Initialize a full 'tailwind.config.js' file",
          "name": [
            "-f",
            "--full"
          ]
        },
        {
          "description": "Display usage information",
          "name": [
            "--help",
            "-h"
          ]
        }
      ]
    },
    {
      "description": "Build CSS file",
      "name": "build",
      "options": [
        {
          "args": {
            "name": "input file",
            "template": "filepaths"
          },
          "description": "Specify input file",
          "name": [
            "-i",
            "--input"
          ]
        },
        {
          "args": {
            "name": "output file",
            "template": "filepaths"
          },
          "description": "Specify output file",
          "name": [
            "-o",
            "--output"
          ]
        },
        {
          "args": {
            "name": "config file",
            "template": "filepaths"
          },
          "description": "Specify config file to use",
          "name": [
            "-c",
            "--config"
          ]
        },
        {
          "args": {
            "isOptional": true,
            "name": "postcss config file",
            "template": "filepaths"
          },
          "description": "Load custom PostCSS configuration",
          "name": [
            "--postcss"
          ]
        },
        {
          "description": "Content paths to use for removing unused classes. [Deprecated]: use `--content` instead",
          "name": [
            "--purge"
          ]
        },
        {
          "description": "Content paths to use for removing unused classes",
          "name": [
            "--content"
          ]
        },
        {
          "description": "Watch for changes and rebuild as needed",
          "name": [
            "--watch",
            "-w"
          ]
        },
        {
          "description": "Minify the output",
          "name": [
            "--minify",
            "-m"
          ]
        },
        {
          "description": "Disable autoprefixer",
          "name": [
            "--no-autoprefixer"
          ]
        },
        {
          "description": "Display usage information",
          "name": [
            "--help",
            "-h"
          ]
        }
      ]
    }
  ]
}
