{
  "description": "Coda Local development CLI tool. It comes bundled with the Pack SDK and makes it easy to build and manage Packs from the CLI",
  "name": "coda",
  "options": [
    {
      "description": "Show version number",
      "name": [
        "--version"
      ],
      "priority": 1
    },
    {
      "description": "Show help",
      "name": [
        "--help"
      ],
      "priority": 2
    }
  ],
  "subcommands": [
    {
      "description": "Initialize an empty project with the recommended settings and dependencies",
      "name": "init"
    },
    {
      "args": [
        {
          "description": "The path to the pack.ts file. E.g. src/pack.ts",
          "generators": [
            {
              "js_source": "(p,m,_)=>de(this,void 0,void 0,function*(){var f;let{isDangerous:b,currentWorkingDirectory:O,searchTerm:h}=_,k=(f=(0,y.getCurrentInsertedDirectory)(l??O,h,_))!==null&&f!==void 0?f:\"/\";try{let R=yield m({command:\"ls\",args:[\"-1ApL\"],cwd:k}),Z=W(R.stdout.split(`\n`),[\".DS_Store\"]),q=[];for(let j of Z)if(j){let L=j.endsWith(\"/\")?\"folders\":\"filepaths\";(L===\"filepaths\"&&u!==\"only\"||L===\"folders\"&&u!==\"never\")&&q.push({type:L===\"filepaths\"?\"file\":\"folder\",name:j,insertValue:j,isDangerous:b,context:{templateType:L}})}return S(g(q))}catch{return[]}})",
              "requires_js": true
            }
          ],
          "name": "path/to/pack.ts"
        },
        {
          "description": "Formula name to execute",
          "generators": [
            {
              "script": [
                "bash",
                "-c",
                "grep -A5 --include=*.ts --exclude-dir=node_modules -r 'addFormula\\|addSyncTable\\|makeFormula\\|makeSyncTable' . | grep -A3 -i formula | grep name: | grep -oE \"['\\\"]\\w*['\\\"]\""
              ],
              "transforms": [
                "split_lines",
                "filter_empty",
                "trim"
              ]
            }
          ],
          "name": "formula"
        },
        {
          "description": "Arguments to pass to the formula",
          "isOptional": true,
          "isVariadic": true,
          "name": "params"
        }
      ],
      "description": "Execute the formula and print the output to the terminal",
      "name": "execute",
      "options": [
        {
          "args": {
            "description": "The URL to sync from",
            "name": "url"
          },
          "description": "To run a sync for a dynamic sync table, use this parameter to specify which URL to sync from",
          "name": [
            "--dynamicUrl"
          ]
        }
      ]
    },
