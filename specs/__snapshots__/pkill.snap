{
  "args": {
    "description": "Specifies an Extended Regular Expression for matching against the process names or command lines",
    "name": "pattern"
  },
  "description": "Send  the  specified  signal  (by default SIGTERM) to each specified process",
  "name": "pkill",
  "options": [
    {
      "args": {
        "description": "Signal to send",
        "name": "signal",
        "suggestions": [
          {
            "name": "SIGABRT"
          },
          {
            "name": "SIGALRM"
          },
          {
            "name": "SIGBUS"
          },
          {
            "name": "SIGCHLD"
          },
          {
            "name": "SIGCLD"
          },
          {
            "name": "SIGCONT"
          },
          {
            "name": "SIGEMT"
          },
          {
            "name": "SIGFPE"
          },
          {
            "name": "SIGHUP"
          },
          {
            "name": "SIGILL"
          },
          {
            "name": "SIGINFO"
          },
          {
            "name": "SIGINT"
          },
          {
            "name": "SIGIO"
          },
          {
            "name": "SIGIOT"
          },
          {
            "name": "SIGKILL"
          },
          {
            "name": "SIGLOST"
          },
          {
            "name": "SIGPIPE"
          },
          {
            "name": "SIGPOLL"
          },
          {
            "name": "SIGPROF"
          },
          {
            "name": "SIGPWR"
          },
          {
            "name": "SIGQUIT"
          },
          {
            "name": "SIGSEGV"
          },
          {
            "name": "SIGSTKFLT"
          },
          {
            "name": "SIGSTOP"
          },
          {
            "name": "SIGTSTP"
          },
          {
            "name": "SIGSYS"
          },
          {
            "name": "SIGTERM"
          },
          {
            "name": "SIGTRAP"
          },
          {
            "name": "SIGTTIN"
          },
          {
            "name": "SIGTTOU"
          },
          {
            "name": "SIGUNUSED"
          },
          {
            "name": "SIGURG"
          },
          {
            "name": "SIGUSR1"
          },
          {
            "name": "SIGUSR2"
          },
          {
            "name": "SIGVTALRM"
          },
          {
            "name": "SIGXCPU"
          },
          {
            "name": "SIGXFSZ"
          },
          {
            "name": "SIGWINCH"
          }
        ]
      },
      "description": "Signal to send (either number or name)",
      "name": [
        "--signal"
      ]
    },
    {
      "args": {
        "name": "value"
      },
      "description": "Integer value to be sent with the signal",
      "name": [
        "-q",
        "--queue"
      ]
    },
    {
      "description": "Display what is killed",
      "name": [
        "-e",
        "--echo"
      ]
    },
    {
      "description": "Use full process name to match",
      "name": [
        "-f",
        "--full"
      ]
    },
    {
      "args": {
        "isVariadic": true,
        "name": "PGID"
      },
      "description": "Match listed process group IDs",
      "name": [
        "-g",
        "--pgroup"
      ]
    },
    {
      "args": {
        "isVariadic": true,
        "name": "GID"
      },
      "description": "Match real group IDs",
      "name": [
        "-G",
        "--group"
      ]
    },
    {
      "description": "Match case insensitively",
      "name": [
        "-i",
        "--ignore-case"
      ]
    },
    {
      "description": "Select most recently started",
      "name": [
        "-n",
        "--newest"
      ]
    },
    {
      "description": "Select least recently started",
      "name": [
        "-o",
        "--oldest"
      ]
    },
    {
      "args": {
        "name": "seconds"
      },
      "description": "Select where older than seconds",
      "name": [
        "-O",
        "--older"
      ]
    },
    {
      "args": {
        "isVariadic": true,
        "name": "PPID"
      },
      "description": "Match only child processes of the given parent",
      "name": [
        "-P",
        "--parent"
      ]
    },
    {
      "args": {
        "isVariadic": true,
        "name": "SID"
      },
      "description": "Match session IDs",
      "name": [
        "-s",
        "--session"
      ]
    },
    {
      "args": {
        "isVariadic": true,
        "name": "tty"
      },
      "description": "Match by controlling terminal",
      "name": [
        "-t",
        "--terminal"
      ]
    },
    {
      "args": {
        "isVariadic": true,
        "name": "ID"
      },
      "description": "Match by effective IDs",
      "name": [
        "-u",
        "--euid"
      ]
    },
    {
      "args": {
        "isVariadic": true,
        "name": "ID"
      },
      "description": "Match by real IDs",
      "name": [
        "-U",
        "--uid"
      ]
    },
    {
      "description": "Match exactly with the command name",
      "name": [
        "-x",
        "--exact"
      ]
    },
    {
      "args": {
        "name": "file",
        "template": "filepaths"
      },
      "description": "Read PIDs from file",
      "name": [
        "-F",
        "--pidfile"
      ]
    },
    {
      "description": "Fail if PID file is not locked",
      "name": [
        "-L",
        "logpidfile"
      ]
    },
    {
      "args": {
        "name": "state"
      },
      "description": "Match runstates",
      "name": [
        "-r",
        "--runstates"
      ]
    },
    {
      "args": {
        "name": "PID"
      },
      "description": "Match the processes that belong to a specified PID",
      "name": [
        "--ns"
      ]
    },
    {
      "args": {
        "isVariadic": true,
        "name": "ns",
        "suggestions": [
          {
            "name": "ipc"
          },
          {
            "name": "mnt"
          },
          {
            "name": "net"
          },
          {
            "name": "pid"
          },
          {
            "name": "user"
          },
          {
            "name": "uts"
          }
        ]
      },
      "description": "List which namespaces will be considered for the --ns option",
      "name": [
        "--nslist"
      ]
    },
    {
      "description": "Output help message and exit",
      "name": [
        "-h",
        "--help"
      ]
    },
    {
      "description": "Output version information and exit",
      "name": [
        "-V",
        "--version"
      ]
    }
  ]
}
