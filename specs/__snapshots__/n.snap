{
  "args": {
    "generators": [
      {
        "js_source": "function(e){let n=new Set,t=e.split(`\n`).slice(1);for(let i of t){n.add(i);let r=i.split(\".\");n.add(r[0]+\".\"+r[1]),n.add(r[0])}return Array.from(n).map(i=>({name:[i,`v${i}`],description:`Node.js ${i}`}))}",
        "requires_js": true,
        "script": [
          "n",
          "lsr",
          "--all"
        ]
      }
    ],
    "isOptional": true,
    "name": "version",
    "suggestions": [
      {
        "description": "Newest official release",
        "name": "latest"
      },
