      "name": [
        "--config"
      ]
    },
    {
      "args": {
        "name": "unstable-features"
      },
      "description": "Unstable (nightly-only) flags to Cargo, see 'cargo -Z help' for details",
      "name": [
        "-Z"
      ]
    },
    {
      "description": "Print help information",
      "name": [
        "-h",
        "--help"
      ]
    },
    {
      "description": "Print version info and exit",
      "name": [
