{
  "description": "Swiss Army Knife for macOS",
  "name": "m",
  "options": [
    {
      "description": "Update m-cli to the latest version",
      "name": [
        "--update"
      ]
    },
    {
      "description": "Uninstall m-cli",
      "name": [
        "--uninstall"
      ]
    }
