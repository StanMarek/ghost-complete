    {
      "description": "Manage trash",
      "name": "trash",
      "subcommands": [
        {
          "description": "Get trash info",
          "name": "status"
        },
        {
          "description": "Clean trash",
          "name": "clean"
        },
        {
          "description": "Show help",
          "name": "help"
        }
      ]
    },
    {
      "description": "Manage user",
      "name": "user",
      "subcommands": [
        {
          "description": "List all users",
          "name": "ls"
        },
        {
          "args": {
            "description": "Username",
            "generators": [
              {
                "script": [
                  "bash",
                  "-c",
                  "m user list | awk '{ print $1 }'"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim"
                ]
              }
            ],
            "name": "username"
          },
          "description": "Get user info",
          "name": "info"
        },
        {
          "description": "Create a new user",
          "name": "create"
        },
        {
          "args": {
            "description": "Username",
            "generators": [
              {
                "script": [
                  "bash",
                  "-c",
                  "m user list | awk '{ print $1 }'"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim"
                ]
              }
            ],
            "name": "username"
          },
          "description": "Delete a user",
          "name": "delete"
        },
        {
          "description": "Show help",
          "name": "help"
        }
      ]
    },
    {
      "args": {
        "description": "Volume level up/down/(+/-)number",
        "name": "volume"
      },
      "description": "Manage volume level",
      "name": "volume",
      "subcommands": [
        {
          "description": "Set mute",
          "name": "mute"
        },
        {
          "description": "Unset mute",
          "name": "unmute"
        },
        {
          "description": "Check the volume status",
          "name": "ismute"
        },
        {
          "description": "Increase the volume by 6.25",
          "name": "up"
        },
        {
          "description": "Decrease the volume by 6.25",
          "name": "down"
        },
        {
          "description": "Show help",
          "name": "help"
        }
      ]
    },
    {
      "description": "Manage VPN connections",
      "name": "vpn",
      "subcommands": [
        {
          "description": "List VPN connections",
          "name": "ls"
        },
        {
          "args": [
            {
              "description": "VPN connection name",
              "isOptional": true,
              "name": "VPN"
            },
            {
              "description": "VPN connection user",
              "isOptional": true,
              "name": "USER"
            },
            {
              "description": "VPN connection password",
              "isOptional": true,
              "name": "PASS"
            },
            {
              "description": "VPN connection secret",
              "isOptional": true,
              "name": "SECRET"
            }
          ],
          "description": "Start a VPN connection",
          "name": "start"
        },
        {
          "args": {
            "description": "VPN connection name",
            "isOptional": true,
            "name": "VPN"
          },
          "description": "Stop a VPN connection",
          "name": "stop"
        },
        {
          "args": {
            "description": "VPN connection name",
            "isOptional": true,
            "name": "VPN"
          },
          "description": "Get the status of a VPN connection",
          "name": "status"
        },
        {
          "description": "Show help",
          "name": "help"
        }
      ]
    },
    {
      "args": {
        "description": "Path to the wallpaper",
        "name": "image",
        "template": "filepaths"
      },
      "description": "Change wallpaper",
      "name": "wallpaper",
      "subcommands": [
        {
          "description": "Show help",
          "name": "help"
        }
      ]
    },
    {
      "description": "Manage wifi",
      "name": "wifi",
      "subcommands": [
        {
          "description": "Get wifi status",
          "name": "status"
        },
        {
          "description": "Scan wifi",
          "name": "scan"
        },
        {
          "args": {
            "description": "ESSID",
            "generators": [
              {
                "script": [
                  "bash",
                  "-c",
                  "networksetup -listallhardwareports | awk '/Wi-Fi/{getline; print $2}' | xargs networksetup -listpreferredwirelessnetworks | tail -n +2"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim"
                ]
              }
            ],
            "isOptional": true,
            "name": "ESSID"
          },
          "description": "Show wifi network password",
          "name": "showpassword"
        },
        {
          "description": "List known wifi networks",
          "name": "ls"
        },
        {
          "args": {
            "description": "ESSID",
            "generators": [
              {
                "script": [
                  "bash",
                  "-c",
                  "networksetup -listallhardwareports | awk '/Wi-Fi/{getline; print $2}' | xargs networksetup -listpreferredwirelessnetworks | tail -n +2"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim"
                ]
              }
            ],
            "name": "ESSID"
          },
          "description": "Forget a wifi network",
          "name": "forget"
        },
        {
          "description": "Wifi connection history",
          "name": "history"
        },
        {
          "description": "Turn off your wifi",
          "name": "off"
        },
        {
          "description": "Turn on your wifi",
          "name": "on"
        },
        {
          "args": [
            {
              "description": "ESSID",
              "name": "ESSID"
            },
            {
              "description": "Password",
              "isOptional": true,
              "name": "PASSWORD"
            }
          ],
          "description": "Join a wifi network",
          "name": "connect"
        },
        {
          "description": "Show help",
          "name": "help"
        }
      ]
    }
  ]
}
