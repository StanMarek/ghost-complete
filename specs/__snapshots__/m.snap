    {
      "description": "Manage iTunes",
      "name": "itunes",
      "subcommands": [
        {
          "description": "Show status",
          "name": "status"
        },
        {
          "description": "Play track",
          "name": "play"
        },
        {
          "description": "Pause track",
          "name": "pause"
        },
        {
          "description": "Play next track",
          "name": "next"
        },
        {
          "description": "Play previous track",
          "name": "prev"
        },
        {
          "description": "Mute iTunes",
          "name": "mute"
        },
        {
          "description": "Unmute iTunes",
          "name": "unmute"
        },
        {
          "args": {
            "description": "Up/Down/Number",
            "isOptional": true,
            "name": "up/down/#",
            "suggestions": [
              {
                "name": "up"
              },
              {
                "name": "down"
              }
            ]
          },
          "description": "Volume",
          "name": "vol"
        },
        {
          "description": "Stop track",
          "name": "stop"
        },
        {
          "description": "Quit iTunes",
          "name": "quit"
        },
        {
          "description": "Show help",
          "name": "help"
        }
      ]
    },
    {
      "description": "Manage localhost",
      "name": "localhost",
      "subcommands": [
        {
          "description": "List current records in localhost",
          "name": "ls"
        },
        {
          "args": [
            {
              "description": "IP of the host",
              "name": "IP"
            },
            {
              "description": "Hostname of the host",
              "name": "HOSTNAME"
            }
          ],
          "description": "Add a new host to the localhost file",
          "name": "add"
        },
        {
          "args": {
            "description": "Hostname of the host",
            "name": "HOSTNAME"
          },
          "description": "Remove a host from the localhost file",
          "name": "remove"
        },
        {
          "description": "Show help",
          "name": "help"
        }
      ]
    },
    {
      "description": "Lock session",
      "name": "lock"
    },
    {
      "description": "Manage network",
      "name": "network",
      "subcommands": [
        {
          "description": "List network interfaces",
          "name": "ls"
        },
        {
          "description": "Manage location",
          "name": "location",
          "subcommands": [
            {
              "description": "List locations",
              "name": "ls"
            },
            {
              "args": {
                "description": "Name of the location",
                "name": "name"
              },
              "description": "Create a location",
              "name": "create"
            },
            {
              "args": {
                "description": "Name of the location",
                "generators": [
                  {
                    "script": [
                      "bash",
                      "-c",
                      "m network location list | tail -n +2"
                    ],
                    "transforms": [
                      "split_lines",
                      "filter_empty"
                    ]
                  }
                ],
                "name": "name"
              },
              "description": "Delete a location",
              "name": "delete"
            },
            {
              "args": {
                "description": "Name of the location",
                "name": "name"
              },
              "description": "Switch location",
              "name": "switch"
            }
          ]
        },
        {
          "description": "Show help",
          "name": "help"
        }
      ]
    },
    {
      "description": "Manage no sleep",
      "name": "nosleep",
      "subcommands": [
        {
          "args": {
            "name": "time or script",
            "template": "filepaths"
          },
          "description": "No sleep until",
          "name": "until",
          "subcommands": [
            {
              "args": {
                "description": "Process id",
                "generators": [
                  {
                    "script": [
                      "bash",
                      "-c",
                      "ps axo pid,comm | sed 1d"
                    ],
                    "transforms": [
                      "split_lines",
                      "filter_empty",
                      "trim"
                    ]
                  }
                ],
                "name": "pid"
              },
              "description": "No sleep until process id ends",
              "name": "pid"
            }
          ]
        },
        {
          "description": "Show help",
          "name": "help"
        }
      ]
    },
