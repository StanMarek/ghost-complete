                  "description": "Path to format the volume",
                  "generators": [
                    {
                      "template": "filepaths"
                    },
                    {
                      "script": [
                        "ls",
                        "/Volumes"
                      ],
                      "transforms": [
                        "split_lines",
                        "filter_empty",
                        "trim"
                      ]
                    }
                  ],
                  "name": "path"
