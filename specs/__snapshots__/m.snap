        {
          "description": "Disable AirDrop",
          "name": "off"
        },
        {
          "description": "Disable AirDrop",
          "name": "disable"
        },
        {
          "description": "Show help",
          "name": "help"
        }
      ]
    },
    {
      "description": "Manage appearance",
      "name": "appearance",
