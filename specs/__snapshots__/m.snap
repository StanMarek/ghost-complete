    {
      "description": "Manage directories",
      "name": "dir",
      "subcommands": [
        {
          "args": {
            "description": "Path to show tree view of folders",
            "isOptional": true,
            "name": "path",
            "template": "folders"
          },
          "description": "Show tree view of folders in the current path",
          "name": "tree"
        },
        {
          "description": "Delete folders",
          "name": "delete",
          "subcommands": [
            {
              "args": {
                "description": "Path to delete empty folders",
                "isOptional": true,
                "name": "path",
                "template": "folders"
              },
              "description": "Delete empty folders recursively in the current path",
              "name": "empty"
            },
            {
              "args": {
                "description": "Delete .DS_Store files recursively in a specific path",
                "isOptional": true,
                "name": "path",
                "template": "folders"
              },
              "description": "Delete .DS_Store files recursively in the current path",
              "name": "dsfiles"
            }
          ]
        },
        {
          "description": "Manage .DS_Store files",
          "name": "dsfiles",
          "subcommands": [
            {
              "description": "Restore generation of .DS_Store",
              "name": "on"
            },
            {
              "description": "Prohibit generation of .DS_Store",
              "name": "off"
            }
          ]
        },
        {
          "args": {
            "description": "Path to calculate folder size",
            "isOptional": true,
            "name": "path",
            "template": "folders"
          },
          "description": "Calculate current folder size",
          "name": "size"
        },
        {
          "description": "Show help",
          "name": "help"
        }
      ]
    },
    {
      "description": "Manage disks",
      "name": "disk",
      "subcommands": [
        {
          "args": {
            "description": "Path to the disk file",
            "generators": [
              {
                "template": "filepaths"
              },
              {
                "script": [
                  "ls",
                  "/dev"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim"
                ]
              }
            ],
            "isOptional": true,
            "name": "path"
          },
          "description": "List disk partitions",
          "name": "ls"
        },
        {
          "args": {
            "description": "Path to show disk information",
            "generators": [
              {
                "template": "filepaths"
              },
              {
                "script": [
                  "ls",
                  "/dev"
                ],
                "transforms": [
                  "split_lines",
                  "filter_empty",
                  "trim"
                ]
              }
            ],
            "name": "path"
          },
          "description": "Show disk information",
          "name": "info"
        },
        {
          "description": "Eject all mountable volumes",
          "name": "ejectall"
        },
        {
