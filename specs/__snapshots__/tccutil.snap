    {
      "generators": [
        {
          "cache": {},
          "js_source": "s=>{let e=new Map(s.split(`\n`).map(n=>{let o=n.indexOf(\" \");return[n.slice(0,o),n.slice(o+1)]}));e.delete(\"(null)\");let i=[];for(let[n,o]of e.entries())i.push({name:n,description:o,icon:`fig://${o}`});return i}",
          "requires_js": true,
          "script": [
            "bash",
            "-c",
            "mdfind kMDItemContentTypeTree=com.apple.application-bundle -onlyin /Applications | while read line; do echo $(mdls -name kMDItemCFBundleIdentifier -r \"$line\") $line; done"
          ]
        }
      ],
      "isOptional": true,
      "name": "bundle id"
    }
  ],
  "description": "Manage the privacy database",
