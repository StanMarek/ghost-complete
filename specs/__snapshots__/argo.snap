              ]
            },
            {
              "args": {
                "name": "string"
              },
              "description": "Output format. One of: name|json|yaml|wide",
              "name": [
                "--output",
                "-o"
              ]
            },
            {
              "description": "Perform strict workflow validation (default true)",
              "name": [
                "--strict"
              ]
            }
          ]
        },
        {
          "args": {
            "name": "WORKFLOW_TEMPLATE"
          },
          "description": "Delete a cluster workflow template",
