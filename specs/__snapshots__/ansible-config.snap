              },
              {
                "name": "connection"
              },
              {
                "name": "httpapi"
              },
              {
                "name": "inventory"
              },
              {
                "name": "lookup"
              },
              {
                "name": "netconf"
              },
              {
                "name": "shell"
              },
              {
                "name": "vars"
              }
            ]
          },
          "description": "Filter down to a specific plugin type",
          "name": [
            "--type",
            "-t"
          ]
        }
      ]
    },
