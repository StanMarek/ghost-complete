        },
        {
          "description": "Verbose mode (-vvv for more, -vvvv to enable connection debugging)",
          "name": [
            "-v"
          ]
        },
        {
          "description": "Only show configurations that have changed from the default",
          "name": [
            "--only-changed",
            "--changed-only"
          ]
        },
        {
          "args": {
            "description": "Path to configuration file",
            "name": "CONFIG_FILE",
            "template": [
              "filepaths"
