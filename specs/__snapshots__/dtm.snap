{
  "description": "DevStream is an open-source DevOps toolchain manager",
  "name": "dtm",
  "options": [
    {
      "description": "Debug level log",
      "name": [
        "--debug"
      ]
    },
    {
      "description": "Display help",
      "name": [
        "--help",
        "-h"
      ]
    }
  ],
  "subcommands": [
    {
      "description": "Create or update DevOps tools according to DevStream configuration file",
      "name": "apply",
      "options": [
        {
          "args": {
            "generators": [
              {
