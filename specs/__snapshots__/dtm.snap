    {
      "description": "Develop is used for develop a new plugin",
      "name": "develop",
      "subcommands": [
        {
          "description": "Create a new plugin",
          "name": "create-plugin",
          "options": [
            {
              "args": {
                "name": "name"
              },
              "description": "Specify name of the plugin to be created",
              "name": [
                "--name",
                "-n"
              ]
            }
          ]
        },
        {
          "description": "Validate a plugin",
          "name": "validate-plugin",
          "options": [
            {
              "description": "Validate all plugins",
              "name": [
                "--all",
                "-a"
              ]
            },
            {
              "args": {
                "name": "name"
              },
              "description": "Specify name of the plugin to be validated",
              "name": [
                "--name",
                "-n"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Download needed plugins according to the config file",
      "name": "init",
      "options": [
        {
          "description": "Download all plugins",
          "name": [
            "--all",
            "-a"
          ]
        },
        {
          "args": {
            "name": "arch"
          },
          "description": "Download plugins for specific arch",
          "name": [
            "--arch"
          ]
        },
        {
          "args": {
            "generators": [
              {
                "js_source": "(p,g,w)=>ue(this,void 0,void 0,function*(){var f;let{isDangerous:b,currentWorkingDirectory:S,searchTerm:m}=w,_=(f=(0,y.getCurrentInsertedDirectory)(c??S,m,w))!==null&&f!==void 0?f:\"/\";try{let E=yield g({command:\"ls\",args:[\"-1ApL\"],cwd:_}),Z=R(E.stdout.split(`\n`),[\".DS_Store\"]),z=[];for(let j of Z)if(j){let V=j.endsWith(\"/\")?\"folders\":\"filepaths\";(V===\"filepaths\"&&u!==\"only\"||V===\"folders\"&&u!==\"never\")&&z.push({type:V===\"filepaths\"?\"file\":\"folder\",name:j,insertValue:j,isDangerous:b,context:{templateType:V}})}return O(h(z))}catch{return[]}})",
                "requires_js": true
              }
            ],
            "name": "config-file",
            "template": [
              "filepaths"
            ]
          },
          "description": "Config file",
          "name": [
            "--config-file",
            "-f"
          ]
        },
        {
          "description": "Download plugins only",
          "name": [
            "--download-only"
          ]
        },
        {
          "args": {
            "name": "os"
          },
          "description": "Download plugins for specific os",
          "name": [
            "--os"
          ]
        },
        {
          "args": {
            "name": "plugin-dir",
            "template": [
              "folders"
            ]
          },
          "description": "Plugins directory",
          "name": [
            "--plugin-dir",
            "-d"
          ]
        },
        {
          "args": {
            "name": "plugins"
          },
          "description": "The plugins to be downloaded",
          "name": [
            "--plugins",
            "-p"
          ]
        }
      ]
    },
    {
      "description": "This command only supports listing plugins now",
      "name": "list",
      "subcommands": [
        {
          "description": "List all plugins",
          "name": "plugins",
          "options": [
            {
              "args": {
                "name": "filter"
              },
              "description": "Filter plugin by regex",
              "name": [
                "--filter",
                "-r"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Show is used to print plugins' configuration templates or status",
      "name": "show",
      "subcommands": [
        {
          "description": "Show configuration information",
          "name": "config",
          "options": [
            {
              "args": {
                "generators": [
                  {
                    "script": [
                      "dtm",
                      "list",
                      "plugins"
                    ],
                    "transforms": [
                      {
                        "starts_with": "fatal:",
                        "type": "error_guard"
                      },
                      "split_lines",
                      "filter_empty",
                      "trim"
                    ]
                  }
                ],
                "name": "plugin"
              },
              "description": "Specify name with the plugin",
              "name": [
                "--plugin",
                "-p"
              ]
            },
            {
              "args": {
                "name": "template"
              },
              "description": "Print a template config, e.g. quickstart/gitops/",
              "name": [
                "--template",
                "-t"
              ]
            }
          ]
        },
        {
          "description": "Show status information",
          "name": "status",
          "options": [
            {
              "description": "Show all instances of all plugins status",
              "name": [
                "--all",
                "-a"
              ]
            },
            {
              "args": {
                "name": "config-file"
              },
              "description": "Config file",
              "name": [
                "--config-file",
                "-f"
              ]
            },
            {
              "args": {
                "name": "id"
              },
              "description": "Specify id with the plugin instance",
              "name": [
                "--id",
                "-i"
              ]
            },
            {
              "args": {
                "name": "plugin"
              },
              "description": "Specify name with the plugin",
              "name": [
                "--plugin",
                "-p"
              ]
            },
            {
              "args": {
                "name": "plugin-dir"
              },
              "description": "Plugins directory",
              "name": [
                "--plugin-dir",
                "-d"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Upgrade dtm to the latest release version",
      "name": "upgrade",
      "options": [
        {
          "description": "Upgrade directly without confirmation",
          "name": [
            "--yes",
            "-y"
          ]
        }
      ]
    },
