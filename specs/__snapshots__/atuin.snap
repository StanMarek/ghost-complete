{
  "description": "Magical shell history",
  "name": "atuin",
  "options": [
    {
      "description": "Print help",
      "name": [
        "--help",
        "-h"
      ]
    },
    {
      "description": "Print version",
      "name": [
        "--version",
        "-V"
      ]
    }
  ],
  "subcommands": [
    {
      "description": "Manipulate shell history",
      "name": "history",
      "subcommands": [
        {
          "args": {
            "isVariadic": true,
            "name": "COMMAND"
          },
          "description": "Begins a new command in the history",
          "name": "start"
        },
        {
          "args": {
            "name": "ID"
          },
          "description": "Finishes a new command in the history (adds time, exit code)",
          "name": "end",
          "options": [
            {
              "args": {
                "name": "EXIT"
              },
              "name": [
                "--exit",
                "-e"
              ]
            }
          ]
        },
        {
          "description": "List all items in history",
          "name": "list",
          "options": [
            {
              "name": [
                "--cwd",
                "-c"
              ]
            },
            {
              "name": [
                "--session",
                "-s"
              ]
            },
            {
              "name": [
                "--human"
              ]
            },
            {
              "description": "Show only the text of the command",
              "name": [
                "--cmd-only"
              ]
            },
            {
              "args": {
                "description": "Available variables: {command}, {directory}, {duration}, {user}, {host} and {time}. Example: --format \"{time} - [{duration}] - {directory}$\\t{command}\"",
                "name": "FORMAT"
              },
              "name": [
                "--format",
                "-f"
              ]
            }
          ]
        },
        {
          "description": "Get the last command ran",
          "name": "last",
          "options": [
            {
              "name": [
                "--human"
              ]
            },
            {
              "description": "Show only the text of the command",
              "name": [
                "--cmd-only"
              ]
            },
            {
              "args": {
                "description": "Available variables: {command}, {directory}, {duration}, {user}, {host} and {time}. Example: --format \"{time} - [{duration}] - {directory}$\\t{command}\"",
                "name": "FORMAT"
              },
              "name": [
                "--format",
                "-f"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Import shell history from file",
      "name": "import",
      "subcommands": [
        {
          "description": "Import history for the current shell",
          "name": "auto"
        },
        {
          "description": "Import history from the zsh history file",
          "name": "zsh"
        },
        {
          "description": "Import history from the zsh history file",
          "name": "zsh-hist-db"
        },
        {
          "description": "Import history from the bash history file",
          "name": "bash"
        },
        {
          "description": "Import history from the resh history file",
          "name": "resh"
        },
        {
          "description": "Import history from the fish history file",
          "name": "fish"
        },
        {
          "description": "Import history from the nu history file",
          "name": "nu"
        },
        {
          "description": "Import history from the nu history file",
          "name": "nu-hist-db"
        }
      ]
    },
    {
      "args": {
        "description": "Compute statistics for the specified period, leave blank for statistics since the beginning",
        "isVariadic": true,
        "name": "PERIOD"
      },
      "description": "Calculate statistics for your history",
      "name": "stats",
      "options": [
        {
          "args": {
            "name": "COUNT"
          },
          "description": "How many top commands to list",
          "name": [
            "--count",
            "-c"
          ]
        }
      ]
    },
    {
      "args": {
        "isVariadic": true,
        "name": "QUERY"
      },
      "description": "Interactive history search",
      "name": "search",
      "options": [
        {
          "args": {
            "name": "CWD"
          },
          "description": "Filter search result by directory",
          "name": [
            "--cwd",
            "-c"
          ]
        },
        {
          "args": {
            "name": "EXCLUDE_CWD"
          },
          "description": "Exclude directory from results",
          "name": [
            "--exclude-cwd"
          ]
        },
        {
          "args": {
            "name": "EXIT"
          },
          "description": "Filter search result by exit code",
          "name": [
            "--exit",
            "-e"
          ]
        },
        {
          "args": {
            "name": "EXCLUDE_EXIT"
          },
          "description": "Exclude results with this exit code",
          "name": [
            "--exclude-exit"
          ]
        },
        {
          "args": {
            "name": "BEFORE"
          },
          "description": "Only include results added before this date",
          "name": [
            "--before",
            "-b"
          ]
        },
        {
          "args": {
            "name": "AFTER"
          },
          "description": "Only include results after this date",
          "name": [
            "--after"
          ]
        },
        {
          "args": {
            "name": "LIMIT"
          },
          "description": "How many entries to return at most",
          "name": [
            "--limit"
          ]
        },
        {
          "args": {
            "name": "OFFSET"
          },
          "description": "Offset from the start of the results",
          "name": [
            "--offset"
          ]
        },
        {
          "description": "Open interactive search UI",
          "name": [
            "--interactive",
            "-i"
          ]
        },
        {
          "args": {
            "name": "FILTER_MODE",
            "suggestions": [
              {
                "name": "global"
              },
              {
                "name": "host"
              },
              {
                "name": "session"
              },
              {
                "name": "directory"
              },
              {
                "name": "workspace"
              }
            ]
          },
          "description": "Allow overriding filter mode over config",
          "name": [
            "--filter-mode"
          ]
        },
        {
          "args": {
            "name": "SEARCH_MODE",
            "suggestions": [
              {
                "name": "prefix"
              },
              {
                "name": "full-text"
              },
              {
                "name": "fuzzy"
              },
              {
                "name": "skim"
              }
            ]
          },
          "description": "Allow overriding search mode over config",
          "name": [
            "--search-mode"
          ]
        },
        {
          "description": "Use human-readable formatting for time",
          "name": [
            "--human"
          ]
        },
        {
          "description": "Show only the text of the command",
          "name": [
            "--cmd-only"
          ]
        },
        {
          "description": "Delete anything matching this query. Will not print out the match",
          "name": [
            "--delete"
          ]
        },
        {
          "description": "Delete EVERYTHING!",
          "name": [
            "--delete-it-all"
          ]
        },
        {
          "description": "Reverse the order of results, oldest first",
          "name": [
            "--reverse",
            "-r"
          ]
        },
        {
          "args": {
            "description": "Available variables: {command}, {directory}, {duration}, {user}, {host} and {time}. Example: --format \"{time} - [{duration}] - {directory}$\\t{command}\"",
            "name": "FORMAT"
          },
          "name": [
            "--format",
            "-f"
          ]
        },
        {
          "args": {
            "name": "INLINE_HEIGHT"
          },
          "description": "Set the maximum number of lines Atuin's interface should take up",
          "name": [
            "--inline-height"
          ]
        }
      ]
    },
    {
      "description": "Sync with the configured server",
      "name": "sync",
      "options": [
        {
          "description": "Force re-download everything",
          "name": [
            "--force",
            "-f"
          ]
        }
      ]
    },
    {
      "description": "Login to the configured server",
      "name": "login",
      "options": [
        {
          "args": {
            "name": "USERNAME"
          },
          "name": [
            "--username",
            "-u"
          ]
        },
        {
          "args": {
            "name": "PASSWORD"
          },
          "name": [
            "--password",
            "-p"
          ]
        },
        {
          "args": {
            "name": "KEY"
          },
          "description": "The encryption key for your account",
          "name": [
            "--key",
            "-k"
          ]
        }
      ]
    },
    {
      "description": "Log out",
      "name": "logout"
    },
    {
      "description": "Register with the configured server",
      "name": "register",
      "options": [
        {
          "args": {
            "name": "USERNAME"
          },
          "name": [
            "--username",
            "-u"
          ]
        },
        {
          "args": {
            "name": "PASSWORD"
          },
          "name": [
            "--password",
            "-p"
          ]
        },
        {
          "args": {
            "name": "EMAIL"
          },
          "name": [
            "--email",
            "-e"
          ]
        }
      ]
    },
    {
      "description": "Print the encryption key for transfer to another machine",
      "name": "key",
      "options": [
        {
          "description": "Switch to base64 output of the key",
          "name": [
            "--base64"
          ]
        }
      ]
    },
    {
      "name": "status"
    },
    {
      "name": "account",
      "subcommands": [
        {
          "description": "Login to the configured server",
          "name": "login",
          "options": [
            {
              "args": {
                "name": "USERNAME"
              },
              "name": [
                "--username",
                "-u"
              ]
            },
            {
              "args": {
                "name": "PASSWORD"
              },
              "name": [
                "--password",
                "-p"
              ]
            },
            {
              "args": {
                "name": "KEY"
              },
              "description": "The encryption key for your account",
              "name": [
                "--key",
                "-k"
              ]
            }
          ]
        },
        {
          "name": "register",
          "options": [
            {
              "args": {
                "name": "USERNAME"
              },
              "name": [
                "--username",
                "-u"
              ]
            },
            {
              "args": {
                "name": "PASSWORD"
              },
              "name": [
                "--password",
                "-p"
              ]
            },
            {
              "args": {
                "name": "EMAIL"
              },
              "name": [
                "--email",
                "-e"
              ]
            }
          ]
        },
        {
          "description": "Log out",
          "name": "logout"
        },
        {
          "name": "delete"
        }
      ]
    },
    {
      "name": "kv",
      "subcommands": [
        {
          "args": {
            "name": "VALUE"
          },
          "name": "set",
          "options": [
            {
              "args": {
                "name": "KEY"
              },
              "name": [
                "--key",
                "-k"
              ]
            },
            {
              "args": {
                "name": "NAMESPACE"
              },
              "name": [
                "--namespace",
                "-n"
              ]
            }
          ]
        },
        {
          "args": {
            "name": "KEY"
          },
          "name": "get",
          "options": [
            {
              "args": {
                "name": "NAMESPACE"
              },
              "name": [
                "--namespace",
                "-n"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Start an atuin server",
      "name": "server",
      "subcommands": [
        {
          "description": "Start the server",
          "name": "start",
          "options": [
            {
              "args": {
                "name": "HOST"
              },
              "description": "The host address to bind",
              "name": [
                "--host"
              ]
            },
            {
              "args": {
                "name": "PORT"
              },
              "description": "The port to bind",
              "name": [
                "--port",
                "-p"
              ]
            }
          ]
        }
      ]
    },
    {
      "args": {
        "name": "SHELL",
        "suggestions": [
          {
            "name": "zsh"
          },
          {
            "name": "bash"
          },
          {
            "name": "fish"
          },
          {
            "name": "nu"
          }
        ]
      },
      "description": "Output shell setup",
      "name": "init",
      "options": [
        {
          "description": "Disable the binding of CTRL-R to atuin",
          "name": [
            "--disable-ctrl-r"
          ]
        },
        {
          "description": "Disable the binding of the Up Arrow key to atuin",
          "name": [
            "--disable-up-arrow"
          ]
        }
      ]
    },
    {
      "description": "Generate a UUID",
      "name": "uuid"
    },
    {
      "name": "contributors"
    },
    {
      "description": "Generate shell completions",
      "name": "gen-completions",
      "options": [
        {
          "args": {
            "name": "SHELL",
            "suggestions": [
              {
                "name": "bash"
              },
              {
                "name": "elvish"
              },
              {
                "name": "fish"
              },
              {
                "name": "powershell"
              },
              {
                "name": "zsh"
              }
            ]
          },
          "description": "Set the shell for generating completions",
          "name": [
            "--shell",
            "-s"
          ]
        },
        {
          "args": {
            "name": "OUT_DIR"
          },
          "description": "Set the output directory",
          "name": [
            "--out-dir",
            "-o"
          ]
        }
      ]
    }
  ]
}
