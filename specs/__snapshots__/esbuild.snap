      "name": [
        "--minify"
      ]
    },
    {
      "args": {
        "name": "path",
        "template": "folders"
      },
      "description": "The output directory for multiple entrypoints",
      "name": [
        "--outdir"
      ]
    },
    {
      "args": {
        "name": "path",
