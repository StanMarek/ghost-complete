      "name": [
        "--target"
      ]
    },
    {
      "args": {
        "isOptional": true,
        "name": "forever",
        "suggestions": [
          {
            "name": "forever"
          }
        ]
      },
      "description": "Rebuild on file system changes",
      "name": [
