      ]
    },
    {
      "description": "Allow output files to overwrite input files",
      "name": [
        "--allow-overwrite"
      ]
    },
    {
      "args": {
        "isOptional": true,
        "name": "verbose",
        "suggestions": [
          {
            "name": "verbose"
