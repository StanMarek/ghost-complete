          },
          {
            "name": "neutral"
          }
        ]
      },
      "description": "The platform target",
      "name": [
        "--platform"
      ]
    },
    {
      "args": {
        "isOptional": true,
        "name": "[address:]port"
      },
      "description": "Start a local HTTP server on this host:port",
      "name": [
        "--serve"
      ]
    },
    {
      "description": "Enable code splitting",
