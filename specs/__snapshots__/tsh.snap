              },
              {
                "name": "Protocol"
              },
              {
                "name": "ProxyCommand"
              },
              {
                "name": "PubkeyAuthentication"
              },
              {
                "name": "RekeyLimit"
              },
              {
                "name": "RequestTTY"
              },
              {
                "name": "RhostsRSAAuthentication"
              },
              {
                "name": "RSAAuthentication"
              },
              {
                "name": "SendEnv"
              },
              {
                "name": "ServerAliveInterval"
              },
              {
                "name": "ServerAliveCountMax"
              },
              {
                "name": "StrictHostKeyChecking"
              },
              {
                "name": "TCPKeepAlive"
              },
              {
                "name": "Tunnel"
              },
              {
                "name": "TunnelDevice"
              },
              {
                "name": "UsePrivilegedPort"
              },
              {
                "name": "User"
              },
              {
                "name": "UserKnownHostsFile"
              },
              {
                "name": "VerifyHostKeyDNS"
              },
              {
                "name": "VisualHostKey"
              },
              {
                "name": "XAuthLocation"
              }
            ]
          },
          "description": "Can be used to give options in the format used in the configuration file",
          "name": [
            "-o"
          ]
        },
        {
          "args": {
            "description": "Port to connect to",
            "name": "port"
          },
          "description": "Port to connect to on the remote host",
          "name": [
            "-p"
          ]
        },
        {
          "description": "Quiet mode.  Causes most warning and diagnostic messages to be suppressed",
          "name": [
            "-q"
          ]
        },
        {
          "args": {
            "description": "Local port, followed by host and host port to forward to",
            "name": "port:host:hostport"
          },
          "description": "Specifies that the given port on the remote (server) host is to be forwarded to the given host and port on the local side",
          "name": [
            "-R"
          ]
        },
        {
          "args": {
            "description": "Location of the control socket",
            "name": "ctl_path",
            "template": "filepaths"
          },
          "description": "Specifies the location of a control socket for connection sharing, or the string 'none' to disable connection sharing",
          "name": [
            "-S"
          ]
        },
        {
          "description": "May be used to request invocation of a subsystem on the remote system",
          "name": [
            "-s"
          ]
        },
        {
          "description": "Disable pseudo-tty allocation",
          "name": [
            "-T"
          ]
        },
        {
          "description": "Force pseudo-tty allocation",
          "name": [
            "-t"
          ]
        },
        {
          "description": "Display the version number and exit",
          "name": [
            "-V"
          ]
        },
        {
          "description": "Verbose mode.  Causes ssh to print debugging messages about its progress",
          "name": [
            "-v"
          ]
        },
        {
          "args": {
            "description": "Host and port to forward to",
            "name": "host:port"
          },
          "description": "Requests that standard input and output on the client be forwarded to host on port over the secure channel",
          "name": [
            "-W"
          ]
        },
        {
          "args": {
            "description": "Local device to forward to",
            "name": "local tun"
          },
          "description": "Requests tunnel device forwarding with the specified tun(4) devices between the client (local_tun) and the server (remote_tun)",
          "name": [
            "-w"
          ]
        },
        {
          "description": "Enables X11 forwarding",
          "name": [
            "-X"
          ]
        },
        {
          "description": "Disables X11 forwarding",
          "name": [
            "-x"
          ]
        },
        {
          "description": "Enables trusted X11 forwarding",
          "name": [
            "-Y"
          ]
        },
        {
          "description": "Send log information using the syslog(3) system module",
          "name": [
            "-y"
          ]
        }
      ]
    },
    {
      "description": "Access AWS API",
      "name": "aws",
      "options": [
        {
          "description": "Remote host login",
          "name": [
            "-l",
            "--login"
          ]
        },
        {
          "args": {
            "generators": [
              {
                "js_source": "t=>JSON.parse(t).map(n=>n.cluster_name)",
                "requires_js": true,
                "script": [
                  "tsh",
                  "clusters",
                  "--format=json"
                ]
              }
            ],
            "name": "Teleport proxy address"
          },
          "description": "SSH proxy address",
          "name": [
            "--proxy"
          ]
        },
        {
          "args": {
            "generators": [
              {
                "js_source": "t=>[JSON.parse(t).active.username]",
                "requires_js": true,
                "script": [
                  "tsh",
                  "status",
                  "--format",
                  "json"
                ]
              }
            ],
            "name": "user"
          },
          "description": "SSH proxy user",
          "name": [
            "--user"
          ]
        },
        {
          "args": {
            "name": "time"
          },
          "description": "Minutes to live for a SSH session",
          "name": [
            "--ttl"
          ]
        },
        {
          "args": {
            "name": "file",
            "template": "filepaths"
          },
          "description": "Identity file",
          "name": [
            "-i",
            "--identity"
          ]
        },
        {
          "args": {},
          "description": "SSH certificate format",
          "name": [
            "--cert-format"
          ]
        },
        {
          "description": "Do not verify server's certificate and host name. Use only in test environments",
          "name": [
            "--insecure"
          ]
        },
        {
          "args": {},
          "description": "Specify the name of authentication connector to use",
          "name": [
            "--auth"
          ]
        },
        {
          "description": "Skip version checking between server and client",
          "name": [
            "--skip-version-check"
          ]
        },
        {
          "description": "Verbose logging to stdout",
          "name": [
            "-d",
            "--debug"
          ]
        },
        {
          "description": "Controls how keys are handled. Valid values are [auto no yes only]",
          "name": [
            "-k",
            "--add-keys-to-agent"
          ]
        },
        {
          "description": "Enable support for SSH escape sequences. Type '~?' during an SSH session to list supported sequences. Default is enabled",
          "name": [
            "--enable-escape-sequences"
          ]
        },
        {
          "description": "Override host:port used when opening a browser for cluster logins",
          "name": [
            "--bind-addr"
          ]
        },
        {
          "description": "SSH jumphost",
          "name": [
            "-J",
            "--jumphost"
          ]
        },
        {
          "args": {
            "name": "format",
            "suggestions": [
              {
                "name": "text"
              },
              {
                "name": "json"
              },
              {
                "name": "yaml"
              }
            ]
          },
          "description": "Format output",
          "name": [
            "-f",
            "--format"
          ]
        },
        {
          "description": "Quiet mode",
          "name": [
            "-q",
            "--quiet"
          ]
        }
      ]
    },
