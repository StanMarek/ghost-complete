{
  "description": "Background job framework for Ruby",
  "name": "sidekiq",
  "options": [
    {
      "args": {
        "name": "INT"
      },
      "description": "Processor threads to use",
      "name": [
        "--concurrency",
        "-c"
      ]
    },
    {
      "args": {
        "name": "ENV"
      },
      "description": "Application environment",
      "name": [
        "--environment",
        "-e"
      ]
    },
    {
      "args": {
        "name": "TAG"
      },
      "description": "Process tag for procline",
      "name": [
        "--tag",
        "-g"
      ]
    },
    {
      "args": [
        {
          "name": "QUEUE"
        },
        {
          "isOptional": true,
          "name": "WEIGHT"
        }
      ],
      "description": "Queues to process with optional weights",
      "name": [
        "--queue",
        "-q"
      ]
    },
    {
      "args": {
        "name": "PATH|DIR",
        "template": [
          "folders",
          "filepaths"
        ]
      },
      "description": "Location of Rails application with jobs or file to require",
      "name": [
        "--require",
        "-r"
      ]
    },
    {
      "args": {
        "name": "NUM"
      },
      "description": "Shutdown timeout",
      "name": [
        "--timeout",
        "-t"
      ]
    },
    {
      "description": "Print more verbose output",
      "name": [
        "--verbose",
        "-v"
      ]
    },
    {
      "args": {
        "generators": [
          {
            "js_source": "(h,v,O)=>ae(this,void 0,void 0,function*(){var d;let{isDangerous:_,currentWorkingDirectory:b,searchTerm:p}=O,w=(d=(0,y.getCurrentInsertedDirectory)(a??b,p,O))!==null&&d!==void 0?d:\"/\";try{let D=yield v({command:\"ls\",args:[\"-1ApL\"],cwd:w}),X=k(D.stdout.split(`\n`),[\".DS_Store\"]),N=[];for(let V of X)if(V){let F=V.endsWith(\"/\")?\"folders\":\"filepaths\";(F===\"filepaths\"&&c!==\"only\"||F===\"folders\"&&c!==\"never\")&&N.push({type:F===\"filepaths\"?\"file\":\"folder\",name:V,insertValue:V,isDangerous:_,context:{templateType:F}})}return S(g(N))}catch{return[]}})",
            "requires_js": true
          }
        ],
        "name": "PATH"
      },
      "description": "Path to YAML config file",
      "name": [
        "--config",
        "-C"
      ]
    },
    {
      "description": "Show help for sidekiq run",
      "name": [
        "--help",
        "-h"
      ]
    },
    {
      "description": "Print version and exit",
      "name": [
        "--version",
        "-V"
      ]
    }
  ]
}
