        {
          "description": "Show help for command",
          "name": [
            "--help",
            "-h"
          ],
          "priority": 1
        },
        {
          "description": "Displays all commands available in the CLI",
          "name": [
            "--all"
          ],
          "priority": 1
        }
      ]
    },
    {
      "description": "Infra service",
