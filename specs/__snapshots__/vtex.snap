              "description": "Show help for command",
              "name": [
                "--help",
                "-h"
              ],
              "priority": 1
            }
          ]
        }
      ]
    },
    {
      "args": {
        "description": "Command to show help about",
        "isOptional": true,
        "name": "COMMAND"
      },
      "description": "Displays help for VTEX CLI commands",
      "name": "help",
