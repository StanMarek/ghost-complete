          ]
        }
      ]
    },
    {
      "args": {
        "description": "Name of the npm script to run",
        "generators": [
          {
            "js_source": "e=>{let a=e.split(\"END\").filter(i=>i.trim()!==\"\"),r=[];return a.forEach(i=>{let m=JSON.parse(i);r=r.concat(Object.keys(m.scripts))}),Array.from(new Set(r)).map(i=>({name:i,icon:\"fig://icon?type=npm\"}))}",
            "requires_js": true,
            "script": [
              "bash",
              "-c",
              "lerna list -p | while read p; do\n \\cat $p/package.json && echo END\ndone"
            ]
          }
        ],
        "name": "script"
      },
      "description": "Run an npm script in each package that contains that script",
      "name": "run",
      "options": [
        {
          "description": "How many threads to use when Lerna parallelizes the tasks (defaults to count of logical CPU cores)",
          "name": [
            "--concurrency"
