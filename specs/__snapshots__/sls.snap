              },
              {
                "name": "ca-central-1"
              },
              {
                "name": "cn-north-1"
              },
              {
                "name": "cn-northwest-1"
              },
              {
                "name": "eu-central-1"
              },
              {
                "name": "eu-west-1"
              },
              {
                "name": "eu-west-2"
              },
              {
                "name": "eu-south-1"
              },
              {
