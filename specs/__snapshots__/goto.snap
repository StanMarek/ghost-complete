{
  "args": {
    "generators": [
      {
        "js_source": "async(c,a,r)=>{let{stdout:n}=await a({command:\"cat\",args:[`${r.environmentVariables.HOME}/.config/goto`]}),t=new Map;for(let s of n.split(`\n`)){let o=s.split(\" \");t.set(s,{name:o[0],description:\"Goto \"+o[1],icon:\"\\u{1F516}\",priority:80})}return[...t.values()]}",
        "requires_js": true
      }
    ],
    "name": "alias"
  },
  "name": "goto",
  "options": [
    {
      "description": "Show help for goto",
      "name": [
        "--help",
        "-h"
      ]
    },
    {
      "args": [
        {
          "name": "alias"
        },
        {
          "name": "target",
          "template": "folders"
        }
      ],
      "description": "Registers an alias",
      "name": [
        "--register",
        "-r"
      ]
    },
    {
      "args": {
        "generators": [
          {
            "js_source": "async(c,a,r)=>{let{stdout:n}=await a({command:\"cat\",args:[`${r.environmentVariables.HOME}/.config/goto`]}),t=new Map;for(let s of n.split(`\n`)){let o=s.split(\" \");t.set(s,{name:o[0],description:\"Goto \"+o[1],icon:\"\\u{1F516}\",priority:80})}return[...t.values()]}",
            "requires_js": true
          }
        ],
        "name": "alias"
      },
      "description": "Unregister an alias",
      "name": [
        "--unregister",
        "-u"
      ]
    },
    {
      "description": "Pushes the current directory onto the stack, then performs goto",
      "name": [
        "--push",
        "-p"
      ]
    },
    {
      "description": "Pops the top directory from the stack, then changes to that directory",
      "name": [
        "--pop",
        "-o"
      ]
    },
    {
      "description": "Pops the top directory from the stack, then changes to that directory",
      "name": [
        "--list",
        "-l"
      ]
    },
    {
      "args": {
        "generators": [
          {
            "js_source": "async(c,a,r)=>{let{stdout:n}=await a({command:\"cat\",args:[`${r.environmentVariables.HOME}/.config/goto`]}),t=new Map;for(let s of n.split(`\n`)){let o=s.split(\" \");t.set(s,{name:o[0],description:\"Goto \"+o[1],icon:\"\\u{1F516}\",priority:80})}return[...t.values()]}",
            "requires_js": true
          }
        ],
        "name": "alias"
      },
      "description": "Expands an alias",
      "name": [
        "--expand",
        "-x"
