    {
      "args": {
        "name": "channelId"
      },
      "description": "Create a Firebase Hosting channel",
      "name": "hosting:channel:create",
      "options": [
        {
          "args": {},
          "description": "Duration string (e.g. 12h or 30d) for channel expiration, max 30d",
          "name": [
