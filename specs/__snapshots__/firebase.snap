    {
      "args": {
        "name": "channelId"
      },
      "description": "Delete a Firebase Hosting channel",
      "name": "hosting:channel:delete",
      "options": [
        {
          "args": {},
          "description": "Site in which the channel exists",
          "name": [
            "--site"
          ]
