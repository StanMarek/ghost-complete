{
  "description": "Mypy is a static type checker for Python",
  "name": "mypy",
  "options": [
    {
      "description": "Asks mypy to type check the provided module",
      "name": [
        "--module"
      ]
    },
    {
      "description": "Asks mypy to type check the provided package",
      "name": [
        "--package"
      ]
    },
    {
      "description": "Asks mypy to type check the provided string as a program",
      "name": [
        "--command"
      ]
    },
    {
      "description": "A regular expression that matches file names, directory names and paths which mypy should ignore while recursively discovering files to check",
      "name": [
        "--exclude"
      ]
    },
    {
      "description": "Show help message and exit",
      "name": [
        "--help"
      ]
    },
    {
      "description": "More verbose messages",
      "name": [
        "--verbose"
      ]
    },
    {
      "description": "Show program's version number and exit",
      "name": [
        "--version"
      ]
    },
    {
      "description": "This flag makes mypy read configuration settings from the given file",
      "name": [
        "--config-file"
      ]
    },
    {
      "description": "This flag makes mypy warn about unused [mypy-<pattern>] config file sections",
      "name": [
        "--warn-unused-configs"
      ]
    },
    {
      "description": "This flag tells mypy that top-level packages will be based in either the current directory, or a member of the MYPYPATH environment variable",
      "name": [
        "--explicit-package-bases"
      ]
    },
    {
      "description": "This flag makes mypy ignore all missing imports",
      "name": [
        "--ignore-missing-imports"
      ]
    },
    {
      "description": "This flag adjusts how mypy follows imported modules that were not explicitly passed in via the command line",
      "name": [
        "silent"
      ]
    },
    {
      "description": "This flag will have mypy collect type information from PEP561 compliant packages installed for the Python executable EXECUTABLE",
      "name": [
        "--python-executable"
      ]
    },
    {
      "description": "This flag will disable searching for PEP561 compliant packages",
      "name": [
        "--no-site-packages"
      ]
    },
    {
      "description": "By default, mypy will suppress any error messages generated within PEP561 compliant packages",
      "name": [
        "--no-silence-site-packages"
      ]
    },
    {
      "description": "The default logic used to scan through search paths to resolve imports has a quadratic worse-case behavior in some cases, which is for instance triggered by a large number of folders sharing",
      "name": [
        "--fast-module-lookup"
      ]
    },
    {
      "description": "This flag disables import discovery of namespace packages (see PEP420)",
      "name": [
        "--no-namespace-packages"
      ]
    },
    {
      "description": "This flag will make mypy type check your code as if it were run under Python version X",
      "name": [
        "--python-version"
      ]
    },
    {
      "description": "This flag will make mypy type check your code as if it were run under the given operating system",
      "name": [
        "--platform"
      ]
    },
    {
      "description": "This flag will treat all variables named NAME as compile-time constants that are always true",
      "name": [
        "--always-true"
      ]
    },
    {
      "description": "This flag will treat all variables named NAME as compile-time constants that are always false",
      "name": [
        "--always-false"
      ]
    },
    {
      "description": "This flag disallows usage of types that come from unfollowed imports (such types become aliases for Any)",
      "name": [
        "--disallow-any-unimported"
      ]
    },
    {
      "description": "This flag disallows all expressions in the module that have type Any",
      "name": [
        "--disallow-any-expr"
      ]
    },
    {
      "description": "This flag disallows functions that have Any in their signature after decorator transformation",
      "name": [
        "--disallow-any-decorated"
      ]
    },
    {
      "description": "This flag disallows explicit Any in type positions such as type annotations and generic type parameters",
      "name": [
        "--disallow-any-explicit"
      ]
    },
    {
      "description": "This flag disallows usage of generic types that do not specify explicit type parameters",
      "name": [
        "--disallow-any-generics"
      ]
    },
    {
      "description": "This flag reports an error whenever a class subclasses a value of type Any",
      "name": [
        "--disallow-subclassing-any"
      ]
    },
    {
      "description": "This flag reports an error whenever a function with type annotations calls a function defined without annotations",
      "name": [
        "--disallow-untyped-calls"
      ]
    },
    {
      "description": "This flag allows to selectively disable option--disallow-untyped-calls for functions and methods defined in specific packages, modules, or classes",
      "name": [
        "--untyped-calls-exclude"
      ]
    },
    {
      "description": "This flag reports an error whenever it encounters a function definition without type annotations or with incomplete type annotations",
      "name": [
        "--disallow-untyped-defs"
      ]
    },
    {
      "description": "This flag reports an error whenever it encounters a partly annotated function definition, while still allowing entirely unannotated definitions",
      "name": [
        "--disallow-incomplete-defs"
      ]
    },
    {
      "description": "This flag is less severe than the previous two options -- it type checks the body of every function, regardless of whether it has type annotations",
      "name": [
        "--check-untyped-defs"
      ]
    },
    {
      "description": "This flag reports an error whenever a function with type annotations is decorated with a decorator without annotations",
      "name": [
        "--disallow-untyped-decorators"
      ]
    },
    {
      "description": "This flag causes mypy to treat arguments with a None default value as having an implicit pydata~typing",
      "name": [
        "--implicit-optional"
      ]
    },
    {
      "description": "This flag disables strict checking of pydata~typing",
      "name": [
        "--no-strict-optional"
      ]
    },
    {
      "description": "This flag will make mypy report an error whenever your code uses an unnecessary cast that can safely be removed",
      "name": [
        "--warn-redundant-casts"
      ]
    },
    {
      "description": "This flag will make mypy report an error whenever your code uses a # type ignore comment on a line that is not actually generating an error message",
      "name": [
        "--warn-unused-ignores"
      ]
    },
    {
      "description": "By default, mypy will generate errors when a function is missing return statements in some execution paths",
      "name": [
        "--no-warn-no-return"
      ]
    },
    {
      "description": "This flag causes mypy to generate a warning when returning a value with type Any from a function declared with a non-Any return type",
      "name": [
        "--warn-return-any"
      ]
    },
    {
      "description": "This flag will make mypy report an error whenever it encounters code determined to be unreachable or redundant after performing type analysis",
      "name": [
        "--warn-unreachable"
      ]
    },
    {
      "description": "This flag causes mypy to suppress errors caused by not being able to fully infer the types of global and class variables",
      "name": [
        "--allow-untyped-globals"
      ]
    },
    {
      "description": "By default, mypy won't allow a variable to be redefined with an unrelated type",
      "name": [
        "--allow-redefinition"
      ]
    },
    {
      "description": "In mypy, the most common cases for partial types are variables initialized using None, but without explicit Optional annotations",
      "name": [
        "--local-partial-types"
      ]
    },
    {
      "description": "By default, imported values to a module are treated as exported and mypy allows other modules to import them",
      "name": [
        "--no-implicit-reexport"
      ]
    },
    {
      "description": "By default, mypy allows always-false comparisons like 42 == 'no'",
      "name": [
        "--strict-equality"
      ]
    },
    {
      "description": "This flag enables additional checks that are technically correct but may be impractical in real code",
      "name": [
        "--extra-checks"
      ]
    },
    {
      "description": "This flag mode enables all optional error checking flags",
      "name": [
        "--strict"
      ]
    },
    {
      "description": "This flag allows disabling one or multiple error codes globally",
      "name": [
        "--disable-error-code"
      ]
    },
    {
      "description": "This flag allows enabling one or multiple error codes globally",
      "name": [
        "--enable-error-code"
      ]
    },
    {
      "description": "This flag will precede all errors with 'note' messages explaining the context of the error",
      "name": [
        "--show-error-context"
      ]
    },
    {
      "description": "This flag will add column offsets to error messages",
      "name": [
        "--show-column-numbers"
      ]
    },
    {
      "description": "This flag will make mypy show not just that start position where an error was detected, but also the end position of the relevant expression",
      "name": [
        "--show-error-end"
      ]
    },
    {
      "description": "This flag will hide the error code [<code>] from error messages",
      "name": [
        "--hide-error-codes"
      ]
    },
    {
      "description": "Use visually nicer output in error messages use soft word wrap, show source code snippets, and show error location markers",
      "name": [
        "--pretty"
      ]
    },
    {
      "description": "This flag will disable color output in error messages, enabled by default",
      "name": [
        "--no-color-output"
      ]
    },
    {
      "description": "This flag will disable error summary",
      "name": [
        "--no-error-summary"
      ]
    },
    {
      "description": "Show absolute paths to files",
      "name": [
        "--show-absolute-path"
      ]
    },
    {
      "description": "This flag will adjust the limit after which mypy will (sometimes) disable reporting most additional errors",
      "name": [
        "--soft-error-limit"
      ]
    },
    {
      "description": "This flag disables incremental mode mypy will no longer reference the cache when re-run",
      "name": [
        "--no-incremental"
      ]
    },
    {
      "description": "By default, mypy stores all cache data inside of a folder named",
      "name": [
        "--cache-dir"
      ]
    },
    {
      "description": "Use an SQLite_ database to store the cache",
      "name": [
        "--sqlite-cache"
      ]
    },
    {
      "description": "Include fine-grained dependency information in the cache for the mypy daemon",
      "name": [
        "--cache-fine-grained"
      ]
    },
    {
      "description": "By default, mypy will ignore cache data generated by a different version of mypy",
      "name": [
        "--skip-version-check"
      ]
    },
    {
      "description": "Skip cache internal consistency checks based on mtime",
      "name": [
        "--skip-cache-mtime-checks"
      ]
    },
    {
      "description": "This flag will invoke the Python debugger when mypy encounters a fatal error",
      "name": [
        "--pdb"
      ]
    },
    {
      "description": "If set, this flag will display a full traceback when mypy encounters a fatal error",
      "name": [
        "--tb"
      ]
    },
    {
      "description": "Raise exception on fatal error",
      "name": [
        "--raise-exceptions"
      ]
    },
    {
      "description": "This flag lets you use a custom module as a substitute for the pymodtyping module",
      "name": [
        "--custom-typing-module"
      ]
    },
    {
      "description": "This flag specifies the directory where mypy looks for standard library typeshed stubs, instead of the typeshed that ships with mypy",
      "name": [
        "--custom-typeshed-dir"
      ]
    },
    {
      "description": "This flag modifies both the option--disallow-untyped-defs and option--disallow-incomplete-defs flags so they also report errors if stubs in typeshed are missing type annotations or has incomplete annotations",
      "name": [
        "--warn-incomplete-stub"
      ]
    },
    {
      "description": "When mypy is asked to type check SOURCE_FILE, this flag makes mypy read from and type check the contents of SHADOW_FILE instead",
      "name": [
        "--shadow-file"
      ]
    },
    {
      "description": "Causes mypy to generate a text file report documenting how many expressions of type Any are present within your codebase",
      "name": [
        "--any-exprs-report"
      ]
    },
    {
      "description": "Causes mypy to generate a Cobertura XML type checking coverage report",
      "name": [
        "--cobertura-xml-report"
      ]
    },
    {
      "description": "Causes mypy to generate an HTML type checking coverage report",
      "name": [
        "--html-report"
      ]
    },
    {
      "description": "Causes mypy to generate a text file report documenting the functions and lines that are typed and untyped within your codebase",
      "name": [
        "--linecount-report"
      ]
    },
    {
      "description": "Causes mypy to generate a JSON file that maps each source file's absolute filename to a list of line numbers that belong to typed functions in that file",
      "name": [
        "--linecoverage-report"
      ]
    },
    {
      "description": "Causes mypy to generate a flat text file report with per-module statistics of how many lines are typechecked etc",
      "name": [
        "--lineprecision-report"
      ]
    },
    {
      "description": "Causes mypy to generate a text file type checking coverage report",
      "name": [
        "--txt-report"
      ]
    },
    {
      "description": "Causes mypy to generate an XML type checking coverage report",
      "name": [
        "--xml-report"
      ]
    },
    {
      "description": "This flag causes mypy to install known missing stub packages for third-party libraries using pip",
      "name": [
        "--install-types"
      ]
    },
    {
      "description": "When used together with option--install-types <mypy --install-types>, this causes mypy to install all suggested stub packages using pip without asking for confirmation, and then continues to perform type checking using the installed stubs, if some files or modules are provided to type check",
      "name": [
        "--non-interactive"
      ]
    },
    {
      "description": "Causes mypy to generate a JUnit XML test result document with type checking results",
      "name": [
        "--junit-xml"
      ]
    },
    {
      "description": "This flag will make mypy print out all usages of a class member based on static type information",
      "name": [
        "--find-occurrences"
      ]
    },
    {
      "description": "This flag will give command line arguments that appear to be scripts",
      "name": [
        "--scripts-are-modules"
      ]
    }
  ]
}
