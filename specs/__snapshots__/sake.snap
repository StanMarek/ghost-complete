{
  "description": "🍶 Swift-based utility for managing project commands, inspired by Make",
  "name": "sake",
  "options": [
    {
      "description": "Show help information",
      "name": [
        "--help",
        "-h"
      ]
    },
    {
      "description": "Show the version",
      "name": [
        "--version"
      ]
    }
  ],
  "subcommands": [
    {
      "description": "Initialize a new SakeApp project template for defining commands",
      "name": "init",
      "options": [
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Specify the path to the configuration file",
          "name": [
            "--config-path",
            "-c"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "folders"
          },
          "description": "Specify the path for the SakeApp package",
          "name": [
            "--sake-app-path",
            "-s"
          ]
        }
      ]
    },
    {
      "description": "Remove all build artifacts generated by the SakeApp to ensure a clean state for future builds",
      "name": "clean",
      "options": [
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Specify the path to the configuration file",
          "name": [
            "--config-path",
            "-c"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "folders"
          },
          "description": "Specify the path for the SakeApp package",
          "name": [
            "--sake-app-path",
            "-s"
          ]
        }
      ]
    },
    {
      "description": "Open the SakeApp in Xcode (macOS only)",
      "name": "edit",
      "options": [
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Specify the path to the configuration file",
          "name": [
            "--config-path",
            "-c"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "folders"
          },
          "description": "Specify the path for the SakeApp package",
          "name": [
            "--sake-app-path",
            "-s"
          ]
        }
      ]
    },
    {
      "description": "List all available commands defined in the SakeApp",
      "name": "list",
      "options": [
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Specify the path to the configuration file",
          "name": [
            "--config-path",
            "-c"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "folders"
          },
          "description": "Specify the path for the SakeApp package",
          "name": [
            "--sake-app-path",
            "-s"
          ]
        },
        {
          "args": {
            "name": "strategy",
            "suggestions": [
              {
                "name": "keepOriginal"
              },
              {
                "name": "toSnakeCase"
              },
              {
                "name": "toKebabCase"
              }
            ]
          },
          "description": "Specify the strategy for converting command names' case",
          "name": [
            "--case-converting-strategy"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Specify the path to the prebuilt SakeApp binary",
          "name": [
            "--sake-app-prebuilt-binary-path",
            "-b"
          ]
        },
        {
          "description": "Output the list of commands in JSON format",
          "name": [
            "--json",
            "-j"
          ]
        }
      ]
    },
    {
      "description": "Manually trigger a rebuild of the SakeApp",
      "name": "build",
      "options": [
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Specify the path to the configuration file",
          "name": [
            "--config-path",
            "-c"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "folders"
          },
          "description": "Specify the path for the SakeApp package",
          "name": [
            "--sake-app-path",
            "-s"
          ]
        },
        {
          "description": "Print the path to the built SakeApp executable",
          "name": [
            "--show-bin-path"
          ]
        }
      ]
    },
    {
      "args": {
        "description": "The command to run",
        "generators": [
          {
            "js_source": "s=>{let t=JSON.parse(s);return Object.keys(t.groups).reduce((a,i)=>{let r=t.groups[i];return[...a,...r.map(n=>({name:n.name,description:n.description,priority:76,icon:\"\\u{1F376}\"}))]},[])}",
            "requires_js": true,
            "script": [
              "sake",
              "list",
              "--json"
            ]
          }
        ],
        "name": "command"
      },
      "description": "Run the specified command from the SakeApp",
      "name": "run",
      "options": [
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Specify the path to the configuration file",
          "name": [
            "--config-path",
            "-c"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "folders"
          },
          "description": "Specify the path for the SakeApp package",
          "name": [
            "--sake-app-path",
            "-s"
          ]
        },
        {
          "args": {
            "name": "strategy",
            "suggestions": [
              {
                "name": "keepOriginal"
              },
              {
                "name": "toSnakeCase"
              },
              {
                "name": "toKebabCase"
              }
            ]
          },
          "description": "Specify the strategy for converting command names' case",
          "name": [
            "--case-converting-strategy"
          ]
        },
        {
          "args": {
            "name": "path",
            "template": "filepaths"
          },
          "description": "Specify the path to the prebuilt SakeApp binary",
          "name": [
            "--sake-app-prebuilt-binary-path",
            "-b"
          ]
        }
      ]
    }
  ]
}
