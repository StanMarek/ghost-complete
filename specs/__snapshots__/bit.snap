        "description": "Pattern for components to match"
      },
      "description": "List the component ids matching the given pattern",
      "name": "pattern",
      "options": [
        {
          "description": "Return the output as JSON",
          "name": [
            "--json",
            "-j"
          ]
        }
      ]
    },
    {
      "args": {
        "description": "Component name to recover"
      },
      "description": "EXPERIMENTAL. Recover component(s) soft-deleted from the workspace, or a remote scope",
      "name": "recover",
      "options": [
        {
          "description": "Do not install packages in case of importing components",
          "name": [
            "--skip-dependency-installation",
            "-x"
          ]
        }
      ]
    },
    {
      "args": [
        {
          "description": "Component name, ID, or pattern"
        },
        {
          "description": "Permitted values: [main, specific-version]"
        }
      ],
      "description": "Replace the current component files by the specified version, leave the version intact",
      "name": "revert",
      "options": [
        {
          "description": "Showing verbose output for inspection",
          "name": [
            "--verbose",
            "-v"
          ]
        },
        {
          "description": "Do not install packages of the imported components",
          "name": [
            "--skip-dependency-installation",
            "-x"
          ]
        }
      ]
    },
    {
      "description": "Manage the scope-name for components\n\nbit scope <sub-command>",
      "name": "scope",
      "subcommands": [
        {
          "args": [
            {
              "description": "Name of the scope to set"
            },
            {
              "description": "Component name, ID, or pattern"
            }
          ],
          "description": "Sets the scope for specified component/s. If no component is specified, sets the default scope of the workspace. Default scopes for components are set in the bitmap file. The default scope for a workspace is set in the workspace.jsonc. A component is set with a scope (as opposed to default scope) only once it is versioned. You can use a pattern for multiple component ids, such as bit scope set scope-name \"org.scope/utils/**\". Use comma to separate patterns and '!' to exclude. Always wrap the pattern with single quotes to avoid collision with shell commands.\n\nUsage: scope set <scope-name> [component-pattern]",
          "name": "set"
        },
        {
          "args": [
            {
              "description": "The current scope name"
            },
            {
              "description": "The new scope name"
            }
          ],
          "description": "Renames the scope name for all components with the specified 'current scope name' - only available for new components that have not yet been snapped/tagged. If <current-scope-name> is also the defaultScope for the workspace, this command will set <new-scope-name> as the defaultScope instead.\n\nUsage: scope rename <current-scope-name> <new-scope-name>",
          "name": "rename",
          "options": [
            {
              "description": "Update the import statements in all dependent components",
              "name": [
                "--refactor",
                "-r"
              ]
            }
          ]
        },
        {
          "args": [
            {
              "description": "The current owner name"
            },
            {
              "description": "The new owner name"
            }
          ],
          "description": "Renames the owner part of the scope-name for all components with the specified 'current owner name'.\n\nUsage: scope rename-owner <current-owner-name> <new-owner-name>",
          "name": "rename-owner",
          "options": [
            {
              "description": "Update the import statements in all dependent components",
              "name": [
                "--refactor",
                "-r"
              ]
            },
            {
              "description": "EXPERIMENTAL. Use AST to transform files instead of regex",
              "name": [
                "--ast"
              ]
            }
          ]
        },
        {
          "description": "Fork all components of the original-scope and refactor the source-code to use the new scope name.\n\nUsage: scope fork <original-scope> <new-scope>",
          "name": "fork",
          "options": [
            {
              "description": "EXPERIMENTAL. Use AST to transform files instead of regex",
              "name": [
                "--ast"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "EXPERIMENTAL. Communicate with bit CLI program via HTTP requests\n\nbit server",
      "name": "server",
      "options": [
        {
          "description": "Port to run the server on",
          "name": [
            "--port",
            "-p"
          ]
        }
      ]
    },
    {
      "description": "System operations\n\nbit system <sub-command>",
      "name": "system",
      "subcommands": [
        {
          "description": "Print debug.log to the screen\n\nUsage: system log",
          "name": "log"
        }
      ]
    },
    {
      "args": {
        "description": "Component name, component ID, or component pattern. Use component pattern to select multiple components. Use comma to separate patterns and \"!\" to exclude. E.g. \"ui/**, !ui/button\". Wrap the pattern with quotes. By default, only new and modified components are snapped (add --unmodified to snap all components in the workspace)"
      },
      "description": "Create an immutable and exportable component snapshot (non-release version)\n\nbit snap [component-pattern]",
      "name": "snap",
      "options": [
        {
          "description": "Snap message describing the latest changes - will appear in component history log",
          "name": [
            "--message",
            "-m"
          ]
        },
        {
          "description": "Include unmodified components (by default, only new and modified components are snapped)",
          "name": [
            "--unmodified"
          ]
        },
        {
          "description": "Complete a merge process by snapping the unmerged components",
          "name": [
            "--unmerged"
          ]
        },
        {
          "description": "Not needed for now. Run the build pipeline locally in case the feature-flag build-on-ci is enabled",
          "name": [
            "--build",
            "-b"
          ]
        },
        {
          "description": "Open an editor to write a snap message per component. Optionally specify the editor-name (defaults to vim)",
          "name": [
            "--editor"
          ]
        },
        {
          "description": "Skip running component tests during snap process",
          "name": [
            "--skip-tests"
          ]
        },
        {
          "description": "Skip auto snapping dependents",
          "name": [
            "--skip-auto-snap"
          ]
        },
        {
          "description": "Skip the snap pipeline. This will for instance skip packing and publishing component version for install, and app deployment",
          "name": [
            "--disable-snap-pipeline"
          ]
        },
        {
          "description": "Proceed to snap pipeline even when build pipeline fails",
          "name": [
            "--ignore-build-errors"
          ]
        },
        {
          "description": "Ignore component issues (shown in \"bit status\" as \"issues found\"), issues to ignore: [MissingPackagesDependenciesOnFs, MissingManuallyConfiguredPackages, MissingComponents, UntrackedDependencies, ResolveErrors, RelativeComponents, RelativeComponentsAuthored, ParseErrors, MissingDists, LegacyInsideHarmony, MissingDependenciesOnFs, ImportNonMainFiles, MultipleEnvs, MissingLinksFromNodeModulesToSrc, CircularDependencies, DuplicateComponentAndPackage, MergeConfigHasConflict, NonLoadedEnv, ExternalEnvWithoutVersion, RemovedDependencies] to ignore multiple issues, separate them by a comma and wrap with quotes. To ignore all issues, specify \"*\"",
          "name": [
            "--ignore-issues",
            "-i"
          ]
        },
        {
          "description": "DEPRECATED (not needed anymore, now the default). Snap all new and modified components",
          "name": [
            "--all",
            "-a"
          ]
        },
        {
          "description": "Stop pipeline execution on the first failed task (by default a task is skipped only when its dependency failed)",
          "name": [
            "--fail-fast"
          ]
        },
        {
          "description": "DEPRECATED (use \"--skip-tests\" or \"--unmodified\" instead). Force-snap even if tests are failing and even when component has not changed",
          "name": [
            "--force",
            "-f"
          ]
        }
      ]
    },
    {
      "description": "Automatically recompile modified components (on save). By default, the watcher doesn't use polling, to keep the CPU idle. In some rare cases, this could result in missing file events (files are not watched). To fix it, try to stop other watchers on the same machine. Alternatively, to use polling, run \"bit config set watch_use_polling true\".\n\nbit watch",
      "name": "watch",
      "options": [
        {
          "description": "Show all watch events and compiler verbose output",
          "name": [
            "--verbose",
            "-v"
          ]
        },
        {
          "description": "Skip compilation step before starting to watch",
          "name": [
            "--skip-pre-compilation"
          ]
        },
        {
          "description": "EXPERIMENTAL. Show errors/warnings for types. Options are [file, project] to investigate only changed file or entire project. Defaults to project",
          "name": [
            "--check-types",
            "-t"
          ]
        }
      ]
    },
    {
      "args": {
        "description": "The component ID of the aspect"
      },
      "description": "Set aspects in the workspace/scope config to make them loadable by the workspace/scope.\n\nbit use <component-id>",
      "name": "use"
    },
    {
      "description": "Manage workspace config files.\n\nbit ws-config <sub-command>",
      "name": "ws-config",
      "subcommands": [
        {
          "description": "EXPERIMENTAL. Write config files in the workspace. Useful for IDEs.\n\nws-config write",
          "name": "ws-config write",
          "options": [
            {
              "description": "Delete existing config files from the workspace. Highly recommended to run it with \"--dry-run\" first",
              "name": [
                "--clean",
                "-c"
              ]
            },
            {
              "description": "Only write config files for the given writers. Use comma to separate multiple writers. Use ws-config list to see all writers",
              "name": [
                "--writers",
                "-w"
              ]
            },
            {
              "description": "Do not prompt for confirmation",
              "name": [
                "--silent",
                "-s"
              ]
            },
            {
              "description": "Write configs inside each one of the component's dir, avoid deduping",
              "name": [
                "--no-dedupe"
              ]
            },
            {
              "description": "Show the paths that configs will be written per env",
              "name": [
                "--dry-run"
              ]
            },
            {
              "description": "Use with --json flag. Show the config content and the paths that will be written per env",
              "name": [
                "--dry-run-with-content"
              ]
            },
            {
              "description": "Showing verbose output for writing",
              "name": [
                "--verbose",
                "-v"
              ]
            },
            {
              "description": "JSON format",
              "name": [
                "--json",
                "-j"
              ]
            }
          ]
        },
        {
          "description": "EXPERIMENTAL. Clean (delete) written config files in the workspace. Useful for IDEs.\n\nws-config clean",
          "name": "ws-config clean",
          "options": [
            {
              "description": "Do not prompt for confirmation",
              "name": [
                "--silent",
                "-s"
              ]
            },
            {
              "description": "Only clean config files for the given writers. Use comma to separate multiple writers. Use ws-config list to see all writers",
              "name": [
                "--writers",
                "-w"
              ]
            },
            {
              "description": "Show the paths of configs that will be cleaned",
              "name": [
                "--dry-run"
              ]
            },
            {
              "description": "JSON format",
              "name": [
                "--json",
                "-j"
              ]
            }
          ]
        },
        {
          "description": "EXPERIMENTAL. List config writers.\n\nws-config list",
          "name": "ws-config list",
          "options": [
            {
              "description": "JSON format",
              "name": [
                "--json",
                "-j"
              ]
            }
          ]
        }
      ]
    }
  ]
}
