    {
      "args": {
        "description": "Component name, component id, or component pattern. Use component pattern to select multiple components. Use comma to separate patterns and \"!\" to exclude. e.g. \"ui/**, !ui/button\" wrap the pattern with quotes. By default, all new and modified are tagged"
      },
      "description": "Create an immutable and exportable component snapshot, tagged with a release version.\nIf no patterns are provided, it will tag all new and modified components.\nIf patterns are entered, you can specify a version per pattern using \"@\" sign, e.g. bit tag foo@1.0.0 bar@minor baz@major\n\nbit tag [component-patterns...]",
      "name": "tag",
      "options": [
        {
          "description": "A log message describing the latest changes",
          "name": [
            "--message",
            "-m"
          ]
        },
        {
          "description": "Include unmodified components (by default, only new and modified components are tagged)",
          "name": [
            "--unmodified",
            "-u"
          ]
        },
        {
          "description": "Open an editor to write a tag message for each component. Optionally, specify the editor-name (defaults to vim)",
          "name": [
            "--editor"
          ]
        },
        {
          "description": "Tag with the given version",
          "name": [
            "--ver",
            "-v"
          ]
        },
        {
          "description": "Options are: [major, premajor, minor, preminor, patch, prepatch, prerelease], default to patch",
          "name": [
            "--increment",
            "-l"
          ]
        },
        {
          "description": "Prerelease identifier (e.g. \"dev\" to get \"1.0.0-dev.1\")",
          "name": [
            "--prerelease-id"
          ]
        },
        {
          "description": "Syntactic sugar for \"--increment patch\"",
          "name": [
            "--patch",
            "-p"
          ]
        },
        {
          "description": "Syntactic sugar for \"--increment minor\"",
          "name": [
            "--minor"
          ]
        },
        {
          "description": "Syntactic sugar for \"--increment major\"",
          "name": [
            "--major"
          ]
        },
        {
          "description": "Syntactic sugar for \"--increment prerelease\" and --prerelease-id <identifier>",
          "name": [
            "--pre-release"
          ]
        },
        {
          "description": "Tag only components whose head is a snap (not a tag)",
          "name": [
            "--snapped"
          ]
        },
        {
          "description": "Complete a merge process by tagging the unmerged components",
          "name": [
            "--unmerged"
          ]
        },
        {
          "description": "Skip running component tests during tag process",
          "name": [
            "--skip-tests"
          ]
        },
        {
          "description": "Skip auto tagging dependents",
          "name": [
            "--skip-auto-tag"
          ]
        },
        {
          "description": "Do not persist. Only keep note of the changes to be made",
          "name": [
            "--soft"
          ]
        },
        {
          "description": "Persist the changes generated by --soft tag",
          "name": [
            "--persist"
          ]
        },
        {
          "description": "Skip the tag pipeline to avoid publishing the components",
          "name": [
            "--disable-tag-pipeline"
          ]
        },
        {
          "description": "Proceed to tag pipeline even when build pipeline fails",
          "name": [
            "--ignore-build-errors"
          ]
        },
        {
          "description": "(default to 1) increment semver flag (patch/minor/major) by. e.g. incrementing patch by 2: 0.0.1 -> 0.0.3",
          "name": [
            "--increment-by"
          ]
        },
        {
          "description": "Ignore component issues (shown in \"bit status\" as \"issues found\"), issues to ignore: [MissingPackagesDependenciesOnFs, MissingManuallyConfiguredPackages, MissingComponents, UntrackedDependencies, ResolveErrors, RelativeComponents, RelativeComponentsAuthored, ParseErrors, MissingDists, LegacyInsideHarmony, MissingDependenciesOnFs, ImportNonMainFiles, MultipleEnvs, MissingLinksFromNodeModulesToSrc, CircularDependencies, DuplicateComponentAndPackage, MergeConfigHasConflict, NonLoadedEnv, ExternalEnvWithoutVersion, RemovedDependencies] to ignore multiple issues, separate them by a comma and wrap with quotes. To ignore all issues, specify '*'",
          "name": [
            "--ignore-issues",
            "-i"
          ]
        },
        {
          "description": "Allow tagging even when the component has newer versions e.g. for hotfixes (default = false)",
          "name": [
            "--ignore-newest-version",
            "-I"
          ]
        },
        {
          "description": "Stop pipeline execution on the first failed task (by default a task is skipped only when its dependency failed)",
          "name": [
            "--fail-fast"
          ]
        },
        {
          "description": "Not needed for now. Run the pipeline build and complete the tag",
          "name": [
            "--build",
            "-b"
          ]
        },
        {
          "description": "DEPRECATED (not needed anymore, it is the default now). Tag all new and modified components",
          "name": [
            "--all",
            "-a"
          ]
        },
        {
          "description": "DEPRECATED (use \"--unmodified\" instead). Tag all components of the local scope",
          "name": [
            "--scope",
            "-s"
          ]
        },
        {
          "description": "DEPRECATED (use \"--skip-tests\", \"--ignore-build-errors\" or \"--unmodified\" instead). Force-tag even if tests are failing and even when component has not changed",
          "name": [
            "--force"
          ]
        },
        {
          "description": "DEPRECATED. Use --disable-tag-pipeline instead",
          "name": [
            "--disable-deploy-pipeline"
          ]
        }
      ]
