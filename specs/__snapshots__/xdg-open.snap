{
  "args": {
    "name": "FILE or URL",
    "template": "filepaths"
  },
  "description": "Opens a file or URL in the user's preferred application",
  "name": "xdg-open",
  "options": [
    {
      "description": "Show command synopsis",
      "name": [
        "--help"
      ]
    },
    {
      "description": "Show manual page",
      "name": [
        "--manual"
      ]
    },
    {
      "description": "Show the xdg-utils version information",
      "name": [
        "--version"
      ]
    }
  ]
}
