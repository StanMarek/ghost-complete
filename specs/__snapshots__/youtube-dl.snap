          },
          {
            "name": "az"
          },
          {
            "name": "bn"
          },
          {
            "name": "eu"
          },
          {
            "name": "be"
          },
          {
            "name": "bs"
          },
          {
            "name": "bg"
          },
          {
            "name": "my"
          },
          {
            "name": "ca"
          },
          {
            "name": "ceb"
          },
          {
            "name": "zh-Hans"
          },
          {
            "name": "zh-Hant"
          },
          {
