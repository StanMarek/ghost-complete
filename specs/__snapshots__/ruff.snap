          "name": [
            "--target-version"
          ]
        },
        {
          "description": "Enable preview mode; enables unstable formatting. Use `--no-preview` to disable",
          "name": [
            "--preview"
          ]
        },
        {
          "description": "Disable cache reads (env: RUFF_NO_CACHE=)",
          "name": [
            "-n",
            "--no-cache"
          ]
        },
