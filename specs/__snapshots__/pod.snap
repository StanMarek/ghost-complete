          "options": [
            {
              "description": "Allows CocoaPods to run as root",
              "name": [
                "--allow-root"
              ]
            }
          ]
        },
        {
          "args": {
            "isOptional": true,
            "name": "QUERY"
          },
          "description": "Prints a spec file",
          "name": "cat",
          "options": [
            {
              "description": "Interpret the `QUERY` as a regular expression",
              "name": [
                "--regex"
              ]
            },
            {
              "description": "Pick from all versions of the given podspec",
              "name": [
                "--show-all"
              ]
            },
            {
              "description": "Allows CocoaPods to run as root",
              "name": [
                "--allow-root"
              ]
            }
          ]
        },
        {
          "args": {
            "isOptional": true,
