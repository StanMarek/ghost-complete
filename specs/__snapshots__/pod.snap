          "options": [
            {
              "description": "Interpret the `QUERY` as a regular expression",
              "name": [
                "--regex"
              ]
            },
            {
              "description": "Print all versions of the given podspec",
              "name": [
                "--show-all"
              ]
            },
            {
              "description": "Allows CocoaPods to run as root",
              "name": [
                "--allow-root"
              ]
            }
          ]
        },
        {
          "args": {
            "generators": [
              {
                "js_source": "(m,f,b)=>de(this,void 0,void 0,function*(){var u;let{isDangerous:y,currentWorkingDirectory:A,searchTerm:h}=b,O=(u=(0,w.getCurrentInsertedDirectory)(l??A,h,b))!==null&&u!==void 0?u:\"/\";try{let V=yield f({command:\"ls\",args:[\"-1ApL\"],cwd:O}),K=H(V.stdout.split(`\n`),[\".DS_Store\"]),F=[];for(let R of K)if(R){let I=R.endsWith(\"/\")?\"folders\":\"filepaths\";(I===\"filepaths\"&&d!==\"only\"||I===\"folders\"&&d!==\"never\")&&F.push({type:I===\"filepaths\"?\"file\":\"folder\",name:R,insertValue:R,isDangerous:y,context:{templateType:I}})}return P(g(F))}catch{return[]}})",
