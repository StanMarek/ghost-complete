{
  "description": "The Typst compiler",
  "name": "typst",
  "options": [
    {
      "args": {
        "name": "cert",
        "template": "filepaths"
      },
      "description": "Path to a custom CA certificate to use when making network requests",
      "name": [
        "--cert"
      ]
    },
    {
      "description": "Sets the level of logging verbosity: -v = warning & error, -vv = info, -vvv = debug, -vvvv = trace",
      "name": [
        "-v",
        "--verbosity"
      ]
    },
    {
      "description": "Print help",
      "name": [
        "-h",
        "--help"
      ]
    },
    {
      "description": "Print version",
      "name": [
        "-V",
        "--version"
      ]
    }
  ],
  "subcommands": [
    {
      "args": [
        {
          "description": "Path to input Typst file",
          "generators": [
            {
              "js_source": "(p,m,_)=>ce(this,void 0,void 0,function*(){var d;let{isDangerous:b,currentWorkingDirectory:O,searchTerm:h}=_,w=(d=(0,v.getCurrentInsertedDirectory)(c??O,h,_))!==null&&d!==void 0?d:\"/\";try{let E=yield m({command:\"ls\",args:[\"-1ApL\"],cwd:w}),Z=$(E.stdout.split(`\n`),[\".DS_Store\"]),N=[];for(let A of Z)if(A){let V=A.endsWith(\"/\")?\"folders\":\"filepaths\";(V===\"filepaths\"&&u!==\"only\"||V===\"folders\"&&u!==\"never\")&&N.push({type:V===\"filepaths\"?\"file\":\"folder\",name:A,insertValue:A,isDangerous:b,context:{templateType:V}})}return x(g(N))}catch{return[]}})",
              "requires_js": true
            }
          ],
          "name": "input"
        },
        {
          "description": "Path to output file (PDF, PNG, or SVG)",
          "isOptional": true,
          "name": "output",
          "template": "filepaths"
        }
      ],
      "description": "Compiles an input file into a supported output format",
      "name": "compile",
      "options": [
        {
          "args": {
            "name": "root",
            "template": "folders"
          },
          "description": "Configures the project root (for absolute paths)",
          "name": [
            "--root"
          ]
        },
        {
          "args": {
            "name": "font_paths",
            "template": "filepaths"
          },
          "description": "Adds additional directories to search for fonts",
          "name": [
            "--font-path"
          ]
        },
        {
          "args": {
            "name": "diagnostic_format",
            "suggestions": [
              {
                "name": "human"
              },
              {
                "name": "short"
              }
            ]
          },
          "description": "The format to emit diagnostics in",
          "name": [
            "--diagnostic-format"
          ]
        },
        {
          "args": {
            "name": "format",
            "suggestions": [
              {
                "name": "pdf"
              },
              {
                "name": "png"
              },
              {
                "name": "svg"
              }
            ]
          },
          "description": "The format of the output file, inferred from the extension by default",
          "name": [
            "-f",
            "--format"
          ]
        },
        {
          "args": {
            "isOptional": true,
            "isVariadic": true,
            "name": "open"
          },
          "description": "Opens the output file using the default viewer after compilation",
          "name": [
            "--open"
          ]
        },
        {
          "args": {
            "name": "ppi"
          },
          "description": "The PPI (pixels per inch) to use for PNG export",
          "name": [
            "--ppi"
          ]
        },
        {
          "args": {
            "isOptional": true,
            "isVariadic": true,
            "name": "flamegraph",
            "template": "filepaths"
          },
          "description": "Produces a flamegraph of the compilation process",
          "name": [
            "--flamegraph"
          ]
        },
        {
          "description": "Print help",
          "name": [
            "-h",
            "--help"
          ]
        }
      ]
    },
