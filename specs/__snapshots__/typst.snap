      ],
      "description": "Processes an input file to extract provided metadata",
      "name": "query",
      "options": [
        {
          "args": {
            "name": "root",
            "template": "folders"
          },
          "description": "Configures the project root (for absolute paths)",
          "name": [
            "--root"
          ]
        },
        {
          "args": {
