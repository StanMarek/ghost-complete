{
  "description": "A tool for glamorous shell scripts",
  "name": "gum",
  "options": [
    {
      "description": "Show context-sensitive help",
      "name": [
        "--help",
        "-h"
      ]
    },
    {
      "description": "Print the version number",
      "name": [
        "--version",
        "-v"
      ]
    }
  ],
