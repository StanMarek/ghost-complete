{
  "name": "dotenv",
  "description": "Loads environment variables from .env",
  "options": [
    {
      "name": [
        "-f"
      ],
      "description": "List of env files to parse",
      "args": {
        "template": "filepaths"
      }
    },
    {
      "name": [
        "-h",
        "--help"
      ],
      "description": "Display help"
    },
    {
      "name": [
        "-v",
        "--version"
      ],
      "description": "Show version"
    },
    {
      "name": [
        "-t",
        "--template"
      ],
      "description": "Create a template env file",
      "args": {
        "template": "filepaths"
      }
    }
  ],
  "args": {}
}
