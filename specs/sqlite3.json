      "args": {
        "name": "COMMAND"
      }
    },
    {
      "name": [
        "-csv"
      ],
      "description": "Set output mode to 'csv'"
    },
    {
      "name": [
        "-echo"
      ],
      "description": "Print commands before execution"
    },
    {
