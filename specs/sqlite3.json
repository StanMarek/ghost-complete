    },
    {
      "name": [
        "-header"
      ],
      "description": "Turn headers on"
    },
    {
      "name": [
        "-noheader"
      ],
      "description": "Turn headers off"
    },
    {
      "name": [
        "-help"
      ],
      "description": "Show help message"
    },
    {
      "name": [
