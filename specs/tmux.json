{
  "name": "tmux",
  "description": "Terminal multiplexer",
  "subcommands": [
    {
      "name": "new-session",
      "description": "Create a new session",
      "options": [
        { "name": ["-d"], "description": "Do not attach to the new session" },
        { "name": ["-D"], "description": "Behave like attach-session if session exists" },
        { "name": ["-A"], "description": "Attach to session if it already exists" },
        { "name": ["-E"], "description": "Do not apply update-environment option" },
        { "name": ["-P"], "description": "Print information about the new session" },
        { "name": ["-X"], "description": "Send SIGHUP to parent process" },
        { "name": ["-s"], "description": "Specify session name", "args": { "name": "session-name" } },
        { "name": ["-n"], "description": "Name the initial window", "args": { "name": "window-name" } },
        { "name": ["-t"], "description": "Group the session with target session", "args": { "name": "group-name" } },
        { "name": ["-c"], "description": "Set starting directory", "args": { "name": "start-directory", "template": "folders" } },
        { "name": ["-x"], "description": "Set window width", "args": { "name": "width" } },
        { "name": ["-y"], "description": "Set window height", "args": { "name": "height" } },
        { "name": ["-F"], "description": "Specify output format", "args": { "name": "format" } },
        { "name": ["-f"], "description": "Set client flags", "args": { "name": "flags" } },
        { "name": ["-e"], "description": "Set environment variable", "args": { "name": "environment" } }
      ],
      "args": [
        { "name": "shell-command", "description": "Initial command to run" }
      ]
    },
    {
      "name": "attach-session",
      "description": "Attach to an existing session",
      "options": [
        { "name": ["-d"], "description": "Detach other clients from the session" },
        { "name": ["-x"], "description": "Set session size from the client" },
        { "name": ["-E"], "description": "Do not apply update-environment option" },
        { "name": ["-t"], "description": "Target session", "args": { "name": "target-session" } },
        { "name": ["-c"], "description": "Set working directory", "args": { "name": "working-directory", "template": "folders" } },
        { "name": ["-f"], "description": "Set client flags", "args": { "name": "flags" } }
      ]
    },
    {
      "name": "detach-client",
      "description": "Detach a client from the server",
      "options": [
        { "name": ["-a"], "description": "Detach all other clients except the specified one" },
        { "name": ["-P"], "description": "Send SIGHUP to the parent process" },
        { "name": ["-t"], "description": "Target client", "args": { "name": "target-client" } },
        { "name": ["-s"], "description": "Target session", "args": { "name": "target-session" } },
        { "name": ["-E"], "description": "Run shell command to replace client", "args": { "name": "shell-command" } }
      ]
    },
    {
      "name": "kill-session",
      "description": "Destroy a session",
      "options": [
        { "name": ["-a"], "description": "Kill all sessions except the target" },
        { "name": ["-C"], "description": "Clear alerts in the session" },
        { "name": ["-t"], "description": "Target session", "args": { "name": "target-session" } }
      ]
    },
    {
      "name": "kill-server",
      "description": "Kill the tmux server and all sessions"
    },
    {
      "name": "list-sessions",
      "description": "List all sessions",
      "options": [
        { "name": ["-F"], "description": "Specify output format", "args": { "name": "format" } },
        { "name": ["-f"], "description": "Filter sessions", "args": { "name": "filter" } }
      ]
    },
    {
      "name": "rename-session",
      "description": "Rename a session",
      "options": [
        { "name": ["-t"], "description": "Target session", "args": { "name": "target-session" } }
      ],
      "args": [
        { "name": "new-name", "description": "New session name" }
      ]
    },
    {
      "name": "has-session",
      "description": "Check if a session exists",
      "options": [
        { "name": ["-t"], "description": "Target session", "args": { "name": "target-session" } }
      ]
    },
    {
      "name": "switch-client",
      "description": "Switch the current client to another session",
      "options": [
        { "name": ["-l"], "description": "Switch to the last session" },
        { "name": ["-n"], "description": "Switch to the next session" },
        { "name": ["-p"], "description": "Switch to the previous session" },
        { "name": ["-r"], "description": "Toggle read-only flag" },
        { "name": ["-E"], "description": "Do not apply update-environment option" },
        { "name": ["-Z"], "description": "Keep zoomed if already zoomed" },
        { "name": ["-t"], "description": "Target session", "args": { "name": "target-session" } },
        { "name": ["-c"], "description": "Target client", "args": { "name": "target-client" } },
        { "name": ["-T"], "description": "Set key table", "args": { "name": "key-table" } }
      ]
    },
    {
      "name": "new-window",
      "description": "Create a new window",
      "options": [
        { "name": ["-a"], "description": "Insert after the current window" },
        { "name": ["-b"], "description": "Insert before the current window" },
        { "name": ["-d"], "description": "Do not make the new window the current window" },
        { "name": ["-k"], "description": "Destroy the window if it already exists" },
        { "name": ["-P"], "description": "Print information about the new window" },
        { "name": ["-S"], "description": "Select the window if name already exists" },
        { "name": ["-n"], "description": "Specify window name", "args": { "name": "window-name" } },
        { "name": ["-t"], "description": "Target window", "args": { "name": "target-window" } },
        { "name": ["-c"], "description": "Set starting directory", "args": { "name": "start-directory", "template": "folders" } },
        { "name": ["-F"], "description": "Specify output format", "args": { "name": "format" } },
        { "name": ["-e"], "description": "Set environment variable", "args": { "name": "environment" } }
      ],
      "args": [
        { "name": "shell-command", "description": "Command to run in the window" }
      ]
    },
    {
      "name": "kill-window",
      "description": "Destroy a window",
      "options": [
        { "name": ["-a"], "description": "Kill all windows except the target" },
        { "name": ["-t"], "description": "Target window", "args": { "name": "target-window" } }
      ]
    },
    {
      "name": "kill-pane",
      "description": "Destroy a pane",
      "options": [
        { "name": ["-a"], "description": "Kill all panes except the target" },
        { "name": ["-t"], "description": "Target pane", "args": { "name": "target-pane" } }
      ]
    },
    {
      "name": "list-windows",
      "description": "List windows in a session",
      "options": [
        { "name": ["-a"], "description": "List windows in all sessions" },
        { "name": ["-F"], "description": "Specify output format", "args": { "name": "format" } },
        { "name": ["-f"], "description": "Filter windows", "args": { "name": "filter" } },
        { "name": ["-t"], "description": "Target session", "args": { "name": "target-session" } }
      ]
    },
    {
      "name": "list-panes",
      "description": "List panes in a window",
      "options": [
        { "name": ["-a"], "description": "List panes in all windows" },
        { "name": ["-s"], "description": "List panes in all windows of a session" },
        { "name": ["-F"], "description": "Specify output format", "args": { "name": "format" } },
        { "name": ["-f"], "description": "Filter panes", "args": { "name": "filter" } },
        { "name": ["-t"], "description": "Target window", "args": { "name": "target-window" } }
      ]
    },
    {
      "name": "rename-window",
      "description": "Rename a window",
      "options": [
        { "name": ["-t"], "description": "Target window", "args": { "name": "target-window" } }
      ],
      "args": [
        { "name": "new-name", "description": "New window name" }
      ]
    },
    {
      "name": "select-window",
      "description": "Select a window",
      "options": [
        { "name": ["-l"], "description": "Select the last window" },
        { "name": ["-n"], "description": "Select the next window" },
        { "name": ["-p"], "description": "Select the previous window" },
        { "name": ["-T"], "description": "Select or deselect the target window" },
        { "name": ["-t"], "description": "Target window", "args": { "name": "target-window" } }
      ]
    },
    {
      "name": "next-window",
      "description": "Move to the next window",
      "options": [
        { "name": ["-a"], "description": "Move to the next window with an alert" },
        { "name": ["-t"], "description": "Target session", "args": { "name": "target-session" } }
      ]
    },
    {
      "name": "previous-window",
      "description": "Move to the previous window",
      "options": [
        { "name": ["-a"], "description": "Move to the previous window with an alert" },
        { "name": ["-t"], "description": "Target session", "args": { "name": "target-session" } }
      ]
    },
    {
      "name": "last-window",
      "description": "Select the last window",
      "options": [
        { "name": ["-t"], "description": "Target session", "args": { "name": "target-session" } }
      ]
    },
    {
      "name": "move-window",
      "description": "Move a window",
      "options": [
        { "name": ["-a"], "description": "Move after the destination" },
        { "name": ["-b"], "description": "Move before the destination" },
        { "name": ["-r"], "description": "Renumber remaining windows" },
        { "name": ["-d"], "description": "Do not make the moved window the current window" },
        { "name": ["-k"], "description": "Kill the target window if it exists" },
        { "name": ["-s"], "description": "Source window", "args": { "name": "src-window" } },
        { "name": ["-t"], "description": "Destination window", "args": { "name": "dst-window" } }
      ]
    },
    {
      "name": "swap-window",
      "description": "Swap two windows",
      "options": [
        { "name": ["-d"], "description": "Do not change the current window" },
        { "name": ["-s"], "description": "Source window", "args": { "name": "src-window" } },
        { "name": ["-t"], "description": "Destination window", "args": { "name": "dst-window" } }
      ]
    },
    {
      "name": "link-window",
      "description": "Link a window to another session",
      "options": [
        { "name": ["-a"], "description": "Move after the destination" },
        { "name": ["-b"], "description": "Move before the destination" },
        { "name": ["-d"], "description": "Do not make the linked window current" },
        { "name": ["-k"], "description": "Kill the target window if it exists" },
        { "name": ["-s"], "description": "Source window", "args": { "name": "src-window" } },
        { "name": ["-t"], "description": "Destination window", "args": { "name": "dst-window" } }
      ]
    },
    {
      "name": "unlink-window",
      "description": "Unlink a window",
      "options": [
        { "name": ["-k"], "description": "Kill the window if it is linked to multiple sessions" },
        { "name": ["-t"], "description": "Target window", "args": { "name": "target-window" } }
      ]
    },
    {
      "name": "find-window",
      "description": "Search for a pattern in windows",
      "options": [
        { "name": ["-i"], "description": "Case-insensitive search" },
        { "name": ["-C"], "description": "Search visible contents" },
        { "name": ["-N"], "description": "Search window names" },
        { "name": ["-T"], "description": "Search window titles" },
        { "name": ["-r"], "description": "Use regular expressions" },
        { "name": ["-Z"], "description": "Zoom the pane" },
        { "name": ["-t"], "description": "Target pane", "args": { "name": "target-pane" } }
      ],
      "args": [
        { "name": "match-string", "description": "Pattern to search for" }
      ]
    },
    {
      "name": "split-window",
      "description": "Split a pane into two",
      "options": [
        { "name": ["-h"], "description": "Split horizontally (left/right)" },
        { "name": ["-v"], "description": "Split vertically (above/below)" },
        { "name": ["-b"], "description": "Create the pane to the left or above" },
        { "name": ["-f"], "description": "Create a full-width or full-height pane" },
        { "name": ["-d"], "description": "Do not make the new pane the active pane" },
        { "name": ["-Z"], "description": "Zoom the new pane" },
        { "name": ["-I"], "description": "Create an empty pane and forward stdin" },
        { "name": ["-l"], "description": "Set pane size (lines or percentage)", "args": { "name": "size" } },
        { "name": ["-t"], "description": "Target pane", "args": { "name": "target-pane" } },
        { "name": ["-c"], "description": "Set starting directory", "args": { "name": "start-directory", "template": "folders" } },
        { "name": ["-F"], "description": "Specify output format", "args": { "name": "format" } },
        { "name": ["-e"], "description": "Set environment variable", "args": { "name": "environment" } }
      ],
      "args": [
        { "name": "shell-command", "description": "Command to run in the new pane" }
      ]
    },
    {
      "name": "select-pane",
      "description": "Make a pane the active one",
      "options": [
        { "name": ["-D"], "description": "Select the pane below" },
        { "name": ["-U"], "description": "Select the pane above" },
        { "name": ["-L"], "description": "Select the pane to the left" },
        { "name": ["-R"], "description": "Select the pane to the right" },
        { "name": ["-l"], "description": "Select the last active pane" },
        { "name": ["-Z"], "description": "Toggle pane zoom" },
        { "name": ["-m"], "description": "Set the marked pane" },
        { "name": ["-M"], "description": "Clear the marked pane" },
        { "name": ["-d"], "description": "Disable input to the pane" },
        { "name": ["-e"], "description": "Enable input to the pane" },
        { "name": ["-T"], "description": "Set pane title", "args": { "name": "title" } },
        { "name": ["-t"], "description": "Target pane", "args": { "name": "target-pane" } }
      ]
    },
    {
      "name": "resize-pane",
      "description": "Resize a pane",
      "options": [
        { "name": ["-D"], "description": "Resize down" },
        { "name": ["-U"], "description": "Resize up" },
        { "name": ["-L"], "description": "Resize left" },
        { "name": ["-R"], "description": "Resize right" },
        { "name": ["-Z"], "description": "Toggle zoom" },
        { "name": ["-M"], "description": "Toggle mouse mode" },
        { "name": ["-T"], "description": "Trim all lines below cursor" },
        { "name": ["-x"], "description": "Set absolute width", "args": { "name": "width" } },
        { "name": ["-y"], "description": "Set absolute height", "args": { "name": "height" } },
        { "name": ["-t"], "description": "Target pane", "args": { "name": "target-pane" } }
      ],
      "args": [
        { "name": "adjustment", "description": "Number of cells to resize by" }
      ]
    },
    {
      "name": "swap-pane",
      "description": "Swap two panes",
      "options": [
        { "name": ["-d"], "description": "Do not change the active pane" },
        { "name": ["-D"], "description": "Swap with the next pane" },
        { "name": ["-U"], "description": "Swap with the previous pane" },
        { "name": ["-Z"], "description": "Keep zoomed if already zoomed" },
        { "name": ["-s"], "description": "Source pane", "args": { "name": "src-pane" } },
        { "name": ["-t"], "description": "Destination pane", "args": { "name": "dst-pane" } }
      ]
    },
    {
      "name": "break-pane",
      "description": "Break a pane into a new window",
      "options": [
        { "name": ["-a"], "description": "Move the window to the next index after" },
        { "name": ["-b"], "description": "Move the window to the next index before" },
        { "name": ["-d"], "description": "Do not make the new window the current window" },
        { "name": ["-P"], "description": "Print information about the new window" },
        { "name": ["-n"], "description": "Set the window name", "args": { "name": "window-name" } },
        { "name": ["-s"], "description": "Source pane", "args": { "name": "src-pane" } },
        { "name": ["-t"], "description": "Target window", "args": { "name": "target-window" } },
        { "name": ["-F"], "description": "Specify output format", "args": { "name": "format" } }
      ]
    },
    {
      "name": "join-pane",
      "description": "Split a window and move a pane into the new space",
      "options": [
        { "name": ["-b"], "description": "Create the pane to the left or above" },
        { "name": ["-h"], "description": "Split horizontally" },
        { "name": ["-v"], "description": "Split vertically" },
        { "name": ["-l"], "description": "Set pane size", "args": { "name": "size" } },
        { "name": ["-s"], "description": "Source pane", "args": { "name": "src-pane" } },
        { "name": ["-t"], "description": "Destination pane", "args": { "name": "dst-pane" } }
      ]
    },
    {
      "name": "rotate-window",
      "description": "Rotate positions of panes in a window",
      "options": [
        { "name": ["-D"], "description": "Rotate downward" },
        { "name": ["-U"], "description": "Rotate upward" },
        { "name": ["-Z"], "description": "Keep zoomed if already zoomed" },
        { "name": ["-t"], "description": "Target window", "args": { "name": "target-window" } }
      ]
    },
    {
      "name": "last-pane",
      "description": "Select the previously active pane",
      "options": [
        { "name": ["-d"], "description": "Disable input to the pane" },
        { "name": ["-e"], "description": "Enable input to the pane" },
        { "name": ["-Z"], "description": "Keep zoomed if already zoomed" },
        { "name": ["-t"], "description": "Target window", "args": { "name": "target-window" } }
      ]
    },
    {
      "name": "display-panes",
      "description": "Display an indicator for each pane",
      "options": [
        { "name": ["-b"], "description": "Do not block other commands" },
        { "name": ["-N"], "description": "Do not wait for a key press" },
        { "name": ["-d"], "description": "Set display duration", "args": { "name": "duration" } },
        { "name": ["-t"], "description": "Target client", "args": { "name": "target-client" } }
      ],
      "args": [
        { "name": "template", "description": "Command template to run on selection" }
      ]
    },
    {
      "name": "capture-pane",
      "description": "Capture the contents of a pane",
      "options": [
        { "name": ["-a"], "description": "Use alternate screen" },
        { "name": ["-e"], "description": "Include escape sequences" },
        { "name": ["-p"], "description": "Print output to stdout" },
        { "name": ["-P"], "description": "Only capture visible contents" },
        { "name": ["-q"], "description": "Quiet mode, do not return error if no alternate screen" },
        { "name": ["-C"], "description": "Escape non-printable characters as octal" },
        { "name": ["-J"], "description": "Join wrapped lines and preserve trailing spaces" },
        { "name": ["-N"], "description": "Preserve trailing spaces" },
        { "name": ["-b"], "description": "Target buffer", "args": { "name": "target-buffer" } },
        { "name": ["-S"], "description": "Start line", "args": { "name": "start-line" } },
        { "name": ["-E"], "description": "End line", "args": { "name": "end-line" } },
        { "name": ["-t"], "description": "Target pane", "args": { "name": "target-pane" } }
      ]
    },
    {
      "name": "pipe-pane",
      "description": "Pipe output from a pane to a shell command",
      "options": [
        { "name": ["-I"], "description": "Connect stdin of the command to the pane" },
        { "name": ["-O"], "description": "Connect stdout of the pane to the command" },
        { "name": ["-o"], "description": "Only open a pipe if none exists" },
        { "name": ["-t"], "description": "Target pane", "args": { "name": "target-pane" } }
      ],
      "args": [
        { "name": "shell-command", "description": "Command to pipe to" }
      ]
    },
    {
      "name": "select-layout",
      "description": "Choose a layout for a pane",
      "options": [
        { "name": ["-E"], "description": "Spread panes evenly" },
        { "name": ["-n"], "description": "Next layout" },
        { "name": ["-o"], "description": "Apply last set layout if possible" },
        { "name": ["-p"], "description": "Previous layout" },
        { "name": ["-t"], "description": "Target pane", "args": { "name": "target-pane" } }
      ],
      "args": [
        { "name": "layout-name", "description": "Layout: even-horizontal, even-vertical, main-horizontal, main-vertical, tiled" }
      ]
    },
    {
      "name": "next-layout",
      "description": "Move a window to the next layout",
      "options": [
        { "name": ["-t"], "description": "Target window", "args": { "name": "target-window" } }
      ]
    },
    {
      "name": "previous-layout",
      "description": "Move a window to the previous layout",
      "options": [
        { "name": ["-t"], "description": "Target window", "args": { "name": "target-window" } }
      ]
    },
    {
      "name": "resize-window",
      "description": "Resize a window",
      "options": [
        { "name": ["-a"], "description": "Set the size of the smallest session" },
        { "name": ["-A"], "description": "Set the size of the largest session" },
        { "name": ["-D"], "description": "Resize down" },
        { "name": ["-L"], "description": "Resize left" },
        { "name": ["-R"], "description": "Resize right" },
        { "name": ["-U"], "description": "Resize up" },
        { "name": ["-x"], "description": "Set absolute width", "args": { "name": "width" } },
        { "name": ["-y"], "description": "Set absolute height", "args": { "name": "height" } },
        { "name": ["-t"], "description": "Target window", "args": { "name": "target-window" } }
      ],
      "args": [
        { "name": "adjustment", "description": "Number of cells to resize by" }
      ]
    },
    {
      "name": "bind-key",
      "description": "Bind a key to a command",
      "options": [
        { "name": ["-n"], "description": "Bind in the root table (no prefix needed)" },
        { "name": ["-r"], "description": "Key may repeat" },
        { "name": ["-N"], "description": "Attach a note to the key", "args": { "name": "note" } },
        { "name": ["-T"], "description": "Set key table", "args": { "name": "key-table" } }
      ],
      "args": [
        { "name": "key", "description": "Key to bind" },
        { "name": "command", "description": "Command to run" }
      ]
    },
    {
      "name": "unbind-key",
      "description": "Unbind a key",
      "options": [
        { "name": ["-a"], "description": "Remove all key bindings" },
        { "name": ["-n"], "description": "Unbind from the root table" },
        { "name": ["-q"], "description": "Do not report an error if the key is not bound" },
        { "name": ["-T"], "description": "Set key table", "args": { "name": "key-table" } }
      ],
      "args": [
        { "name": "key", "description": "Key to unbind" }
      ]
    },
    {
      "name": "list-keys",
      "description": "List all key bindings",
      "options": [
        { "name": ["-1"], "description": "List only the first matching key" },
        { "name": ["-a"], "description": "List the command for keys that do not have a note" },
        { "name": ["-N"], "description": "List only keys with notes" },
        { "name": ["-P"], "description": "Specify a prefix and suffix format", "args": { "name": "prefix" } },
        { "name": ["-T"], "description": "Set key table", "args": { "name": "key-table" } }
      ]
    },
    {
      "name": "set-option",
      "description": "Set a session option",
      "options": [
        { "name": ["-a"], "description": "Append to a string option" },
        { "name": ["-F"], "description": "Expand formats in the option value" },
