      ],
      "description": "Set the panel style to STYLE",
      "args": {
        "name": "style",
        "generators": [
          {
            "requires_js": true,
            "js_source": "async e=>{let a=e[e.length-1].trim().split(\" \"),l=new Set(a),o;return l.has(\"on\")?o=!a.slice(a.indexOf(\"on\")).some(c=>p.has(c))?y:g:o=!a.some(r=>p.has(r))?u:s,o.filter(({name:n})=>!l.has(n))}"
          }
        ]
      }
    },
