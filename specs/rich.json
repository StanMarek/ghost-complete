    {
      "name": [
        "--title"
      ],
      "description": "Set panel title to TEXT",
      "args": {
        "name": "text"
      }
    },
    {
      "name": [
        "--caption"
      ],
      "description": "Set panel caption to TEXT",
      "args": {
        "name": "text"
      }
    },
    {
      "name": [
        "--force-terminal"
      ],
      "description": "Force terminal output when not writing to a terminal"
    },
