{
  "name": "killall",
  "description": "Kill processes by name",
  "args": [
    {
      "name": "name",
      "description": "Process name to signal"
    }
  ],
  "options": [
    {
      "name": [
        "-s"
      ],
      "description": "Send the specified signal",
      "args": {
        "name": "signal"
      }
    },
    {
      "name": [
        "-9"
      ],
      "description": "Force kill processes immediately"
    },
    {
      "name": [
        "-v",
        "--verbose"
      ],
      "description": "Report if the signal was successfully sent"
    },
    {
      "name": [
        "-e",
        "--exact"
      ],
      "description": "Require an exact match for very long names"
    },
    {
      "name": [
        "-I",
        "--ignore-case"
      ],
      "description": "Match process name case-insensitively"
    },
    {
      "name": [
        "-q",
        "--quiet"
      ],
      "description": "Do not complain if no processes were killed"
    },
    {
      "name": [
        "-u",
        "--user"
      ],
      "description": "Kill only processes owned by the specified user",
      "args": {
        "name": "user"
      }
    },
    {
      "name": [
        "-z",
        "--context"
      ],
      "description": "Specify security context for matching"
    },
    {
      "name": [
        "-l",
        "--list"
      ],
      "description": "List all known signal names"
    }
  ]
}
