{
  "name": "kill",
  "description": "Send signals to processes",
  "args": [
    {
      "name": "pid",
      "description": "Process ID to signal"
    }
  ],
  "options": [
    {
      "name": [
        "-s"
      ],
      "description": "Specify the signal to send",
      "args": {
        "name": "signal"
      }
    },
    {
      "name": [
        "-l"
      ],
      "description": "List available signal names"
    },
    {
      "name": [
        "-9",
        "-KILL"
      ],
      "description": "Force kill the process immediately"
    },
    {
      "name": [
        "-15",
        "-TERM"
      ],
      "description": "Terminate the process gracefully"
    },
    {
      "name": [
        "-1",
        "-HUP"
      ],
      "description": "Hang up the process"
    },
    {
      "name": [
        "-2",
        "-INT"
      ],
      "description": "Interrupt the process"
    },
    {
      "name": [
        "-3",
        "-QUIT"
      ],
      "description": "Quit the process with core dump"
    },
    {
      "name": [
        "-STOP"
      ],
      "description": "Stop (pause) the process"
    },
    {
      "name": [
        "-CONT"
      ],
      "description": "Continue a stopped process"
    },
    {
      "name": [
        "-USR1"
      ],
      "description": "Send user-defined signal 1"
    },
    {
      "name": [
        "-USR2"
      ],
      "description": "Send user-defined signal 2"
    }
  ]
}
