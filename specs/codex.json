{
  "name": "codex",
  "description": "OpenAI Codex CLI - AI coding agent",
  "subcommands": [
    {
      "name": "exec",
      "description": "Run Codex non-interactively",
      "subcommands": [
        {
          "name": "resume",
          "description": "Resume a previous session by ID",
          "options": [
            {
              "name": ["--last"],
              "description": "Resume most recent session"
            },
            {
              "name": ["--all"],
              "description": "Show all sessions (disables cwd filtering)"
            },
            {
              "name": ["-i", "--image"],
              "description": "Image(s) to attach",
              "args": {
                "name": "file",
                "template": "filepaths"
              }
            },
            {
              "name": ["-m", "--model"],
              "description": "Model the agent should use",
              "args": {
                "name": "model"
              }
            },
            {
              "name": ["--full-auto"],
              "description": "Alias for -a on-request --sandbox workspace-write"
            },
            {
              "name": ["--dangerously-bypass-approvals-and-sandbox"],
              "description": "Skip all prompts and sandbox"
            },
            {
              "name": ["--skip-git-repo-check"],
              "description": "Allow running outside a Git repository"
            },
            {
              "name": ["--ephemeral"],
              "description": "Run without persisting session files"
            },
            {
              "name": ["--json"],
              "description": "Print events to stdout as JSONL"
            },
            {
              "name": ["-o", "--output-last-message"],
              "description": "File to write last agent message",
              "args": {
                "name": "file",
                "template": "filepaths"
              }
            }
          ],
          "args": [
            {
              "name": "session_id",
              "description": "UUID or thread name",
              "isOptional": true
            },
            {
              "name": "prompt",
              "description": "Prompt after resuming",
              "isOptional": true
            }
          ]
        },
        {
          "name": "review",
          "description": "Run code review in non-interactive mode",
          "options": [
            {
              "name": ["--uncommitted"],
              "description": "Review staged, unstaged, and untracked changes"
            },
            {
              "name": ["--base"],
              "description": "Review against a base branch",
              "args": {
                "name": "branch",
                "generators": [
                  {
                    "type": "git_branches"
                  }
                ]
              }
            },
            {
              "name": ["--commit"],
              "description": "Review changes from a specific commit",
              "args": {
                "name": "sha"
              }
            },
            {
              "name": ["--title"],
              "description": "Optional commit title for review summary",
              "args": {
                "name": "title"
              }
            },
            {
              "name": ["-m", "--model"],
              "description": "Model the agent should use",
              "args": {
                "name": "model"
              }
            },
            {
              "name": ["--full-auto"],
              "description": "Alias for -a on-request --sandbox workspace-write"
            },
            {
              "name": ["--skip-git-repo-check"],
              "description": "Allow running outside a Git repository"
            },
            {
              "name": ["--ephemeral"],
              "description": "Run without persisting session files"
            },
            {
              "name": ["--json"],
              "description": "Print events to stdout as JSONL"
            },
            {
              "name": ["-o", "--output-last-message"],
              "description": "File to write last agent message",
              "args": {
                "name": "file",
                "template": "filepaths"
              }
            }
          ],
          "args": {
            "name": "prompt",
            "description": "Custom review instructions",
            "isOptional": true
          }
        }
      ],
      "options": [
        {
