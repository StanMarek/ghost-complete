    {
      "name": "mcp",
      "description": "Manage external MCP servers",
      "subcommands": [
        {
          "name": "list",
          "description": "List configured MCP servers",
          "options": [
            {
              "name": ["--json"],
              "description": "Output as JSON"
            }
          ]
        },
        {
          "name": "get",
          "description": "Get details about an MCP server",
          "options": [
            {
              "name": ["--json"],
              "description": "Output as JSON"
            }
          ],
          "args": {
            "name": "name",
            "description": "Server name"
          }
        },
        {
          "name": "add",
          "description": "Add an MCP server",
          "options": [
            {
              "name": ["--env"],
              "description": "Environment variables for stdio servers (KEY=VALUE)",
              "args": {
                "name": "KEY=VALUE"
              }
            },
            {
              "name": ["--url"],
              "description": "URL for streamable HTTP MCP server",
              "args": {
                "name": "url"
              }
            },
            {
              "name": ["--bearer-token-env-var"],
              "description": "Env var name for bearer token (HTTP only)",
              "args": {
                "name": "env_var"
              }
            }
          ],
          "args": {
            "name": "name",
            "description": "Name for the MCP server config"
          }
        },
        {
          "name": "remove",
          "description": "Remove an MCP server config",
          "args": {
            "name": "name",
            "description": "Server name to remove"
          }
        },
        {
          "name": "login",
          "description": "Authenticate with an MCP server via OAuth",
          "options": [
            {
              "name": ["--scopes"],
              "description": "Comma-separated OAuth scopes",
              "args": {
                "name": "scopes"
              }
            }
          ],
          "args": {
            "name": "name",
            "description": "Server name to authenticate"
          }
        },
        {
          "name": "logout",
          "description": "Deauthenticate from an MCP server",
          "args": {
            "name": "name",
            "description": "Server name to deauthenticate"
          }
        }
      ]
    },
    {
      "name": "mcp-server",
      "description": "Start Codex as an MCP server (stdio)"
