    {
      "name": "sandbox",
      "description": "Run commands within a Codex-provided sandbox",
      "subcommands": [
        {
          "name": "macos",
          "description": "Seatbelt sandbox (macOS)",
          "options": [
            {
              "name": ["--full-auto"],
              "description": "Network-disabled sandbox, writable to cwd and TMPDIR"
