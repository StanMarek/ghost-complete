{
  "name": "github",
  "description": "Open a git repository in GitHub Desktop",
  "subcommands": [
    {
      "name": "clone",
      "description": "Clone a repository",
      "options": [
        {
          "name": [
            "--branch",
            "-b"
          ],
          "description": "The branch to checkout after cloning",
          "args": {
            "name": "branch"
          }
        }
      ],
      "args": {
        "name": "url|slug",
        "suggestions": [
          {
            "name": "https://github.com/"
          },
          {
            "name": "https://gitlab.com/"
          },
          {
            "name": "https://bitbucket.com/"
          }
        ]
      }
    },
    {
      "name": "open",
      "description": "Open a git repository in GitHub Desktop",
      "args": {
        "name": "path",
        "isOptional": true,
        "generators": [
          {
            "template": "folders"
          }
        ]
      }
    },
    {
      "name": "help",
      "description": "Show the help page for a command",
      "args": {
        "name": "command",
        "isOptional": true,
        "suggestions": [
          {
            "name": "clone"
          },
          {
            "name": "open"
          },
          {
            "name": "help"
          }
        ]
      }
    }
  ],
  "options": [
    {
      "name": [
        "--help"
      ],
      "description": "Show the help page for a command",
      "args": {
        "name": "command",
        "isOptional": true,
        "suggestions": [
          {
            "name": "clone"
          },
          {
            "name": "open"
          },
          {
            "name": "help"
          }
        ]
      }
    }
  ],
  "args": {
    "name": "path",
    "isOptional": true,
    "generators": [
      {
        "template": "folders"
      }
    ]
  }
}
